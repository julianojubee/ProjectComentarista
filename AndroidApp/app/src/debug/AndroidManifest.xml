<?xml version="1.0" encoding="utf-8"?>
<!--
    Só existe no build debug: libera HTTP puro (sem TLS) exclusivamente para o servidor
    dev local (ver network_security_config.xml). O build de release usa o manifest
    principal, sem essa liberação — HTTPS obrigatório com validação normal de certificado.
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <application android:networkSecurityConfig="@xml/network_security_config" />
</manifest>
