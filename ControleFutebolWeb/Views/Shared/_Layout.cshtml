@inject Microsoft.AspNetCore.Identity.UserManager<ControleFutebolWeb.Models.ApplicationUser> _layoutUserManager
@inject ControleFutebolWeb.Data.FutebolContext _layoutContext
@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery _antiforgery
@inject Microsoft.Extensions.Caching.Memory.IMemoryCache _cache
@using Microsoft.EntityFrameworkCore
@using Microsoft.Extensions.Caching.Memory
@{
    // Flag admin + menu de competições "principais" do usuário: cacheados por
    // usuário (60s) para evitar ~3 queries ao banco em TODA renderização de página.
    // O userId vem do cookie (claims), sem hit no banco.
    var _userId = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
    var _layoutIsAdmin = false;
    var _layoutCompeticoesMenu = new List<ControleFutebolWeb.Models.Competicao>();

    if (_userId != null)
    {
        var _dados = await _cache.GetOrCreateAsync($"layout-menu:{_userId}", async entry =>
        {
            entry.AbsoluteExpirationRelativeToNow = TimeSpan.FromSeconds(60);
            entry.Size = 1; // obrigatório: o MemoryCache tem SizeLimit configurado.

            var _user = await _layoutUserManager.FindByIdAsync(_userId);
            var _topIds = await _layoutContext.CompeticoesTopTierUsuario
                .Where(t => t.UsuarioId == _userId)
                .Select(t => t.CompeticaoId)
                .ToListAsync();
            var _comps = await _layoutContext.Competicoes
                .AsNoTracking()
                .Where(c => _topIds.Contains(c.Id))
                .OrderBy(c => c.Nome)
                .ToListAsync();

            return (IsAdmin: _user?.IsAdmin == true, Menu: _comps);
        });

        _layoutIsAdmin = _dados.IsAdmin;
        _layoutCompeticoesMenu = _dados.Menu;
    }

    // Mapeia uma competição para a rota correta (mesma lógica da tela de Competições)
    Func<ControleFutebolWeb.Models.Competicao, string> _rotaCompeticao = (comp) =>
    {
        var nome = comp.Nome?.ToLowerInvariant() ?? "";
        if (nome.Contains("brasileiro") || nome.Contains("brasileirão"))
            return Url.Action("Brasileirao", "Tabela")!;
        if (nome.Contains("copa do brasil"))
            return Url.Action("Index", "CopaBrasil")!;
        if (nome.Contains("copa do mundo"))
            return Url.Action("Index", "CopaDoMundo")!;
        if (nome.Contains("libertadores"))
            return Url.Action("Index", "Libertadores")!;
        if (nome.Contains("sul-americana") || nome.Contains("sudamericana") || nome.Contains("sul americana"))
            return Url.Action("Index", "SulAmericana")!;
        if (nome.Contains("champions"))
            return Url.Action("Index", "ChampionsLeague")!;
        return Url.Action("Detalhes", "Competicoes", new { id = comp.Id })!;
    };
}
<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="csrf-token" content="@_antiforgery.GetAndStoreTokens(Context).RequestToken" />
    @{
        // Título da aba: páginas podem definir ViewData["TitleOverride"] para
        // controlar o título completo; senão usa o padrão "{Title} - Comentarista Esportivo".
        var tituloAba = (ViewData["TitleOverride"] as string)
            ?? ((ViewData["Title"] as string ?? "") + " - Comentarista Esportivo");
    }
    <title>@tituloAba</title>
    @* data-theme aciona os overrides custom (site.css); data-bs-theme aciona o
       theming nativo do Bootstrap 5.3 (forms, accordion, tooltips etc.). *@
    <script>(function(){var t=localStorage.getItem('site-theme');if(t){document.documentElement.setAttribute('data-theme',t);document.documentElement.setAttribute('data-bs-theme',t);}})();</script>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ControleFutebolWeb.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar brand-nav navbar-expand-md navbar-toggleable-md navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand brand-logo text-dark p-0" asp-controller="Home" asp-action="Index" aria-label="Análise de Craque — início">
                    <svg class="brand-mark" width="27" height="40" viewBox="0 0 80 120" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
                        <rect x="0" y="0" width="80" height="120" rx="8" fill="#161616" />
                        <rect x="10" y="10" width="60" height="100" rx="2" fill="#0b130b" stroke="#d4a520" stroke-width="2" />
                        <line x1="10" y1="60" x2="70" y2="60" stroke="#d4a520" stroke-width="1.5" />
                        <circle cx="40" cy="60" r="14" fill="none" stroke="#d4a520" stroke-width="1.5" />
                        <circle cx="40" cy="60" r="3" fill="#d4a520" />
                        <rect x="22" y="10" width="36" height="18" fill="none" stroke="#d4a520" stroke-width="1.5" />
                        <rect x="22" y="92" width="36" height="18" fill="none" stroke="#d4a520" stroke-width="1.5" />
                    </svg>
                    <span class="brand-wordmark">
                        <span class="brand-name">ANÁLISE</span>
                        <span class="brand-tag">DE CRAQUE</span>
                    </span>
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-md-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        </li>

                        <!-- Cadastros -->
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle text-dark" href="#" id="cadastrosDropdown" role="button"
                               data-bs-toggle="dropdown" aria-expanded="false">
                                Cadastros
                            </a>
                            <div class="dropdown-menu" aria-labelledby="cadastrosDropdown">
                                <a class="dropdown-item" asp-controller="Times" asp-action="Index">
                                    <span class="gold-ico">🏟</span> Times
                                </a>
                                <a class="dropdown-item" asp-controller="Jogadores" asp-action="Index">
                                    <span class="gold-ico">👤</span> Jogadores
                                </a>
                                <a class="dropdown-item" asp-controller="Treinadores" asp-action="Index">
                                    <span class="gold-ico">🧑‍💼</span> Treinadores
                                </a>
                                <a class="dropdown-item" asp-controller="Jogos" asp-action="Index">
                                    <span class="gold-ico">📅</span> Jogos
                                </a>
                                <div class="dropdown-divider"></div>
                                <a class="dropdown-item" asp-controller="Formacoes" asp-action="Index">
                                    <span class="gold-ico">⚽</span> Formações
                                </a>
                                <a class="dropdown-item" asp-controller="Formacoes" asp-action="Posicoes">
                                    <span class="gold-ico">🗺</span> Posições de Formação
                                </a>
                                <div class="dropdown-divider"></div>
                                <a class="dropdown-item" asp-controller="CriteriosNota" asp-action="Index">
                                    <span class="gold-ico">📋</span> Critérios de Nota
                                </a>
                            </div>
                        </li>

                        <!-- Competições -->
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle text-dark" href="#" id="competicoesDropdown" role="button"
                               data-bs-toggle="dropdown" aria-expanded="false">
                                Competições
                            </a>
                            <div class="dropdown-menu" aria-labelledby="competicoesDropdown">
                                @if (_layoutCompeticoesMenu.Any())
                                {
                                    foreach (var comp in _layoutCompeticoesMenu)
                                    {
                                        <a class="dropdown-item" href="@_rotaCompeticao(comp)"><span class="gold-ico">⭐</span> @comp.Nome</a>
                                    }
                                    <div class="dropdown-divider"></div>
                                    <a class="dropdown-item" asp-controller="Competicoes" asp-action="Index">Ver todas as competições</a>
                                }
                                else
                                {
                                    <a class="dropdown-item" asp-controller="Competicoes" asp-action="Index">Ver competições</a>
                                    <span class="dropdown-item-text text-muted" style="font-size:12px;">Marque competições como ⭐ Principal para vê-las aqui</span>
                                }
                            </div>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link text-dark"
                               asp-area="" asp-controller="Jogos" asp-action="Hoje">
                                <span class="gold-ico">📅</span> Jogos de Hoje
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark"
                               asp-area="" asp-controller="Relatorios" asp-action="Index">
                                <span class="gold-ico">📊</span> Relatórios
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark"
                               asp-area="" asp-controller="Transferencias" asp-action="Index">
                                <span class="gold-ico">🔁</span> Transferências
                            </a>
                        </li>
                        @if (_layoutIsAdmin)
                        {
                        <li class="nav-item">
                            <a class="nav-link text-dark"
                               asp-area="" asp-controller="TransfermarktLogs" asp-action="Index">
                                Logs Transfermarkt
                            </a>
                        </li>
                        }

                    </ul>

                    <div class="d-flex align-items-center ms-auto me-2">
                        <button id="theme-toggle-btn" onclick="toggleTheme()"
                                style="background:none;border:none;cursor:pointer;padding:4px 8px;font-size:18px;line-height:1;"
                                title="Alternar modo escuro">
                            <span id="theme-toggle-icon">🌙</span>
                        </button>
                    </div>

                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <ul class="navbar-nav align-items-center">
                            @{
                                var nomeUsuario = User.Identity?.Name ?? "";
                            }
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle text-dark" href="#" data-bs-toggle="dropdown">
                                    <span class="gold-ico">👤</span> @nomeUsuario
                                </a>
                                <div class="dropdown-menu dropdown-menu-end">
                                    @{
                                        var isAdmin = User.IsInRole("Admin");
                                    }
                                    <a class="dropdown-item" asp-controller="Account" asp-action="Usuarios"><span class="gold-ico">👥</span> Usuários</a>
                                    <div class="dropdown-divider"></div>
                                    <form asp-controller="Account" asp-action="Logout" method="post" style="display:inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="dropdown-item text-danger">🚪 Sair</button>
                                    </form>
                                </div>
                            </li>
                        </ul>
                    }

                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    @* jQuery não é mais carregado globalmente: só as telas de formulário que usam
       validação client-side precisam dele — carregado em _ValidationScriptsPartial. *@
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
<div aria-live="polite" aria-atomic="true" class="position-relative">
    <div class="toast-container position-fixed bottom-0 end-0 p-3">
        @if (TempData["Mensagem"] != null)
        {
            <div class="toast align-items-center @(TempData["MensagemTipo"]?.ToString() == "erro" ? "text-bg-danger" : "text-bg-success") border-0" role="alert" aria-live="assertive" aria-atomic="true">
                <div class="d-flex">
                    <div class="toast-body">
                        @TempData["Mensagem"]
                    </div>
                    <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Fechar"></button>
                </div>
            </div>
        }
    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        var toastElList = [].slice.call(document.querySelectorAll('.toast'))
        var toastList = toastElList.map(function (toastEl) {
            return new bootstrap.Toast(toastEl, { delay: 6000 });
        });
        toastList.forEach(toast => toast.show());

        var icon = document.getElementById('theme-toggle-icon');
        if (icon) {
            var t = document.documentElement.getAttribute('data-theme') || 'light';
            icon.textContent = t === 'dark' ? '☀️' : '🌙';
        }
    });

    function toggleTheme() {
        var current = document.documentElement.getAttribute('data-theme') || 'light';
        var next = current === 'dark' ? 'light' : 'dark';
        document.documentElement.setAttribute('data-theme', next);
        document.documentElement.setAttribute('data-bs-theme', next);
        localStorage.setItem('site-theme', next);
        var icon = document.getElementById('theme-toggle-icon');
        if (icon) icon.textContent = next === 'dark' ? '☀️' : '🌙';
    }
</script>

</html>
