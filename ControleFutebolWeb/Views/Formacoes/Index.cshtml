@model List<ControleFutebolWeb.Models.Formacao>
@{
    ViewData["Title"] = "Formações";
}

<style>
    .fm-root, .fm-root *, .fm-root *::before, .fm-root *::after { box-sizing: border-box; }

    .fm-root {
        margin: 0 -12px;
        background: #0f0f0f;
        border-radius: 14px;
        overflow: hidden;
        color: #e5e7eb;
        font-family: 'Barlow', Arial, sans-serif;
    }
    .fm-root a { text-decoration: none; color: inherit; }

    /* ── Hero ── */
    .fm-hero {
        position: relative; overflow: hidden;
        background: linear-gradient(135deg, #0a1628 0%, #0f2040 55%, #0a1628 100%);
        padding: 44px 2.5rem 36px;
    }
    .fm-hero-pattern { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; opacity: 0.05; pointer-events: none; }
    .fm-hero-stripe { position: absolute; left: 0; top: 0; bottom: 0; width: 4px; background: #d4a520; }
    .fm-hero-fade { position: absolute; bottom: 0; left: 0; right: 0; height: 60px; background: linear-gradient(to top, #0f0f0f, transparent); pointer-events: none; }
    .fm-hero-inner { position: relative; z-index: 1; display: flex; align-items: flex-end; justify-content: space-between; gap: 24px; flex-wrap: wrap; }
    .fm-hero-kicker { display: flex; align-items: center; gap: 10px; margin-bottom: 12px; }
    .fm-hero-kicker-line { height: 2px; width: 28px; background: #d4a520; }
    .fm-hero-kicker span { font-size: .68rem; font-weight: 700; letter-spacing: .28em; color: #d4a520; text-transform: uppercase; }
    .fm-hero h1 { font-family: 'Barlow Condensed', Arial, sans-serif; font-size: 3.2rem; font-weight: 800; color: #f1f5f9; margin: 0 0 8px; line-height: 1; }
    .fm-hero p { font-size: .9rem; color: #6b7280; margin: 0; }
    .fm-btn-editor {
        display: flex; align-items: center; gap: 7px; padding: 10px 18px;
        background: rgba(212,165,32,0.12); border: 1px solid rgba(212,165,32,0.35); border-radius: 8px;
        color: #d4a520; font-size: .82rem; font-weight: 700; flex-shrink: 0;
    }
    .fm-btn-editor:hover { background: rgba(212,165,32,0.2); color: #d4a520; }

    /* ── Barra: nova formação ── */
    .fm-createbar { background: #141414; border-bottom: 1px solid #222; padding: 14px 2.5rem; }
    .fm-createbar form { max-width: 1400px; margin: 0 auto; display: flex; align-items: center; gap: 10px; flex-wrap: wrap; }
    .fm-search-box {
        display: flex; align-items: center; flex: 1; max-width: 380px;
        background: #1a1a1a; border: 1px solid #2a2a2a; border-radius: 8px; overflow: hidden;
    }
    .fm-search-box:focus-within { border-color: #d4a520; }
    .fm-search-icon { padding: 0 12px; color: #4b5563; display: flex; align-items: center; flex-shrink: 0; }
    .fm-search-box input { flex: 1; padding: 10px 4px; background: transparent; border: none; color: #f1f5f9; font-size: .87rem; outline: none; }
    .fm-btn-criar { padding: 10px 20px; background: #d4a520; color: #141414; font-size: .85rem; font-weight: 800; border: none; border-radius: 8px; cursor: pointer; letter-spacing: .03em; }
    .fm-btn-criar:hover { background: #c49918; }
    .fm-total { font-size: .75rem; color: #4b5563; margin-left: 8px; }

    /* ── Conteúdo ── */
    .fm-content { padding: 32px 2.5rem 64px; max-width: 1544px; margin: 0 auto; }
    .fm-vazio { text-align: center; color: #6b7280; padding: 3rem 1rem; background: #141414; border: 1px dashed #262626; border-radius: 12px; }

    .fm-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; }
    @@media (max-width: 1300px) { .fm-grid { grid-template-columns: repeat(3, 1fr); } }
    @@media (max-width: 980px) { .fm-grid { grid-template-columns: repeat(2, 1fr); } }
    @@media (max-width: 620px) { .fm-grid { grid-template-columns: 1fr; } }

    .fm-card { background: #161616; border: 1px solid #262626; border-radius: 14px; overflow: hidden; transition: border-color .15s; }
    .fm-card:hover { border-color: #333; }

    .fm-preview { position: relative; background: linear-gradient(180deg, #14532d 0%, #166534 100%); height: 160px; overflow: hidden; }
    .fm-preview-linha { position: absolute; left: 0; right: 0; top: 50%; height: 1px; background: rgba(255,255,255,0.2); }
    .fm-preview-area-topo { position: absolute; left: 25%; right: 25%; top: -1px; height: 20%; border: 1px solid rgba(255,255,255,0.2); border-top: none; }
    .fm-preview-area-baixo { position: absolute; left: 25%; right: 25%; bottom: -1px; height: 20%; border: 1px solid rgba(255,255,255,0.2); border-bottom: none; }
    .fm-preview-circulo { position: absolute; left: 50%; top: 50%; width: 30%; height: 22%; border: 1px solid rgba(255,255,255,0.15); border-radius: 50%; transform: translate(-50%, -50%); }
    .fm-preview-dot { position: absolute; width: 14px; height: 14px; border-radius: 50%; background: #dc2626; border: 2px solid rgba(255,255,255,0.7); transform: translate(-50%,-50%); box-shadow: 0 1px 4px rgba(0,0,0,0.5); }
    .fm-preview-label { position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; }
    .fm-preview-label span { font-family: 'Barlow Condensed', Arial, sans-serif; font-size: 2.8rem; font-weight: 900; color: rgba(255,255,255,0.12); letter-spacing: .04em; pointer-events: none; }

    .fm-card-footer { padding: 14px 16px; }
    .fm-card-head { display: flex; align-items: center; justify-content: space-between; margin-bottom: 10px; gap: 8px; }
    .fm-card-nome { font-family: 'Barlow Condensed', Arial, sans-serif; font-size: 1.4rem; font-weight: 800; color: #f1f5f9; line-height: 1; margin-bottom: 3px; }
    .fm-card-count { font-size: .7rem; color: #6b7280; }
    .fm-card-actions { display: flex; gap: 6px; flex-shrink: 0; }
    .fm-btn-editar { padding: 5px 10px; background: rgba(212,165,32,0.1); border: 1px solid rgba(212,165,32,0.28); border-radius: 6px; color: #d4a520; font-size: .72rem; font-weight: 700; cursor: pointer; }
    .fm-btn-editar:hover { background: rgba(212,165,32,0.2); }
    .fm-btn-excluir { padding: 5px 10px; background: rgba(239,68,68,0.08); border: 1px solid rgba(239,68,68,0.2); border-radius: 6px; color: #f87171; font-size: .72rem; font-weight: 700; cursor: pointer; }
    .fm-btn-excluir:hover { background: rgba(239,68,68,0.15); }
    .fm-btn-posicoes {
        display: flex; align-items: center; justify-content: center; gap: 6px; padding: 8px;
        background: #1e1e1e; border: 1px solid #2a2a2a; border-radius: 8px; color: #9ca3af; font-size: .78rem; font-weight: 600;
    }
    .fm-btn-posicoes:hover { border-color: #d4a520; color: #d4a520; }

    /* ── Modais (criação já é inline; este é só o de renomear) ── */
    .fm-modal .modal-content { background: #161616; border: 1px solid #262626; color: #e5e7eb; }
    .fm-modal .modal-header { border-bottom: 1px solid #222; }
    .fm-modal .modal-footer { border-top: 1px solid #222; }
    .fm-modal .form-control { background: #1a1a1a; border: 1px solid #2a2a2a; color: #f1f5f9; }
    .fm-modal .form-control:focus { background: #1a1a1a; border-color: #d4a520; color: #f1f5f9; box-shadow: none; }
    .fm-modal .btn-close { filter: invert(1); }
</style>

<div class="fm-root">
    <!-- ── Hero ── -->
    <div class="fm-hero">
        <img src="~/Images/banner/escudos-pattern.svg" class="fm-hero-pattern" alt="" />
        <div class="fm-hero-stripe"></div>
        <div class="fm-hero-fade"></div>
        <div class="fm-hero-inner">
            <div>
                <div class="fm-hero-kicker">
                    <div class="fm-hero-kicker-line"></div>
                    <span>Configuração Tática</span>
                </div>
                <h1>Formações</h1>
                <p>Cadastre formações táticas e defina as posições dos jogadores no campo.</p>
            </div>
            <a asp-action="Posicoes" class="fm-btn-editor">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2" /><circle cx="12" cy="10" r="3" /></svg>
                Editor de Posições
            </a>
        </div>
    </div>

    @if (TempData["Mensagem"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show m-3" role="alert">
            @TempData["Mensagem"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- ── Nova formação ── -->
    <div class="fm-createbar">
        <form asp-action="Criar" method="post">
            @Html.AntiForgeryToken()
            <div class="fm-search-box">
                <div class="fm-search-icon"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2" /></svg></div>
                <input type="text" name="nome" placeholder="Nome da formação (ex: 4-3-3, 3-5-2...)" required />
            </div>
            <button type="submit" class="fm-btn-criar">+ Criar Formação</button>
            <span class="fm-total">@Model.Count formações cadastradas</span>
        </form>
    </div>

    <!-- ── Grid de formações ── -->
    <div class="fm-content">
        @if (!Model.Any())
        {
            <div class="fm-vazio">Nenhuma formação cadastrada. Use o campo acima para criar a primeira.</div>
        }
        else
        {
            <div class="fm-grid">
                @foreach (var f in Model)
                {
                    var posicoes = f.Posicoes?.OrderBy(p => p.Ordem).ToList() ?? new List<ControleFutebolWeb.Models.PosicaoFormacao>();
                    var total = posicoes.Count;

                    <div class="fm-card">
                        <div class="fm-preview">
                            <div class="fm-preview-linha"></div>
                            <div class="fm-preview-area-topo"></div>
                            <div class="fm-preview-area-baixo"></div>
                            <div class="fm-preview-circulo"></div>
                            @foreach (var p in posicoes)
                            {
                                <div class="fm-preview-dot" style="left:@(p.PosicaoX.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture))%; top:@(p.PosicaoY.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture))%;"></div>
                            }
                            <div class="fm-preview-label"><span>@f.Nome</span></div>
                        </div>

                        <div class="fm-card-footer">
                            <div class="fm-card-head">
                                <div>
                                    <div class="fm-card-nome">@f.Nome</div>
                                    <div class="fm-card-count">@total posiç@(total == 1 ? "ão" : "ões") definida@(total == 1 ? "" : "s")</div>
                                </div>
                                <div class="fm-card-actions">
                                    <button type="button" class="fm-btn-editar"
                                            data-bs-toggle="modal" data-bs-target="#modalEditarFormacao"
                                            data-id="@f.Id" data-nome="@f.Nome">
                                        Editar
                                    </button>
                                    <form asp-action="Excluir" asp-route-id="@f.Id" method="post" style="display:inline;"
                                          onsubmit="return confirm('Excluir a formação @f.Nome? Todas as posições serão removidas.')">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="fm-btn-excluir">Excluir</button>
                                    </form>
                                </div>
                            </div>
                            <a asp-action="Posicoes" asp-route-id="@f.Id" class="fm-btn-posicoes">
                                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10" /><circle cx="12" cy="12" r="3" /></svg>
                                Definir posições no campo
                            </a>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>

<!-- Modal Editar Formação -->
<div class="modal fade fm-modal" id="modalEditarFormacao" tabindex="-1" aria-labelledby="labelEditarFormacao" aria-hidden="true">
    <div class="modal-dialog modal-sm">
        <div class="modal-content">
            <form asp-action="EditarNome" asp-controller="Formacoes" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" id="editarFormacaoId" value="" />
                <div class="modal-header">
                    <h5 class="modal-title" id="labelEditarFormacao">Editar Formação</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <label class="form-label">Nome da formação</label>
                    <input type="text" name="nome" id="editarFormacaoNome" class="form-control" required autofocus />
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-primary">Salvar</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('modalEditarFormacao').addEventListener('show.bs.modal', function (event) {
            var btn = event.relatedTarget;
            document.getElementById('editarFormacaoId').value = btn.getAttribute('data-id');
            document.getElementById('editarFormacaoNome').value = btn.getAttribute('data-nome');
        });
    </script>
}
