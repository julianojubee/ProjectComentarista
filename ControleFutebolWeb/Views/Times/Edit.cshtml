@model ControleFutebolWeb.Models.Time

<h2>Editar Time</h2>

<form asp-action="Edit" method="post" enctype="multipart/form-data">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <input type="hidden" asp-for="Id" />

    <div class="form-group">
        <label asp-for="Nome" class="control-label"></label>
        <input asp-for="Nome" class="form-control" />
        <span asp-validation-for="Nome" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="Cidade" class="control-label"></label>
        <input asp-for="Cidade" class="form-control" />
        <span asp-validation-for="Cidade" class="text-danger"></span>
    </div>

    <!-- pré-visualização do escudo atual -->
    @if (!string.IsNullOrEmpty(Model.EscudoUrl))
    {
        <div class="form-group mt-2">
            <label>Escudo Atual</label><br />
            <img src="@Model.EscudoUrl" alt="Escudo @Model.Nome" style="height:80px;" />
        </div>
    }

    <!-- campo para upload de novo escudo -->
    <div class="form-group mt-2">
        <label for="escudoFile" class="control-label">Novo Escudo</label>
        <input type="file" name="escudoFile" class="form-control" />
    </div>

    <div class="form-group mt-3">
        <input type="submit" value="Salvar" class="btn btn-primary" />
        <a asp-action="Index" class="btn btn-secondary">Voltar</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}