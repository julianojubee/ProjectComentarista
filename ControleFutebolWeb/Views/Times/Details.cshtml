@model ControleFutebolWeb.Models.TimeDetalhesViewModel
@using ControleFutebolWeb.Helpers
@removeTagHelper Microsoft.AspNetCore.Mvc.TagHelpers.OptionTagHelper, Microsoft.AspNetCore.Mvc.TagHelpers

@{
    ViewData["Title"] = Model.Time.Nome;

    // Forma recente do time (últimos 5 jogos finalizados) — usada no hero.
    var formaTime = Model.Jogos
        .Where(j => j.PlacarCasa.HasValue && j.PlacarVisitante.HasValue && j.Data < DateTime.Now)
        .OrderByDescending(j => j.Data)
        .Take(5)
        .Select(j =>
        {
            bool vitoria = (Model.Time.Id == j.TimeCasaId && j.PlacarCasa > j.PlacarVisitante) ||
                           (Model.Time.Id == j.TimeVisitanteId && j.PlacarVisitante > j.PlacarCasa);
            bool empate = j.PlacarCasa == j.PlacarVisitante;
            return vitoria ? "V" : empate ? "E" : "D";
        })
        .ToList();

    string CorForma(string r) => r switch { "V" => "#22c55e", "D" => "#ef4444", _ => "#6b7280" };

    int totalPartidas = Model.Jogos.Count(j => j.PlacarCasa.HasValue && j.PlacarVisitante.HasValue);
}

<link rel="stylesheet" href="~/fonts/barlow/barlow.css" asp-append-version="true" />

<style>
    body {
        background-image: url('@Url.Content(Model.Time.BackgroundUrl)');
        background-size: cover;
        background-position: center;
        background-attachment: fixed;
    }

    body::before {
        content: "";
        position: fixed;
        inset: 0;
        background-color: rgba(0,0,0,0.55);
        z-index: -1;
    }

    .ctd * { box-sizing: border-box; }

    .ctd {
        margin: 0 -12px;
        background: #0f0f0f;
        color: #e5e7eb;
        font-family: 'Barlow', Arial, sans-serif;
        border-radius: 14px;
        overflow: hidden;
    }

    .ctd a { text-decoration: none; color: inherit; }
    .ctd h1 { font-family: 'Barlow Condensed', Arial, sans-serif; }

    /* ── Hero ────────────────────────────────────── */
    .ctd-hero {
        position: relative;
        overflow: hidden;
        background: linear-gradient(135deg, #0a1628 0%, #1a2f4e 55%, #0a1628 100%);
        padding: 2.2rem 2.5rem 1.8rem;
    }

    .ctd-hero-pattern {
        position: absolute; inset: 0; width: 100%; height: 100%;
        object-fit: cover; opacity: 0.06; pointer-events: none;
    }

    .ctd-hero-stripe { position: absolute; left: 0; top: 0; bottom: 0; width: 4px; background: #d4a520; }

    .ctd-hero-row {
        position: relative; z-index: 1;
        display: flex; align-items: flex-start; gap: 24px; flex-wrap: wrap;
    }

    .ctd-badge-lg {
        width: 84px; height: 84px; border-radius: 50%;
        background: rgba(255,255,255,0.07); border: 2px solid rgba(255,255,255,0.15);
        display: flex; align-items: center; justify-content: center; overflow: hidden; flex-shrink: 0;
    }

    .ctd-badge-lg img { width: 82%; height: 82%; object-fit: contain; }
    .ctd-badge-lg span { font-size: 1.4rem; font-weight: 700; color: #9ca3af; }

    .ctd-info { flex: 1; min-width: 200px; padding-top: 2px; }

    .ctd-name-row { display: flex; align-items: center; gap: 10px; margin-bottom: 5px; flex-wrap: wrap; }
    .ctd-name-row h1 { font-size: 2.4rem; font-weight: 800; color: #f1f5f9; margin: 0; line-height: 1; }

    .ctd-formacao-badge {
        background: rgba(212,165,32,0.16); border: 1px solid rgba(212,165,32,0.4);
        color: #eecb6c; font-size: 0.66rem; font-weight: 700; padding: 3px 10px;
        border-radius: 6px; letter-spacing: 0.08em;
    }

    .ctd-cidade { display: flex; align-items: center; gap: 5px; margin-bottom: 14px; }
    .ctd-cidade span { font-size: 0.8rem; color: #9ca3af; }

    .ctd-meta-row { display: flex; align-items: center; gap: 8px; flex-wrap: wrap; }
    .ctd-meta-label {
        font-size: 0.6rem; font-weight: 700; letter-spacing: 0.12em;
        color: #64748b; text-transform: uppercase;
    }
    .ctd-forma-dot {
        display: inline-flex; align-items: center; justify-content: center;
        width: 20px; height: 20px; border-radius: 4px; color: #fff;
        font-size: 9px; font-weight: 800; flex-shrink: 0;
    }
    .ctd-meta-sep { width: 1px; height: 16px; background: rgba(255,255,255,0.14); margin: 0 2px; }
    .ctd-meta-info { font-size: 0.75rem; color: #94a3b8; }

    .ctd-treinador {
        background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1);
        border-radius: 12px; padding: 12px 16px; min-width: 190px; flex-shrink: 0;
    }
    .ctd-treinador-label {
        font-size: 0.58rem; font-weight: 700; letter-spacing: 0.16em;
        color: #6b7280; text-transform: uppercase; margin-bottom: 8px;
    }
    .ctd-treinador-row { display: flex; align-items: center; gap: 10px; }
    .ctd-treinador-foto {
        width: 40px; height: 40px; border-radius: 50%; object-fit: cover;
        border: 2px solid rgba(255,255,255,0.3); flex-shrink: 0;
    }
    .ctd-treinador-placeholder {
        width: 40px; height: 40px; border-radius: 50%; background: rgba(255,255,255,0.1);
        display: flex; align-items: center; justify-content: center; font-size: 1.1rem; flex-shrink: 0;
    }
    .ctd-treinador-nome { font-size: 0.86rem; font-weight: 700; color: #f1f5f9; }
    .ctd-treinador-nac { font-size: 0.7rem; color: #9ca3af; }

    .ctd-actions { display: flex; flex-direction: column; gap: 7px; flex-shrink: 0; }
    .ctd-action-btn {
        display: flex; align-items: center; gap: 7px; padding: 8px 14px;
        background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1);
        border-radius: 8px; color: #c9c5bb; font-size: 0.78rem; font-weight: 700; white-space: nowrap;
    }
    .ctd-action-btn:hover { border-color: #d4a520; color: #d4a520; }
    .ctd-action-btn.primary { background: rgba(212,165,32,0.14); border-color: rgba(212,165,32,0.32); color: #d4a520; }
    .ctd-action-btn.primary:hover { background: rgba(212,165,32,0.24); color: #d4a520; }

    /* ── Grid principal ──────────────────────────── */
    .ctd-grid {
        padding: 26px 2.5rem 3rem;
        display: grid;
        grid-template-columns: 280px 1fr 320px;
        gap: 22px;
        align-items: start;
    }

    @@media (max-width: 1100px) {
        .ctd-grid { grid-template-columns: 1fr; }
    }

    .ctd-col-title { display: flex; align-items: center; gap: 12px; margin-bottom: 14px; }
    .ctd-col-title span {
        font-family: 'Barlow Condensed', Arial, sans-serif; font-size: 0.72rem; font-weight: 700;
        letter-spacing: 0.16em; color: #6b7280; text-transform: uppercase; white-space: nowrap;
    }
    .ctd-col-title .line { flex: 1; height: 1px; background: #222; }
    .ctd-col-title .cnt { font-size: 0.68rem; color: #4b5563; font-weight: 600; }
    .ctd-col-title a { font-size: 0.7rem; color: #d4a520; font-weight: 700; white-space: nowrap; }
    .ctd-col-title a:hover { color: #f0c040; }

    /* ── Elenco ──────────────────────────────────── */
    .ctd-elenco-panel {
        background: #161616; border: 1px solid #262626; border-radius: 12px;
        overflow: hidden; max-height: 560px; overflow-y: auto;
    }

    .jogador-row {
        display: flex; align-items: center; gap: 10px; padding: 9px 14px;
        border-bottom: 1px solid #1a1a1a; cursor: grab; transition: background 0.12s;
    }
    .jogador-row:hover { background: #1e1e1e; }
    .jogador-row.usado { display: none; }

    .ctd-num {
        width: 28px; height: 28px; border-radius: 50%;
        display: flex; align-items: center; justify-content: center;
        font-size: 11px; font-weight: 700; color: #fff; flex-shrink: 0;
    }

    .ctd-jog-info { flex: 1; min-width: 0; }
    .ctd-jog-nome {
        font-size: 0.82rem; font-weight: 600; color: #e5e7eb;
        white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    }
    .ctd-jog-pos {
        font-size: 0.62rem; color: #6b7280; font-weight: 700;
        letter-spacing: 0.08em; text-transform: uppercase; margin-top: 1px;
        display: flex; align-items: center; gap: 5px;
    }
    .ctd-jog-clube { display: inline-flex; align-items: center; gap: 4px; color: rgba(255,255,255,0.5); }
    .ctd-jog-clube img { width: 13px; height: 13px; object-fit: contain; }

    .ctd-stats-link {
        font-size: 0.62rem; padding: 3px 8px; background: rgba(34,197,94,0.1);
        border: 1px solid rgba(34,197,94,0.22); color: #4ade80; border-radius: 5px;
        font-weight: 700; flex-shrink: 0;
    }
    .ctd-stats-link:hover { background: rgba(34,197,94,0.2); color: #4ade80; }

    /* ── Escalação ───────────────────────────────── */
    .ctd-form-row { display: flex; align-items: center; gap: 10px; margin-bottom: 12px; flex-wrap: wrap; }
    .ctd-select {
        appearance: none; background: #1a1a1a; border: 1px solid #333; border-radius: 8px;
        color: #e5e7eb; font-size: 0.84rem; padding: 9px 12px; cursor: pointer; outline: none;
    }
    .ctd-btn {
        padding: 9px 16px; border-radius: 8px; font-size: 0.82rem; font-weight: 700;
        border: none; cursor: pointer; letter-spacing: 0.02em;
    }
    .ctd-btn-gold { background: #d4a520; color: #141414; }
    .ctd-btn-gold:hover { background: #c49918; }
    .ctd-btn-green { background: #16a34a; color: #fff; }
    .ctd-btn-green:hover { background: #15803d; }

    .ctd-campo-wrap { max-width: 320px; margin: 0 auto; }

    .posicao-drop {
        position: absolute; text-align: center; cursor: grab; color: white;
        font-size: 11px; text-shadow: 1px 1px 2px black; transform: translate(-50%, -50%);
    }
    .posicao-drop * { pointer-events: none; }

    /* ── Partidas ────────────────────────────────── */
    .ctd-partidas-list { display: flex; flex-direction: column; gap: 10px; max-height: 560px; overflow-y: auto; }

    .ctd-match-card {
        background: #161616; border: 1px solid #262626; border-radius: 10px; padding: 12px 14px;
        transition: border-color 0.15s;
    }
    .ctd-match-card:hover { border-color: #383838; }

    .ctd-match-top { display: flex; justify-content: space-between; align-items: center; gap: 8px; margin-bottom: 10px; }
    .ctd-match-comp {
        display: flex; align-items: center; gap: 5px; font-size: 0.64rem; font-weight: 700;
        color: #d4a520; text-transform: uppercase; letter-spacing: 0.06em;
        overflow: hidden; text-overflow: ellipsis; white-space: nowrap; min-width: 0;
    }
    .ctd-match-comp img { width: 14px; height: 14px; object-fit: contain; border-radius: 50%; flex-shrink: 0; }
    .ctd-match-date { font-size: 0.64rem; color: #4b5563; flex-shrink: 0; white-space: nowrap; }

    .ctd-match-teams { display: flex; align-items: center; gap: 8px; }
    .ctd-match-team { display: flex; align-items: center; gap: 5px; flex: 1; min-width: 0; }
    .ctd-match-team img { width: 20px; height: 20px; object-fit: contain; flex-shrink: 0; }
    .ctd-match-team span {
        font-size: 0.78rem; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
    }
    .ctd-match-team.right { justify-content: flex-end; }

    .ctd-match-score {
        font-family: 'Barlow Condensed', Arial, sans-serif; font-size: 1.2rem; font-weight: 800;
        color: #f1f5f9; background: #0f0f0f; padding: 2px 10px; border-radius: 6px;
        flex-shrink: 0; letter-spacing: 0.06em; white-space: nowrap;
    }

    .ctd-match-footer {
        display: flex; align-items: center; justify-content: space-between; gap: 8px;
        margin-top: 10px; padding-top: 8px; border-top: 1px solid #1e1e1e;
    }
    .ctd-result-badge {
        color: #fff; border-radius: 4px; width: 20px; height: 20px; display: inline-flex;
        align-items: center; justify-content: center; font-size: 9px; font-weight: 800; flex-shrink: 0;
    }
    .ctd-status-badge {
        font-size: 0.62rem; font-weight: 700; padding: 2px 8px; border-radius: 999px;
        white-space: nowrap;
    }
    .ctd-status-ok { background: rgba(34,197,94,0.14); color: #4ade80; border: 1px solid rgba(34,197,94,0.3); }
    .ctd-status-pending { background: rgba(255,255,255,0.08); color: #9ca3af; border: 1px solid rgba(255,255,255,0.15); }

    .ctd-analisar-link {
        font-size: 0.65rem; color: #6b7280; font-weight: 600; display: flex; align-items: center; gap: 3px;
        flex-shrink: 0;
    }
    .ctd-analisar-link:hover { color: #d4a520; }

    .ctd-empty { text-align: center; padding: 1.5rem 1rem; color: #6b7280; font-size: 0.82rem; }
</style>

<div class="ctd">

    @if (TempData["Mensagem"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show m-3" role="alert">
            @TempData["Mensagem"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Fechar"></button>
        </div>
    }

    <!-- Hero -->
    <div class="ctd-hero">
        <img class="ctd-hero-pattern" src="~/Images/banner/escudos-pattern.svg" alt="" />
        <div class="ctd-hero-stripe"></div>

        <div class="ctd-hero-row">
            <div class="ctd-badge-lg">
                @if (!string.IsNullOrEmpty(Model.Time.EscudoUrl))
                {
                    <img src="@Url.Action("Imagem", "MediaProxy", new { url = Model.Time.EscudoUrl })" alt="@Model.Time.Nome" />
                }
                else
                {
                    <span>@(Model.Time.Nome?.Length >= 3 ? Model.Time.Nome.Substring(0, 3).ToUpper() : Model.Time.Nome)</span>
                }
            </div>

            <div class="ctd-info">
                <div class="ctd-name-row">
                    <h1>@Model.Time.Nome</h1>
                    @if (Model.Time.FormacaoPadrao != null)
                    {
                        <span class="ctd-formacao-badge">@Model.Time.FormacaoPadrao.Nome</span>
                    }
                </div>
                <div class="ctd-cidade">
                    <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="#6b7280" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" /><circle cx="12" cy="10" r="3" /></svg>
                    <span>@Model.Time.Cidade</span>
                </div>
                <div class="ctd-meta-row">
                    @if (formaTime.Any())
                    {
                        <span class="ctd-meta-label">Forma recente</span>
                        @foreach (var r in formaTime)
                        {
                            <span class="ctd-forma-dot" style="background:@CorForma(r);">@r</span>
                        }
                        <div class="ctd-meta-sep"></div>
                    }
                    <span class="ctd-meta-info">@Model.Elenco.Count jogadores</span>
                    <span class="ctd-meta-info">·</span>
                    <span class="ctd-meta-info">@totalPartidas partidas</span>
                </div>
            </div>

            @if (Model.Treinador != null)
            {
                <div class="ctd-treinador">
                    <div class="ctd-treinador-label">Treinador</div>
                    <div class="ctd-treinador-row">
                        @if (!string.IsNullOrWhiteSpace(Model.Treinador.FotoUrl))
                        {
                            <img class="ctd-treinador-foto" src="@Url.FotoSrc(Model.Treinador.FotoUrl)" alt="@Model.Treinador.Nome" />
                        }
                        else
                        {
                            <div class="ctd-treinador-placeholder">🧑‍💼</div>
                        }
                        <div>
                            <div class="ctd-treinador-nome">@Model.Treinador.Nome</div>
                            @if (Model.Treinador.Nacionalidade != null)
                            {
                                <div class="ctd-treinador-nac">@Model.Treinador.Nacionalidade.Nome</div>
                            }
                        </div>
                    </div>
                </div>
            }

            <div class="ctd-actions">
                <a asp-controller="Relatorios" asp-action="Index" asp-route-timeId="@Model.Time.Id" class="ctd-action-btn primary">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="20" x2="18" y2="10" /><line x1="12" y1="20" x2="12" y2="4" /><line x1="6" y1="20" x2="6" y2="14" /></svg>
                    Relatórios
                </a>
                <a asp-controller="AnotacoesTime" asp-action="Index" asp-route-timeId="@Model.Time.Id" class="ctd-action-btn">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" /><polyline points="14 2 14 8 20 8" /></svg>
                    Anotações
                </a>
                <a asp-controller="Times" asp-action="Edit" asp-route-id="@Model.Time.Id" class="ctd-action-btn">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7" /><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z" /></svg>
                    Editar time
                </a>
                <form method="post" asp-action="AtualizarDadosJogadores" asp-controller="Times" asp-route-id="@Model.Time.Id" style="display:inline;"
                      onsubmit="return confirm('Buscar idade, altura e peso na API para os jogadores do elenco que ainda não têm esses dados?')">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="ctd-action-btn">
                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 2v6h-6" /><path d="M3 12a9 9 0 0 1 15-6.7L21 8" /><path d="M3 22v-6h6" /><path d="M21 12a9 9 0 0 1-15 6.7L3 16" /></svg>
                        Atualizar dados jogadores
                    </button>
                </form>
            </div>
        </div>
    </div>

    <!-- Grid principal -->
    <div class="ctd-grid">

        <!-- ── Elenco ──────────────────────────────── -->
        <div>
            <div class="ctd-col-title">
                <span>Elenco</span>
                <div class="line"></div>
                <span class="cnt">@Model.Elenco.Count jog.</span>
            </div>
            <div class="ctd-elenco-panel" id="listaJogadores">
                @foreach (var jogador in Model.Elenco)
                {
                    bool ehConvocado = jogador.TimeId != Model.Time.Id;
                    <div class="jogador-row"
                         id="jogador-@jogador.Id"
                         draggable="true"
                         ondragstart="dragJogador(event, @jogador.Id, '@jogador.Nome', '@(jogador.NumeroCamisa?.ToString() ?? "")')">
                        <div class="ctd-num player-circle-team">@(jogador.NumeroCamisa?.ToString() ?? "")</div>
                        <div class="ctd-jog-info">
                            <div class="ctd-jog-nome">@jogador.Nome</div>
                            <div class="ctd-jog-pos">
                                @jogador.Posicao
                                @if (ehConvocado && jogador.Time != null)
                                {
                                    <span class="ctd-jog-clube">
                                        @if (!string.IsNullOrEmpty(jogador.Time.EscudoUrl))
                                        {
                                            <img src="@Url.Action("Imagem", "MediaProxy", new { url = jogador.Time.EscudoUrl })" alt="" />
                                        }
                                        @jogador.Time.Nome
                                    </span>
                                }
                            </div>
                        </div>
                        <a href="/Jogadores/Estatisticas/@jogador.Id" class="ctd-stats-link" title="Ver estatísticas de @jogador.Nome">Stats</a>
                    </div>
                }
            </div>
        </div>

        <!-- ── Escalação padrão ────────────────────── -->
        <div>
            <div class="ctd-col-title">
                <span>Escalação Padrão</span>
                <div class="line"></div>
            </div>

            <form method="post" asp-action="DefinirFormacao" asp-controller="Times" class="ctd-form-row">
                <input type="hidden" name="id" value="@Model.Time.Id" />
                <select id="formacaoPadrao" name="formacaoPadraoId" class="ctd-select">
                    @foreach (var formacao in Model.Formacoes)
                    {
                        <option value="@formacao.Id" @(formacao.Id == Model.Time.FormacaoPadraoId ? "selected" : "")>
                            @formacao.Nome
                        </option>
                    }
                </select>
                <button type="submit" class="ctd-btn ctd-btn-gold">Definir Formação</button>
            </form>

            <form id="formEscalacao" method="post" asp-action="SalvarEscalacaoPadrao" asp-controller="Times">
                <input type="hidden" name="id" value="@Model.Time.Id" />

                <div class="ctd-campo-wrap">
                    <div id="campo" class="campo" style="position:relative;"
                         ondrop="dropNoCampo(event)" ondragover="allowDrop(event)">

                        @{
                            var index = 0;
                        }
                        @foreach (var esc in Model.TimeEscalacaoPadrao)
                        {
                            <div class="posicao-drop"
                                 data-index="@index"
                                 data-posicao="@esc.Posicao"
                                 draggable="true"
                                 ondragstart="dragPosicao(event, @index)"
                                 ondrop="dropEscalacao(event, @index)"
                                 ondragover="allowDrop(event)"
                                 style="left:@esc.PosicaoX%; top:@esc.PosicaoY%;">

                                <span>@esc.Posicao</span>

                                @if (esc.Jogador != null)
                                {
                                    <div class="player-circle player-circle-team">@(esc.Jogador.NumeroCamisa?.ToString() ?? "")</div>
                                    <div class="player-name">@esc.Jogador.Nome</div>
                                }
                            </div>

                            <input type="hidden" name="escalacao[@index].Id" value="@esc.Id" />
                            <input type="hidden" name="escalacao[@index].PosicaoId" value="@esc.PosicaoId" />
                            <input type="hidden" id="escalacao_@(index)__JogadorId" name="escalacao[@index].JogadorId" value="@esc.JogadorId" />
                            <input type="hidden" id="escalacao_@(index)__PosicaoX" name="escalacao[@index].PosicaoX" value="@esc.PosicaoX" />
                            <input type="hidden" id="escalacao_@(index)__PosicaoY" name="escalacao[@index].PosicaoY" value="@esc.PosicaoY" />
                            index++;
                        }
                    </div>
                </div>

                <div class="mt-3 text-center">
                    <button type="submit" class="ctd-btn ctd-btn-green">Salvar Escalação Padrão</button>
                </div>
            </form>
        </div>

        <!-- ── Partidas ────────────────────────────── -->
        <div>
            <div class="ctd-col-title">
                <span>Partidas</span>
                <div class="line"></div>
            </div>

            <div class="ctd-partidas-list">
                @if (!Model.JogosPassados.Any() && !Model.JogosFuturos.Any())
                {
                    <div class="ctd-empty">Nenhuma partida registrada ainda.</div>
                }

                @foreach (var jogo in Model.JogosPassados)
                {
                    bool vitoria = (Model.Time.Id == jogo.TimeCasaId && jogo.PlacarCasa > jogo.PlacarVisitante) ||
                                   (Model.Time.Id == jogo.TimeVisitanteId && jogo.PlacarVisitante > jogo.PlacarCasa);
                    bool empate = jogo.PlacarCasa == jogo.PlacarVisitante;
                    string resLetra = vitoria ? "V" : empate ? "E" : "D";
                    string resCor = vitoria ? "#22c55e" : empate ? "#6b7280" : "#ef4444";
                    bool casaVenceu = jogo.PlacarCasa > jogo.PlacarVisitante;
                    bool visVenceu = jogo.PlacarVisitante > jogo.PlacarCasa;
                    var logoComp = CompeticaoHelper.GetLogoCompeticao(jogo.CompeticaoId);
                    var nomeComp = CompeticaoHelper.GetNomeCompeticao(jogo.CompeticaoId);

                    <a asp-controller="Jogos" asp-action="Analisar" asp-route-id="@jogo.Id" class="ctd-match-card" style="display:block;">
                        <div class="ctd-match-top">
                            <span class="ctd-match-comp">
                                @if (!string.IsNullOrEmpty(logoComp))
                                {
                                    <img src="@logoComp" alt="" />
                                }
                                @nomeComp
                            </span>
                            <span class="ctd-match-date">@DateHelper.FormatarData(jogo.Data, "dd/MM")</span>
                        </div>
                        <div class="ctd-match-teams">
                            <div class="ctd-match-team">
                                <img src="@Url.Action("Imagem", "MediaProxy", new { url = jogo.TimeCasa?.EscudoUrl })" alt="" />
                                <span style="font-weight:@(casaVenceu ? "700" : "500"); color:@(casaVenceu ? "#f1f5f9" : "#6b7280");">@jogo.TimeCasa?.Nome</span>
                            </div>
                            <span class="ctd-match-score">@jogo.PlacarCasa &ndash; @jogo.PlacarVisitante</span>
                            <div class="ctd-match-team right">
                                <span style="font-weight:@(visVenceu ? "700" : "500"); color:@(visVenceu ? "#f1f5f9" : "#6b7280");">@jogo.TimeVisitante?.Nome</span>
                                <img src="@Url.Action("Imagem", "MediaProxy", new { url = jogo.TimeVisitante?.EscudoUrl })" alt="" />
                            </div>
                        </div>
                        @if (jogo.PenaltisCasa.HasValue && jogo.PenaltisVisitante.HasValue)
                        {
                            <div style="text-align:center; font-size:0.62rem; color:#6b7280; margin-top:4px;">(@jogo.PenaltisCasa-@jogo.PenaltisVisitante pên.)</div>
                        }
                        <div class="ctd-match-footer">
                            <div style="display:flex; align-items:center; gap:8px;">
                                <span class="ctd-result-badge" style="background:@resCor;">@resLetra</span>
                                @if (jogo.Analisado == 1)
                                {
                                    <span class="ctd-status-badge ctd-status-ok">✅ Analisado</span>
                                }
                                else
                                {
                                    <span class="ctd-status-badge ctd-status-pending">⏳ Pendente</span>
                                }
                            </div>
                            <span class="ctd-analisar-link">
                                <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="11" cy="11" r="8" /><line x1="21" y1="21" x2="16.65" y2="16.65" /></svg>
                                @(jogo.Analisado == 1 ? "Ver análise" : "Analisar")
                            </span>
                        </div>
                    </a>
                }

                @foreach (var jogo in Model.JogosFuturos)
                {
                    var logoComp = CompeticaoHelper.GetLogoCompeticao(jogo.CompeticaoId);
                    var nomeComp = CompeticaoHelper.GetNomeCompeticao(jogo.CompeticaoId);

                    <a asp-controller="Jogos" asp-action="Analisar" asp-route-id="@jogo.Id" class="ctd-match-card" style="display:block;">
                        <div class="ctd-match-top">
                            <span class="ctd-match-comp">
                                @if (!string.IsNullOrEmpty(logoComp))
                                {
                                    <img src="@logoComp" alt="" />
                                }
                                @nomeComp
                            </span>
                            <span class="ctd-match-date">@DateHelper.FormatarData(jogo.Data, "dd/MM")</span>
                        </div>
                        <div class="ctd-match-teams">
                            <div class="ctd-match-team">
                                <img src="@Url.Action("Imagem", "MediaProxy", new { url = jogo.TimeCasa?.EscudoUrl })" alt="" />
                                <span style="color:#9ca3af;">@jogo.TimeCasa?.Nome</span>
                            </div>
                            <span class="ctd-match-score" style="color:#6b7280;">vs</span>
                            <div class="ctd-match-team right">
                                <span style="color:#9ca3af;">@jogo.TimeVisitante?.Nome</span>
                                <img src="@Url.Action("Imagem", "MediaProxy", new { url = jogo.TimeVisitante?.EscudoUrl })" alt="" />
                            </div>
                        </div>
                        <div class="ctd-match-footer">
                            <span class="ctd-status-badge ctd-status-pending">Agendado</span>
                            <span class="ctd-analisar-link">
                                <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="11" cy="11" r="8" /><line x1="21" y1="21" x2="16.65" y2="16.65" /></svg>
                                Analisar
                            </span>
                        </div>
                    </a>
                }
            </div>
        </div>

    </div>
</div>

<script>
    // ── Estado global (igual ao Analisar) ──────────────────────────────────
    const usados = new Set();
    let dragData          = {};
    let draggingPosicao   = false;
    let posicaoArrastando = null;


    // ── Inicializa jogadores já posicionados ───────────────────────────────
    function initUsados() {
        document.querySelectorAll('[id^="escalacao_"][id$="__JogadorId"]').forEach(el => {
            if (el.value) usados.add(el.value);
        });
        atualizarLista();
    }

    function atualizarLista() {
        usados.forEach(id => {
            const row = document.getElementById('jogador-' + id);
            if (row) row.classList.add('usado');
        });
    }

    function marcarUsado(jogadorId) {
        usados.add(String(jogadorId));
        const row = document.getElementById('jogador-' + jogadorId);
        if (row) row.classList.add('usado');
    }

    function desmarcarUsado(jogadorId) {
        usados.delete(String(jogadorId));
        const row = document.getElementById('jogador-' + jogadorId);
        if (row) row.classList.remove('usado');
    }

    // ── Drag helpers ───────────────────────────────────────────────────────
    function allowDrop(ev) { ev.preventDefault(); }

    // Arrastar jogador da lista lateral
    function dragJogador(ev, jogadorId, jogadorNome, jogadorNumero) {
        draggingPosicao = false;
        dragData = { jogadorId: String(jogadorId), jogadorNome, jogadorNumero };
        ev.dataTransfer.setData("text/plain", String(jogadorId));
    }

    // ── Soltar jogador em slot do campo ───────────────────────────────────
    function dropEscalacao(ev, index) {
        ev.preventDefault();
        ev.stopPropagation();
        if (draggingPosicao) return;

        const { jogadorId, jogadorNome, jogadorNumero } = dragData;
        if (!jogadorId) return;

        if (usados.has(jogadorId)) {
            alert("Esse jogador já está em campo!");
            return;
        }

        const hidden    = document.getElementById(`escalacao_${index}__JogadorId`);
        if (!hidden) return;

        const antigoId  = hidden.value;
        if (antigoId) desmarcarUsado(antigoId);

        hidden.value = jogadorId;
        marcarUsado(jogadorId);

        const posEl      = document.querySelector(`.posicao-drop[data-index='${index}']`);
        const nomePosicao = posEl.dataset.posicao;

        posEl.innerHTML = `
            <span>${nomePosicao}</span>
            <div class="player-circle player-circle-team">${jogadorNumero}</div>
            <div class="player-name">${jogadorNome}</div>`;
    }

    // ── Arrastar posição já no campo (reposicionar) ────────────────────────
    function dragPosicao(ev, index) {
        draggingPosicao   = true;
        posicaoArrastando = index;
        ev.dataTransfer.setData("text/plain", String(index));
    }

    // Drop no fundo do campo para reposicionar slot
    function dropNoCampo(ev) {
        ev.preventDefault();
        ev.stopPropagation();

        if (!draggingPosicao || posicaoArrastando === null) return;

        const index = posicaoArrastando;
        const campo = document.getElementById("campo");
        const rect  = campo.getBoundingClientRect();

        const newX = Math.round(((ev.clientX - rect.left)  / rect.width)  * 100);
        const newY = Math.round(((ev.clientY - rect.top)   / rect.height) * 100);

        if (newX < 0 || newX > 100 || newY < 0 || newY > 100) return;

        const el = document.querySelector(`.posicao-drop[data-index='${index}']`);
        if (!el) return;

        el.style.left = newX + "%";
        el.style.top  = newY + "%";

        document.getElementById(`escalacao_${index}__PosicaoX`).value = newX;
        document.getElementById(`escalacao_${index}__PosicaoY`).value = newY;

        draggingPosicao   = false;
        posicaoArrastando = null;
    }

    // Inicializa ao carregar
    initUsados();
</script>

<!-- ══ ESTATÍSTICAS DA TEMPORADA (API) ══════════════════════════════════════ -->
<div id="painel-estatisticas-api" style="margin-top:2rem;">
    <div style="background:#0f172a;border:1px solid #1e293b;border-radius:16px;padding:1.5rem;">
        <h5 style="color:#f1f5f9;font-family:'Barlow Condensed',sans-serif;font-size:20px;font-weight:800;margin-bottom:1rem;">
            📊 Estatísticas da Temporada
        </h5>

        <div style="display:flex;gap:.75rem;align-items:flex-end;flex-wrap:wrap;margin-bottom:1.25rem;">
            @if (Model.CompeticoesApi.Any())
            {
                <!-- data-season em cada option para preencher automaticamente o campo temporada -->
                <div>
                    <label style="font-size:11px;color:#94a3b8;text-transform:uppercase;letter-spacing:1px;display:block;margin-bottom:.3rem;">Competição</label>
                    <select id="sel-league" onchange="syncSeason(this)"
                            style="background:#1e293b;color:#f1f5f9;border:1px solid #334155;border-radius:8px;padding:.45rem .75rem;font-size:13px;min-width:200px;">
                        @foreach (var c in Model.CompeticoesApi)
                        {
                            <option value="@c.LeagueId" data-season="@c.Season">@c.Nome (@c.Season)</option>
                        }
                    </select>
                </div>
                <div>
                    <label style="font-size:11px;color:#94a3b8;text-transform:uppercase;letter-spacing:1px;display:block;margin-bottom:.3rem;">Temporada</label>
                    <input id="sel-season" type="number" value="@Model.CompeticoesApi.First().Season"
                           style="background:#1e293b;color:#f1f5f9;border:1px solid #334155;border-radius:8px;padding:.45rem .75rem;font-size:13px;width:100px;" />
                </div>
            }
            else
            {
                <div>
                    <label style="font-size:11px;color:#94a3b8;text-transform:uppercase;letter-spacing:1px;display:block;margin-bottom:.3rem;">ID Liga (API)</label>
                    <input id="sel-league" type="number" value="71" style="background:#1e293b;color:#f1f5f9;border:1px solid #334155;border-radius:8px;padding:.45rem .75rem;font-size:13px;width:110px;" />
                </div>
                <div>
                    <label style="font-size:11px;color:#94a3b8;text-transform:uppercase;letter-spacing:1px;display:block;margin-bottom:.3rem;">Temporada</label>
                    <input id="sel-season" type="number" value="@DateTime.Now.Year" style="background:#1e293b;color:#f1f5f9;border:1px solid #334155;border-radius:8px;padding:.45rem .75rem;font-size:13px;width:100px;" />
                </div>
            }
            <button onclick="buscarEstatisticasApi()" style="background:#3b82f6;color:#fff;border:none;border-radius:8px;padding:.5rem 1.25rem;font-size:13px;font-weight:700;cursor:pointer;align-self:flex-end;">
                🔍 Buscar
            </button>
        </div>

        <div id="estat-loading" style="display:none;color:#94a3b8;text-align:center;padding:1rem;">Buscando estatísticas...</div>
        <div id="estat-erro"    style="display:none;color:#ef4444;padding:.5rem 0;"></div>
        <div id="estat-result"  style="display:none;"></div>
    </div>
</div>

<script>
function syncSeason(sel) {
    const season = sel.options[sel.selectedIndex].dataset.season;
    if (season) document.getElementById('sel-season').value = season;
}

async function buscarEstatisticasApi() {
    const leagueId = document.getElementById('sel-league').value;
    const season   = document.getElementById('sel-season').value;
    const timeId   = @Model.Time.Id;

    document.getElementById('estat-loading').style.display = 'block';
    document.getElementById('estat-erro').style.display    = 'none';
    document.getElementById('estat-result').style.display  = 'none';

    try {
        const res  = await fetch(`/Times/EstatisticasApi?timeId=${timeId}&leagueId=${leagueId}&season=${season}`);
        const data = await res.json();

        document.getElementById('estat-loading').style.display = 'none';

        if (data.erro) {
            document.getElementById('estat-erro').textContent    = data.erro;
            document.getElementById('estat-erro').style.display  = 'block';
            return;
        }

        renderEstatisticas(data);
        document.getElementById('estat-result').style.display = 'block';
    } catch(e) {
        document.getElementById('estat-loading').style.display = 'none';
        document.getElementById('estat-erro').textContent    = 'Erro ao buscar estatísticas.';
        document.getElementById('estat-erro').style.display  = 'block';
    }
}

function renderEstatisticas(d) {
    const f = d.fixtures;
    const g = d.goals;
    const b = d.biggest;

    // Form string colorida
    const formHtml = (d.form || '').split('').map(c => {
        const cor = c === 'W' ? '#22c55e' : c === 'D' ? '#6b7280' : '#ef4444';
        const letra = c === 'W' ? 'V' : c === 'D' ? 'E' : 'D';
        return `<span style="display:inline-block;width:22px;height:22px;line-height:22px;text-align:center;border-radius:4px;background:${cor};color:#fff;font-size:11px;font-weight:700;margin:1px;">${letra}</span>`;
    }).join('');

    // Formações mais usadas
    const lineupsHtml = (d.lineups || []).slice(0, 5).map((l, i) => {
        const pct = f.played.total > 0 ? Math.round(l.played / f.played.total * 100) : 0;
        const cor = i === 0 ? '#3b82f6' : '#475569';
        return `<div style="display:flex;align-items:center;gap:.5rem;margin-bottom:.4rem;">
            <span style="font-size:13px;font-weight:700;color:#f1f5f9;min-width:70px;">${l.formation}</span>
            <div style="flex:1;background:#334155;border-radius:4px;height:8px;">
                <div style="width:${pct}%;background:${cor};height:100%;border-radius:4px;"></div>
            </div>
            <span style="font-size:12px;color:#94a3b8;min-width:40px;text-align:right;">${l.played}x</span>
        </div>`;
    }).join('');

    // Gols por minuto (pró)
    const minuteKeys = ['0-15','16-30','31-45','46-60','61-75','76-90','91-105'];
    const goalsForMinute  = g.for.minute  || {};
    const goalsAgMinute   = g.against.minute || {};
    const maxFor = Math.max(1, ...minuteKeys.map(k => goalsForMinute[k]?.total || 0));
    const maxAg  = Math.max(1, ...minuteKeys.map(k => goalsAgMinute[k]?.total  || 0));

    const minuteHtml = minuteKeys.map(k => {
        const vf = goalsForMinute[k]?.total  || 0;
        const va = goalsAgMinute[k]?.total   || 0;
        return `<div style="text-align:center;">
            <div style="font-size:10px;color:#64748b;margin-bottom:2px;">${k}'</div>
            <div style="height:60px;display:flex;align-items:flex-end;justify-content:center;gap:2px;">
                <div title="Marcados: ${vf}" style="width:14px;background:#22c55e;height:${Math.round(vf/maxFor*60)}px;border-radius:2px 2px 0 0;"></div>
                <div title="Sofridos: ${va}" style="width:14px;background:#ef4444;height:${Math.round(va/maxAg*60)}px;border-radius:2px 2px 0 0;"></div>
            </div>
            <div style="font-size:9px;color:#94a3b8;">${vf}/${va}</div>
        </div>`;
    }).join('');

    // Cartões amarelos por minuto
    const cardKeys = ['0-15','16-30','31-45','46-60','61-75','76-90','91-105'];
    const yellowM = d.cards?.yellow || {};
    const maxY = Math.max(1, ...cardKeys.map(k => yellowM[k]?.total || 0));
    const yellowHtml = cardKeys.map(k => {
        const v = yellowM[k]?.total || 0;
        return `<div style="text-align:center;">
            <div style="font-size:10px;color:#64748b;margin-bottom:2px;">${k}'</div>
            <div style="height:50px;display:flex;align-items:flex-end;justify-content:center;">
                <div title="${v} cartões" style="width:16px;background:#fbbf24;height:${Math.round(v/maxY*50)}px;border-radius:2px 2px 0 0;"></div>
            </div>
            <div style="font-size:9px;color:#94a3b8;">${v}</div>
        </div>`;
    }).join('');

    const html = `
    <!-- Forma recente -->
    <div style="margin-bottom:1.5rem;">
        <div style="font-size:11px;color:#94a3b8;text-transform:uppercase;letter-spacing:1px;margin-bottom:.5rem;">Forma recente</div>
        <div>${formHtml}</div>
    </div>

    <!-- Cards: resultados -->
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(130px,1fr));gap:.75rem;margin-bottom:1.5rem;">
        ${statBox('Jogos',    f.played.total, '#94a3b8', `🏠 ${f.played.home} / ✈️ ${f.played.away}`)}
        ${statBox('Vitórias', f.wins.total,   '#22c55e', `🏠 ${f.wins.home} / ✈️ ${f.wins.away}`)}
        ${statBox('Empates',  f.draws.total,  '#6b7280', `🏠 ${f.draws.home} / ✈️ ${f.draws.away}`)}
        ${statBox('Derrotas', f.loses.total,  '#ef4444', `🏠 ${f.loses.home} / ✈️ ${f.loses.away}`)}
        ${statBox('Gols pró', g.for.total.total,     '#3b82f6', `Média: ${g.for.average.total}/jogo`)}
        ${statBox('Gols contr.', g.against.total.total, '#f97316', `Média: ${g.against.average.total}/jogo`)}
        ${statBox('Clean sheets', d.cleanSheet?.total ?? 0, '#a3e635', '')}
        ${statBox('Sem marcar',   d.failedToScore?.total ?? 0, '#94a3b8', '')}
    </div>

    <!-- Pênaltis e maiores resultados -->
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:.75rem;margin-bottom:1.5rem;">
        <div style="background:#1e293b;border-radius:10px;padding:.9rem 1rem;">
            <div style="font-size:11px;color:#94a3b8;text-transform:uppercase;letter-spacing:1px;margin-bottom:.5rem;">⚽ Pênaltis</div>
            <div style="font-size:13px;color:#f1f5f9;">Cobrados: <b>${d.penalty?.total ?? 0}</b> | Convertidos: <b>${d.penalty?.scored?.total ?? 0}</b> (${d.penalty?.scored?.percentage ?? '0%'})</div>
        </div>
        <div style="background:#1e293b;border-radius:10px;padding:.9rem 1rem;">
            <div style="font-size:11px;color:#94a3b8;text-transform:uppercase;letter-spacing:1px;margin-bottom:.5rem;">🏆 Maiores vitórias</div>
            <div style="font-size:13px;color:#f1f5f9;">🏠 ${b.wins?.home || '—'} | ✈️ ${b.wins?.away || '—'}</div>
        </div>
        <div style="background:#1e293b;border-radius:10px;padding:.9rem 1rem;">
            <div style="font-size:11px;color:#94a3b8;text-transform:uppercase;letter-spacing:1px;margin-bottom:.5rem;">😞 Maiores derrotas</div>
            <div style="font-size:13px;color:#f1f5f9;">🏠 ${b.loses?.home || '—'} | ✈️ ${b.loses?.away || '—'}</div>
        </div>
        <div style="background:#1e293b;border-radius:10px;padding:.9rem 1rem;">
            <div style="font-size:11px;color:#94a3b8;text-transform:uppercase;letter-spacing:1px;margin-bottom:.5rem;">🔥 Sequências</div>
            <div style="font-size:13px;color:#f1f5f9;">✅ ${b.streak?.wins}V | ⬜ ${b.streak?.draws}E | ❌ ${b.streak?.loses}D</div>
        </div>
    </div>

    <!-- Gols por minuto -->
    <div style="background:#1e293b;border-radius:10px;padding:.9rem 1rem;margin-bottom:1rem;">
        <div style="font-size:11px;color:#94a3b8;text-transform:uppercase;letter-spacing:1px;margin-bottom:.75rem;">
            ⚽ Gols por intervalo &nbsp;<span style="color:#22c55e;">■ Marcados</span> &nbsp;<span style="color:#ef4444;">■ Sofridos</span>
        </div>
        <div style="display:flex;gap:.5rem;align-items:flex-end;">${minuteHtml}</div>
    </div>

    <!-- Cartões por minuto -->
    <div style="background:#1e293b;border-radius:10px;padding:.9rem 1rem;margin-bottom:1rem;">
        <div style="font-size:11px;color:#94a3b8;text-transform:uppercase;letter-spacing:1px;margin-bottom:.75rem;">🟨 Cartões amarelos por intervalo</div>
        <div style="display:flex;gap:.5rem;align-items:flex-end;">${yellowHtml}</div>
    </div>

    <!-- Formações -->
    <div style="background:#1e293b;border-radius:10px;padding:.9rem 1rem;">
        <div style="font-size:11px;color:#94a3b8;text-transform:uppercase;letter-spacing:1px;margin-bottom:.75rem;">🧩 Formações utilizadas</div>
        ${lineupsHtml}
    </div>`;

    document.getElementById('estat-result').innerHTML = html;
}

function statBox(label, valor, cor, sub) {
    return `<div style="background:#1e293b;border-radius:10px;padding:.75rem .9rem;">
        <div style="font-size:10px;color:#94a3b8;text-transform:uppercase;letter-spacing:1px;">${label}</div>
        <div style="font-size:26px;font-weight:800;color:${cor};font-family:'Barlow Condensed',sans-serif;">${valor ?? '—'}</div>
        ${sub ? `<div style="font-size:11px;color:#64748b;">${sub}</div>` : ''}
    </div>`;
}
</script>
