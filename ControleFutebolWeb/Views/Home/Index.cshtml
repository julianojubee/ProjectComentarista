@model ControleFutebolWeb.Models.ViewModels.HomeViewModel

@{
    ViewData["Title"] = "Início";
}

<style>
    /* ── Reset local ─────────────────────────────── */
    .cf-home * {
        box-sizing: border-box;
    }

    /* ── Hero ────────────────────────────────────── */
    .cf-hero {
        position: relative;
        background: linear-gradient(135deg, #0a1628 0%, #1a2f4e 55%, #0f2040 100%);
        border-radius: 14px;
        padding: 3.5rem 2rem;
        text-align: center;
        overflow: hidden;
        margin-bottom: 2rem;
    }

    .cf-hero-pitch {
        position: absolute;
        inset: 0;
        opacity: 0.06;
        background-image: radial-gradient(circle at 50% 50%, transparent 28%, #fff 28.5%, #fff 29.2%, transparent 29.8%), linear-gradient(90deg, transparent 49.5%, #fff 49.5%, #fff 50.5%, transparent 50.5%), linear-gradient(transparent 49.5%, #fff 49.5%, #fff 50.5%, transparent 50.5%);
        pointer-events: none;
    }

    .cf-hero-content {
        position: relative;
        z-index: 1;
    }

    .cf-hero-badge {
        display: inline-block;
        background: rgba(55, 138, 221, 0.2);
        color: #85b7eb;
        font-size: 11px;
        font-weight: 600;
        padding: 4px 14px;
        border-radius: 20px;
        border: 1px solid rgba(55, 138, 221, 0.35);
        letter-spacing: 1px;
        text-transform: uppercase;
        margin-bottom: 1.1rem;
    }

    .cf-hero h1 {
        font-size: 2rem;
        font-weight: 600;
        color: #fff;
        margin-bottom: 0.6rem;
        letter-spacing: -0.5px;
    }

    .cf-hero p {
        color: rgba(255,255,255,0.5);
        font-size: 0.95rem;
        margin-bottom: 1.4rem;
    }

    /* ── Search ──────────────────────────────────── */
    .cf-search-wrap {
        position: relative;
        max-width: 480px;
        margin: 0 auto 1.4rem;
    }
    .cf-search-input {
        width: 100%;
        padding: 11px 44px 11px 16px;
        border-radius: 10px;
        border: 1px solid rgba(255,255,255,0.18);
        background: rgba(255,255,255,0.10);
        color: #fff;
        font-size: 14px;
        outline: none;
        transition: border-color .15s, background .15s;
    }
    .cf-search-input::placeholder { color: rgba(255,255,255,0.45); }
    .cf-search-input:focus {
        border-color: rgba(55,138,221,0.7);
        background: rgba(255,255,255,0.14);
    }
    .cf-search-icon {
        position: absolute;
        right: 13px;
        top: 50%;
        transform: translateY(-50%);
        color: rgba(255,255,255,0.45);
        font-size: 16px;
        pointer-events: none;
    }
    .cf-search-dropdown {
        position: absolute;
        top: calc(100% + 6px);
        left: 0; right: 0;
        background: var(--surface);
        border: 0.5px solid var(--border);
        border-radius: 10px;
        box-shadow: 0 8px 24px rgba(0,0,0,.12);
        z-index: 999;
        overflow: hidden;
        display: none;
    }
    .cf-search-dropdown.open { display: block; }
    .cf-search-item {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 9px 14px;
        text-decoration: none;
        color: var(--text);
        font-size: 13px;
        border-bottom: 0.5px solid var(--border-subtle);
        transition: background .1s;
    }
    .cf-search-item:last-child { border-bottom: none; }
    .cf-search-item:hover { background: var(--surface-2); text-decoration: none; color: inherit; }
    .cf-search-badge {
        font-size: 10px;
        font-weight: 700;
        padding: 2px 7px;
        border-radius: 20px;
        letter-spacing: .04em;
        white-space: nowrap;
        flex-shrink: 0;
    }
    .cf-badge-time      { background: #dbeafe; color: #1d4ed8; }
    .cf-badge-jogador   { background: #dcfce7; color: #15803d; }
    .cf-badge-competicao{ background: #fef9c3; color: #854d0e; }
    .cf-badge-jogo      { background: #f3e8ff; color: #6b21a8; }
    .cf-search-nome     { flex: 1; font-weight: 500; }
    .cf-search-extra    { font-size: 11px; color: var(--text-muted); }
    .cf-search-empty    { padding: 14px; text-align: center; color: var(--text-muted); font-size: 13px; }

    .cf-hero-actions {
        display: flex;
        gap: 10px;
        justify-content: center;
        flex-wrap: wrap;
    }

    .cf-btn-primary {
        background: #378add;
        color: #fff;
        border: none;
        padding: 10px 24px;
        border-radius: 8px;
        font-size: 14px;
        font-weight: 500;
        text-decoration: none;
        display: inline-block;
        transition: background 0.15s;
    }

        .cf-btn-primary:hover {
            background: #2a6db5;
            color: #fff;
            text-decoration: none;
        }

    .cf-btn-ghost {
        background: rgba(255,255,255,0.07);
        color: rgba(255,255,255,0.7);
        border: 1px solid rgba(255,255,255,0.18);
        padding: 10px 24px;
        border-radius: 8px;
        font-size: 14px;
        text-decoration: none;
        display: inline-block;
        transition: background 0.15s;
    }

        .cf-btn-ghost:hover {
            background: rgba(255,255,255,0.12);
            color: #fff;
            text-decoration: none;
        }

    /* ── Stats strip ─────────────────────────────── */
    .cf-stats {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(130px, 1fr));
        gap: 10px;
        margin-bottom: 2rem;
    }

    .cf-stat-card {
        background: var(--surface);
        border: 0.5px solid var(--border);
        border-radius: 10px;
        padding: 1rem 1.25rem;
        text-align: center;
    }

    .cf-stat-num {
        font-size: 26px;
        font-weight: 600;
        color: var(--text);
        line-height: 1.1;
        margin-bottom: 4px;
    }

    .cf-stat-label {
        font-size: 12px;
        color: var(--text-muted);
        font-weight: 400;
    }

    /* ── Section label ───────────────────────────── */
    .cf-section-label {
        font-size: 11px;
        font-weight: 600;
        color: var(--text-muted);
        text-transform: uppercase;
        letter-spacing: 0.7px;
        margin-bottom: 12px;
    }

    /* ── Feature cards ───────────────────────────── */
    .cf-modules {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
        gap: 10px;
        margin-bottom: 2rem;
    }

    .cf-module-card {
        background: var(--surface);
        border: 0.5px solid var(--border);
        border-radius: 12px;
        padding: 1.1rem 1.1rem 1rem;
        text-decoration: none;
        display: block;
        transition: border-color 0.15s, box-shadow 0.15s;
    }

        .cf-module-card:hover {
            border-color: var(--accent-border);
            box-shadow: 0 2px 12px rgba(55,138,221,0.08);
            text-decoration: none;
        }

    .cf-module-icon {
        width: 34px;
        height: 34px;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 10px;
        font-size: 16px;
    }

    .cf-module-card h3 {
        font-size: 13px;
        font-weight: 600;
        color: var(--text);
        margin: 0 0 4px;
    }

    .cf-module-card p {
        font-size: 12px;
        color: var(--text-muted);
        margin: 0;
        line-height: 1.5;
    }

    /* ── Two-col grid ────────────────────────────── */
    .cf-two-col {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 12px;
        margin-bottom: 2rem;
    }

    @@media (max-width: 640px) {
        .cf-two-col { grid-template-columns: 1fr; }
        .cf-hero { padding: 1.8rem 1rem; }
        .cf-hero h1 { font-size: 1.5rem; }
        .cf-hero-actions { flex-direction: column; align-items: center; }
        .cf-btn-primary, .cf-btn-ghost { width: 100%; max-width: 260px; text-align: center; }
        .cf-modules { grid-template-columns: repeat(2, 1fr); }
        .cf-stats { grid-template-columns: repeat(2, 1fr); }
    }

    .cf-panel {
        background: var(--surface);
        border: 0.5px solid var(--border);
        border-radius: 12px;
        padding: 1.1rem 1.25rem;
    }

    .cf-panel-header {
        font-size: 13px;
        font-weight: 600;
        color: var(--text);
        margin-bottom: 12px;
        padding-bottom: 10px;
        border-bottom: 0.5px solid var(--border-subtle);
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .cf-panel-link {
        font-size: 11px;
        color: #378add;
        text-decoration: none;
        font-weight: 400;
    }

        .cf-panel-link:hover {
            text-decoration: underline;
        }

    /* ── Match items ─────────────────────────────── */
    .cf-match {
        display: flex;
        align-items: center;
        gap: 7px;
        padding: 7px 0;
        border-bottom: 0.5px solid var(--border-subtle);
        font-size: 12px;
    }

        .cf-match:last-child {
            border-bottom: none;
            padding-bottom: 0;
        }

    .cf-team-badge {
        width: 24px;
        height: 24px;
        border-radius: 50%;
        overflow: hidden;
        background: var(--surface-3);
        border: 0.5px solid var(--border);
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

        .cf-team-badge img {
            width: 100%;
            height: 100%;
            object-fit: contain;
        }

    .cf-team-badge-abbr {
        font-size: 8px;
        font-weight: 600;
        color: var(--text-muted);
    }

    .cf-team-name {
        flex: 1;
        color: var(--text-2);
        font-size: 12px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        min-width: 0;
    }

    .cf-score {
        font-weight: 600;
        font-size: 12px;
        background: var(--surface-2);
        border: 0.5px solid var(--border);
        padding: 2px 8px;
        border-radius: 6px;
        color: var(--text);
        white-space: nowrap;
        flex-shrink: 0;
    }

    .cf-result {
        font-size: 10px;
        padding: 2px 7px;
        border-radius: 10px;
        font-weight: 600;
        flex-shrink: 0;
    }

    .cf-result-w {
        background: #dcfce7;
        color: #15803d;
    }

    .cf-result-d {
        background: #fef9c3;
        color: #a16207;
    }

    .cf-result-l {
        background: #fee2e2;
        color: #b91c1c;
    }

    .cf-match-date {
        font-size: 10px;
        color: var(--text-muted);
        white-space: nowrap;
        flex-shrink: 0;
    }

    /* ── Classificação ───────────────────────────── */
    .cf-classif {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 6px 0;
        border-bottom: 0.5px solid var(--border-subtle);
        font-size: 12px;
    }

        .cf-classif:last-child {
            border-bottom: none;
        }

    .cf-rank {
        width: 20px;
        font-size: 11px;
        font-weight: 600;
        text-align: center;
        flex-shrink: 0;
    }

    .cf-rank-top {
        color: #d97706;
    }

    .cf-rank-normal {
        color: var(--text-muted);
    }

    .cf-rank-drop {
        color: #b91c1c;
    }

    .cf-pts {
        font-size: 11px;
        font-weight: 600;
        background: #eff6ff;
        color: #1d4ed8;
        padding: 2px 8px;
        border-radius: 10px;
        margin-left: auto;
        flex-shrink: 0;
    }

    .cf-classif-detail {
        font-size: 10px;
        color: var(--text-muted);
        white-space: nowrap;
        flex-shrink: 0;
    }

    /* ── Quick actions ───────────────────────────── */
    .cf-quick {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
        gap: 8px;
    }

    .cf-qa {
        background: var(--surface-2);
        border: 0.5px solid var(--border);
        border-radius: 9px;
        padding: 10px 12px;
        font-size: 13px;
        color: var(--text-2);
        text-decoration: none;
        display: flex;
        align-items: center;
        gap: 8px;
        transition: background 0.15s, border-color 0.15s;
    }

        .cf-qa:hover {
            background: var(--accent-surface);
            border-color: var(--accent-border);
            color: var(--link-hover);
            text-decoration: none;
        }

    .cf-qa-dot {
        width: 7px;
        height: 7px;
        border-radius: 50%;
        flex-shrink: 0;
    }

    /* ── Rodada badge ────────────────────────────── */
    .cf-rodada {
        font-size: 10px;
        color: var(--text-muted);
    }
</style>

<div class="cf-home">

    <!-- Hero -->
    <div class="cf-hero">
        <div class="cf-hero-pitch"></div>
        <div class="cf-hero-content">
            <div class="cf-hero-badge">Futebol 2026</div>
            <h1>Controle de Futebol</h1>
            <p>Gerencie times, escalações, jogos e competições com análise tática completa.</p>

            <div class="cf-search-wrap">
                <input id="cfSearchInput" type="text" class="cf-search-input"
                       placeholder="Buscar time, jogador, competição…" autocomplete="off" />
                <span class="cf-search-icon ti ti-search"></span>
                <div id="cfSearchDropdown" class="cf-search-dropdown"></div>
            </div>

            <div class="cf-hero-actions">
                <a href="@Url.Action("Index", "Jogos")" class="cf-btn-primary">Ver jogos &rarr;</a>
                <a href="@Url.Action("Index", "Times")" class="cf-btn-ghost">Gerenciar times</a>
            </div>
        </div>
    </div>

    <!-- Stats strip -->
    <div class="cf-stats">
        <div class="cf-stat-card">
            <div class="cf-stat-num">@Model.TotalTimes</div>
            <div class="cf-stat-label">Times</div>
        </div>
        <div class="cf-stat-card">
            <div class="cf-stat-num">@Model.TotalJogadores</div>
            <div class="cf-stat-label">Jogadores</div>
        </div>
        <div class="cf-stat-card">
            <div class="cf-stat-num">@Model.TotalJogos</div>
            <div class="cf-stat-label">Jogos</div>
        </div>
        <div class="cf-stat-card">
            <div class="cf-stat-num">@Model.TotalCompeticoes</div>
            <div class="cf-stat-label">Competições</div>
        </div>
    </div>

    <!-- Módulos -->
    <div class="cf-section-label">Módulos do sistema</div>
    <div class="cf-modules">
        <a href="@Url.Action("Index", "Times")" class="cf-module-card">
            <div class="cf-module-icon" style="background:#eff6ff;">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                    <rect x="2" y="4" width="12" height="9" rx="1.5" stroke="#378add" stroke-width="1.4" />
                    <path d="M5 4V3a3 3 0 016 0v1" stroke="#378add" stroke-width="1.4" />
                    <circle cx="8" cy="9" r="1.5" fill="#378add" />
                </svg>
            </div>
            <h3>Times</h3>
            <p>Elenco, escudo, camisa e formação padrão.</p>
        </a>
        <a href="@Url.Action("Index", "Jogadores")" class="cf-module-card">
            <div class="cf-module-icon" style="background:#f0fdf4;">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                    <circle cx="8" cy="5" r="2.5" stroke="#16a34a" stroke-width="1.4" />
                    <path d="M3 14c0-2.761 2.239-5 5-5s5 2.239 5 5" stroke="#16a34a" stroke-width="1.4" stroke-linecap="round" />
                </svg>
            </div>
            <h3>Jogadores</h3>
            <p>Posição, camisa, idade e nacionalidade.</p>
        </a>
        <a href="@Url.Action("Index", "Jogos")" class="cf-module-card">
            <div class="cf-module-icon" style="background:#fffbeb;">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                    <rect x="2" y="2" width="12" height="12" rx="2" stroke="#d97706" stroke-width="1.4" />
                    <path d="M8 5v3l2 2" stroke="#d97706" stroke-width="1.4" stroke-linecap="round" />
                </svg>
            </div>
            <h3>Jogos</h3>
            <p>Placares, gols, cartões e escalação tática.</p>
        </a>
        <a href="@Url.Action("Index", "Competicoes")" class="cf-module-card">
            <div class="cf-module-icon" style="background:#f0fdf9;">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                    <path d="M8 2l1.5 4h4l-3.5 2.5 1.5 4L8 10l-3.5 2.5 1.5-4L2.5 6h4L8 2z" stroke="#0f766e" stroke-width="1.3" stroke-linejoin="round" />
                </svg>
            </div>
            <h3>Competições</h3>
            <p>Classificação, grupos e tabela por rodada.</p>
        </a>
    </div>

    <!-- Jogos recentes + Classificação -->
    <div class="cf-two-col">

        <!-- Jogos recentes -->
        <div class="cf-panel">
            <div class="cf-panel-header">
                Jogos recentes
                <a href="@Url.Action("Index", "Jogos")" class="cf-panel-link">ver todos &rarr;</a>
            </div>

            @if (!Model.JogosRecentes.Any())
            {
                <p style="font-size:12px; color:var(--text-muted); text-align:center; padding:1rem 0;">
                    Nenhum jogo finalizado ainda.
                </p>
            }
            else
            {
                @foreach (var jogo in Model.JogosRecentes)
                {
                    <div class="cf-match">
                        <div class="cf-team-badge">
                            @if (!string.IsNullOrEmpty(jogo.TimeCasa?.EscudoUrl))
                            {
                                <img src="@Url.Action("Imagem", "MediaProxy", new { url = jogo.TimeCasa.EscudoUrl })" alt="@jogo.TimeCasa.Nome" />
                            }
                            else
                            {
                                <span class="cf-team-badge-abbr">
                                    @(jogo.TimeCasa?.Nome?.Length >= 3 ? jogo.TimeCasa.Nome.Substring(0, 3).ToUpper() : jogo.TimeCasa?.Nome)
                                </span>
                            }
                        </div>
                        <span class="cf-team-name">@jogo.TimeCasa?.Nome</span>
                        <span class="cf-score">
                            @jogo.PlacarCasa &times; @jogo.PlacarVisitante
                            @if (jogo.PenaltisCasa.HasValue && jogo.PenaltisVisitante.HasValue)
                            {
                                <span class="cf-pen-score">(@jogo.PenaltisCasa-@jogo.PenaltisVisitante pên.)</span>
                            }
                        </span>
                        <span class="cf-team-name" style="text-align:right;">@jogo.TimeVisitante?.Nome</span>
                        <div class="cf-team-badge">
                            @if (!string.IsNullOrEmpty(jogo.TimeVisitante?.EscudoUrl))
                            {
                                <img src="@Url.Action("Imagem", "MediaProxy", new { url = jogo.TimeVisitante.EscudoUrl })" alt="@jogo.TimeVisitante.Nome" />
                            }
                            else
                            {
                                <span class="cf-team-badge-abbr">
                                    @(jogo.TimeVisitante?.Nome?.Length >= 3 ? jogo.TimeVisitante.Nome.Substring(0, 3).ToUpper() : jogo.TimeVisitante?.Nome)
                                </span>
                            }
                        </div>
                        <span class="cf-rodada">R@(jogo.Rodada)</span>
                    </div>
                }
            }
        </div>

        <!-- Classificação -->
        <div class="cf-panel">
            <div class="cf-panel-header">
                Classificação
                <a href="@Url.Action("Index", "Competicoes")" class="cf-panel-link">ver completa &rarr;</a>
            </div>

            @if (!Model.Classificacao.Any())
            {
                <p style="font-size:12px; color:var(--text-muted); text-align:center; padding:1rem 0;">
                    Nenhum dado disponível ainda.
                </p>
            }
            else
            {
                @foreach (var c in Model.Classificacao)
                {
                    string rankClass = c.Posicao <= 4 ? "cf-rank-top" : (c.Posicao >= Model.Classificacao.Count - 2 ? "cf-rank-drop" : "cf-rank-normal");

                    <div class="cf-classif">
                        <span class="cf-rank @rankClass">@c.Posicao</span>
                        <div class="cf-team-badge">
                            @if (!string.IsNullOrEmpty(c.Time?.EscudoUrl))
                            {
                                <img src="@Url.Action("Imagem", "MediaProxy", new { url = c.Time.EscudoUrl })" alt="@c.Time.Nome" />
                            }
                            else
                            {
                                <span class="cf-team-badge-abbr">
                                    @(c.Time?.Nome?.Length >= 3 ? c.Time.Nome.Substring(0, 3).ToUpper() : c.Time?.Nome)
                                </span>
                            }
                        </div>
                        <span class="cf-team-name">@c.Time?.Nome</span>
                        <span class="cf-classif-detail">@c.Jogos J &bull; @c.SaldoGols SG</span>
                        <span class="cf-pts">@c.Pontos pts</span>
                    </div>
                }
            }
        </div>
    </div>

    <!-- Ações rápidas -->
    <div class="cf-section-label">Ações rápidas</div>
    <div class="cf-quick">
        <a href="@Url.Action("Create", "Jogos")" class="cf-qa">
            <div class="cf-qa-dot" style="background:#378add;"></div>
            Novo jogo
        </a>
        <a href="@Url.Action("Index", "Brasileirao")" class="cf-qa">
            <div class="cf-qa-dot" style="background:#16a34a;"></div>
            Importar jogadores
        </a>
        <a href="@Url.Action("Index", "Times")" class="cf-qa">
            <div class="cf-qa-dot" style="background:#d97706;"></div>
            Escalação padrão
        </a>
        <a href="@Url.Action("Create", "Times")" class="cf-qa">
            <div class="cf-qa-dot" style="background:#0f766e;"></div>
            Cadastrar time
        </a>
        <a href="@Url.Action("Index", "Jogadores")" class="cf-qa">
            <div class="cf-qa-dot" style="background:#7c3aed;"></div>
            Ver jogadores
        </a>
        <a href="@Url.Action("Index", "Competicoes")" class="cf-qa">
            <div class="cf-qa-dot" style="background:#be185d;"></div>
            Competições
        </a>
    </div>

</div>

@section Scripts {
<script>
(function () {
    const input = document.getElementById('cfSearchInput');
    const dropdown = document.getElementById('cfSearchDropdown');
    if (!input || !dropdown) return;

    const urls = {
        Time:       id => '/Times/Details/' + id,
        Jogador:    id => '/Jogadores/Estatisticas/' + id,
        Competição: id => '/Competicoes/Detalhes/' + id,
    };

    const badgeClass = {
        Time:       'cf-badge-time',
        Jogador:    'cf-badge-jogador',
        Competição: 'cf-badge-competicao',
    };

    let timer;

    input.addEventListener('input', function () {
        clearTimeout(timer);
        const q = this.value.trim();
        if (q.length < 2) { close(); return; }
        timer = setTimeout(() => fetchResults(q), 220);
    });

    document.addEventListener('click', function (e) {
        if (!input.contains(e.target) && !dropdown.contains(e.target)) close();
    });

    input.addEventListener('keydown', function (e) {
        if (e.key === 'Escape') close();
    });

    function close() {
        dropdown.classList.remove('open');
        dropdown.innerHTML = '';
    }

    async function fetchResults(q) {
        try {
            const res = await fetch('/Home/Buscar?q=' + encodeURIComponent(q));
            const data = await res.json();
            render(data, q);
        } catch { close(); }
    }

    function esc(str) {
        return String(str ?? '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
    }

    function render(items, q) {
        if (!items.length) {
            dropdown.innerHTML = '<div class="cf-search-empty">Nenhum resultado encontrado.</div>';
            dropdown.classList.add('open');
            return;
        }

        const re = new RegExp('(' + q.replace(/[.*+?^${}()|[\]\\]/g, '\\$&') + ')', 'gi');

        dropdown.innerHTML = items.map(item => {
            const url   = esc((urls[item.tipo] || (() => '#'))(item.id));
            const nome  = esc(item.nome || '').replace(re, '<mark style="background:#fef08a;border-radius:2px;padding:0 1px">$1</mark>');
            const badge = `<span class="cf-search-badge ${esc(badgeClass[item.tipo] || '')}">${esc(item.tipo)}</span>`;
            const extra = item.extra ? `<span class="cf-search-extra">${esc(item.extra)}</span>` : '';
            return `<a href="${url}" class="cf-search-item">${badge}<span class="cf-search-nome">${nome}</span>${extra}</a>`;
        }).join('');

        dropdown.classList.add('open');
    }
})();
</script>
}

