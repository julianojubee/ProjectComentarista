@{
    ViewData["Title"] = "Home Page";
}

<!DOCTYPE html>
<html>
<head>
    <title>@ViewData["Title"]</title>
    <style>
        body {
            background-image: url('/images/copa_overlay.png'); /* imagem salva em wwwroot/images */
            background-size: cover;
            background-position: center;
            background-repeat: no-repeat;
            height: 100vh;
            margin: 0;
            position: relative;
            font-family: 'Segoe UI', sans-serif;
        }

        /* Overlay escuro para contraste */
        body::before {
            content: "";
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-color: rgba(0, 0, 0, 0.5);
            z-index: 0;
        }

        .text-center {
            position: relative;
            z-index: 1;
            color: white;
            text-align: center;
            padding-top: 150px;
        }

        h1 {
            font-size: 3rem;
            text-shadow: 2px 2px 6px black;
        }

        p {
            font-size: 1.2rem;
            margin-top: 20px;
        }

        a.btn {
            display: inline-block;
            margin-top: 30px;
            padding: 12px 30px;
            background-color: #ffc107;
            color: black;
            font-weight: bold;
            border-radius: 8px;
            text-decoration: none;
            transition: 0.3s;
        }

        a.btn:hover {
            background-color: #ffca2c;
            transform: scale(1.05);
        }
    </style>
</head>
<body>
    <div class="text-center">
        <h1 class="display-4">Bem-vindo ao Controle de Futebol</h1>
        <p>Gerencie seus times, jogadores e jogos com facilidade.</p>
        <a asp-controller="Jogos" asp-action="Index" class="btn">Entrar no Sistema</a>
    </div>
</body>


</html>