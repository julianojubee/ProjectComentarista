@{
    Layout = null;
    ViewData["Title"] = "Esqueci minha senha";
}
<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Esqueci minha senha — Análise de Craque</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <style>
        body {
            background: linear-gradient(135deg, #0a1628 0%, #1a2f4e 55%, #0f2040 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .login-card {
            background: #fff;
            border-radius: 16px;
            padding: 2.5rem 2rem;
            width: 100%;
            max-width: 400px;
            box-shadow: 0 20px 60px rgba(0,0,0,0.4);
            text-align: center;
        }
    </style>
</head>
<body>
    <div class="login-card">
        <div style="font-size:2.5rem">📬</div>
        <h1 class="h5 fw-bold mt-2">Verifique seu e-mail</h1>
        <p class="text-muted small">Se o e-mail informado estiver cadastrado, enviamos um link para você redefinir a senha. O link é válido por 24 horas.</p>
        <a asp-action="Login" class="text-decoration-none small">Voltar para o login</a>
    </div>
</body>
</html>
