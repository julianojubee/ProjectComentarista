@{
    Layout = null;
    ViewData["Title"] = "Senha redefinida";
}
<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Senha redefinida — Comentarista</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <style>
        body {
            background: linear-gradient(135deg, #0a1628 0%, #1a2f4e 55%, #0f2040 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .login-card {
            background: #fff;
            border-radius: 16px;
            padding: 2.5rem 2rem;
            width: 100%;
            max-width: 400px;
            box-shadow: 0 20px 60px rgba(0,0,0,0.4);
            text-align: center;
        }
        .btn-login {
            background: linear-gradient(135deg, #1a2f4e, #2563eb);
            color: #fff;
            border: none;
            width: 100%;
            padding: 0.75rem;
            border-radius: 10px;
            font-weight: 600;
            font-size: 1rem;
            margin-top: 1rem;
            text-decoration: none;
            display: inline-block;
        }
        .btn-login:hover { opacity: 0.92; color: #fff; }
    </style>
</head>
<body>
    <div class="login-card">
        <div style="font-size:2.5rem">✅</div>
        <h1 class="h5 fw-bold mt-2">Senha redefinida</h1>
        <p class="text-muted small">Sua senha foi alterada com sucesso. Já pode fazer login com a nova senha.</p>
        <a asp-action="Login" class="btn-login">Ir para o login</a>
    </div>
</body>
</html>
