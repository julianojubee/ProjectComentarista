@model IEnumerable<Competicao>
@using ControleFutebolWeb.Helpers
@using ControleFutebolWeb.Models
@{
    ViewData["Title"] = "Competições";

    // Mesma lógica de roteamento usada no menu do layout — mantém consistência
    // entre o menu superior e os cards desta tela (inclui o fix da rota da Champions,
    // que antes caía de volta em Competicoes/Index).
    Func<Competicao, string> rotaCompeticao = (comp) =>
    {
        var nome = comp.Nome?.ToLowerInvariant() ?? "";
        if (nome.Contains("brasileiro") || nome.Contains("brasileirão"))
            return Url.Action("Brasileirao", "Tabela")!;
        if (nome.Contains("copa do brasil"))
            return Url.Action("Index", "CopaBrasil")!;
        if (nome.Contains("copa do mundo"))
            return Url.Action("Index", "CopaDoMundo")!;
        if (nome.Contains("libertadores"))
            return Url.Action("Index", "Libertadores")!;
        if (nome.Contains("sul-americana") || nome.Contains("sudamericana") || nome.Contains("sul americana"))
            return Url.Action("Index", "SulAmericana")!;
        if (nome.Contains("champions"))
            return Url.Action("Index", "ChampionsLeague")!;
        return Url.Action("Detalhes", "Competicoes", new { id = comp.Id })!;
    };

    // Competicao.Tipo é o FORMATO da competição (ver Create/Edit: PONTOS_CORRIDOS,
    // GRUPOS, MATA_MATA) — não uma classificação geográfica. Usamos isso para
    // colorir o header do card (mantém a variedade visual do mock, mas fiel ao dado real).
    (string bg, string accent) CorTipo(string? tipoRaw)
    {
        return (tipoRaw ?? "").Trim().ToUpperInvariant() switch
        {
            "MATA_MATA"       => ("linear-gradient(135deg,#1a0a0a,#2d1010)", "#dc2626"),
            "GRUPOS"          => ("linear-gradient(135deg,#0a0a1a,#101028)", "#3b82f6"),
            "PONTOS_CORRIDOS" => ("linear-gradient(135deg,#0a1a0a,#102810)", "#22c55e"),
            _                 => ("linear-gradient(135deg,#141414,#1c1c1c)", "#d4a520")
        };
    }

    string LabelTipo(string? tipoRaw) => (tipoRaw ?? "").Trim().ToUpperInvariant() switch
    {
        "MATA_MATA"       => "Mata-Mata",
        "GRUPOS"          => "Grupos",
        "PONTOS_CORRIDOS" => "Pontos Corridos",
        _                 => tipoRaw ?? ""
    };

    var jogosPorCompeticao = ViewBag.JogosPorCompeticao as Dictionary<int, int> ?? new();
    var timesPorCompeticao = ViewBag.TimesPorCompeticao as Dictionary<int, int> ?? new();
    var topTierIds = (HashSet<int>)(ViewBag.TopTierIds ?? new HashSet<int>());
    var topTier = Model.Where(c => topTierIds.Contains(c.Id)).OrderBy(c => c.Nome).ToList();
    var demais = Model.Where(c => !topTierIds.Contains(c.Id)).OrderBy(c => c.Nome).ToList();
}

<style>
    .co, .co *, .co *::before, .co *::after { box-sizing: border-box; }

    .co {
        margin: 0 -12px;
        background: #0f0f0f;
        color: #e5e7eb;
        font-family: 'Barlow', Arial, sans-serif;
        border-radius: 14px;
        overflow: hidden;
    }
    .co a { text-decoration: none; color: inherit; }

    /* ── Hero ── */
    .co-hero {
        position: relative;
        overflow: hidden;
        background: linear-gradient(135deg, #0a1628 0%, #0f2040 55%, #0a1628 100%);
        padding: 52px 2.5rem 44px;
    }
    .co-hero-pattern { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; opacity: 0.06; pointer-events: none; }
    .co-hero-stripe { position: absolute; left: 0; top: 0; bottom: 0; width: 4px; background: #d4a520; }
    .co-hero-fade { position: absolute; bottom: 0; left: 0; right: 0; height: 60px; background: linear-gradient(to top, #0f0f0f, transparent); pointer-events: none; }
    .co-hero-content { position: relative; z-index: 1; text-align: center; }
    .co-hero-badge {
        display: inline-flex; align-items: center; gap: 8px; padding: 4px 16px;
        background: rgba(212,165,32,0.12); border: 1px solid rgba(212,165,32,0.28); border-radius: 999px; margin-bottom: 16px;
    }
    .co-hero-badge span { font-size: .65rem; font-weight: 700; letter-spacing: .2em; color: #d4a520; text-transform: uppercase; }
    .co-hero h1 { font-family: 'Barlow Condensed', Arial, sans-serif; font-size: 3.2rem; font-weight: 800; color: #f1f5f9; margin: 0 0 10px; line-height: 1; }
    .co-hero p { font-size: .9rem; color: #6b7280; margin: 0; }

    .co-hero-acoes { position: absolute; top: 24px; right: 2.5rem; z-index: 2; display: flex; gap: 10px; }
    .co-hero-nova {
        display: flex; align-items: center; gap: 7px; padding: 8px 16px;
        background: #d4a520; color: #141414; font-size: .82rem; font-weight: 800; border-radius: 8px; border: none; cursor: pointer;
    }
    .co-hero-nova:hover { background: #c49918; }
    .co-hero-api {
        display: flex; align-items: center; gap: 7px; padding: 8px 16px;
        background: transparent; color: #d4a520; font-size: .82rem; font-weight: 800;
        border-radius: 8px; border: 1px solid #d4a52055; cursor: pointer;
    }
    .co-hero-api:hover { background: #d4a52015; }

    /* ── Conteúdo ── */
    .co-main { padding: 32px 2.5rem 64px; max-width: 1500px; margin: 0 auto; }

    .co-alert {
        border-radius: 10px; padding: .8rem 1.1rem; margin-bottom: 1rem; font-size: .88rem;
        display: flex; align-items: center; justify-content: space-between; gap: 1rem;
    }
    .co-alert-sucesso { background: rgba(34,197,94,.1); border: 1px solid rgba(34,197,94,.3); color: #4ade80; }
    .co-alert-erro { background: rgba(239,68,68,.1); border: 1px solid rgba(239,68,68,.3); color: #f87171; }
    .co-alert-close { background: none; border: none; color: inherit; font-size: 1rem; cursor: pointer; opacity: .7; }
    .co-alert-close:hover { opacity: 1; }

    .co-section-row { display: flex; align-items: center; gap: 12px; margin-bottom: 20px; }
    .co-section-titulo {
        font-size: .65rem; font-weight: 700; letter-spacing: .18em; color: #6b7280; text-transform: uppercase;
        white-space: nowrap; display: flex; align-items: center; gap: 5px;
    }
    .co-section-titulo.co-principais-titulo { color: #d4a520; }
    .co-section-linha { flex: 1; height: 1px; background: #222; }

    .co-nova-inline {
        display: inline-flex; align-items: center; gap: 7px; padding: 8px 16px;
        background: #d4a520; color: #141414; font-size: .82rem; font-weight: 800; border-radius: 8px; border: none; cursor: pointer;
        margin-bottom: 20px;
    }
    .co-nova-inline:hover { background: #c49918; }

    /* ── Grid principais ── */
    .co-grid-principais { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 16px; margin-bottom: 40px; }
    .co-card {
        display: flex; flex-direction: column; background: #161616; border: 1px solid #262626; border-radius: 14px;
        overflow: hidden; transition: all .18s;
    }
    .co-card:hover { border-color: #d4a520; background: #1a1a1a; }
    .co-card-header { padding: 20px 16px 16px; text-align: center; position: relative; }
    .co-escudo-circle {
        width: 52px; height: 52px; border-radius: 50%; background: rgba(255,255,255,.12);
        display: flex; align-items: center; justify-content: center; margin: 0 auto 10px; overflow: hidden;
    }
    .co-escudo-circle img { width: 100%; height: 100%; object-fit: cover; }
    .co-card-nome { font-family: 'Barlow Condensed', Arial, sans-serif; font-size: 1.1rem; font-weight: 800; color: #f1f5f9; margin-bottom: 2px; }
    .co-card-sub { font-size: .68rem; color: rgba(255,255,255,.5); }
    .co-card-footer { padding: 12px 16px; display: flex; align-items: center; justify-content: space-between; }
    .co-stats { display: flex; gap: 10px; }
    .co-stat { text-align: center; }
    .co-stat-val { font-family: 'Barlow Condensed', Arial, sans-serif; font-size: 1.1rem; font-weight: 800; color: #f1f5f9; line-height: 1; }
    .co-stat-lbl { font-size: .58rem; color: #4b5563; text-transform: uppercase; letter-spacing: .08em; margin-top: 1px; }
    .co-stat-sep { width: 1px; background: #222; align-self: stretch; }
    .co-abrir { font-size: .72rem; color: #d4a520; font-weight: 700; display: flex; align-items: center; gap: 3px; }

    .co-card-actions {
        display: flex; align-items: center; gap: 6px; flex-wrap: wrap; padding: 0 16px 14px;
        border-top: 1px solid #1e1e1e; padding-top: 10px; margin: 0 16px 14px; padding-left: 0; padding-right: 0;
    }

    /* ── Grid todas ── */
    .co-grid-todas { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 12px; }
    .co-row-card {
        background: #161616; border: 1px solid #262626; border-radius: 12px; padding: 14px 16px;
        display: flex; flex-direction: column; transition: all .15s;
    }
    .co-row-card:hover { border-color: #333; background: #1a1a1a; }
    .co-row-main { display: flex; align-items: flex-start; gap: 12px; }
    .co-row-badge {
        width: 36px; height: 36px; border-radius: 8px; display: flex; align-items: center; justify-content: center;
        flex-shrink: 0; overflow: hidden;
    }
    .co-row-badge img { width: 100%; height: 100%; object-fit: cover; }
    .co-row-info { flex: 1; min-width: 0; }
    .co-row-nome {
        font-size: .88rem; font-weight: 700; color: #f1f5f9; white-space: nowrap; overflow: hidden;
        text-overflow: ellipsis; margin-bottom: 2px; display: block;
    }
    .co-row-sub { font-size: .68rem; color: #6b7280; }
    .co-row-actions { display: flex; flex-direction: column; gap: 4px; flex-shrink: 0; align-items: flex-end; }
    .co-row-actions-row { display: flex; gap: 4px; flex-wrap: wrap; justify-content: flex-end; margin-top: 10px; padding-top: 10px; border-top: 1px solid #1e1e1e; }

    /* ── Botões pill (compartilhados) ── */
    .co-pill {
        font-size: .65rem; padding: 2px 8px; border-radius: 5px; font-weight: 600; white-space: nowrap;
        border: 1px solid #2a2a2a; background: #1e1e1e; color: #9ca3af; cursor: pointer;
    }
    .co-pill:hover { border-color: #d4a520; color: #d4a520; }
    .co-pill-abrir { background: rgba(34,197,94,0.08); border-color: rgba(34,197,94,0.2); color: #4ade80; }
    .co-pill-abrir:hover { background: rgba(34,197,94,0.14); color: #4ade80; border-color: rgba(34,197,94,0.2); }
    .co-pill-principal { background: rgba(212,165,32,0.1); border-color: rgba(212,165,32,0.3); color: #d4a520; }
    .co-pill-principal:hover { background: rgba(212,165,32,0.18); color: #d4a520; }
    .co-pill-sucesso { background: rgba(34,197,94,0.1); border-color: rgba(34,197,94,0.3); color: #4ade80; }
    .co-pill-sucesso:hover { background: rgba(34,197,94,0.18); color: #4ade80; }

    /* ── Modais (Bootstrap) reskin dark ── */
    .co .modal-content { background: #161616; border: 1px solid #262626; color: #e5e7eb; }
    .co .modal-header, .co .modal-footer { border-color: #262626; }
    .co .modal-title { color: #f1f5f9; }
    .co .form-control { background: #1a1a1a; border-color: #2a2a2a; color: #e5e7eb; }
    .co .form-control:focus { background: #1a1a1a; border-color: #d4a520; color: #e5e7eb; box-shadow: none; }
    .co .form-text { color: #6b7280; }
    .co .btn-close { filter: invert(1); }
</style>

<div class="co">
    <!-- ── Hero ── -->
    <div class="co-hero">
        <img src="~/Images/banner/escudos-pattern.svg" class="co-hero-pattern" alt="" />
        <div class="co-hero-stripe"></div>
        <div class="co-hero-fade"></div>
        <div class="co-hero-acoes">
            <button type="button" class="co-hero-api" onclick="window.location.href='@Url.Action("CompeticoesApi", "Competicoes")'"
                    title="Catálogo de ligas da api-football (temporada 2026) com o código para registro">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10" /><line x1="2" y1="12" x2="22" y2="12" /><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z" /></svg>
                Competições API
            </button>
            <button type="button" class="co-hero-nova" onclick="window.location.href='@Url.Action("Create", "Competicoes")'">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19" /><line x1="5" y1="12" x2="19" y2="12" /></svg>
                Nova Competição
            </button>
        </div>
        <div class="co-hero-content">
            <div class="co-hero-badge">
                <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="#d4a520" stroke-width="2"><path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6" /><path d="M18 9h1.5a2.5 2.5 0 0 0 0-5H18" /><path d="M4 22h16" /><path d="M18 2H6v7a6 6 0 0 0 12 0V2Z" /></svg>
                <span>Painel de Competições</span>
            </div>
            <h1>Competições</h1>
            <p>Acompanhe campeonatos, acesse classificações, grupos e tabelas.</p>
        </div>
    </div>

    <div class="co-main">

        @if (TempData["Sucesso"] != null)
        {
            <div class="co-alert co-alert-sucesso">
                <span>@TempData["Sucesso"]</span>
                <button type="button" class="co-alert-close" onclick="this.parentElement.remove()">✕</button>
            </div>
        }
        @if (TempData["Erro"] != null)
        {
            <div class="co-alert co-alert-erro">
                <span>@TempData["Erro"]</span>
                <button type="button" class="co-alert-close" onclick="this.parentElement.remove()">✕</button>
            </div>
        }

        @if (topTier.Any())
        {
            <div class="co-section-row">
                <span class="co-section-titulo co-principais-titulo">
                    <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="#d4a520" stroke-width="2.5"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" /></svg>
                    Principais
                </span>
                <div class="co-section-linha"></div>
            </div>

            <div class="co-grid-principais">
                @foreach (var comp in topTier)
                {
                    var (bg, accent) = CorTipo(comp.Tipo);
                    var jogos = jogosPorCompeticao.TryGetValue(comp.Id, out var j) ? j : 0;
                    var times = timesPorCompeticao.TryGetValue(comp.Id, out var t) ? t : 0;

                    <div class="co-card">
                        <a href="@rotaCompeticao(comp)">
                            <div class="co-card-header" style="background:@bg; border-bottom:2px solid @(accent)20;">
                                <div class="co-escudo-circle">
                                    <img src="@CompeticaoHelper.GetLogoCompeticao(comp.Id, comp.LogoUrl)" alt="@comp.Nome" />
                                </div>
                                <div class="co-card-nome">@comp.Nome</div>
                                <div class="co-card-sub">@comp.Regiao · @LabelTipo(comp.Tipo)</div>
                            </div>
                            <div class="co-card-footer">
                                <div class="co-stats">
                                    <div class="co-stat"><div class="co-stat-val">@times</div><div class="co-stat-lbl">Times</div></div>
                                    <div class="co-stat-sep"></div>
                                    <div class="co-stat"><div class="co-stat-val">@jogos</div><div class="co-stat-lbl">Jogos</div></div>
                                </div>
                                <span class="co-abrir">
                                    Abrir
                                    <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7" /></svg>
                                </span>
                            </div>
                        </a>
                        <div class="co-card-actions">
                            <a asp-action="Edit" asp-route-id="@comp.Id" class="co-pill">Editar</a>
                            <button type="button" class="co-pill" data-bs-toggle="modal" data-bs-target="#linkModal-@comp.Id">Link</button>
                            <button type="button" class="co-pill" data-bs-toggle="modal" data-bs-target="#logoModal-@comp.Id">🖼 Escudo</button>
                            @if (!string.IsNullOrWhiteSpace(comp.LinkTransfermarket))
                            {
                                <form asp-action="BuscarJogos" asp-route-id="@comp.Id" method="post" style="display:inline;">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="co-pill co-pill-sucesso"
                                            onclick="this.disabled=true; this.innerText='Buscando...'; this.form.submit();">
                                        Buscar Jogos
                                    </button>
                                </form>
                            }
                            <form asp-action="ToggleTopTier" asp-route-id="@comp.Id" method="post" style="display:inline;">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="co-pill co-pill-principal" title="Remover dos principais">⭐ Principal</button>
                            </form>
                        </div>
                    </div>

                    @await Html.PartialAsync("_CompeticaoModais", comp)
                }
            </div>
        }

        <div class="co-section-row">
            <span class="co-section-titulo">Todas as Competições</span>
            <div class="co-section-linha"></div>
        </div>

        <div class="co-grid-todas">
            @foreach (var comp in demais)
            {
                var (bg, accent) = CorTipo(comp.Tipo);

                <div class="co-row-card">
                    <div class="co-row-main">
                        <div class="co-row-badge" style="background:@bg; border:1px solid @(accent)30;">
                            <img src="@CompeticaoHelper.GetLogoCompeticao(comp.Id, comp.LogoUrl)" alt="@comp.Nome" />
                        </div>
                        <a href="@rotaCompeticao(comp)" class="co-row-info">
                            <span class="co-row-nome">@comp.Nome</span>
                            <div class="co-row-sub">@comp.Regiao · @LabelTipo(comp.Tipo)</div>
                        </a>
                        <div class="co-row-actions">
                            <a asp-action="Edit" asp-route-id="@comp.Id" class="co-pill">Editar</a>
                            <a href="@rotaCompeticao(comp)" class="co-pill co-pill-abrir">Abrir →</a>
                        </div>
                    </div>
                    <div class="co-row-actions-row">
                        <button type="button" class="co-pill" data-bs-toggle="modal" data-bs-target="#linkModal-@comp.Id">Link</button>
                        <button type="button" class="co-pill" data-bs-toggle="modal" data-bs-target="#logoModal-@comp.Id">🖼 Escudo</button>
                        @if (!string.IsNullOrWhiteSpace(comp.LinkTransfermarket))
                        {
                            <form asp-action="BuscarJogos" asp-route-id="@comp.Id" method="post" style="display:inline;">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="co-pill co-pill-sucesso"
                                        onclick="this.disabled=true; this.innerText='...'; this.form.submit();">
                                    Buscar Jogos
                                </button>
                            </form>
                        }
                        <form asp-action="ToggleTopTier" asp-route-id="@comp.Id" method="post" style="display:inline;">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="co-pill co-pill-principal" title="Marcar como principal">☆ Principal</button>
                        </form>
                    </div>
                </div>

                @await Html.PartialAsync("_CompeticaoModais", comp)
            }
        </div>

    </div>
</div>
