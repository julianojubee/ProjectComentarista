@model IEnumerable<Competicao>
@using ControleFutebolWeb.Helpers;
@{
    ViewData["Title"] = "Competições";
}

<style>
    .cf-competicoes * {
        box-sizing: border-box;
    }

    .cf-comp-hero {
        position: relative;
        background: linear-gradient(135deg, #0a1628 0%, #1a2f4e 55%, #0f2040 100%);
        border-radius: 14px;
        padding: 2.6rem 2rem;
        margin-bottom: 1.5rem;
        overflow: hidden;
    }

    .cf-comp-hero::before {
        content: "";
        position: absolute;
        inset: 0;
        opacity: 0.08;
        background-image: linear-gradient(90deg, transparent 49.5%, #fff 49.5%, #fff 50.5%, transparent 50.5%), linear-gradient(transparent 49.5%, #fff 49.5%, #fff 50.5%, transparent 50.5%);
    }

    .cf-comp-hero-content {
        position: relative;
        z-index: 1;
        text-align: center;
    }

    .cf-comp-badge {
        display: inline-block;
        background: rgba(55, 138, 221, 0.2);
        color: #85b7eb;
        font-size: 11px;
        font-weight: 600;
        padding: 4px 14px;
        border-radius: 20px;
        border: 1px solid rgba(55, 138, 221, 0.35);
        letter-spacing: 1px;
        text-transform: uppercase;
        margin-bottom: 0.9rem;
    }

    .cf-comp-hero h1 {
        font-size: 1.9rem;
        color: #fff;
        margin-bottom: 0.6rem;
        font-weight: 600;
    }

    .cf-comp-hero p {
        color: rgba(255, 255, 255, 0.65);
        margin: 0;
        font-size: 0.95rem;
    }

    .cf-comp-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 12px;
    }

    .cf-comp-card {
        background: #fff;
        border: 0.5px solid #e5e7eb;
        border-radius: 12px;
        padding: 1rem 1.1rem;
        display: block;
        transition: border-color 0.15s, box-shadow 0.15s, transform 0.15s;
    }

    .cf-comp-card:hover {
        border-color: #c0d4f0;
        box-shadow: 0 2px 12px rgba(55, 138, 221, 0.08);
        transform: translateY(-1px);
    }

    .cf-comp-card-main {
        display: block;
        text-decoration: none;
    }

    .cf-comp-card-main:hover {
        text-decoration: none;
    }

    .cf-comp-title {
        font-size: 1rem;
        font-weight: 600;
        color: #111827;
        margin: 0 0 0.35rem;
    }

    .cf-comp-meta {
        font-size: 12px;
        color: #6b7280;
        margin-bottom: 0.7rem;
    }

    .cf-comp-link {
        font-size: 12px;
        color: #378add;
        font-weight: 600;
    }
</style>

<div class="cf-competicoes">
    <div class="cf-comp-hero">
        <div class="cf-comp-hero-content">
            <div class="cf-comp-badge">Painel de competições</div>
            <h1>Competições</h1>
            <p>Acompanhe os campeonatos e acesse classificação, grupos e tabelas.</p>
        </div>
    </div>
    @if (TempData["Sucesso"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show mt-2" role="alert">
            @TempData["Sucesso"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Erro"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show mt-2" role="alert">
            @TempData["Erro"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    <a class="btn btn-success" href="@Url.Action("Create", "Competicoes")">+ Nova Competição</a>

    @{ var topTierIds = (HashSet<int>)(ViewBag.TopTierIds ?? new HashSet<int>()); var topTier = Model.Where(c => topTierIds.Contains(c.Id)).OrderBy(c => c.Nome).ToList(); var demais = Model.Where(c => !topTierIds.Contains(c.Id)).OrderBy(c => c.Nome).ToList(); }

    @if (topTier.Any())
    {
        <div style="display:flex;align-items:center;gap:.6rem;margin:1.2rem 0 .6rem;">
            <span style="font-size:.7rem;font-weight:700;text-transform:uppercase;letter-spacing:.1em;color:#6b7280;">⭐ Principais</span>
            <div style="flex:1;height:1px;background:#e5e7eb;"></div>
        </div>
    }
    <div class="cf-comp-grid">
        @foreach (var comp in topTier)
        {
            var nome = comp.Nome?.ToLowerInvariant() ?? "";

            // Mapeamento de rotas especiais
            string url;
            if (nome.Contains("brasileiro") || nome.Contains("brasileirão"))
                url = Url.Action("Brasileirao", "Tabela");
            else if (nome.Contains("copa do brasil"))
                url = Url.Action("Index", "CopaBrasil");
            else if (nome.Contains("copa do mundo"))
                url = Url.Action("Index", "CopaDoMundo");
            else if (nome.Contains("copa libertadores"))
                url = Url.Action("Index", "Libertadores");
            else if (nome.Contains("champions"))
                url = Url.Action("Index", "Competicoes"); // exemplo
            else
                url = Url.Action("Detalhes", "Competicoes", new { id = comp.Id });

            <div class="cf-comp-card">
                <a class="cf-comp-card-main" href="@url">
                    <div style="display:flex; align-items:center; gap:8px;">
                        <img src="@CompeticaoHelper.GetLogoCompeticao(comp.Id, comp.LogoUrl)"
                             alt="@comp.Nome"
                             style="width:28px; height:28px; border-radius:50%; object-fit:cover;" />
                        <h2 class="cf-comp-title">@comp.Nome</h2>
                    </div>
                    <div class="cf-comp-meta">Região: @comp.Regiao | Tipo: @comp.Tipo</div>
                    <span class="cf-comp-link">Abrir competição &rarr;</span>
                </a>

                <div class="d-flex gap-2 align-items-center flex-wrap mt-2">
                    <a asp-action="Edit" asp-route-id="@comp.Id" class="btn btn-sm btn-outline-secondary">
                        Editar
                    </a>

                    <button type="button" class="btn btn-sm btn-outline-primary"
                            data-bs-toggle="modal" data-bs-target="#linkModal-@comp.Id">
                        Informar link
                    </button>

                    <button type="button" class="btn btn-sm btn-outline-secondary"
                            data-bs-toggle="modal" data-bs-target="#logoModal-@comp.Id">
                        🖼 Escudo
                    </button>

                    @if (!string.IsNullOrWhiteSpace(comp.LinkTransfermarket))
                    {
                        <form asp-action="BuscarJogos" asp-route-id="@comp.Id" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-success"
                                    onclick="this.disabled=true; this.innerText='Buscando...'; this.form.submit();">
                                Buscar Jogos
                            </button>
                        </form>
                    }
                    <form asp-action="ToggleTopTier" asp-route-id="@comp.Id" method="post" class="d-inline">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-sm btn-warning" title="Remover dos principais">⭐ Principal</button>
                    </form>
                </div>
            </div>

            <!-- Modal link -->
            <div class="modal fade" id="linkModal-@comp.Id" tabindex="-1" aria-hidden="true">
                <div class="modal-dialog">
                    <div class="modal-content">
                        <form asp-action="SalvarLinkCompeticao" asp-route-id="@comp.Id" method="post">
                            @Html.AntiForgeryToken()
                            <div class="modal-header">
                                <h5 class="modal-title">Informar URL da Competição</h5>
                                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                            </div>
                            <div class="modal-body">
                                <input type="text" name="linkCompeticao" class="form-control"
                                       placeholder="Cole o link aqui"
                                       value="@comp.LinkTransfermarket" />
                            </div>
                            <div class="modal-footer">
                                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                                <button type="submit" class="btn btn-primary">Salvar</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>

            <!-- Modal escudo -->
            <div class="modal fade" id="logoModal-@comp.Id" tabindex="-1" aria-hidden="true">
                <div class="modal-dialog">
                    <div class="modal-content">
                        <form asp-action="SalvarLogo" asp-route-id="@comp.Id" method="post">
                            @Html.AntiForgeryToken()
                            <div class="modal-header">
                                <h5 class="modal-title">Escudo de @comp.Nome</h5>
                                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                            </div>
                            <div class="modal-body">
                                @if (!string.IsNullOrWhiteSpace(comp.LogoUrl))
                                {
                                    <div class="text-center mb-3">
                                        <img src="@comp.LogoUrl" alt="@comp.Nome"
                                             style="width:64px;height:64px;border-radius:50%;object-fit:cover;border:1px solid #e5e7eb;" />
                                    </div>
                                }
                                <label class="form-label fw-semibold">URL do escudo</label>
                                <input type="url" name="logoUrl" class="form-control"
                                       placeholder="https://..."
                                       value="@comp.LogoUrl" />
                                <div class="form-text">Cole a URL da imagem. Deixe vazio para usar o escudo padrão.</div>
                            </div>
                            <div class="modal-footer">
                                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                                <button type="submit" class="btn btn-primary">Salvar</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        }
    </div>

    @if (demais.Any())
    {
        <div style="display:flex;align-items:center;gap:.6rem;margin:1.5rem 0 .6rem;">
            <span style="font-size:.7rem;font-weight:700;text-transform:uppercase;letter-spacing:.1em;color:#6b7280;">Todas as competições</span>
            <div style="flex:1;height:1px;background:#e5e7eb;"></div>
        </div>
        <div class="cf-comp-grid">
            @foreach (var comp in demais)
            {
                var nome = comp.Nome?.ToLowerInvariant() ?? "";

                string url;
                if (nome.Contains("brasileiro") || nome.Contains("brasileirão"))
                    url = Url.Action("Brasileirao", "Tabela");
                else if (nome.Contains("copa do brasil"))
                    url = Url.Action("Index", "CopaBrasil");
                else if (nome.Contains("copa do mundo"))
                    url = Url.Action("Index", "CopaDoMundo");
                else if (nome.Contains("copa libertadores"))
                    url = Url.Action("Index", "Libertadores");
                else if (nome.Contains("champions"))
                    url = Url.Action("Index", "Competicoes");
                else
                    url = Url.Action("Detalhes", "Competicoes", new { id = comp.Id });

                <div class="cf-comp-card">
                    <a class="cf-comp-card-main" href="@url">
                        <div style="display:flex; align-items:center; gap:8px;">
                            <img src="@CompeticaoHelper.GetLogoCompeticao(comp.Id, comp.LogoUrl)"
                                 alt="@comp.Nome"
                                 style="width:28px; height:28px; border-radius:50%; object-fit:cover;" />
                            <h2 class="cf-comp-title">@comp.Nome</h2>
                        </div>
                        <div class="cf-comp-meta">Região: @comp.Regiao | Tipo: @comp.Tipo</div>
                        <span class="cf-comp-link">Abrir competição &rarr;</span>
                    </a>

                    <div class="d-flex gap-2 align-items-center flex-wrap mt-2">
                        <a asp-action="Edit" asp-route-id="@comp.Id" class="btn btn-sm btn-outline-secondary">Editar</a>

                        <button type="button" class="btn btn-sm btn-outline-primary"
                                data-bs-toggle="modal" data-bs-target="#linkModal-@comp.Id">
                            Informar link
                        </button>

                        <button type="button" class="btn btn-sm btn-outline-secondary"
                                data-bs-toggle="modal" data-bs-target="#logoModal-@comp.Id">
                            🖼 Escudo
                        </button>

                        @if (!string.IsNullOrWhiteSpace(comp.LinkTransfermarket))
                        {
                            <form asp-action="BuscarJogos" asp-route-id="@comp.Id" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-success"
                                        onclick="this.disabled=true; this.innerText='Buscando...'; this.form.submit();">
                                    Buscar Jogos
                                </button>
                            </form>
                        }

                        <form asp-action="ToggleTopTier" asp-route-id="@comp.Id" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-outline-warning" title="Marcar como principal">
                                ☆ Principal
                            </button>
                        </form>
                    </div>
                </div>

                <!-- Modal link -->
                <div class="modal fade" id="linkModal-@comp.Id" tabindex="-1" aria-hidden="true">
                    <div class="modal-dialog">
                        <div class="modal-content">
                            <form asp-action="SalvarLinkCompeticao" asp-route-id="@comp.Id" method="post">
                                @Html.AntiForgeryToken()
                                <div class="modal-header">
                                    <h5 class="modal-title">Informar URL da Competição</h5>
                                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                </div>
                                <div class="modal-body">
                                    <input type="text" name="linkCompeticao" class="form-control"
                                           placeholder="Cole o link aqui"
                                           value="@comp.LinkTransfermarket" />
                                </div>
                                <div class="modal-footer">
                                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                                    <button type="submit" class="btn btn-primary">Salvar</button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>

                <!-- Modal escudo -->
                <div class="modal fade" id="logoModal-@comp.Id" tabindex="-1" aria-hidden="true">
                    <div class="modal-dialog">
                        <div class="modal-content">
                            <form asp-action="SalvarLogo" asp-route-id="@comp.Id" method="post">
                                @Html.AntiForgeryToken()
                                <div class="modal-header">
                                    <h5 class="modal-title">Escudo de @comp.Nome</h5>
                                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                </div>
                                <div class="modal-body">
                                    @if (!string.IsNullOrWhiteSpace(comp.LogoUrl))
                                    {
                                        <div class="text-center mb-3">
                                            <img src="@comp.LogoUrl" alt="@comp.Nome"
                                                 style="width:64px;height:64px;border-radius:50%;object-fit:cover;border:1px solid #e5e7eb;" />
                                        </div>
                                    }
                                    <label class="form-label fw-semibold">URL do escudo</label>
                                    <input type="url" name="logoUrl" class="form-control"
                                           placeholder="https://..."
                                           value="@comp.LogoUrl" />
                                    <div class="form-text">Cole a URL da imagem. Deixe vazio para usar o escudo padrão.</div>
                                </div>
                                <div class="modal-footer">
                                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                                    <button type="submit" class="btn btn-primary">Salvar</button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
