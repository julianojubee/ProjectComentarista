@model IEnumerable<Competicao>

<div class="container-fluid">
    <div class="row">
        <!-- Sidebar -->
        <nav class="col-md-3 col-lg-2 d-md-block bg-dark sidebar">
            <div class="sidebar-sticky">
                <h4 class="text-white mt-3">Competições</h4>
                <ul class="nav flex-column">
                    @foreach (var comp in Model)
                    {
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-controller="Competicoes" asp-action="Detalhes" asp-route-id="@comp.Id">
                                @comp.Nome
                            </a>
                        </li>
                    }
                </ul>
            </div>
        </nav>

        <!-- Conteúdo principal -->
        <main role="main" class="col-md-9 ml-sm-auto col-lg-10 px-4">
            <h2 class="mt-4">Selecione uma competição no menu</h2>
        </main>
    </div>
</div>