@model Competicao

@{
    ViewData["Title"] = "Editar Competição";
}

<h2>Editar Competição</h2>

<form asp-action="Edit" asp-controller="Competicoes" asp-route-id="@Model.Id" method="post">
    <input type="hidden" asp-for="Id" />
    <div class="form-group">
        <label asp-for="Nome"></label>
        <input asp-for="Nome" class="form-control" />
        <span asp-validation-for="Nome" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="Regiao"></label>
        <input asp-for="Regiao" class="form-control" />
        <span asp-validation-for="Regiao" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="Tipo"></label>
        <select asp-for="Tipo" class="form-control">
            <option value="">Selecione...</option>
            <option value="PONTOS_CORRIDOS">Pontos Corridos</option>
            <option value="GRUPOS">Grupos</option>
            <option value="MATA_MATA">Mata-Mata</option>
        </select>
        <span asp-validation-for="Tipo" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="LinkTransfermarket">Link Transfermarkt</label>
        <input asp-for="LinkTransfermarket" class="form-control" />
        <span asp-validation-for="LinkTransfermarket" class="text-danger"></span>
    </div>
    <div class="form-group mb-3">
        <label asp-for="IdApi">ID da Liga na API (api-football)</label>
        <input asp-for="IdApi" type="number" class="form-control" placeholder="Ex.: 71 = Brasileirão Série A" />
        <small class="text-muted">Necessário para buscar estatísticas de times. Consulte em v3.football.api-sports.io/leagues</small>
    </div>
    <div class="form-check">
        <input asp-for="EhSelecaoNacional" class="form-check-input" />
        <label asp-for="EhSelecaoNacional" class="form-check-label">
            É uma competição de seleções nacionais (Copa do Mundo, Eliminatórias, Copa América...)
        </label>
    </div>
    <button type="submit" class="btn btn-primary">Salvar</button>
</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
