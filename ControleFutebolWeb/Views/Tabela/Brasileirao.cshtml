@model List<ControleFutebolWeb.Models.ViewModels.ClassificacaoViewModel>
@using System.Globalization
@using ControleFutebolWeb.Helpers
@using ControleFutebolWeb.Controllers
@removeTagHelper Microsoft.AspNetCore.Mvc.TagHelpers.OptionTagHelper, Microsoft.AspNetCore.Mvc.TagHelpers
@{
    ViewData["Title"] = "Tabela do Brasileirão";

    var temporadasBr = ViewBag.TemporadasDisponiveis as List<int> ?? new List<int>();
    var temporadaBrSel = ViewBag.Temporada as int?;

    int rodadaRef = (int)(ViewBag.RodadaRef ?? 0);
    int rodadaMaxima = (int)(ViewBag.RodadaMaxima ?? 38);
    int totalRodadas = (int)(ViewBag.TotalRodadasBrasileirao ?? 38);
    var proximaRodadaJogos = ViewBag.ProximaRodadaJogos as List<ControleFutebolWeb.Models.Jogo> ?? new();
    int ultimaRodadaNum = (int)(ViewBag.UltimaRodadaNum ?? 0);
    var ultimaRodadaJogos = ViewBag.UltimaRodadaJogos as List<ControleFutebolWeb.Models.Jogo> ?? new();
    var artilheiros = ViewBag.Artilheiros as List<ArtilheiroViewModel> ?? new();

    int totalGols = Model.Sum(t => t.GolsPro);

    Func<int, string> linkRodada = (r) =>
    {
        var qs = $"?rodada={r}";
        if (temporadaBrSel.HasValue) qs += $"&temporada={temporadaBrSel}";
        return Url.Action("Brasileirao") + qs;
    };
}

<style>
    .br-root, .br-root *, .br-root *::before, .br-root *::after { box-sizing: border-box; }

    .br-root {
        margin: 0 -12px;
        background: #0f0f0f;
        border-radius: 14px;
        overflow: hidden;
        color: #e5e7eb;
        font-family: 'Barlow', Arial, sans-serif;
    }
    .br-root a { text-decoration: none; color: inherit; }

    /* ── Hero ── */
    .br-hero {
        position: relative; overflow: hidden;
        background: linear-gradient(135deg, #0a1200 0%, #152000 55%, #0a1200 100%);
        padding: 38px 2.5rem 32px;
    }
    .br-hero-pattern { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; opacity: 0.06; pointer-events: none; }
    .br-hero-stripe { position: absolute; left: 0; top: 0; bottom: 0; width: 4px; background: #22c55e; }
    .br-hero-fade { position: absolute; bottom: 0; left: 0; right: 0; height: 60px; background: linear-gradient(to top, #0f0f0f, transparent); pointer-events: none; }
    .br-hero-inner { position: relative; z-index: 1; display: flex; align-items: center; gap: 22px; flex-wrap: wrap; }
    .br-hero-flag { width: 64px; height: 64px; border-radius: 50%; background: rgba(34,197,94,0.12); border: 2px solid rgba(34,197,94,0.3); display: flex; align-items: center; justify-content: center; font-size: 2rem; flex-shrink: 0; }
    .br-hero-kicker { display: flex; align-items: center; gap: 10px; margin-bottom: 8px; }
    .br-hero-kicker-line { height: 2px; width: 24px; background: #22c55e; }
    .br-hero-kicker span { font-size: .65rem; font-weight: 700; letter-spacing: .24em; color: #22c55e; text-transform: uppercase; }
    .br-hero h1 { font-family: 'Barlow Condensed', Arial, sans-serif; font-size: 3rem; font-weight: 800; color: #f1f5f9; margin: 0 0 6px; line-height: 1; }
    .br-hero p { font-size: .88rem; color: #6b7280; margin: 0; }
    .br-hero-temporada select {
        margin-top: 6px; padding: 4px 10px; border-radius: 7px; border: 1px solid #2a2a2a; background: #1a1a1a; color: #e5e7eb; font-size: .8rem; font-weight: 600;
    }

    .br-rodnav { display: flex; align-items: center; gap: 8px; flex-shrink: 0; }
    .br-rodnav-btn {
        width: 34px; height: 34px; border-radius: 50%; background: #1a1a1a; border: 1px solid #2a2a2a;
        color: #9ca3af; cursor: pointer; display: flex; align-items: center; justify-content: center;
    }
    .br-rodnav-btn:hover { border-color: #22c55e; color: #22c55e; }
    .br-rodnav-num { text-align: center; min-width: 80px; }
    .br-rodnav-num .val { font-family: 'Barlow Condensed', Arial, sans-serif; font-size: 1.6rem; font-weight: 800; color: #f1f5f9; line-height: 1; }
    .br-rodnav-num .lbl { font-size: .62rem; color: #6b7280; text-transform: uppercase; letter-spacing: .1em; margin-top: 2px; }

    .br-stats { display: flex; gap: 20px; flex-shrink: 0; padding: 14px 20px; background: rgba(0,0,0,0.3); border: 1px solid rgba(34,197,94,0.15); border-radius: 10px; }
    .br-stat { text-align: center; }
    .br-stat .val { font-family: 'Barlow Condensed', Arial, sans-serif; font-size: 1.6rem; font-weight: 800; color: #4ade80; line-height: 1; }
    .br-stat .lbl { font-size: .58rem; color: #4b5563; text-transform: uppercase; letter-spacing: .08em; margin-top: 2px; }
    .br-stat-sep { width: 1px; background: rgba(34,197,94,0.15); align-self: stretch; }

    /* ── Layout principal ── */
    .br-layout { padding: 24px 2.5rem 64px; max-width: 1500px; margin: 0 auto; display: grid; grid-template-columns: 1fr 300px; gap: 24px; align-items: start; }
    /* min-width:0 nos itens do grid: sem isso, o item cujo conteúdo (.br-tablewrap
       rolável) pede 620px de min-content faz a própria trilha do grid crescer em
       vez de deixar só o wrapper interno rolar — estourando a página no mobile. */
    .br-layout > div { min-width: 0; }
    @@media (max-width: 1100px) { .br-layout { grid-template-columns: 1fr; } }

    /* ── Tabela ── */
    .br-tablewrap { background: #161616; border: 1px solid #262626; border-radius: 14px; overflow: hidden; }
    .br-cols {
        display: grid; grid-template-columns: 36px 36px 1fr 36px 36px 36px 36px 36px 44px 60px 80px; gap: 4px;
        padding: 10px 14px; background: #111; border-bottom: 1px solid #1e1e1e; align-items: center;
    }
    .br-cols span { font-size: .58rem; color: #374151; font-weight: 700; text-transform: uppercase; text-align: center; }
    .br-cols span.left { text-align: left; }

    .br-row { display: grid; grid-template-columns: 4px 36px 28px 1fr 36px 36px 36px 36px 36px 44px 60px 80px; gap: 4px; padding: 10px 14px; padding-left: 0; border-bottom: 1px solid #111; align-items: center; transition: background .12s; }
    .br-row:last-child { border-bottom: none; }
    .br-row:hover { background: #1a1a1a; }
    .br-row.lider { background: rgba(212,165,32,0.04); }

    .br-zonebar { width: 4px; height: 100%; align-self: stretch; flex-shrink: 0; }
    .br-pos { font-family: 'Barlow Condensed', Arial, sans-serif; font-size: 1rem; font-weight: 700; text-align: center; }
    .br-escudo { width: 28px; height: 28px; border-radius: 50%; background: #0f0f0f; border: 1px solid #2a2a2a; display: flex; align-items: center; justify-content: center; overflow: hidden; flex-shrink: 0; font-size: .6rem; color: #6b7280; }
    .br-escudo img { width: 90%; height: 90%; object-fit: contain; }
    .br-nome { font-size: .86rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; display: block; }
    .br-nome:hover { text-decoration: underline; }
    .br-cell { font-size: .8rem; color: #9ca3af; text-align: center; }
    .br-cell.v { color: #22c55e; font-weight: 600; }
    .br-cell.e { color: #f59e0b; }
    .br-cell.d { color: #ef4444; }
    .br-sg { font-family: 'Barlow Condensed', Arial, sans-serif; font-size: .88rem; font-weight: 700; text-align: center; }

    .br-aprov { display: flex; flex-direction: column; gap: 2px; align-items: center; }
    .br-aprov span { font-size: .72rem; color: #9ca3af; font-weight: 600; }
    .br-aprov-bar { width: 44px; height: 3px; background: #222; border-radius: 2px; overflow: hidden; }
    .br-aprov-bar div { height: 100%; border-radius: 2px; }

    .br-pts { display: flex; align-items: center; justify-content: center; }
    .br-pts span { font-family: 'Barlow Condensed', Arial, sans-serif; font-size: 1.1rem; font-weight: 900; padding: 2px 8px; border-radius: 6px; }

    .br-legend { padding: 12px 18px; background: #111; border-top: 1px solid #1e1e1e; display: flex; gap: 16px; flex-wrap: wrap; }
    .br-legend-item { display: flex; align-items: center; gap: 5px; }
    .br-legend-dot { width: 10px; height: 3px; border-radius: 2px; }
    .br-legend-item span { font-size: .62rem; color: #4b5563; font-weight: 600; }

    /* ── Sidebar ── */
    .br-sidebar { display: flex; flex-direction: column; gap: 16px; }
    .br-side-card { background: #161616; border: 1px solid #262626; border-radius: 12px; overflow: hidden; }
    .br-side-header { padding: 12px 16px; background: #111; border-bottom: 1px solid #1e1e1e; display: flex; align-items: center; gap: 8px; }
    .br-side-title { font-family: 'Barlow Condensed', Arial, sans-serif; font-size: .88rem; font-weight: 700; color: #f1f5f9; text-transform: uppercase; letter-spacing: .04em; }
    .br-side-badge { margin-left: auto; font-size: .65rem; font-weight: 700; padding: 2px 8px; border-radius: 999px; }
    .br-side-badge.blue { color: #60a5fa; background: rgba(59,130,246,0.1); border: 1px solid rgba(59,130,246,0.25); }
    .br-side-badge.green { color: #4ade80; background: rgba(34,197,94,0.1); border: 1px solid rgba(34,197,94,0.25); }

    .br-artilheiro { display: flex; align-items: center; gap: 10px; padding: 9px 14px; border-bottom: 1px solid #111; transition: background .12s; }
    .br-artilheiro:last-child { border-bottom: none; }
    .br-artilheiro:hover { background: #1e1e1e; }
    .br-art-rank { font-size: .72rem; font-weight: 700; width: 14px; text-align: center; flex-shrink: 0; }
    .br-art-avatar { width: 30px; height: 30px; border-radius: 50%; background: #1e293b; border: 1px solid #2a3a52; display: flex; align-items: center; justify-content: center; flex-shrink: 0; overflow: hidden; }
    .br-art-avatar img { width: 100%; height: 100%; object-fit: cover; }
    .br-art-nome { font-size: .82rem; font-weight: 600; color: #e5e7eb; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .br-art-clube { display: flex; align-items: center; gap: 4px; margin-top: 1px; }
    .br-art-clube img { width: 12px; height: 12px; object-fit: contain; }
    .br-art-clube span { font-size: .64rem; color: #4b5563; }
    .br-art-gols { font-family: 'Barlow Condensed', Arial, sans-serif; font-size: 1.1rem; font-weight: 800; color: #4ade80; flex-shrink: 0; }

    .br-jogo { padding: 10px 14px; border-bottom: 1px solid #111; transition: background .12s; }
    .br-jogo:last-child { border-bottom: none; }
    .br-jogo:hover { background: #1e1e1e; }
    .br-jogo-hora { font-size: .62rem; color: #d4a520; font-weight: 700; letter-spacing: .06em; text-transform: uppercase; margin-bottom: 6px; }
    .br-jogo-teams { display: flex; align-items: center; gap: 8px; }
    .br-jogo-lado { flex: 1; display: flex; align-items: center; gap: 6px; min-width: 0; }
    .br-jogo-lado.casa { justify-content: flex-end; }
    .br-jogo-lado span { font-size: .82rem; font-weight: 600; color: #f1f5f9; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .br-jogo-lado.casa span { text-align: right; }
    .br-jogo-lado img { width: 20px; height: 20px; object-fit: contain; flex-shrink: 0; }
    .br-jogo-x { font-family: 'Barlow Condensed', Arial, sans-serif; font-size: .75rem; font-weight: 700; color: #4b5563; flex-shrink: 0; }

    .br-vazio { text-align: center; color: #6b7280; padding: 2rem 1rem; font-size: .82rem; }

    /* ── Responsivo ── */
    @@media (max-width: 768px) {
        .br-hero { padding: 26px 1.1rem 22px; }
        .br-hero h1 { font-size: 2.2rem; }
        .br-layout { padding: 18px 1.1rem 40px; }
        .br-tablewrap { overflow-x: auto; -webkit-overflow-scrolling: touch; }
        .br-cols, .br-row { min-width: 620px; }
    }
</style>

<div class="br-root">
    <!-- ── Hero ── -->
    <div class="br-hero">
        <img src="~/Images/banner/escudos-pattern.svg" class="br-hero-pattern" alt="" />
        <div class="br-hero-stripe"></div>
        <div class="br-hero-fade"></div>
        <div class="br-hero-inner">
            <div class="br-hero-flag">🇧🇷</div>
            <div style="flex:1; min-width:180px;">
                <div class="br-hero-kicker">
                    <div class="br-hero-kicker-line"></div>
                    <span>Série A · Brasil@(temporadaBrSel.HasValue ? " · " + temporadaBrSel : "")</span>
                </div>
                <h1>Brasileirão</h1>
                <p>Classificação atualizada · Rodada @rodadaRef de @totalRodadas</p>
                @if (temporadasBr.Count > 1)
                {
                    <form method="get" class="br-hero-temporada">
                        <input type="hidden" name="rodada" value="@rodadaRef" />
                        <select name="temporada" onchange="this.form.submit()">
                            @foreach (var temp in temporadasBr)
                            {
                                <option value="@temp" selected="@(temporadaBrSel == temp)">@temp</option>
                            }
                        </select>
                    </form>
                }
            </div>

            <!-- Navegação de rodada -->
            <div class="br-rodnav">
                <a class="br-rodnav-btn" href="@linkRodada(Math.Max(1, rodadaRef - 1))" aria-label="Rodada anterior">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="15 18 9 12 15 6" /></svg>
                </a>
                <div class="br-rodnav-num">
                    <div class="val">@(rodadaRef)ª</div>
                    <div class="lbl">Rodada</div>
                </div>
                <a class="br-rodnav-btn" href="@linkRodada(Math.Min(rodadaMaxima, rodadaRef + 1))" aria-label="Próxima rodada">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9 18 15 12 9 6" /></svg>
                </a>
            </div>

            <!-- Stats strip -->
            <div class="br-stats">
                <div class="br-stat"><div class="val">@Model.Count</div><div class="lbl">Times</div></div>
                <div class="br-stat-sep"></div>
                <div class="br-stat"><div class="val">@rodadaRef</div><div class="lbl">Rodadas</div></div>
                <div class="br-stat-sep"></div>
                <div class="br-stat"><div class="val">@totalGols</div><div class="lbl">Gols</div></div>
            </div>
        </div>
    </div>

    <!-- ── Layout principal ── -->
    <div class="br-layout">

        <!-- ── Tabela ── -->
        <div>
            <div class="br-tablewrap">
                <div class="br-cols">
                    <span>#</span>
                    <span></span>
                    <span class="left">Clube</span>
                    <span>J</span>
                    <span style="color:#22c55e;">V</span>
                    <span style="color:#f59e0b;">E</span>
                    <span style="color:#ef4444;">D</span>
                    <span>GP</span>
                    <span>SG</span>
                    <span>%</span>
                    <span style="color:#d4a520;">Pts</span>
                </div>

                @for (int i = 0; i < Model.Count; i++)
                {
                    var t = Model[i];
                    var pos = i + 1;
                    bool lider = pos == 1;
                    var zoneColor = pos <= 6 ? "#3b82f6" : pos <= 12 ? "#f97316" : pos >= 17 ? "#ef4444" : "#374151";
                    var totalJogados = t.Vitorias + t.Empates + t.Derrotas;
                    var aprov = totalJogados > 0 ? (int)Math.Round(t.Pontos / (double)(totalJogados * 3) * 100) : 0;
                    var aprovColor = aprov >= 60 ? "#22c55e" : aprov >= 40 ? "#f59e0b" : "#ef4444";
                    var sgColor = t.SaldoGols > 0 ? "#4ade80" : t.SaldoGols < 0 ? "#f87171" : "#6b7280";

                    <div class="br-row @(lider ? "lider" : "")">
                        <div class="br-zonebar" style="background:@zoneColor;"></div>
                        <span class="br-pos" style="color:@(pos <= 3 ? "#d4a520" : "#6b7280");">@pos</span>
                        <div class="br-escudo">
                            @if (!string.IsNullOrEmpty(t.Time?.EscudoUrl))
                            {
                                <img src="@Url.Action("Imagem", "MediaProxy", new { url = t.Time.EscudoUrl })" alt="@t.Time.Nome" />
                            }
                            else
                            {
                                @(t.Time?.Nome?.Substring(0, 1) ?? "?")
                            }
                        </div>
                        <div style="min-width:0;">
                            @if (t.Time?.Id > 0)
                            {
                                <a asp-controller="Times" asp-action="Details" asp-route-id="@t.Time.Id" class="br-nome" style="font-weight:@(lider ? 800 : 600); color:@(lider ? "#f1f5f9" : "#e5e7eb");">@t.Time.Nome</a>
                            }
                            else
                            {
                                <span class="br-nome" style="color:#e5e7eb;">@(t.Time?.Nome ?? "—")</span>
                            }
                        </div>
                        <span class="br-cell">@totalJogados</span>
                        <span class="br-cell v">@t.Vitorias</span>
                        <span class="br-cell e">@t.Empates</span>
                        <span class="br-cell d">@t.Derrotas</span>
                        <span class="br-cell">@t.GolsPro</span>
                        <span class="br-sg" style="color:@sgColor;">@(t.SaldoGols > 0 ? "+" : "")@t.SaldoGols</span>
                        <div class="br-aprov">
                            <span>@(aprov)%</span>
                            <div class="br-aprov-bar"><div style="width:@(aprov)%; background:@aprovColor;"></div></div>
                        </div>
                        <div class="br-pts">
                            <span style="color:@(lider ? "#d4a520" : "#f1f5f9"); background:@(lider ? "rgba(212,165,32,0.12)" : "transparent");">@t.Pontos</span>
                        </div>
                    </div>
                }

                <div class="br-legend">
                    <div class="br-legend-item"><div class="br-legend-dot" style="background:#3b82f6;"></div><span>Libertadores (G6)</span></div>
                    <div class="br-legend-item"><div class="br-legend-dot" style="background:#f97316;"></div><span>Sul-Americana (G12)</span></div>
                    <div class="br-legend-item"><div class="br-legend-dot" style="background:#ef4444;"></div><span>Rebaixamento (Z4)</span></div>
                </div>
            </div>
        </div>

        <!-- ── Sidebar ── -->
        <div class="br-sidebar">

            <!-- Artilheiros -->
            <div class="br-side-card">
                <div class="br-side-header">
                    <span style="font-size:1rem;">⚽</span>
                    <span class="br-side-title">Artilheiros</span>
                </div>
                @{ var rankColors = new[] { "#f59e0b", "#9ca3af", "#b45309", "#374151", "#374151" }; }
                @if (!artilheiros.Any())
                {
                    <div class="br-vazio">Nenhum gol registrado ainda.</div>
                }
                else
                {
                    for (int i = 0; i < artilheiros.Count; i++)
                    {
                        var a = artilheiros[i];
                        <div class="br-artilheiro">
                            <span class="br-art-rank" style="color:@rankColors[Math.Min(i, rankColors.Length - 1)];">@(i + 1)</span>
                            <div class="br-art-avatar">
                                @if (!string.IsNullOrEmpty(a.Jogador.FotoUrl))
                                {
                                    <img src="@Url.FotoSrc(a.Jogador.FotoUrl)" alt="@a.Jogador.NomeExibicao" />
                                }
                                else
                                {
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#64748b" stroke-width="1.5"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" /><circle cx="12" cy="7" r="4" /></svg>
                                }
                            </div>
                            <div style="flex:1; min-width:0;">
                                <div class="br-art-nome">@a.Jogador.NomeExibicao</div>
                                <div class="br-art-clube">
                                    @if (!string.IsNullOrEmpty(a.Jogador.Time?.EscudoUrl))
                                    {
                                        <img src="@Url.Action("Imagem", "MediaProxy", new { url = a.Jogador.Time.EscudoUrl })" alt="" />
                                    }
                                    <span>@(a.Jogador.Time?.Nome ?? "—")</span>
                                </div>
                            </div>
                            <span class="br-art-gols">@(a.Gols)⚽</span>
                        </div>
                    }
                }
            </div>

            <!-- Próxima Rodada -->
            <div class="br-side-card">
                <div class="br-side-header">
                    <span style="font-size:1rem;">📅</span>
                    <span class="br-side-title">Próxima Rodada</span>
                    <span class="br-side-badge blue">Rod. @rodadaRef</span>
                </div>
                @if (!proximaRodadaJogos.Any())
                {
                    <div class="br-vazio">Nenhum jogo agendado para esta rodada.</div>
                }
                else
                {
                    foreach (var jg in proximaRodadaJogos)
                    {
                        <div class="br-jogo">
                            <div class="br-jogo-hora">@DateHelper.FormatarData(jg.Data, "HH:mm") · @DateHelper.FormatarData(jg.Data, "dd/MM")</div>
                            <div class="br-jogo-teams">
                                <div class="br-jogo-lado casa">
                                    <span>@(jg.TimeCasa?.Nome ?? "?")</span>
                                    @if (!string.IsNullOrEmpty(jg.TimeCasa?.EscudoUrl))
                                    {
                                        <img src="@Url.Action("Imagem", "MediaProxy", new { url = jg.TimeCasa.EscudoUrl })" alt="" />
                                    }
                                </div>
                                <span class="br-jogo-x">×</span>
                                <div class="br-jogo-lado">
                                    @if (!string.IsNullOrEmpty(jg.TimeVisitante?.EscudoUrl))
                                    {
                                        <img src="@Url.Action("Imagem", "MediaProxy", new { url = jg.TimeVisitante.EscudoUrl })" alt="" />
                                    }
                                    <span>@(jg.TimeVisitante?.Nome ?? "?")</span>
                                </div>
                            </div>
                        </div>
                    }
                }
            </div>

            <!-- Últimos resultados -->
            <div class="br-side-card">
                <div class="br-side-header">
                    <span style="font-size:1rem;">🕘</span>
                    <span class="br-side-title">Última Rodada</span>
                    <span class="br-side-badge green">Rod. @ultimaRodadaNum</span>
                </div>
                @if (!ultimaRodadaJogos.Any())
                {
                    <div class="br-vazio">Nenhum resultado disponível.</div>
                }
                else
                {
                    foreach (var ur in ultimaRodadaJogos)
                    {
                        bool casaW = ur.PlacarCasa > ur.PlacarVisitante;
                        bool visW = ur.PlacarVisitante > ur.PlacarCasa;
                        <a asp-controller="Jogos" asp-action="Analisar" asp-route-id="@ur.Id" class="br-jogo" style="display:block;">
                            <div style="display:flex; align-items:center; gap:6px;">
                                <div class="br-jogo-lado casa" style="flex:1;">
                                    <span style="font-weight:@(casaW ? 700 : 500); color:@(casaW ? "#f1f5f9" : "#6b7280");">@(ur.TimeCasa?.Nome ?? "?")</span>
                                    @if (!string.IsNullOrEmpty(ur.TimeCasa?.EscudoUrl))
                                    {
                                        <img src="@Url.Action("Imagem", "MediaProxy", new { url = ur.TimeCasa.EscudoUrl })" alt="" style="width:18px;height:18px;" />
                                    }
                                </div>
                                <span style="font-family:'Barlow Condensed',Arial,sans-serif; font-size:1rem; font-weight:800; color:#f1f5f9; background:#0f0f0f; padding:1px 8px; border-radius:5px; flex-shrink:0;">@ur.PlacarCasa–@ur.PlacarVisitante</span>
                                <div class="br-jogo-lado" style="flex:1;">
                                    @if (!string.IsNullOrEmpty(ur.TimeVisitante?.EscudoUrl))
                                    {
                                        <img src="@Url.Action("Imagem", "MediaProxy", new { url = ur.TimeVisitante.EscudoUrl })" alt="" style="width:18px;height:18px;" />
                                    }
                                    <span style="font-weight:@(visW ? 700 : 500); color:@(visW ? "#f1f5f9" : "#6b7280");">@(ur.TimeVisitante?.Nome ?? "?")</span>
                                </div>
                            </div>
                        </a>
                    }
                }
            </div>

        </div>
    </div>
</div>
