@model List<ControleFutebolWeb.Models.ViewModels.ClassificacaoViewModel>
@using System.Globalization
@using ControleFutebolWeb.Helpers
@removeTagHelper Microsoft.AspNetCore.Mvc.TagHelpers.OptionTagHelper, Microsoft.AspNetCore.Mvc.TagHelpers
@{
    ViewData["Title"] = "Tabela do Brasileirão";
    var proximaRodada = ViewBag.ProximaRodada as List<ControleFutebolWeb.Models.Jogo> ?? new();
    var numeroRodada = (int)(ViewBag.NumeroRodada ?? 0);
    var calendario = ViewBag.CalendarioPorData as List<ControleFutebolWeb.Controllers.ProximosJogosDia> ?? new();
    var totalAgendados = (int)(ViewBag.TotalAgendados ?? 0);
    var ptBR = new CultureInfo("pt-BR");
}

<style>

    .cf-comp-hero {
        position: relative;
        border-radius: 14px;
        padding: 1.5rem 1.6rem;
        margin-bottom: 1rem;
        overflow: hidden;
        background: linear-gradient(135deg, #0b5f2a 0%, #1f8f45 55%, #0d6d30 100%);
    }

        .cf-comp-hero::before {
            content: "";
            position: absolute;
            inset: 0;
            opacity: 0.12;
            background-image: radial-gradient(circle at 50% 50%, transparent 28%, #fff 28.5%, #fff 29.2%, transparent 29.8%), linear-gradient(90deg, transparent 49.5%, #fff 49.5%, #fff 50.5%, transparent 50.5%), linear-gradient(transparent 49.5%, #fff 49.5%, #fff 50.5%, transparent 50.5%);
        }

    .cf-comp-hero-content {
        position: relative;
        z-index: 1;
    }

    .cf-comp-badge {
        display: inline-block;
        background: rgba(255, 255, 255, 0.16);
        color: #e6f7eb;
        font-size: 10px;
        font-weight: 700;
        letter-spacing: 0.8px;
        text-transform: uppercase;
        padding: 4px 11px;
        border-radius: 999px;
        margin-bottom: 0.55rem;
    }

    .cf-comp-title-wrap {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 0.2rem;
    }

    .cf-comp-logo {
        width: 34px;
        height: 34px;
        object-fit: contain;
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.12);
        padding: 2px;
    }

    .cf-comp-title {
        color: #fff;
        font-size: 1.35rem;
        font-weight: 700;
        margin: 0 0 0.2rem;
    }

    .cf-comp-sub {
        color: rgba(255, 255, 255, 0.85);
        font-size: 0.92rem;
        margin: 0;
    }

    .bra-page {
        display: grid;
        grid-template-columns: 1fr 340px;
        gap: 1.75rem;
        align-items: start;
    }

    /* ── Tabela ── */
    .bra-card {
        background: var(--color-background-primary);
        border: 0.5px solid var(--color-border-tertiary);
        border-radius: var(--border-radius-lg);
        overflow: hidden;
    }

    .bra-card-header {
        padding: 1rem 1.25rem 0.875rem;
        border-bottom: 0.5px solid var(--color-border-tertiary);
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .bra-card-title {
        font-size: 14px;
        font-weight: 500;
        color: var(--color-text-primary);
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .bra-badge-rodada {
        font-size: 11px;
        font-weight: 500;
        background: var(--color-background-secondary);
        color: var(--color-text-secondary);
        border: 0.5px solid var(--color-border-tertiary);
        padding: 2px 8px;
        border-radius: 20px;
    }

    .bra-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 13px;
    }

        .bra-table thead th {
            padding: 0.45rem 0.6rem;
            font-size: 11px;
            font-weight: 500;
            color: var(--color-text-secondary);
            text-align: center;
            border-bottom: 0.5px solid var(--color-border-tertiary);
            background: var(--color-background-secondary);
            white-space: nowrap;
        }

            .bra-table thead th:nth-child(2) {
                text-align: left;
            }

        .bra-table tbody td {
            padding: 0.5rem 0.6rem;
            text-align: center;
            border-bottom: 0.5px solid var(--color-border-tertiary);
            color: var(--color-text-primary);
            vertical-align: middle;
        }

        .bra-table tbody tr:last-child td {
            border-bottom: none;
        }

        .bra-table tbody td:nth-child(2) {
            text-align: left;
        }

        .bra-table tbody tr:hover td {
            background: var(--color-background-secondary);
        }

        /* Zona de classificação */
        .bra-table tbody tr.zona-lib td:first-child {
            border-left: 2.5px solid #22c55e;
        }

        .bra-table tbody tr.zona-sul td:first-child {
            border-left: 2.5px solid #3b82f6;
        }

        .bra-table tbody tr.zona-pre td:first-child {
            border-left: 2.5px solid #f97316;
        }

        .bra-table tbody tr.zona-rel td:first-child {
            border-left: 2.5px solid #ef4444;
        }

    .bra-pos {
        font-weight: 500;
        color: var(--color-text-secondary);
        min-width: 20px;
    }

    .bra-team-cell {
        display: flex;
        align-items: center;
        gap: 8px;
        min-width: 140px;
    }

    .bra-escudo {
        width: 20px;
        height: 20px;
        object-fit: contain;
        flex-shrink: 0;
    }

    .bra-escudo-ph {
        width: 20px;
        height: 20px;
        border-radius: 50%;
        background: var(--color-background-info);
        color: var(--color-text-info);
        font-size: 9px;
        font-weight: 500;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .bra-team-name {
        font-weight: 500;
        color: var(--color-text-primary);
        text-decoration: none;
    }

    a.bra-team-name:hover {
        color: #16a34a;
        text-decoration: underline;
    }

    .bra-pts {
        font-weight: 500;
        color: var(--color-text-primary);
    }

    .bra-saldo-pos {
        color: var(--color-text-success);
    }

    .bra-saldo-neg {
        color: var(--color-text-danger);
    }

    .bra-saldo-zer {
        color: var(--color-text-secondary);
    }

    .bra-form-dot {
        display: inline-block;
        width: 7px;
        height: 7px;
        border-radius: 50%;
        margin: 0 1px;
    }

    .bra-form-v {
        background: #22c55e;
    }

    .bra-form-e {
        background: #f59e0b;
    }

    .bra-form-d {
        background: #ef4444;
    }

    /* Legenda */
    .bra-legenda {
        display: flex;
        gap: 1rem;
        padding: 0.6rem 1.25rem;
        border-top: 0.5px solid var(--color-border-tertiary);
        flex-wrap: wrap;
    }

    .bra-leg-item {
        display: flex;
        align-items: center;
        gap: 5px;
        font-size: 11px;
        color: var(--color-text-secondary);
    }

    .bra-leg-dot {
        width: 8px;
        height: 8px;
        border-radius: 2px;
        flex-shrink: 0;
    }

    /* ── Sidebar ── */
    .bra-sidebar {
        display: flex;
        flex-direction: column;
        gap: 1.25rem;
    }

    /* ── Calendário ── */
    .cal-card {
        background: var(--color-background-primary);
        border: 0.5px solid var(--color-border-tertiary);
        border-radius: var(--border-radius-lg);
        overflow: hidden;
    }

    .cal-header {
        padding: 0.875rem 1rem 0.75rem;
        border-bottom: 0.5px solid var(--color-border-tertiary);
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .cal-title {
        font-size: 13px;
        font-weight: 500;
        color: var(--color-text-primary);
        display: flex;
        align-items: center;
        gap: 6px;
    }

    .cal-count {
        font-size: 11px;
        color: var(--color-text-secondary);
        background: var(--color-background-secondary);
        border: 0.5px solid var(--color-border-tertiary);
        padding: 1px 7px;
        border-radius: 20px;
    }

    .cal-body {
        max-height: 520px;
        overflow-y: auto;
    }

    .cal-day-group {
    }

    .cal-day-label {
        position: sticky;
        top: 0;
        z-index: 1;
        padding: 0.4rem 1rem;
        font-size: 11px;
        font-weight: 500;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        color: var(--color-text-secondary);
        background: var(--color-background-secondary);
        border-bottom: 0.5px solid var(--color-border-tertiary);
        display: flex;
        align-items: center;
        gap: 6px;
    }

    .cal-hoje-pill {
        background: var(--color-background-success);
        color: var(--color-text-success);
        font-size: 10px;
        padding: 1px 6px;
        border-radius: 20px;
        font-weight: 500;
    }

    .cal-match {
        padding: 0.55rem 1rem;
        border-bottom: 0.5px solid var(--color-border-tertiary);
        display: grid;
        grid-template-columns: 1fr auto 1fr;
        align-items: center;
        gap: 0.5rem;
        transition: background 0.15s;
        text-decoration: none;
        color: inherit;
    }

        .cal-match:hover {
            background: var(--color-background-secondary);
        }

        .cal-match:last-child {
            border-bottom: none;
        }

    .cal-team {
        display: flex;
        align-items: center;
        gap: 5px;
        font-size: 12px;
        font-weight: 500;
        color: var(--color-text-primary);
        overflow: hidden;
    }

        .cal-team.away {
            flex-direction: row-reverse;
            text-align: right;
        }

    .cal-team-name {
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .cal-esc {
        width: 16px;
        height: 16px;
        object-fit: contain;
        flex-shrink: 0;
    }

    .cal-esc-ph {
        width: 16px;
        height: 16px;
        border-radius: 50%;
        background: var(--color-background-info);
        color: var(--color-text-info);
        font-size: 8px;
        font-weight: 500;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .cal-vs {
        text-align: center;
        flex-shrink: 0;
    }

    .cal-vs-hora {
        font-size: 11px;
        font-weight: 500;
        color: var(--color-text-primary);
        line-height: 1.2;
    }

    .cal-vs-rodada {
        font-size: 10px;
        color: var(--color-text-secondary);
    }

    .cal-vs-tag {
        display: inline-block;
        font-size: 10px;
        font-weight: 500;
        color: var(--color-text-secondary);
        background: var(--color-background-secondary);
        border: 0.5px solid var(--color-border-tertiary);
        padding: 1px 5px;
        border-radius: 3px;
    }

    /* Quando não há data definida */
    .cal-semdata {
        font-size: 11px;
        color: var(--color-text-secondary);
        padding: 0.6rem 1rem;
        font-style: italic;
    }

    /* Próxima rodada — título da sidebar */
    .rodada-sidebar-title {
        font-size: 14px; font-weight: 700; color: var(--color-text-primary);
        margin-bottom: .75rem; display: flex; align-items: center; gap: .5rem;
    }
    .rodada-sidebar-badge {
        font-size: 11px; font-weight: 700; background: #16a34a; color: #fff;
        padding: 2px 10px; border-radius: 999px;
    }
    .rodada-sidebar-sub { font-size: 11px; color: var(--color-text-secondary); margin-left: auto; }

    /* Card individual de jogo da próxima rodada */
    .bra-jogo-card {
        background: #fff;
        border: 0.5px solid #e5e7eb;
        border-radius: 10px;
        overflow: hidden;
        margin-bottom: .6rem;
        transition: box-shadow .15s;
    }
    .bra-jogo-card:hover { box-shadow: 0 2px 10px rgba(22,163,74,.15); }

    .bra-jogo-header {
        background: linear-gradient(90deg, #14532d, #16a34a);
        color: #bbf7d0;
        font-size: 10px; font-weight: 600; letter-spacing: .4px;
        padding: 5px 10px;
        display: flex; justify-content: space-between; align-items: center;
    }

    .bra-jogo-body { padding: 10px 12px; }

    .bra-jogo-teams {
        display: flex; justify-content: space-between; align-items: center; gap: 6px;
    }

    .bra-jogo-team {
        display: flex; flex-direction: column; align-items: center; gap: 4px;
        flex: 1; min-width: 0;
    }
    .bra-jogo-team img { width: 32px; height: 32px; object-fit: contain; border-radius: 4px; }
    .bra-jogo-team span {
        font-size: 11px; font-weight: 500; color: #374151;
        text-align: center; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 80px;
    }

    .bra-jogo-vs {
        font-size: 11px; font-weight: 700; color: #9ca3af; flex-shrink: 0;
        display: flex; flex-direction: column; align-items: center; gap: 2px;
    }
    .bra-jogo-score {
        background: #111827; color: #f9fafb;
        font-size: 14px; font-weight: 800;
        padding: 4px 10px; border-radius: 6px; min-width: 52px; text-align: center;
    }

    .bra-jogo-footer {
        display: flex; justify-content: space-between; align-items: center;
        margin-top: 8px; padding-top: 6px; border-top: 0.5px solid #f3f4f6;
    }
    .bra-badge-agendado {
        font-size: 10px; background: #f3f4f6; color: #6b7280;
        padding: 2px 8px; border-radius: 999px;
    }
    .bra-analisar-btn {
        font-size: 10px; padding: 3px 10px; border-radius: 6px;
        background: transparent; color: #16a34a;
        border: 1px solid #16a34a; text-decoration: none; font-weight: 600;
        transition: background .15s, color .15s;
    }
    .bra-analisar-btn:hover { background: #16a34a; color: #fff; text-decoration: none; }

    @@media (max-width: 900px) {
        .bra-page {
            grid-template-columns: 1fr;
        }

        .bra-sidebar {
            order: -1;
        }
    }

    @@media (max-width: 600px) {
        .bra-form-dot { display: none; }
        .bra-table .hide-mob { display: none; }
        .bra-team-name { max-width: 100px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
        .cf-comp-hero { padding: 1rem 1.1rem; }
        .cf-comp-title { font-size: 1.1rem; }
    }
</style>

<div style="padding: 0.5rem 0 2rem">

    <!-- Banner Campeonato Brasileiro -->
    <div class="cf-comp-hero">
        <div class="cf-comp-hero-content">
            <span class="cf-comp-badge">Competição nacional</span>
            <div class="cf-comp-title-wrap">
                <img src="~/images/background/campeonatobrasileiro.png"
                     alt="Escudo Campeonato Brasileiro"
                     class="cf-comp-logo" />
                <h2 class="cf-comp-title">Campeonato Brasileiro</h2>
            </div>
            <p class="cf-comp-sub">Classificação geral e jogos da rodada atual.</p>
            @{
                var temporadasBr = ViewBag.TemporadasDisponiveis as List<int> ?? new List<int>();
                var temporadaBrSel = ViewBag.Temporada as int?;
            }
            @if (temporadasBr.Count > 1)
            {
                <form method="get" style="margin-top:8px;">
                    <label style="color:#fff;font-size:12px;font-weight:600;margin-right:6px;">Temporada:</label>
                    <select name="temporada" onchange="this.form.submit()"
                            style="padding:5px 10px;border-radius:7px;border:none;font-size:13px;font-weight:600;">
                        @foreach (var temp in temporadasBr)
                        {
                            <option value="@temp" @(temporadaBrSel == temp ? "selected" : "")>@temp</option>
                        }
                    </select>
                </form>
            }
        </div>
    </div>

    <div class="bra-page">

        <!-- ── TABELA ── -->
        <div>
            <div class="bra-card">
                <div class="bra-card-header">
                    <span class="bra-card-title">
                        <i class="ti ti-list-numbers" aria-hidden="true" style="font-size:16px"></i>
                        Classificação
                    </span>
                    @if (numeroRodada > 0)
                    {
                        <span class="bra-badge-rodada">Rodada @numeroRodada</span>
                    }
                </div>

                <table class="bra-table">
                    <thead>
                        <tr>
                            <th style="width:28px">#</th>
                            <th>Clube</th>
                            <th>J</th>
                            <th>Pts</th>
                            <th class="hide-mob">V</th>
                            <th class="hide-mob">E</th>
                            <th class="hide-mob">D</th>
                            <th class="hide-mob">GP</th>
                            <th class="hide-mob">GC</th>
                            <th>SG</th>
                        </tr>
                    </thead>
                    <tbody>
                        @for (int i = 0; i < Model.Count; i++)
                        {
                            var t = Model[i];
                            var pos = i + 1;
                            string zonaCls = pos <= 6 ? "zona-lib"
                            : pos <= 12 ? "zona-pre"
                            : pos >= 17 ? "zona-rel"
                            : pos >= 13 ? "zona-sul"
                            : "";

                            var saldoCls = t.SaldoGols > 0 ? "bra-saldo-pos"
                            : t.SaldoGols < 0 ? "bra-saldo-neg"
                            : "bra-saldo-zer";

                            var totalJogados = t.Vitorias + t.Empates + t.Derrotas;
                            <tr class="@zonaCls">
                                <td class="bra-pos">@pos</td>
                                <td>
                                    <div class="bra-team-cell">
                                        @if (!string.IsNullOrEmpty(t.Time?.EscudoUrl))
                                        {
                                            <img src="@Url.Action("Imagem", "MediaProxy", new { url = t.Time.EscudoUrl })" alt="@t.Time.Nome" class="bra-escudo" />
                                        }
                                        else
                                        {
                                            <div class="bra-escudo-ph">@(t.Time?.Nome?.Substring(0, 1) ?? "?")</div>
                                        }
                                        @if (t.Time?.Id > 0)
                                        {
                                            <a asp-controller="Times" asp-action="Details" asp-route-id="@t.Time.Id" class="bra-team-name">@t.Time.Nome</a>
                                        }
                                        else
                                        {
                                            <span class="bra-team-name">@(t.Time?.Nome ?? "—")</span>
                                        }
                                    </div>
                                </td>
                                <td style="color:var(--color-text-secondary)">@totalJogados</td>
                                <td class="bra-pts">@t.Pontos</td>
                                <td class="hide-mob" style="color:var(--color-text-success)">@t.Vitorias</td>
                                <td class="hide-mob" style="color:var(--color-text-secondary)">@t.Empates</td>
                                <td class="hide-mob" style="color:var(--color-text-danger)">@t.Derrotas</td>
                                <td class="hide-mob" style="color:var(--color-text-secondary)">@t.GolsPro</td>
                                <td class="hide-mob" style="color:var(--color-text-secondary)">@t.GolsContra</td>
                                <td class="@saldoCls">@(t.SaldoGols > 0 ? "+" : "")@t.SaldoGols</td>
                            </tr>
                        }
                    </tbody>
                </table>

                <div class="bra-legenda">
                    <div class="bra-leg-item">
                        <div class="bra-leg-dot" style="background:#22c55e"></div>
                        Fase de grupos Libertadores
                    </div>
                    <div class="bra-leg-item">
                        <div class="bra-leg-dot" style="background:#3b82f6"></div>
                        Sul-Americana
                    </div>
                    <div class="bra-leg-item">
                        <div class="bra-leg-dot" style="background:#f97316"></div>
                        Pré-Libertadores
                    </div>
                    <div class="bra-leg-item">
                        <div class="bra-leg-dot" style="background:#ef4444"></div>
                        Rebaixamento
                    </div>
                </div>
            </div>
        </div>

        <!-- ── SIDEBAR ── -->
        <div class="bra-sidebar">

            <!-- Próxima Rodada -->
            @if (proximaRodada.Any())
            {
                <div class="rodada-sidebar-title">
                    <i class="ti ti-calendar-event" style="font-size:15px"></i>
                    Rodada @numeroRodada
                    <span class="rodada-sidebar-badge">@proximaRodada.Count jogos</span>
                </div>

                @foreach (var j in proximaRodada)
                {
                    bool realizado = j.PlacarCasa.HasValue && j.PlacarVisitante.HasValue;
                    <div class="bra-jogo-card">
                        <div class="bra-jogo-header">
                            <span>@DateHelper.FormatarData(j.Data, "dd/MM/yyyy HH:mm")</span>
                            <span>R@(j.Rodada)</span>
                        </div>
                        <div class="bra-jogo-body">
                            <div class="bra-jogo-teams">
                                <div class="bra-jogo-team">
                                    @if (!string.IsNullOrEmpty(j.TimeCasa?.EscudoUrl))
                                    {
                                        <img src="@Url.Action("Imagem", "MediaProxy", new { url = j.TimeCasa.EscudoUrl })" alt="@j.TimeCasa!.Nome" />
                                    }
                                    else
                                    {
                                        <div class="bra-escudo-ph">@(j.TimeCasa?.Nome?.Substring(0, 1) ?? "?")</div>
                                    }
                                    <span>@(j.TimeCasa?.Nome ?? "?")</span>
                                </div>

                                <div class="bra-jogo-vs">
                                    @if (realizado)
                                    {
                                        <span class="bra-jogo-score">@j.PlacarCasa x @j.PlacarVisitante</span>
                                    }
                                    else
                                    {
                                        <span>vs</span>
                                    }
                                </div>

                                <div class="bra-jogo-team">
                                    @if (!string.IsNullOrEmpty(j.TimeVisitante?.EscudoUrl))
                                    {
                                        <img src="@Url.Action("Imagem", "MediaProxy", new { url = j.TimeVisitante.EscudoUrl })" alt="@j.TimeVisitante!.Nome" />
                                    }
                                    else
                                    {
                                        <div class="bra-escudo-ph">@(j.TimeVisitante?.Nome?.Substring(0, 1) ?? "?")</div>
                                    }
                                    <span>@(j.TimeVisitante?.Nome ?? "?")</span>
                                </div>
                            </div>

                            <div class="bra-jogo-footer">
                                @if (realizado)
                                {
                                    <span style="color:#16a34a;font-weight:600;font-size:10px;">✔ Realizado</span>
                                }
                                else
                                {
                                    <span class="bra-badge-agendado">Agendado</span>
                                }
                                <a asp-controller="Jogos" asp-action="Analisar" asp-route-id="@j.Id" class="bra-analisar-btn">
                                    Analisar →
                                </a>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="bra-card" style="padding: 1.5rem; text-align:center">
