@model ControleFutebolWeb.Models.Nota

<h2>Cadastrar Nota</h2>

<form asp-action="Create" method="post">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="form-group">
        <label>Jogador</label>
        <select asp-for="JogadorId" class="form-control" asp-items="@(new SelectList(ViewBag.Jogadores, "Id", "Nome"))"></select>
        <span asp-validation-for="JogadorId" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label>Jogo</label>
        <select asp-for="JogoId" class="form-control" asp-items="@(new SelectList(ViewBag.Jogos, "Id", "Adversario"))"></select>
        <span asp-validation-for="JogoId" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label>Nota</label>
        <input asp-for="Valor" type="number" min="0" max="10" class="form-control" />
        <span asp-validation-for="Valor" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label>Comentário</label>
        <textarea asp-for="Comentario" class="form-control"></textarea>
        <span asp-validation-for="Comentario" class="text-danger"></span>
    </div>
    <div class="form-group mt-2">
        <button type="submit" class="btn btn-success">Salvar</button>
        <a asp-action="Index" class="btn btn-secondary">Voltar</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}