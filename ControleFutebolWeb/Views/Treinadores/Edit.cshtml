@model ControleFutebolWeb.Models.Treinador

<h2>Editar Treinador</h2>

<form asp-action="Edit" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />

    <div class="mb-3">
        <label class="form-label">Nome</label>
        <input asp-for="Nome" class="form-control" />
    </div>

    <div class="mb-3">
        <label class="form-label">Nacionalidade</label>
        @Html.DropDownList("NacionalidadeId", (SelectList)ViewBag.Nacionalidades, "Selecione", new { @class = "form-select" })
    </div>

    <div class="mb-3">
        <label class="form-label">Data de Nascimento</label>
        <input asp-for="DataNascimento" type="date" class="form-control" />
    </div>

    <div class="mb-3">
        <label class="form-label">Time Atual</label>
        @Html.DropDownList("TimeId", (SelectList)ViewBag.Times, "Selecione", new { @class = "form-select" })
    </div>

    <button type="submit" class="btn btn-primary">Salvar Alterações</button>
    <a asp-action="Index" class="btn btn-secondary">Voltar</a>
</form>
