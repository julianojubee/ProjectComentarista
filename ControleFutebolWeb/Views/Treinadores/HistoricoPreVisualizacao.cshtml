@model ControleFutebolWeb.Services.TreinadorTMInfo
@{
    ViewData["Title"] = $"Histórico — {Model.NomeCompleto}";
}

<style>
    /* Reaproveitando o mesmo estilo da tela de jogadores */
    @@import url('https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;600;700;800&family=Barlow:wght@400;500&display=swap');

    :root {
        --cinza1: #0f172a;
        --cinza2: #1e293b;
        --cinza3: #334155;
        --texto: #f1f5f9;
        --muted: #94a3b8;
        --verde: #16a34a;
        --verde2: #22c55e;
    }

    .estat-page {
        background: var(--cinza1);
        min-height: 100vh;
        color: var(--texto);
        font-family: 'Barlow', sans-serif;
        padding: 2rem 1rem 4rem;
    }

    .jogador-header {
        display: flex;
        align-items: center;
        gap: 1.5rem;
        margin-bottom: 2rem;
        padding-bottom: 1.5rem;
        border-bottom: 1px solid var(--cinza3);
    }

    .jogador-foto {
        width: 72px;
        height: 72px;
        object-fit: cover;
        border-radius: 12px;
        border: 2px solid var(--cinza3);
        background: var(--cinza2);
    }

    .jogador-nome {
        font-family: 'Barlow Condensed', sans-serif;
        font-size: 2.4rem;
        font-weight: 800;
        margin: 0;
    }

    .jogador-meta {
        font-size: .85rem;
        color: var(--muted);
        margin-top: .3rem;
        display: flex;
        gap: 1rem;
        flex-wrap: wrap;
    }

    .jogos-titulo {
        font-family: 'Barlow Condensed', sans-serif;
        font-size: 1.4rem;
        font-weight: 700;
        text-transform: uppercase;
        margin-bottom: 1rem;
        display: flex;
        align-items: center;
        gap: .6rem;
    }

    .jogo-item {
        background: var(--cinza2);
        border: 1px solid var(--cinza3);
        border-radius: 10px;
        padding: .9rem 1.1rem;
        margin-bottom: .6rem;
        display: grid;
        grid-template-columns: 1fr auto;
        align-items: center;
        gap: 1rem;
    }

    .jogo-adversario {
        font-size: .95rem;
        font-weight: 500;
    }

    .jogo-data {
        font-size: .75rem;
        color: var(--muted);
        margin-top: .2rem;
    }

    .btn-voltar {
        display: inline-flex;
        align-items: center;
        gap: .4rem;
        background: var(--cinza2);
        border: 1px solid var(--cinza3);
        color: var(--texto);
        padding: .45rem 1rem;
        border-radius: 8px;
        font-size: .85rem;
        text-decoration: none;
        margin-bottom: 1.5rem;
    }
</style>

<div class="estat-page">
    <div class="container" style="max-width:860px;">

        <a href="javascript:history.back()" class="btn-voltar">← Voltar</a>

        <!-- Header -->
        <div class="jogador-header">
            @if (!string.IsNullOrWhiteSpace(ViewBag.FotoUrl))
            {
                <img src="@Url.Action("Imagem", "MediaProxy", new { url = ViewBag.FotoUrl })" class="jogador-foto" />
            }
            else
            {
                <img src="/images/placeholder-treinador.png" class="jogador-foto" />
            }

            <div>
                <h1 class="jogador-nome">@Model.NomeCompleto</h1>
                <div class="jogador-meta">
                    @if (!string.IsNullOrWhiteSpace(Model.Nacionalidade))
                    {
                        <span>🌍 @Model.Nacionalidade</span>
                    }
                    @if (ViewBag.Treinador?.Time != null)
                    {
                        <span>🏟️ @ViewBag.Treinador.Time.Nome</span>
                    }
                    @if (Model.DataNascimento.HasValue)
                    {
                        <span>📅 @Model.DataNascimento.Value.ToString("dd/MM/yyyy")</span>
                    }
                </div>
            </div>
        </div>

        <!-- Histórico -->
        <div class="jogos-titulo">Histórico de Trabalhos</div>

        @if (!Model.Historico.Any())
        {
            <div class="sem-dados">Nenhum histórico encontrado para este treinador.</div>
        }
        else
        {
            foreach (var item in Model.Historico)
            {
                <div class="jogo-item">
                    <div>
                        <div class="jogo-adversario">
                            @item.NomeTime
                            @if (!string.IsNullOrEmpty(item.Funcao))
                            {
                                <span style="color:var(--muted); font-size:.8rem; margin-left:.5rem;">
                                    — @item.Funcao
                                </span>
                            }
                        </div>
                        <div class="jogo-data">
                            @item.DtInicio?.ToString("dd/MM/yyyy")
                            até @(item.DtFim?.ToString("dd/MM/yyyy") ?? "Atual")
                        </div>
                    </div>
                    <div>
                        @if (item.Jogos.HasValue)
                        {
                            <span>🎮 @item.Jogos jogos</span>
                        }
                        @if (item.PpjMedia.HasValue)
                        {
                            <span>📊 @item.PpjMedia PPJ</span>
                        }
                    </div>
                </div>
            }
        }

        <!-- Botão de salvar -->
        <form asp-action="SalvarHistorico" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="treinadorId" value="@ViewBag.Treinador.Id" />
            <input type="hidden" name="profileUrl" value="@ViewBag.ProfileUrl" />
            <input type="hidden" name="atualizarFoto" value="true" />
            <button type="submit" class="btn btn-success">Salvar Histórico</button>
        </form>
    </div>
</div>
