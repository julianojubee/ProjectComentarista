@model IEnumerable<ControleFutebolWeb.Models.Treinador>
@using ControleFutebolWeb.Helpers

@section Scripts {
    <script>
        (function () {
            function initMulti(wrapId, boxId, panelId, placeholder, onChange) {
                var wrap  = document.getElementById(wrapId);
                var box   = document.getElementById(boxId);
                var panel = document.getElementById(panelId);
                if (!wrap) return null;

                function render() {
                    var checks = panel.querySelectorAll('input[type=checkbox]');
                    var marcados = Array.prototype.filter.call(checks, function (c) { return c.checked; });
                    box.innerHTML = '';
                    if (marcados.length === 0) {
                        var ph = document.createElement('span');
                        ph.className = 'ms-placeholder';
                        ph.textContent = placeholder;
                        box.appendChild(ph);
                        return;
                    }
                    marcados.forEach(function (c) {
                        var chip = document.createElement('span');
                        chip.className = 'ms-chip';
                        var txt = document.createElement('span');
                        txt.textContent = c.dataset.nome;
                        var x = document.createElement('span');
                        x.className = 'ms-chip-x';
                        x.textContent = '×';
                        x.addEventListener('click', function (e) {
                            e.stopPropagation();
                            c.checked = false;
                            render();
                            if (onChange) onChange();
                        });
                        chip.appendChild(txt);
                        chip.appendChild(x);
                        box.appendChild(chip);
                    });
                }

                function bindChecks() {
                    panel.querySelectorAll('input[type=checkbox]').forEach(function (c) {
                        c.addEventListener('change', function () { render(); if (onChange) onChange(); });
                    });
                }

                box.addEventListener('click', function () { panel.classList.toggle('open'); });
                box.addEventListener('keydown', function (e) {
                    if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); panel.classList.toggle('open'); }
                });
                document.addEventListener('click', function (e) {
                    if (!wrap.contains(e.target)) panel.classList.remove('open');
                });

                bindChecks();
                render();
                return { render: render, bindChecks: bindChecks, panel: panel };
            }

            function ligarBusca(inputId, optionsContainerId) {
                var input = document.getElementById(inputId);
                if (!input) return;
                function filtrar() {
                    var termo = input.value.trim().toLowerCase();
                    document.querySelectorAll('#' + optionsContainerId + ' .ms-opt').forEach(function (lbl) {
                        var nome = (lbl.querySelector('span')?.textContent || '').toLowerCase();
                        lbl.style.display = (termo === '' || nome.indexOf(termo) !== -1) ? '' : 'none';
                    });
                }
                input.addEventListener('input', filtrar);
                input.addEventListener('click', function (e) { e.stopPropagation(); });
            }

            ligarBusca('compSearch', 'compOptions');
            var timeCtl = initMulti('timeMulti', 'timeBox', 'timePanel', 'Todos os times');
            ligarBusca('timeSearch', 'timeOptions');
            initMulti('nacMulti', 'nacBox', 'nacPanel', 'Todas as nacionalidades');
            ligarBusca('nacSearch', 'nacOptions');

            function recarregarTimes() {
                var compChecks = document.querySelectorAll('#compPanel input[type=checkbox]:checked');
                var ids = Array.prototype.map.call(compChecks, function (c) { return c.value; });
                if (!timeCtl) return;

                var selecionados = Array.prototype.map.call(
                    timeCtl.panel.querySelectorAll('input[type=checkbox]:checked'),
                    function (c) { return c.value; });

                var qs = ids.length ? ids.map(function (id) { return 'competicaoIds=' + id; }).join('&') : '';
                fetch('/Jogos/TimesPorCompeticoes?' + qs)
                    .then(function (r) { return r.json(); })
                    .then(function (times) {
                        var opts = document.getElementById('timeOptions');
                        opts.innerHTML = '';
                        times.forEach(function (t) {
                            var lbl = document.createElement('label');
                            lbl.className = 'ms-opt';
                            var inp = document.createElement('input');
                            inp.type = 'checkbox';
                            inp.name = 'timeIds';
                            inp.value = t.id;
                            inp.dataset.nome = t.nome;
                            if (selecionados.indexOf(String(t.id)) !== -1) inp.checked = true;
                            var sp = document.createElement('span');
                            sp.textContent = t.nome;
                            lbl.appendChild(inp);
                            lbl.appendChild(sp);
                            opts.appendChild(lbl);
                        });
                        timeCtl.bindChecks();
                        timeCtl.render();
                    });
            }

            initMulti('compMulti', 'compBox', 'compPanel', 'Todas as competições', recarregarTimes);
        })();
    </script>
}

<style>
    /* Home identity (hero + cards) */
    .cf-hero {
        position: relative;
        background: linear-gradient(135deg, #0a1628 0%, #1a2f4e 55%, #0f2040 100%);
        border-radius: 14px;
        padding: 2.6rem 2rem;
        text-align: center;
        overflow: hidden;
        margin-bottom: 1.5rem;
        color: #fff;
        min-height: 280px;
    }

    /* Recorte dos treinadores (PNG sem fundo) ancorado à direita do banner */
    .cf-hero-treinadores {
        position: absolute;
        right: 0;
        bottom: 0;
        height: 128%;
        z-index: 0;
        pointer-events: none;
        display: flex;
        align-items: flex-end;
    }

    .cf-hero-treinadores img {
        height: 100%;
        width: auto;
        object-fit: contain;
        object-position: bottom right;
        filter: drop-shadow(0 4px 10px rgba(0,0,0,0.35));
        opacity: 0.95;
    }

    /* Escurecimento na esquerda para o texto ficar legível sobre o gradiente */
    .cf-hero-overlay {
        position: absolute;
        inset: 0;
        z-index: 1;
        background: linear-gradient(90deg, rgba(10,22,40,0.55) 0%, rgba(10,22,40,0.15) 45%, rgba(10,22,40,0) 70%);
        pointer-events: none;
    }

    .cf-hero-content {
        position: relative;
        z-index: 2;
        text-align: left;
    }

    @@media (max-width: 640px) {
        .cf-hero-treinadores { opacity: 0.35; }
        .cf-hero-content { text-align: center; }
    }

    .cf-hero-badge {
        display: inline-block;
        background: rgba(55, 138, 221, 0.2);
        color: #85b7eb;
        font-size: 11px;
        font-weight: 600;
        padding: 4px 14px;
        border-radius: 20px;
        border: 1px solid rgba(55, 138, 221, 0.35);
        letter-spacing: 1px;
        text-transform: uppercase;
        margin-bottom: 0.9rem;
    }

    .cf-hero h1 {
        font-size: 1.9rem;
        color: #fff;
        margin-bottom: 0.6rem;
        font-weight: 600;
    }

    .cf-hero p {
        color: rgba(255,255,255,0.65);
        margin: 0;
        font-size: 0.95rem;
    }

    /* Filters row */
    .players-filter {
        display: flex;
        gap: 12px;
        align-items: flex-end;
        flex-wrap: wrap;
        margin-bottom: 12px;
    }

    /* ── Tag selector (igual Times/Relatórios) ── */
    .ms-wrap { position: relative; min-width: 220px; flex: 1; }
    .ms-box {
        display: flex; flex-wrap: wrap; gap: 5px; align-items: center;
        min-height: 38px; padding: 4px 30px 4px 8px; cursor: pointer;
        border: 1px solid #d1d5db; border-radius: 8px; background: #fff; font-size: 13px;
    }
    .ms-box::after {
        content: "▾"; position: absolute; right: 10px; top: 50%; transform: translateY(-50%);
        color: #6b7280; pointer-events: none;
    }
    .ms-placeholder { color: #9ca3af; }
    .ms-chip {
        display: inline-flex; align-items: center; gap: 4px;
        background: #eef2ff; color: #4338ca; border: 1px solid #c7d2fe;
        border-radius: 6px; padding: 2px 6px; font-size: 12px; font-weight: 600;
    }
    .ms-chip-x { cursor: pointer; font-weight: 700; line-height: 1; opacity: .7; }
    .ms-chip-x:hover { opacity: 1; }
    .ms-panel {
        position: absolute; top: calc(100% + 4px); left: 0; right: 0; z-index: 50;
        background: #fff; border: 1px solid #d1d5db; border-radius: 8px;
        box-shadow: 0 8px 24px rgba(0,0,0,.12); max-height: 280px; overflow-y: auto;
        display: none; padding: 4px;
    }
    .ms-panel.open { display: block; }
    .ms-opt {
        display: flex; align-items: center; gap: 8px; padding: 7px 10px;
        border-radius: 6px; cursor: pointer; font-size: 13px; color: #111827;
    }
    .ms-opt:hover { background: #f3f4f6; }
    .ms-opt input { cursor: pointer; }
    .ms-search {
        width: 100%; box-sizing: border-box; padding: 7px 10px; margin-bottom: 4px;
        border: 1px solid #d1d5db; border-radius: 6px; font-size: 13px; outline: none;
        position: sticky; top: 0; background: #fff;
    }
    .ms-search:focus { border-color: #6366f1; }

    /* Lista de treinadores (igual Jogadores) */
    .player-list { display: flex; flex-direction: column; gap: 0; margin-top: 1rem; }

    .player-row {
        display: flex;
        align-items: center;
        gap: 14px;
        padding: 10px 14px;
        background: #fff;
        border: 0.5px solid #e5e7eb;
        border-bottom: none;
        transition: background 0.12s;
    }

    .player-row:first-child { border-radius: 10px 10px 0 0; }
    .player-row:last-child  { border-bottom: 0.5px solid #e5e7eb; border-radius: 0 0 10px 10px; }
    .player-row:only-child  { border-radius: 10px; border-bottom: 0.5px solid #e5e7eb; }
    .player-row:hover { background: #f0f6ff; }

    .player-photo {
        width: 42px;
        height: 42px;
        border-radius: 50%;
        background: #f3f4f6;
        border: 0.5px solid #e5e7eb;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
        flex-shrink: 0;
    }

    .player-photo img { width: 100%; height: 100%; object-fit: cover; }

    .player-info { flex: 1; min-width: 0; }

    .tr-name { font-weight: 600; color: #111827; font-size: 0.97rem; white-space: normal; overflow-wrap: break-word; }

    .player-meta { color: #6b7280; font-size: 13px; margin-top: 1px; }

    .player-club {
        display: flex;
        align-items: center;
        gap: 6px;
        flex-shrink: 0;
        min-width: 140px;
    }

    .player-club img { width: 22px; height: 22px; object-fit: contain; }

    .player-club-name { font-size: 13px; color: #374151; }

    .player-actions { display: flex; gap: 6px; flex-shrink: 0; flex-wrap: wrap; }

    .cf-small-btn {
        font-size: 12px;
        padding: 5px 9px;
    }

    @@media (max-width: 640px) {
        .cf-hero {
            padding: 1.8rem 1rem;
        }
        .player-club { min-width: 100px; }
    }
</style>
<div class="cf-hero">
    <div class="cf-hero-treinadores">
        <img src="~/Images/banner/treinadores.png" alt="" />
    </div>
    <div class="cf-hero-overlay"></div>
    <div class="cf-hero-content">
        <div class="cf-hero-badge">Cadastros</div>
        <h1>Treinadores</h1>
        <p>Consulte e gerencie os treinadores cadastrados no sistema.</p>
    </div>
</div>

@{
    var competicoesLista = ViewBag.Competicoes as IEnumerable<ControleFutebolWeb.Models.Competicao> ?? Enumerable.Empty<ControleFutebolWeb.Models.Competicao>();
    var timesLista = ViewBag.Times as IEnumerable<ControleFutebolWeb.Models.Time> ?? Enumerable.Empty<ControleFutebolWeb.Models.Time>();
    var nacLista = ViewBag.NacionalidadesLista as IEnumerable<Nacionalidade> ?? Enumerable.Empty<Nacionalidade>();
    var compSel = ViewBag.CompeticaoIdsFiltro as List<int> ?? new List<int>();
    var timeSel = ViewBag.TimeIdsFiltro as List<int> ?? new List<int>();
    var nacSel = ViewBag.NacionalidadesFiltro as List<string> ?? new List<string>();
}

<form asp-action="Index" method="get" class="players-filter">
    <div style="flex:1;min-width:220px;">
        <label class="form-label">Competições</label>
        <div class="ms-wrap" id="compMulti">
            <div class="ms-box" id="compBox" tabindex="0"></div>
            <div class="ms-panel" id="compPanel">
                <input type="text" class="ms-search" id="compSearch" placeholder="Buscar competição…" autocomplete="off" />
                <div id="compOptions">
                    @foreach (var c in competicoesLista)
                    {
                        <label class="ms-opt">
                            <input type="checkbox" name="competicaoIds" value="@c.Id" data-nome="@c.Nome"
                                   @(compSel.Contains(c.Id) ? "checked" : "") />
                            <span>@c.Nome</span>
                        </label>
                    }
                </div>
            </div>
        </div>
    </div>

    <div style="flex:1;min-width:220px;">
        <label class="form-label">Times</label>
        <div class="ms-wrap" id="timeMulti">
            <div class="ms-box" id="timeBox" tabindex="0"></div>
            <div class="ms-panel" id="timePanel">
                <input type="text" class="ms-search" id="timeSearch" placeholder="Buscar time…" autocomplete="off" />
                <div id="timeOptions">
                    @foreach (var t in timesLista)
                    {
                        <label class="ms-opt">
                            <input type="checkbox" name="timeIds" value="@t.Id" data-nome="@t.Nome"
                                   @(timeSel.Contains(t.Id) ? "checked" : "") />
                            <span>@t.Nome</span>
                        </label>
                    }
                </div>
            </div>
        </div>
    </div>

    <div style="flex:1;min-width:220px;">
        <label class="form-label">Nacionalidades</label>
        <div class="ms-wrap" id="nacMulti">
            <div class="ms-box" id="nacBox" tabindex="0"></div>
            <div class="ms-panel" id="nacPanel">
                <input type="text" class="ms-search" id="nacSearch" placeholder="Buscar nacionalidade…" autocomplete="off" />
                <div id="nacOptions">
                    @foreach (var n in nacLista)
                    {
                        <label class="ms-opt">
                            <input type="checkbox" name="nacionalidades" value="@n.Nome" data-nome="@n.Nome"
                                   @(nacSel.Contains(n.Nome) ? "checked" : "") />
                            <span>@n.Nome</span>
                        </label>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="d-flex align-items-end gap-2">
        <button type="submit" class="btn btn-primary cf-small-btn">Filtrar</button>
        @if (compSel.Any() || timeSel.Any() || nacSel.Any())
        {
            <a asp-action="Index" class="btn btn-outline-secondary cf-small-btn">✕ Limpar</a>
        }
        <a asp-action="Create" class="btn btn-success cf-small-btn">Novo Treinador</a>
    </div>
</form>

@{
    int paginaAtual = ViewBag.PaginaAtual ?? 1;
    int totalPaginas = ViewBag.TotalPaginas ?? 1;
    int totalTreinadores = ViewBag.TotalTreinadores ?? Model.Count();
    int pageSize = ViewBag.PageSize ?? 50;
    int primeiroDaPagina = totalTreinadores == 0 ? 0 : (paginaAtual - 1) * pageSize + 1;
    int ultimoDaPagina = Math.Min(paginaAtual * pageSize, totalTreinadores);

    // Monta a query string preservando os filtros multi-seleção
    var filtrosQs = new System.Text.StringBuilder();
    foreach (var id in compSel) filtrosQs.Append("&competicaoIds=").Append(id);
    foreach (var id in timeSel) filtrosQs.Append("&timeIds=").Append(id);
    foreach (var nn in nacSel) filtrosQs.Append("&nacionalidades=").Append(Uri.EscapeDataString(nn));
    Func<int, string> linkPagina = (p) => $"{Url.Action("Index")}?page={p}{filtrosQs}";
}

<div style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:8px;margin:6px 0;color:#6b7280;font-size:13px;">
    <span>Mostrando <strong>@primeiroDaPagina–@ultimoDaPagina</strong> de <strong>@totalTreinadores</strong> treinadores</span>
    <span>Página @paginaAtual de @totalPaginas</span>
</div>

<div class="player-list">
    @foreach (var treinador in Model)
    {
        <div class="player-row">
            <!-- Foto -->
            <div class="player-photo">
                @if (!string.IsNullOrEmpty(treinador.FotoUrl))
                {
                    <img src="@Url.FotoSrc(treinador.FotoUrl)" alt="@treinador.Nome"
                         loading="lazy" decoding="async" width="42" height="42"
                         onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';" />
                    <span style="display:none; color:#6b7280; font-size:18px;">👤</span>
                }
                else
                {
                    <span style="color:#6b7280; font-size:18px;">👤</span>
                }
            </div>

            <!-- Nome + meta -->
            <div class="player-info">
                <div class="tr-name">@treinador.Nome</div>
                <div class="player-meta">@treinador.Idade anos • <span title="@treinador.Nacionalidade?.Nome">@FlagHelper.GetFlagEmoji(treinador.Nacionalidade?.Nome)</span></div>
            </div>

            <!-- Clube -->
            <div class="player-club">
                @if (treinador.Time != null)
                {
                    @if (!string.IsNullOrEmpty(treinador.Time.EscudoUrl))
                    {
                        <img src="@Url.Action("Imagem", "MediaProxy", new { url = treinador.Time.EscudoUrl })" alt="@treinador.Time.Nome"
                             loading="lazy" decoding="async" width="22" height="22" />
                    }
                    <span class="player-club-name">@treinador.Time.Nome</span>
                }
                else
                {
                    <span class="player-club-name text-muted">—</span>
                }
            </div>

            <!-- Ações -->
            <div class="player-actions">
                <a asp-action="Details" asp-route-id="@treinador.Id" class="btn btn-outline-primary btn-sm cf-small-btn">Detalhes</a>
                <a asp-action="Edit" asp-route-id="@treinador.Id" class="btn btn-warning btn-sm cf-small-btn">Editar</a>
                <a asp-action="Delete" asp-route-id="@treinador.Id" class="btn btn-danger btn-sm cf-small-btn">Excluir</a>
                <a asp-action="ConsultarHistorico" asp-route-id="@treinador.Id" class="btn btn-outline-info btn-sm cf-small-btn">📊 Histórico</a>
                <form asp-action="BuscarFoto" asp-route-id="@treinador.Id" method="post" style="display:inline;">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="page" value="@paginaAtual" />
                    @foreach (var cid in compSel)
                    {
                        <input type="hidden" name="competicaoIds" value="@cid" />
                    }
                    @foreach (var tid in timeSel)
                    {
                        <input type="hidden" name="timeIds" value="@tid" />
                    }
                    @foreach (var nn in nacSel)
                    {
                        <input type="hidden" name="nacionalidades" value="@nn" />
                    }
                    <button type="submit" class="btn btn-outline-success btn-sm cf-small-btn"
                            title="Atualizar nacionalidade, idade e foto pela API"
                            onclick="return confirm('Atualizar informações de @treinador.Nome pela API?')">
                        🔄 Atualizar Informações
                    </button>
                </form>
            </div>
        </div>
    }
</div>

@if (totalPaginas > 1)
{
    int janela = 2;
    int inicio = Math.Max(1, paginaAtual - janela);
    int fim = Math.Min(totalPaginas, paginaAtual + janela);

    <nav aria-label="Paginação de treinadores" style="margin-top:14px;">
        <ul class="pagination justify-content-center flex-wrap">
            <li class="page-item @(paginaAtual <= 1 ? "disabled" : "")">
                <a class="page-link" href="@linkPagina(paginaAtual - 1)">«</a>
            </li>

            @if (inicio > 1)
            {
                <li class="page-item"><a class="page-link" href="@linkPagina(1)">1</a></li>
                @if (inicio > 2)
                {
                    <li class="page-item disabled"><span class="page-link">…</span></li>
                }
            }

            @for (int p = inicio; p <= fim; p++)
            {
                <li class="page-item @(p == paginaAtual ? "active" : "")">
                    <a class="page-link" href="@linkPagina(p)">@p</a>
                </li>
            }

            @if (fim < totalPaginas)
            {
                @if (fim < totalPaginas - 1)
                {
                    <li class="page-item disabled"><span class="page-link">…</span></li>
                }
                <li class="page-item"><a class="page-link" href="@linkPagina(totalPaginas)">@totalPaginas</a></li>
            }

            <li class="page-item @(paginaAtual >= totalPaginas ? "disabled" : "")">
                <a class="page-link" href="@linkPagina(paginaAtual + 1)">»</a>
            </li>
        </ul>
    </nav>
}
