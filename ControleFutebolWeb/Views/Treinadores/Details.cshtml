@model ControleFutebolWeb.Models.Treinador
@{
    ViewData["Title"] = $"Detalhes — {Model.Nome}";
}

<div class="estat-page">
    <div class="container" style="max-width:860px;">

        <a href="javascript:history.back()" class="btn-voltar">← Voltar</a>

        <!-- Header -->
        <div class="jogador-header">
            @if (!string.IsNullOrWhiteSpace(Model.FotoUrl))
            {
                <img src="@Model.FotoUrl" class="jogador-foto" />
            }
            else
            {
                <img src="/images/placeholder-treinador.png" class="jogador-foto" />
            }

            <div>
                <h1 class="jogador-nome">@Model.Nome</h1>
                <div class="jogador-meta">
                    <span>📅 @Model.Idade anos</span>
                    @if (Model.Time != null)
                    {
                        <span>🏟️ @Model.Time.Nome</span>
                    }
                    @if (Model.Nacionalidade != null)
                    {
                        <span>🌍 @Model.Nacionalidade.Nome</span>
                    }
                </div>
            </div>
        </div>

        <!-- Histórico atual -->
        <div class="jogos-titulo">Histórico no Banco</div>
        @if (!Model.Historicos.Any())
        {
            <div class="sem-dados">Nenhum histórico salvo ainda.</div>
        }
        else
        {
            foreach (var h in Model.Historicos)
            {
                <div class="jogo-item">
                    <div>
                        <div class="jogo-adversario">@h.Time.Nome</div>
                        <div class="jogo-data">
                            @h.DtInicio.ToString("dd/MM/yyyy")
                            até @(h.DtFim != null ? h.DtFim.Value.ToString("dd/MM/yyyy") : "Atual")
                        </div>
                    </div>
                </div>
            }
        }

        <!-- Ações -->
        <div class="cf-card-actions" style="margin-top:1rem;">
            <form asp-action="BuscarFoto" asp-route-id="@Model.Id" method="post" style="display:inline;">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-outline-secondary btn-sm cf-small-btn"
                        title="Buscar foto"
                        onclick="return confirm('Buscar foto de @Model.Nome ?')">
                    📷 Buscar Foto
                </button>
            </form>

            <a asp-action="PreVisualizarHistorico" asp-route-id="@Model.Id"
               class="btn btn-primary btn-sm cf-small-btn">
                📊 Importar Histórico (nome + time)
            </a>

            <form asp-action="PreVisualizarHistoricoUrl" method="get" style="display:inline;">
                <input type="hidden" name="id" value="@Model.Id" />
                <input type="text" name="url" placeholder="URL Transfermarkt" style="width:280px;" />
                <button type="submit" class="btn btn-outline-primary btn-sm cf-small-btn">
                    🔗 Importar por URL
                </button>
            </form>
        </div>
    </div>
</div>
