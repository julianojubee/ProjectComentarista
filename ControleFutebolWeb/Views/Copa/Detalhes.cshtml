@model ControleFutebolWeb.Models.Competicao

<h2>@Model.Nome (@Model.Regiao)</h2>

@if (TempData["Sucesso"] != null)
{
    <div class="alert alert-success">@TempData["Sucesso"]</div>
}
@if (TempData["Aviso"] != null)
{
    <div class="alert alert-warning">@TempData["Aviso"]</div>
}
@if (TempData["Erro"] != null)
{
    <div class="alert alert-danger">@TempData["Erro"]</div>
}

<h4>Jogos</h4>
<div class="table-responsive">
<table class="table table-bordered">
    <thead>
        <tr>
            <th>Data</th>
            <th>Casa</th>
            <th>Visitante</th>
            <th>Placar</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var jogo in Model.Jogos)
        {
            <tr>
                <td>@ControleFutebolWeb.Helpers.DateHelper.FormatarData(jogo.Data, "dd/MM/yyyy HH:mm")</td>
                <td>@jogo.TimeCasa?.Nome</td>
                <td>@jogo.TimeVisitante?.Nome</td>
                <td>
                    @(jogo.PlacarCasa.HasValue ? $"{jogo.PlacarCasa} x {jogo.PlacarVisitante}" : "-")
                    @if (jogo.PenaltisCasa.HasValue && jogo.PenaltisVisitante.HasValue)
                    {
                        <span class="text-muted">(@jogo.PenaltisCasa-@jogo.PenaltisVisitante pên.)</span>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>
</div>
