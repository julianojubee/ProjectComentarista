@model List<ControleFutebolWeb.Models.Transferencia>
@using ControleFutebolWeb.Helpers

@{
    ViewData["Title"] = "Janela de Transferências";
}

<style>
    .trf-page {
        background: #0f172a;
        min-height: 100vh;
        color: #f1f5f9;
        padding: 2rem 1rem 4rem;
    }

    .trf-wrap { max-width: 980px; margin: 0 auto; }

    .trf-titulo {
        font-size: 1.6rem;
        font-weight: 800;
        letter-spacing: .5px;
        margin-bottom: .3rem;
    }

    .trf-sub {
        color: #94a3b8;
        font-size: .85rem;
        margin-bottom: 1.4rem;
    }

    .trf-filtros {
        background: #1e293b;
        border: 1px solid #334155;
        border-radius: 12px;
        padding: .9rem 1rem;
        display: flex;
        gap: .6rem;
        flex-wrap: wrap;
        align-items: center;
        margin-bottom: 1.2rem;
    }

        .trf-filtros select,
        .trf-filtros input {
            background: #0f172a;
            border: 1px solid #334155;
            color: #e2e8f0;
            border-radius: 8px;
            padding: .4rem .6rem;
            font-size: .85rem;
        }

    .trf-card {
        background: #1e293b;
        border: 1px solid #334155;
        border-radius: 12px;
        padding: .8rem 1.1rem;
        margin-bottom: .55rem;
        display: flex;
        align-items: center;
        gap: 1rem;
        flex-wrap: wrap;
    }

    .trf-data {
        flex: 0 0 82px;
        color: #94a3b8;
        font-size: .78rem;
    }

    .trf-jogador {
        flex: 1 1 180px;
        display: flex;
        align-items: center;
        gap: .6rem;
        min-width: 0;
    }

        .trf-jogador img {
            width: 34px;
            height: 34px;
            border-radius: 50%;
            object-fit: cover;
            border: 1px solid #334155;
            background: #0f172a;
        }

    .trf-jogador-nome {
        font-weight: 700;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .trf-jogador-pos {
        font-size: .72rem;
        color: #94a3b8;
    }

    .trf-fluxo {
        flex: 1 1 260px;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: .7rem;
    }

    .trf-time {
        display: flex;
        align-items: center;
        gap: .45rem;
        min-width: 0;
    }

        .trf-time img {
            width: 24px;
            height: 24px;
            object-fit: contain;
        }

        .trf-time span {
            font-size: .85rem;
            font-weight: 600;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            max-width: 140px;
        }

    .trf-seta {
        color: #facc15;
        font-size: 1.1rem;
        font-weight: 800;
        flex-shrink: 0;
    }

    .trf-contexto {
        flex: 0 0 auto;
        text-align: right;
        font-size: .74rem;
        color: #94a3b8;
    }

        .trf-contexto a {
            color: #60a5fa;
            text-decoration: none;
        }

    .trf-excluir {
        background: none;
        border: none;
        color: #f87171;
        font-size: .72rem;
        cursor: pointer;
        padding: 0;
        margin-top: .3rem;
        text-decoration: underline;
    }

        .trf-excluir:hover { color: #ef4444; }

    .trf-vazio {
        text-align: center;
        color: #94a3b8;
        padding: 3rem 1rem;
        background: #1e293b;
        border: 1px dashed #334155;
        border-radius: 12px;
    }
</style>

<div class="trf-page">
    <div class="trf-wrap">
        <div class="trf-titulo">🔁 Janela de Transferências</div>
        <div class="trf-sub">
            Trocas de clube detectadas automaticamente: quando um jogador já cadastrado para um
            time aparece na escalação de outro clube, ele é transferido e a movimentação fica
            registrada aqui. Seleções nacionais não contam como transferência.
        </div>

        @if (TempData["Sucesso"] != null)
        {
            <div style="background:rgba(34,197,94,.12); color:#4ade80; border:1px solid rgba(34,197,94,.25);
                        border-radius:8px; padding:.7rem 1rem; margin-bottom:1rem; font-size:.88rem;">
                ✅ @TempData["Sucesso"]
            </div>
        }
        @if (TempData["Erro"] != null)
        {
            <div style="background:rgba(239,68,68,.12); color:#f87171; border:1px solid rgba(239,68,68,.25);
                        border-radius:8px; padding:.7rem 1rem; margin-bottom:1rem; font-size:.88rem;">
                ⚠️ @TempData["Erro"]
            </div>
        }

        <!-- ── Transferência manual ── -->
        <div class="trf-filtros" style="flex-direction:column; align-items:stretch; gap:.5rem;">
            <div style="display:flex; align-items:center; justify-content:space-between; cursor:pointer;"
                 onclick="const f = document.getElementById('formTrfManual'); f.style.display = f.style.display === 'none' ? '' : 'none';">
                <span style="font-weight:700; font-size:.9rem;">➕ Transferência manual</span>
                <span style="font-size:.75rem; color:#94a3b8;">
                    para quando você não quer esperar o jogador aparecer escalado num jogo
                </span>
            </div>
            <form id="formTrfManual" method="post" asp-action="TransferirManual"
                  style="display:none; gap:.6rem; flex-wrap:wrap; align-items:center;"
                  onsubmit="return confirm('Confirmar a transferência do jogador selecionado?');">
                @Html.AntiForgeryToken()
                <input type="text" id="buscaJogadorManual" placeholder="Digite para filtrar jogadores…"
                       style="flex:1 1 200px; min-width:180px;"
                       oninput="filtrarJogadoresManual(this.value)" />
                <select name="jogadorId" id="selJogadorManual" required style="flex:1 1 240px; min-width:200px;">
                    <option value="">Selecione o jogador…</option>
                    @foreach (var j in ViewBag.JogadoresManual)
                    {
                        <option value="@j.Id">@j.Rotulo</option>
                    }
                </select>
                <span class="trf-seta">→</span>
                <select name="timeDestinoId" required style="flex:1 1 180px; min-width:160px;">
                    <option value="">Clube de destino…</option>
                    @foreach (var item in (Microsoft.AspNetCore.Mvc.Rendering.SelectList)ViewBag.TimesDestino)
                    {
                        <option value="@item.Value">@item.Text</option>
                    }
                </select>
                <button type="submit" class="btn btn-warning btn-sm" style="font-weight:700;">Transferir</button>
            </form>
        </div>

        <form method="get" class="trf-filtros">
            <select name="timeId" onchange="this.form.submit()">
                <option value="">Todos os times</option>
                @foreach (var item in (Microsoft.AspNetCore.Mvc.Rendering.SelectList)ViewBag.Times)
                {
                    <option value="@item.Value" selected="@item.Selected">@item.Text</option>
                }
            </select>
            <select name="competicaoId" onchange="this.form.submit()">
                <option value="">Todas as competições</option>
                @foreach (var item in (Microsoft.AspNetCore.Mvc.Rendering.SelectList)ViewBag.Competicoes)
                {
                    <option value="@item.Value" selected="@item.Selected">@item.Text</option>
                }
            </select>
            <input type="text" name="jogador" value="@ViewBag.FiltroJogador"
                   placeholder="Buscar jogador…" style="flex:1; min-width:160px;" />
            <button type="submit" class="btn btn-primary btn-sm">Filtrar</button>
            @if (ViewBag.FiltroTimeId != null || ViewBag.FiltroCompeticaoId != null || !string.IsNullOrEmpty((string?)ViewBag.FiltroJogador))
            {
                <a href="@Url.Action("Index")" class="btn btn-outline-secondary btn-sm">Limpar</a>
            }
        </form>

        @if (!Model.Any())
        {
            <div class="trf-vazio">
                Nenhuma transferência registrada ainda.<br />
                <span style="font-size:.8rem;">
                    As transferências passam a ser registradas automaticamente quando um jogador
                    aparece escalado por um clube diferente do atual em uma importação de jogo.
                </span>
            </div>
        }
        else
        {
            foreach (var t in Model)
            {
                <div class="trf-card">
                    <div class="trf-data">@t.Data.ToString("dd/MM/yyyy")</div>

                    <div class="trf-jogador">
                        <img src="@(string.IsNullOrEmpty(t.Jogador.FotoUrl) ? "/images/placeholder-jogador.png" : Url.FotoSrc(t.Jogador.FotoUrl))"
                             onerror="this.src='/images/placeholder-jogador.png'" alt="" />
                        <div style="min-width:0;">
                            <div class="trf-jogador-nome">
                                <a href="@Url.Action("Estatisticas", "Jogadores", new { id = t.JogadorId })"
                                   style="color:inherit; text-decoration:none;">@t.Jogador.NomeExibicao</a>
                            </div>
                            <div class="trf-jogador-pos">@t.Jogador.Posicao</div>
                        </div>
                    </div>

                    <div class="trf-fluxo">
                        <div class="trf-time">
                            @if (!string.IsNullOrEmpty(t.TimeOrigem?.EscudoUrl))
                            {
                                <img src="@Url.Action("Imagem", "MediaProxy", new { url = t.TimeOrigem.EscudoUrl })" alt="" />
                            }
                            <span>@(t.TimeOrigem?.Nome ?? "—")</span>
                        </div>
                        <span class="trf-seta">→</span>
                        <div class="trf-time">
                            @if (!string.IsNullOrEmpty(t.TimeDestino?.EscudoUrl))
                            {
                                <img src="@Url.Action("Imagem", "MediaProxy", new { url = t.TimeDestino.EscudoUrl })" alt="" />
                            }
                            <span>@t.TimeDestino?.Nome</span>
                        </div>
                    </div>

                    <div class="trf-contexto">
                        @if (t.Jogo != null)
                        {
                            <div>@(t.Jogo.Competicao?.Nome ?? "")</div>
                            <a href="@Url.Action("Analisar", "Jogos", new { id = t.JogoId })">ver jogo →</a>
                        }
                        else
                        {
                            <div style="color:#facc15;">manual</div>
                            @if (t.UsuarioId != null && t.UsuarioId == (string?)ViewBag.UsuarioAtualId)
                            {
                                <form method="post" asp-action="Excluir" asp-route-id="@t.Id"
                                      onsubmit="return confirm('Excluir esta transferência? Se o jogador ainda estiver em @t.TimeDestino?.Nome, ele volta para @(t.TimeOrigem?.Nome ?? "o clube anterior").');">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="trf-excluir">excluir</button>
                                </form>
                            }
                        }
                    </div>
                </div>
            }
        }
    </div>
</div>

<script>
    // Filtro client-side do select de jogadores da transferência manual
    function filtrarJogadoresManual(termo) {
        const sel = document.getElementById('selJogadorManual');
        const t = (termo || '').toLowerCase();
        for (const opt of sel.options) {
            if (!opt.value) continue; // placeholder sempre visível
            opt.hidden = t.length > 0 && !opt.text.toLowerCase().includes(t);
        }
        // Se a seleção atual ficou escondida, volta pro placeholder
        if (sel.selectedOptions[0]?.hidden) sel.value = '';
    }
</script>
