@model List<ControleFutebolWeb.Models.CriterioNota>
@{
    ViewData["Title"] = "Critérios de Nota";
}

<style>
    .cn-hero {
        position: relative;
        border-radius: 14px;
        padding: 1.5rem 1.6rem;
        margin-bottom: 1.5rem;
        background: linear-gradient(135deg, #1e3a5f 0%, #2d5f9e 60%, #1a3355 100%);
        overflow: hidden;
    }
    .cn-hero::before {
        content: "";
        position: absolute;
        inset: 0;
        background: radial-gradient(circle at 80% 50%, rgba(255,255,255,0.06) 0%, transparent 60%);
    }
    .cn-hero-content { position: relative; z-index: 1; }
    .cn-hero-badge {
        display: inline-block;
        background: rgba(255,255,255,0.15);
        color: #c7d9f5;
        font-size: 10px;
        font-weight: 700;
        letter-spacing: 0.8px;
        text-transform: uppercase;
        padding: 3px 10px;
        border-radius: 999px;
        margin-bottom: 0.5rem;
    }
    .cn-hero h1 { color: #fff; font-size: 1.4rem; font-weight: 700; margin: 0 0 0.2rem; }
    .cn-hero p { color: rgba(255,255,255,0.75); font-size: 0.9rem; margin: 0; }

    .cn-card {
        background: var(--color-background-primary);
        border: 0.5px solid var(--color-border-tertiary);
        border-radius: var(--border-radius-lg);
        overflow: hidden;
    }
    .cn-card-header {
        padding: 0.875rem 1.25rem;
        border-bottom: 0.5px solid var(--color-border-tertiary);
        display: flex;
        align-items: center;
        justify-content: space-between;
        background: var(--color-background-secondary);
    }
    .cn-card-title {
        font-size: 13px;
        font-weight: 500;
        color: var(--color-text-primary);
        display: flex;
        align-items: center;
        gap: 6px;
    }

    .cn-table { width: 100%; border-collapse: collapse; font-size: 13px; }
    .cn-table thead th {
        padding: 0.5rem 0.75rem;
        font-size: 11px;
        font-weight: 500;
        color: var(--color-text-secondary);
        text-align: left;
        border-bottom: 0.5px solid var(--color-border-tertiary);
        background: var(--color-background-secondary);
        white-space: nowrap;
    }
    .cn-table tbody td {
        padding: 0.6rem 0.75rem;
        border-bottom: 0.5px solid var(--color-border-tertiary);
        color: var(--color-text-primary);
        vertical-align: middle;
    }
    .cn-table tbody tr:last-child td { border-bottom: none; }
    .cn-table tbody tr:hover td { background: var(--color-background-secondary); }

    .cn-peso-pos { color: var(--color-text-success); font-weight: 600; }
    .cn-peso-neg { color: var(--color-text-danger); font-weight: 600; }
    .cn-peso-zer { color: var(--color-text-secondary); font-weight: 600; }

    .cn-badge-ativo {
        display: inline-block;
        padding: 2px 8px;
        border-radius: 20px;
        font-size: 11px;
        font-weight: 500;
        background: var(--color-background-success);
        color: var(--color-text-success);
    }
    .cn-badge-inativo {
        display: inline-block;
        padding: 2px 8px;
        border-radius: 20px;
        font-size: 11px;
        font-weight: 500;
        background: var(--color-background-secondary);
        color: var(--color-text-secondary);
    }

    .cn-btn-sm {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        padding: 4px 10px;
        border-radius: 6px;
        font-size: 12px;
        font-weight: 500;
        border: 0.5px solid var(--color-border-tertiary);
        background: var(--color-background-secondary);
        color: var(--color-text-primary);
        cursor: pointer;
        text-decoration: none;
        transition: background 0.15s;
    }
    .cn-btn-sm:hover { background: var(--color-background-tertiary); color: var(--color-text-primary); }
    .cn-btn-danger { border-color: #fca5a5; background: #fef2f2; color: #b91c1c; }
    .cn-btn-danger:hover { background: #fee2e2; color: #b91c1c; }
    .cn-btn-primary {
        background: #1e3a5f;
        color: #fff;
        border-color: #1e3a5f;
    }
    .cn-btn-primary:hover { background: #2d5f9e; color: #fff; }

    .cn-alert {
        padding: 0.75rem 1rem;
        border-radius: 8px;
        font-size: 13px;
        margin-bottom: 1rem;
        background: var(--color-background-success);
        color: var(--color-text-success);
        border: 0.5px solid var(--color-border-success, #86efac);
    }

    .cn-acaoid {
        font-family: monospace;
        font-size: 12px;
        background: var(--color-background-secondary);
        padding: 2px 6px;
        border-radius: 4px;
        color: var(--color-text-secondary);
    }
</style>

<div style="padding: 0.5rem 0 2rem">

    @if (TempData["Sucesso"] != null)
    {
        <div class="cn-alert">@TempData["Sucesso"]</div>
    }

    <div class="cn-hero">
        <div class="cn-hero-content">
            <span class="cn-hero-badge">Configuração</span>
            <h1>Critérios de Nota</h1>
            <p>Defina os pesos de cada ação usados na avaliação dos jogadores.</p>
        </div>
    </div>

    <div class="cn-card">
        <div class="cn-card-header">
            <span class="cn-card-title">
                <i class="ti ti-adjustments-horizontal" style="font-size:15px"></i>
                @Model.Count critério(s) cadastrado(s)
            </span>
            <a href="@Url.Action("Create")" class="cn-btn-sm cn-btn-primary">
                <i class="ti ti-plus" style="font-size:13px"></i>
                Novo Critério
            </a>
        </div>

        @{
            var acoesPersonalizadas = (HashSet<string>)(ViewBag.AcoesPersonalizadas ?? new HashSet<string>());
            var overrideIds = (Dictionary<string, int>)(ViewBag.OverrideIds ?? new Dictionary<string, int>());
        }
        <table class="cn-table">
            <thead>
                <tr>
                    <th style="width:40px">Ordem</th>
                    <th>Label</th>
                    <th>ID de Ação</th>
                    <th style="width:90px;text-align:center">Peso</th>
                    <th style="width:80px;text-align:center">Status</th>
                    <th style="text-align:right">Ações</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var c in Model)
                {
                    bool personalizado = acoesPersonalizadas.Contains(c.AcaoId);
                    bool customCriado = personalizado && !overrideIds.ContainsKey(c.AcaoId) == false && c.Id > 0;
                    <tr>
                        <td style="color:var(--color-text-secondary);text-align:center">@c.Ordem</td>
                        <td style="font-weight:500">
                            @c.Label
                            @if (personalizado)
                            {
                                <span style="font-size:10px;font-weight:600;background:#fef3c7;color:#92400e;padding:2px 7px;border-radius:20px;margin-left:6px;">Personalizado</span>
                            }
                        </td>
                        <td><span class="cn-acaoid">@c.AcaoId</span></td>
                        <td style="text-align:center">
                            <span class="@(c.Peso > 0 ? "cn-peso-pos" : c.Peso < 0 ? "cn-peso-neg" : "cn-peso-zer")">
                                @(c.Peso > 0 ? "+" : "")@c.Peso
                            </span>
                        </td>
                        <td style="text-align:center">
                            <span class="@(c.Ativo ? "cn-badge-ativo" : "cn-badge-inativo")">
                                @(c.Ativo ? "Ativo" : "Inativo")
                            </span>
                        </td>
                        <td style="text-align:right">
                            <div style="display:flex;gap:6px;justify-content:flex-end">
                                <a href="@Url.Action("Edit", new { acaoId = c.AcaoId })" class="cn-btn-sm">
                                    <i class="ti ti-edit" style="font-size:12px"></i>
                                    Ajustar peso
                                </a>
                                @if (personalizado)
                                {
                                    <form method="post" asp-action="Resetar" style="display:inline"
                                          onsubmit="return confirm('Resetar \'@c.Label\' para o padrão?')">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="acaoId" value="@c.AcaoId" />
                                        <button type="submit" class="cn-btn-sm cn-btn-danger">
                                            <i class="ti ti-refresh" style="font-size:12px"></i>
                                            Resetar
                                        </button>
                                    </form>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div style="margin-top:1rem; padding:0.75rem 1rem; background:var(--color-background-secondary); border-radius:8px; font-size:12px; color:var(--color-text-secondary);">
        <strong>Como funciona:</strong> O peso de cada critério é multiplicado pela quantidade registrada na avaliação de cada jogador.
        Pesos positivos somam pontos; negativos subtraem.
        Critérios <em>inativos</em> não aparecem na avaliação manual nem são usados no cálculo automático.
    </div>
</div>
