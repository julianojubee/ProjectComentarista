@model List<ControleFutebolWeb.Models.CriterioNota>
@{
    ViewData["Title"] = "Critérios de Nota";

    var acoesPersonalizadas = (HashSet<string>)(ViewBag.AcoesPersonalizadas ?? new HashSet<string>());
    var acaoIdsCompartilhados = (HashSet<string>)(ViewBag.AcaoIdsCompartilhados ?? new HashSet<string>());
}

<style>
    .cn-root, .cn-root *, .cn-root *::before, .cn-root *::after { box-sizing: border-box; }

    .cn-root {
        margin: 0 -12px;
        background: #0f0f0f;
        border-radius: 14px;
        overflow: hidden;
        color: #e5e7eb;
        font-family: 'Barlow', Arial, sans-serif;
    }
    .cn-root a { text-decoration: none; color: inherit; }

    /* ── Hero ── */
    .cn-hero {
        position: relative; overflow: hidden;
        background: linear-gradient(135deg, #0a0f1a 0%, #111827 55%, #0a0f1a 100%);
        padding: 40px 2.5rem 34px;
    }
    .cn-hero-pattern { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; opacity: 0.04; pointer-events: none; }
    .cn-hero-stripe { position: absolute; left: 0; top: 0; bottom: 0; width: 4px; background: #d4a520; }
    .cn-hero-fade { position: absolute; bottom: 0; left: 0; right: 0; height: 50px; background: linear-gradient(to top, #0f0f0f, transparent); pointer-events: none; }
    .cn-hero-inner { position: relative; z-index: 1; display: flex; align-items: flex-end; justify-content: space-between; gap: 24px; flex-wrap: wrap; }
    .cn-hero-kicker { display: flex; align-items: center; gap: 10px; margin-bottom: 12px; }
    .cn-hero-kicker-line { height: 2px; width: 28px; background: #d4a520; }
    .cn-hero-kicker span { font-size: .68rem; font-weight: 700; letter-spacing: .28em; color: #d4a520; text-transform: uppercase; }
    .cn-hero h1 { font-family: 'Barlow Condensed', Arial, sans-serif; font-size: 3rem; font-weight: 800; color: #f1f5f9; margin: 0 0 8px; line-height: 1; }
    .cn-hero p { font-size: .9rem; color: #6b7280; margin: 0; max-width: 480px; }
    .cn-btn-novo {
        display: flex; align-items: center; gap: 7px; padding: 9px 16px;
        background: rgba(168,85,247,0.12); border: 1px solid rgba(168,85,247,0.3); border-radius: 8px;
        color: #c084fc; font-size: .82rem; font-weight: 700; flex-shrink: 0;
    }
    .cn-btn-novo:hover { background: rgba(168,85,247,0.2); color: #c084fc; }

    /* ── Banner informativo ── */
    .cn-infobar { background: rgba(212,165,32,0.06); border-bottom: 1px solid rgba(212,165,32,0.15); padding: 10px 2.5rem; }
    .cn-infobar-inner { max-width: 1400px; margin: 0 auto; display: flex; align-items: center; gap: 10px; }
    .cn-infobar span.txt { font-size: .78rem; color: #9ca3af; }
    .cn-infobar b.gold { color: #d4a520; font-weight: 700; }
    .cn-infobar b.blue { color: #60a5fa; font-weight: 700; }

    /* ── Conteúdo ── */
    .cn-content { padding: 28px 2.5rem 64px; max-width: 1200px; margin: 0 auto; }

    .cn-resumo { display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; margin-bottom: 28px; }
    @@media (max-width: 700px) { .cn-resumo { grid-template-columns: repeat(2, 1fr); } }
    .cn-resumo-card { background: #161616; border: 1px solid #262626; border-radius: 12px; padding: 16px; text-align: center; }
    .cn-resumo-val { font-family: 'Barlow Condensed', Arial, sans-serif; font-size: 2rem; font-weight: 800; line-height: 1; }
    .cn-resumo-label { font-size: .68rem; color: #4b5563; text-transform: uppercase; letter-spacing: .1em; margin-top: 4px; font-weight: 700; }

    .cn-table-wrap { background: #161616; border: 1px solid #262626; border-radius: 14px; overflow: hidden; }
    .cn-thead {
        display: grid; grid-template-columns: 1fr 90px 90px 130px 220px; gap: 12px;
        padding: 10px 20px; background: #111; border-bottom: 1px solid #1e1e1e; align-items: center;
    }
    .cn-thead span { font-size: .62rem; color: #374151; font-weight: 700; text-transform: uppercase; letter-spacing: .1em; }

    .cn-row {
        display: grid; grid-template-columns: 1fr 90px 90px 130px 220px; gap: 12px;
        padding: 11px 20px; border-bottom: 1px solid #111; align-items: center; transition: background .12s;
    }
    .cn-row:last-child { border-bottom: none; }
    .cn-row:hover { background: #1a1a1a; }

    .cn-label { font-size: .88rem; font-weight: 600; color: #f1f5f9; margin-bottom: 2px; }
    .cn-acaoid { font-size: .68rem; color: #4b5563; font-family: monospace; }

    .cn-peso { display: inline-flex; align-items: center; padding: 2px 10px; border-radius: 6px; font-size: .78rem; font-weight: 700; font-family: 'Barlow Condensed', Arial, sans-serif; }
    .cn-peso-pos { background: rgba(34,197,94,0.12); border: 1px solid rgba(34,197,94,0.3); color: #22c55e; }
    .cn-peso-neg { background: rgba(239,68,68,0.12); border: 1px solid rgba(239,68,68,0.3); color: #f87171; }
    .cn-peso-zer { background: rgba(107,114,128,0.12); border: 1px solid rgba(107,114,128,0.3); color: #9ca3af; }

    .cn-ativo { font-size: .72rem; font-weight: 700; padding: 2px 8px; border-radius: 5px; }
    .cn-ativo-sim { color: #4ade80; background: rgba(34,197,94,0.1); }
    .cn-ativo-nao { color: #6b7280; background: rgba(107,114,128,0.1); }

    .cn-origem { font-size: .68rem; font-weight: 700; padding: 2px 8px; border-radius: 5px; }
    .cn-origem-padrao { color: #60a5fa; background: rgba(59,130,246,0.1); }
    .cn-origem-override { color: #fbbf24; background: rgba(251,191,36,0.1); }
    .cn-origem-proprio { color: #c084fc; background: rgba(168,85,247,0.1); }

    .cn-actions { display: flex; align-items: center; gap: 6px; justify-content: flex-end; }
    .cn-btn-editar { font-size: .7rem; padding: 4px 10px; background: #1e1e1e; border: 1px solid #2a2a2a; border-radius: 6px; color: #9ca3af; font-weight: 600; }
    .cn-btn-editar:hover { border-color: #d4a520; color: #d4a520; }
    .cn-btn-resetar { font-size: .7rem; padding: 4px 10px; background: rgba(59,130,246,0.08); border: 1px solid rgba(59,130,246,0.22); border-radius: 6px; color: #60a5fa; font-weight: 600; cursor: pointer; }
    .cn-btn-resetar:hover { background: rgba(59,130,246,0.15); }
    .cn-btn-excluir { font-size: .7rem; padding: 4px 10px; background: rgba(239,68,68,0.08); border: 1px solid rgba(239,68,68,0.2); border-radius: 6px; color: #f87171; font-weight: 600; cursor: pointer; }
    .cn-btn-excluir:hover { background: rgba(239,68,68,0.15); }

    .cn-alert { border-radius: 8px; padding: .7rem 1rem; margin: 0 2.5rem 1rem; font-size: .88rem; background: rgba(34,197,94,.12); color: #4ade80; border: 1px solid rgba(34,197,94,.25); }
</style>

<div class="cn-root">
    <!-- ── Hero ── -->
    <div class="cn-hero">
        <img src="~/Images/banner/escudos-pattern.svg" class="cn-hero-pattern" alt="" />
        <div class="cn-hero-stripe"></div>
        <div class="cn-hero-fade"></div>
        <div class="cn-hero-inner">
            <div>
                <div class="cn-hero-kicker">
                    <div class="cn-hero-kicker-line"></div>
                    <span>Configuração</span>
                </div>
                <h1>Critérios de Nota</h1>
                <p>Configure os pesos de cada ação na avaliação automática dos jogadores. Personalize por usuário ou use os padrões compartilhados.</p>
            </div>
            <a href="@Url.Action("Create")" class="cn-btn-novo">+ Novo critério</a>
        </div>
    </div>

    <!-- ── Banner informativo ── -->
    <div class="cn-infobar">
        <div class="cn-infobar-inner">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#d4a520" stroke-width="2"><circle cx="12" cy="12" r="10" /><line x1="12" y1="8" x2="12" y2="12" /><line x1="12" y1="16" x2="12.01" y2="16" /></svg>
            <span class="txt">
                Critérios marcados com <b class="gold">⭐ Padrão</b> são compartilhados. Ao editar, você cria uma versão pessoal sem afetar outros usuários.
                Use <b class="blue">Resetar</b> para voltar ao padrão. Critérios <em>inativos</em> não aparecem na avaliação manual nem são usados no cálculo automático.
            </span>
        </div>
    </div>

    @if (TempData["Sucesso"] != null)
    {
        <div class="cn-alert">@TempData["Sucesso"]</div>
    }

    <!-- ── Conteúdo ── -->
    <div class="cn-content">

        @{
            int totalCriterios = Model.Count;
            int ativos = Model.Count(c => c.Ativo);
            int personalizadosCount = Model.Count(c => acoesPersonalizadas.Contains(c.AcaoId) && acaoIdsCompartilhados.Contains(c.AcaoId));
            int propriosCount = Model.Count(c => acoesPersonalizadas.Contains(c.AcaoId) && !acaoIdsCompartilhados.Contains(c.AcaoId));
        }

        <!-- Resumo -->
        <div class="cn-resumo">
            <div class="cn-resumo-card">
                <div class="cn-resumo-val" style="color:#94a3b8;">@totalCriterios</div>
                <div class="cn-resumo-label">Total critérios</div>
            </div>
            <div class="cn-resumo-card">
                <div class="cn-resumo-val" style="color:#4ade80;">@ativos</div>
                <div class="cn-resumo-label">Ativos</div>
            </div>
            <div class="cn-resumo-card">
                <div class="cn-resumo-val" style="color:#fbbf24;">@personalizadosCount</div>
                <div class="cn-resumo-label">Personalizados</div>
            </div>
            <div class="cn-resumo-card">
                <div class="cn-resumo-val" style="color:#c084fc;">@propriosCount</div>
                <div class="cn-resumo-label">Seus critérios</div>
            </div>
        </div>

        <!-- Tabela -->
        <div class="cn-table-wrap">
            <div class="cn-thead">
                <span>Ação / Critério</span>
                <span style="text-align:center;">Peso</span>
                <span style="text-align:center;">Ativo</span>
                <span style="text-align:center;">Origem</span>
                <span style="text-align:right;">Ações</span>
            </div>

            @foreach (var c in Model)
            {
                bool personalizado = acoesPersonalizadas.Contains(c.AcaoId) && acaoIdsCompartilhados.Contains(c.AcaoId);
                bool proprio = acoesPersonalizadas.Contains(c.AcaoId) && !acaoIdsCompartilhados.Contains(c.AcaoId);

                <div class="cn-row">
                    <div>
                        <div class="cn-label">@c.Label</div>
                        <div class="cn-acaoid">@c.AcaoId</div>
                    </div>

                    <div style="text-align:center;">
                        <span class="cn-peso @(c.Peso > 0 ? "cn-peso-pos" : c.Peso < 0 ? "cn-peso-neg" : "cn-peso-zer")">
                            @(c.Peso > 0 ? "+" : "")@c.Peso.ToString("0.00")
                        </span>
                    </div>

                    <div style="text-align:center;">
                        <span class="cn-ativo @(c.Ativo ? "cn-ativo-sim" : "cn-ativo-nao")">@(c.Ativo ? "✓ Sim" : "✗ Não")</span>
                    </div>

                    <div style="text-align:center;">
                        @if (personalizado)
                        {
                            <span class="cn-origem cn-origem-override">✏ Seu override</span>
                        }
                        else if (proprio)
                        {
                            <span class="cn-origem cn-origem-proprio">👤 Seu critério</span>
                        }
                        else
                        {
                            <span class="cn-origem cn-origem-padrao">⭐ Padrão</span>
                        }
                    </div>

                    <div class="cn-actions">
                        <a href="@Url.Action("Edit", new { acaoId = c.AcaoId })" class="cn-btn-editar">Editar</a>
                        @if (personalizado)
                        {
                            <form method="post" asp-action="Resetar" style="display:inline;"
                                  onsubmit="return confirm('Resetar \'@c.Label\' para o padrão?')">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="acaoId" value="@c.AcaoId" />
                                <button type="submit" class="cn-btn-resetar">Resetar</button>
                            </form>
                        }
                        @if (proprio)
                        {
                            <form method="post" asp-action="Delete" style="display:inline;"
                                  onsubmit="return confirm('Excluir o critério \'@c.Label\'?')">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@c.Id" />
                                <button type="submit" class="cn-btn-excluir">Excluir</button>
                            </form>
                        }
                    </div>
                </div>
            }
        </div>

    </div>
</div>
