    // Extrai só a letra do grupo para exibição ("Grupo A" → "A", "A" → "A")
    string LetraGrupo(string? g)
    {
        if (string.IsNullOrWhiteSpace(g)) return "";
        var tokens = g.Trim().ToUpperInvariant()
                      .Split(new[] { ' ', '_' }, StringSplitOptions.RemoveEmptyEntries);
        var last = tokens[tokens.Length - 1];
        return last.Length == 1 && char.IsLetter(last[0]) ? last : g.Trim().ToUpperInvariant();
    }
}

