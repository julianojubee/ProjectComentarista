        /* Card de confronto */
        .bkt-match {
            width: 100%; background: #fff; border: 1px solid #e5e7eb; border-radius: 10px;
            overflow: hidden; box-shadow: 0 1px 3px rgba(0,0,0,.04); position: relative; z-index: 1;
        }
        .bkt-match.done { border-color: #bbf7d0; }
        .bkt-match-no {
            display: flex; justify-content: space-between; align-items: center;
            background: linear-gradient(90deg,#006400,#228B22); color: #fde68a;
            font-size: 9px; font-weight: 700; padding: 3px 8px; letter-spacing: .3px;
        }
        .bkt-team {
            display: flex; align-items: center; gap: 6px; padding: 6px 8px;
            border-bottom: 1px solid #f3f4f6;
        }
        .bkt-team:last-of-type { border-bottom: none; }
        .bkt-team img { width: 20px; height: 20px; object-fit: contain; border-radius: 50%; border: .5px solid #e5e7eb; background: #f9f9f9; flex-shrink: 0; }
        .bkt-flag-ph { width: 20px; height: 20px; border-radius: 50%; background: repeating-linear-gradient(45deg,#f3f4f6,#f3f4f6 4px,#e5e7eb 4px,#e5e7eb 8px); flex-shrink: 0; }
        .bkt-tname { flex: 1; min-width: 0; font-size: 12px; font-weight: 600; color: #111827; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
        .bkt-tname.placeholder { font-weight: 500; font-style: italic; color: #9ca3af; }
        .bkt-tname.prov { color: #6b7280; }
        .bkt-team.win .bkt-tname { color: #15803d; }
        .bkt-team.win { background: rgba(34,139,34,.06); }
        .bkt-score { font-size: 13px; font-weight: 800; color: #111827; min-width: 18px; text-align: center; flex-shrink: 0; }
        .bkt-foot {
            display: flex; justify-content: space-between; align-items: center; gap: 6px;
            padding: 4px 8px; border-top: 1px solid #f3f4f6; background: #fafafa;
        }
        .bkt-date { font-size: 9px; color: #9ca3af; }
        .bkt-analisar {
            font-size: 9px; padding: 2px 8px; border-radius: 5px; border: 1px solid #15803d;
            color: #15803d; background: transparent; text-decoration: none; font-weight: 700;
            transition: background .15s,color .15s; white-space: nowrap;
        }
        .bkt-analisar:hover { background: #15803d; color: #fff; text-decoration: none; }

        /* Conectores — lado esquerdo (linhas saem à direita) */
        .bkt-left .bkt-col:not(.bkt-sf) .bkt-cell::after {
            content: ''; position: absolute; top: 50%; right: 0;
            width: var(--bkt-gap); height: 2px; background: var(--bkt-line);
            transform: translate(100%,-50%);
        }
        .bkt-left .bkt-col:not(.bkt-sf) .bkt-cell:nth-child(odd)::before {
            content: ''; position: absolute; top: 50%; right: calc(-1 * var(--bkt-gap));
            width: 2px; height: 100%; background: var(--bkt-line);
        }
        /* Conectores — lado direito (linhas saem à esquerda) */
        .bkt-right .bkt-col:not(.bkt-sf) .bkt-cell::after {
            content: ''; position: absolute; top: 50%; left: 0;
            width: var(--bkt-gap); height: 2px; background: var(--bkt-line);
            transform: translate(-100%,-50%);
        }
        .bkt-right .bkt-col:not(.bkt-sf) .bkt-cell:nth-child(odd)::before {
            content: ''; position: absolute; top: 50%; left: calc(-1 * var(--bkt-gap));
            width: 2px; height: 100%; background: var(--bkt-line);
        }
        /* Semifinais → Final (stubs apontando ao centro) */
        .bkt-left .bkt-sf .bkt-cell::after {
            content: ''; position: absolute; top: 50%; right: 0;
            width: calc(var(--bkt-gap) + 8px); height: 2px; background: var(--bkt-line);
            transform: translate(100%,-50%);
        }
        .bkt-right .bkt-sf .bkt-cell::after {
            content: ''; position: absolute; top: 50%; left: 0;
            width: calc(var(--bkt-gap) + 8px); height: 2px; background: var(--bkt-line);
            transform: translate(-100%,-50%);
        }

        /* Centro: Final + disputa de 3º lugar */
        .bkt-center { width: var(--bkt-w); display: flex; flex-direction: column; }
        .bkt-center .bkt-col-label { color: #b45309; }
        .bkt-final-wrap { flex: 1; display: flex; flex-direction: column; justify-content: center; align-items: center; gap: 8px; }
        .bkt-center .bkt-cell { flex: 0 0 auto; min-height: 0; width: 100%; }
        .bkt-trophy { font-size: 30px; line-height: 1; filter: drop-shadow(0 2px 6px rgba(0,0,0,.2)); }
        .bkt-final-cell .bkt-match { border-color: #fbbf24; box-shadow: 0 2px 10px rgba(251,191,36,.25); }
        .bkt-final-cell .bkt-match-no { background: linear-gradient(90deg,#b45309,#f59e0b); color: #fff; }
        .bkt-bronze-label { font-size: 10px; font-weight: 700; color: #b45309; text-transform: uppercase; letter-spacing: .5px; margin-top: 4px; }
        .bkt-bronze-cell .bkt-match-no { background: linear-gradient(90deg,#92400e,#d97706); }

        @@media (max-width: 700px) {
            .bkt-tree { --bkt-w: 168px; --bkt-gap: 26px; }
        }

        /* ── Aba Seleção (campinho + escolha por posição) ───────────── */
        .sel-bar { display:flex; align-items:center; gap:10px; flex-wrap:wrap; margin-bottom:14px; }
        .sel-bar label { font-size:13px; font-weight:600; color:#374151; }
        .sel-bar select { padding:7px 10px; border-radius:8px; border:1px solid #d1d5db; font-size:13px; }
        .sel-nome { padding:7px 10px; border-radius:8px; border:1px solid #d1d5db; font-size:13px; min-width:150px; }
        .sel-save { padding:8px 16px; border:none; border-radius:8px; background:#16a34a; color:#fff; font-weight:600; font-size:13px; cursor:pointer; }
        .sel-save:hover { background:#15803d; }
        .sel-del { padding:8px 12px; border:1px solid #fecaca; border-radius:8px; background:#fef2f2; color:#b91c1c; font-weight:600; font-size:13px; cursor:pointer; }
        .sel-del:hover { background:#fee2e2; }
        [data-theme="dark"] .sel-nome { background:#2a2a2a; color:#e0e0e0; border-color:#444; }
        [data-theme="dark"] .sel-del { background:#3a1a1a; border-color:#7f1d1d; color:#fca5a5; }
        .sel-msg { background:#dcfce7; color:#15803d; padding:8px 12px; border-radius:8px; margin-bottom:12px; font-size:13px; }
        .sel-empty { padding:2rem; text-align:center; color:#9ca3af; font-size:14px; }
        .sel-titulo { text-align:center; font-weight:800; font-size:1.15rem; color:#111827; margin:4px 0 12px; font-family:'Barlow Condensed', sans-serif; letter-spacing:.5px; text-transform:uppercase; }
        [data-theme="dark"] .sel-titulo { color:#e5e7eb; }

        .sel-pitch {
            position:relative; width:100%; max-width:520px; margin:0 auto; aspect-ratio:2/3;
            border-radius:14px; overflow:hidden;
            background:
                repeating-linear-gradient(0deg, #1c8043 0 8.33%, #197439 8.33% 16.66%);
            border:2px solid rgba(255,255,255,.25);
        }
        .sel-pitch::before {
            content:""; position:absolute; inset:8px; border:2px solid rgba(255,255,255,.35); border-radius:8px;
        }
        .sel-pitch::after {
            content:""; position:absolute; left:8px; right:8px; top:50%; height:2px; background:rgba(255,255,255,.35);
        }
        .sel-slot { position:absolute; transform:translate(-50%,-50%); width:70px; text-align:center; cursor:pointer; z-index:2; }
        .sel-slot-photo {
            width:46px; height:46px; border-radius:50%; margin:0 auto;
            background:rgba(255,255,255,.18); border:2px solid #fff;
            display:flex; align-items:center; justify-content:center; overflow:hidden;
        }
        .sel-slot-photo img { width:100%; height:100%; object-fit:cover; }
        .sel-slot-plus { color:#fff; font-size:24px; font-weight:700; line-height:1; }
        .sel-slot-name {
            font-size:11px; color:#fff; font-weight:700; margin-top:3px;
            text-shadow:0 1px 3px rgba(0,0,0,.7); white-space:nowrap; overflow:hidden; text-overflow:ellipsis;
        }

        .sel-picker-overlay { position:fixed; inset:0; background:rgba(0,0,0,.5); display:none; z-index:1000; align-items:center; justify-content:center; padding:12px; }
        .sel-picker-overlay.open { display:flex; }
        .sel-picker-box { background:#fff; border-radius:12px; width:min(420px,94vw); max-height:80vh; display:flex; flex-direction:column; overflow:hidden; }
        .sel-picker-head { display:flex; gap:8px; padding:12px; border-bottom:1px solid #eee; }
        .sel-picker-head input { flex:1; padding:8px 10px; border:1px solid #d1d5db; border-radius:8px; font-size:14px; outline:none; }
        .sel-picker-head select { padding:8px 8px; border:1px solid #d1d5db; border-radius:8px; font-size:13px; outline:none; background:#fff; }
        [data-theme="dark"] .sel-picker-head select { background:#2a2a2a; color:#e0e0e0; border-color:#444; }
        .sel-picker-close { border:none; background:#f3f4f6; border-radius:8px; padding:0 12px; cursor:pointer; font-size:14px; }
        .sel-picker-list { overflow-y:auto; padding:6px; }
        .sel-pick-item { display:flex; align-items:center; gap:10px; padding:8px 10px; border-radius:8px; cursor:pointer; }
        .sel-pick-item:hover { background:#f3f4f6; }
        .sel-pick-remove { color:#b91c1c; font-weight:600; font-size:13px; justify-content:center; }
        .sel-pick-photo { width:34px; height:34px; border-radius:50%; background:#f3f4f6; display:flex; align-items:center; justify-content:center; overflow:hidden; flex-shrink:0; }
        .sel-pick-photo img { width:100%; height:100%; object-fit:cover; }
        .sel-pick-info { display:flex; flex-direction:column; min-width:0; }
        .sel-pick-nome { font-size:13px; font-weight:600; color:#111827; }
        .sel-pick-meta { font-size:11px; color:#6b7280; }

        [data-theme="dark"] .sel-bar label { color:#cbd5e1; }
        [data-theme="dark"] .sel-bar select { background:#2a2a2a; color:#e0e0e0; border-color:#444; }
        [data-theme="dark"] .sel-picker-box { background:#1a1a1a; }
        [data-theme="dark"] .sel-picker-head { border-bottom-color:#333; }
        [data-theme="dark"] .sel-picker-head input { background:#2a2a2a; color:#e0e0e0; border-color:#444; }
        [data-theme="dark"] .sel-picker-close { background:#333; color:#e5e7eb; }
        [data-theme="dark"] .sel-pick-item:hover { background:#202020; }
        [data-theme="dark"] .sel-pick-nome { color:#e5e7eb; }
        [data-theme="dark"] .sel-pick-photo { background:#2a2a2a; }
    </style>

    <div class="cdm-bracket">
        <div class="cdm-bracket-head">
            <h3>🏆 Fase de Grupos &amp; Mata-Mata</h3>
            <small>Selecione uma aba para ver a classificação dos grupos ou o chaveamento do mata-mata.</small>
        </div>

        <div class="cdm-tabs" role="tablist">
            @if (temGrupos)
            {
                <button type="button" class="cdm-tab active" data-cdm-tab="grupos">📊 Grupos</button>
            }
            @if (temChave)
            {
                <button type="button" class="cdm-tab @(!temGrupos ? "active" : "")" data-cdm-tab="chave">⚔️ Mata-Mata</button>
            }
            <button type="button" class="cdm-tab" data-cdm-tab="selecao">⭐ Seleção</button>
        </div>

        @if (temChave)
        {
            <div class="cdm-panel @(!temGrupos ? "active" : "")" data-cdm-panel="chave">
                <div class="bkt-legend">
                    <span><span class="bkt-leg-dot" style="background:#15803d;"></span>Vencedor / classificado</span>
                    <span><span class="bkt-leg-box prov"></span>Confronto provisório (grupos/fase em andamento)</span>
                    <span><span class="bkt-leg-box"></span>A definir</span>
                </div>

                <div class="bkt-scroll">
                    <div class="bkt-tree">
                        <!-- ── Lado esquerdo ── -->
                        <div class="bkt-side bkt-left">
                            <div class="bkt-colwrap">
                                <div class="bkt-col-label">1/16</div>
                                <div class="bkt-col bkt-r32">
                                    @foreach (var n in colR32E) { <div class="bkt-cell">@renderMatch(confrontoPorNumero[n])</div> }
                                </div>
                            </div>
                            <div class="bkt-colwrap">
                                <div class="bkt-col-label">1/8</div>
                                <div class="bkt-col bkt-r16">
                                    @foreach (var n in colR16E) { <div class="bkt-cell">@renderMatch(confrontoPorNumero[n])</div> }
                                </div>
                            </div>
                            <div class="bkt-colwrap">
                                <div class="bkt-col-label">Quartas</div>
                                <div class="bkt-col bkt-qf">
                                    @foreach (var n in colQFE) { <div class="bkt-cell">@renderMatch(confrontoPorNumero[n])</div> }
                                </div>
                            </div>
                            <div class="bkt-colwrap">
                                <div class="bkt-col-label">Semi</div>
                                <div class="bkt-col bkt-sf">
                                    @foreach (var n in colSFE) { <div class="bkt-cell">@renderMatch(confrontoPorNumero[n])</div> }
                                </div>
                            </div>
                        </div>

                        <!-- ── Centro: Final + 3º lugar ── -->
                        <div class="bkt-center">
                            <div class="bkt-col-label">Final</div>
                            <div class="bkt-final-wrap">
                                <div class="bkt-trophy">🏆</div>
                                <div class="bkt-cell bkt-final-cell">@renderMatch(confrontoPorNumero[104])</div>
                                <div class="bkt-bronze-label">Disputa de 3º Lugar</div>
                                <div class="bkt-cell bkt-bronze-cell">@renderMatch(confrontoPorNumero[103])</div>
                            </div>
                        </div>

                        <!-- ── Lado direito ── -->
                        <div class="bkt-side bkt-right">
                            <div class="bkt-colwrap">
                                <div class="bkt-col-label">Semi</div>
                                <div class="bkt-col bkt-sf">
                                    @foreach (var n in colSFD) { <div class="bkt-cell">@renderMatch(confrontoPorNumero[n])</div> }
                                </div>
                            </div>
                            <div class="bkt-colwrap">
                                <div class="bkt-col-label">Quartas</div>
                                <div class="bkt-col bkt-qf">
                                    @foreach (var n in colQFD) { <div class="bkt-cell">@renderMatch(confrontoPorNumero[n])</div> }
                                </div>
                            </div>
                            <div class="bkt-colwrap">
                                <div class="bkt-col-label">1/8</div>
                                <div class="bkt-col bkt-r16">
                                    @foreach (var n in colR16D) { <div class="bkt-cell">@renderMatch(confrontoPorNumero[n])</div> }
                                </div>
                            </div>
                            <div class="bkt-colwrap">
                                <div class="bkt-col-label">1/16</div>
                                <div class="bkt-col bkt-r32">
                                    @foreach (var n in colR32D) { <div class="bkt-cell">@renderMatch(confrontoPorNumero[n])</div> }
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }

        @if (temGrupos)
        {
            <div class="cdm-panel active" data-cdm-panel="grupos">
                <div class="lib-layout">

        <!-- Coluna esquerda: grupos -->
        <div>
            <!-- Legenda -->
            <div class="lib-legenda">
                <span><span class="lib-leg-dot" style="background:#7c3aed;"></span>Classificado (1º/2º lugar)</span>
                <span><span class="lib-leg-dot" style="background:#f59e0b;"></span>Disputa vaga (3º lugar)</span>
                <span><span class="lib-leg-dot" style="background:#d1d5db;"></span>Eliminado</span>
            </div>

            <div class="lib-grupos">
                @foreach (var grupo in grupos)
                {
                    <div class="lib-grupo-card">
                        <div class="lib-grupo-header">
                            <img src="~/images/background/copadomundo.png" alt="CopaDoMundo" />
                            Grupo @LetraGrupo(grupo.Nome)
                        </div>

                        @if (!grupo.Times.Any())
                        {
                            <div style="padding:14px;font-size:12px;color:#9ca3af;text-align:center;">
                                Nenhum jogo realizado ainda neste grupo.
                            </div>
                        }
                        else
                        {
                            <div style="overflow-x:auto;">
                            <table class="lib-table">
                                <thead>
                                    <tr>
                                        <th style="width:20px;">#</th>
                                        <th>Time</th>
                                        <th title="Jogos">J</th>
                                        <th title="Vitórias">V</th>
                                        <th title="Empates">E</th>
                                        <th title="Derrotas">D</th>
                                        <th title="Saldo de Gols">SG</th>
                                        <th title="Pontos">Pts</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var time in grupo.Times)
                                    {
                                        string posClass = time.Posicao switch
                                        {
                                            1 => "lib-pos-1",
                                            2 => "lib-pos-2",
                                            3 => "lib-pos-3",
                                            _ => "lib-pos-default"
                                        };

                                        <tr>
                                            <td>
                                                <span class="lib-pos @posClass">@time.Posicao</span>
                                            </td>
                                            <td>
                                                <div class="lib-team-cell">
                                                    @if (!string.IsNullOrEmpty(time.Time?.EscudoUrl))
                                                    {
                                                        <img src="@Url.Action("Imagem", "MediaProxy", new { url = time.Time.EscudoUrl })" alt="@time.Time.Nome" />
                                                    }
                                                    <a href="/Times/Details/@time.Time?.Id" style="color:inherit;text-decoration:none;font-size:12px;font-weight:500;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:130px;">@time.Time?.Nome</a>
                                                </div>
                                            </td>
                                            <td>@time.Jogos</td>
                                            <td>@time.Vitorias</td>
                                            <td>@time.Empates</td>
                                            <td>@time.Derrotas</td>
                                            <td>@time.SaldoGols</td>
                                            <td class="lib-pts">@time.Pontos</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                            </div>
                        }
                    </div>
                }
            </div>

            @if (terceirosColocados.Any())
            {
                <!-- Tabela de 3ºs colocados -->
                <div style="margin-top:20px;">
                    <div style="display:flex;align-items:center;gap:10px;margin-bottom:10px;">
                        <div style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:#6b7280;">🏅 Classificação dos 3ºs Colocados</div>
                        <div style="flex:1;height:1px;background:#e5e7eb;"></div>
                        <span style="font-size:10px;color:#6b7280;background:#f3f4f6;border:0.5px solid #e5e7eb;border-radius:20px;padding:2px 9px;">Os 8 melhores avançam</span>
                    </div>
                    <div style="background:#fff;border:0.5px solid #e5e7eb;border-radius:12px;overflow:hidden;">
                        <div style="background:linear-gradient(90deg,#92400e,#d97706);color:#fff;padding:8px 14px;font-size:12px;font-weight:700;display:flex;align-items:center;gap:8px;">
                            <img src="~/images/background/copadomundo.png" alt="Copa" style="width:16px;height:16px;object-fit:contain;" />
                            Melhores Terceiros Colocados — Disputa de Vagas
                        </div>
                        <div style="overflow-x:auto;">
                        <table class="lib-table">
                            <thead>
                                <tr>
                                    <th style="width:20px;">#</th>
                                    <th>Seleção</th>
                                    <th title="Grupo">Gr</th>
                                    <th title="Jogos">J</th>
                                    <th title="Vitórias">V</th>
                                    <th title="Empates">E</th>
                                    <th title="Derrotas">D</th>
                                    <th title="Gols Pró">GP</th>
                                    <th title="Gols Contra">GC</th>
                                    <th title="Saldo de Gols">SG</th>
                                    <th title="Fair Play (menor = melhor)">FP</th>
                                    <th title="Pontos">Pts</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var time in terceirosColocados)
                                {
                                    bool classificado = time.Posicao <= 8;
                                    string rowStyle = classificado ? "background:rgba(245,158,11,0.06);" : "";
                                    <tr style="@rowStyle">
                                        <td>
                                            @if (classificado)
                                            {
                                                <span class="lib-pos lib-pos-3">@time.Posicao</span>
                                            }
                                            else
                                            {
                                                <span class="lib-pos lib-pos-default">@time.Posicao</span>
                                            }
                                        </td>
                                        <td>
                                            <div class="lib-team-cell">
                                                @if (!string.IsNullOrEmpty(time.Time?.EscudoUrl))
                                                {
                                                    <img src="@Url.Action("Imagem", "MediaProxy", new { url = time.Time.EscudoUrl })" alt="@time.Time.Nome" />
                                                }
                                                <a href="/Times/Details/@time.Time?.Id" style="color:inherit;text-decoration:none;font-size:12px;font-weight:500;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:130px;">@time.Time?.Nome</a>
                                            </div>
                                        </td>
                                        <td style="font-weight:700;color:#d97706;">@time.Grupo</td>
                                        <td>@time.Jogos</td>
                                        <td>@time.Vitorias</td>
                                        <td>@time.Empates</td>
                                        <td>@time.Derrotas</td>
                                        <td>@time.GolsPro</td>
                                        <td>@time.GolsContra</td>
                                        <td>@time.SaldoGols</td>
                                        <td style="color:#6b7280;font-size:11px;">@time.FairPlay</td>
                                        <td class="lib-pts">@time.Pontos</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                        </div>
                        <div style="padding:8px 14px;font-size:10px;color:#9ca3af;border-top:0.5px solid #f3f4f6;">
                            Critérios: Pontos → Saldo de Gols → Gols Pró → Fair Play (amarelo=1pt · vermelho direto=3pt · 2º amarelo+vermelho=4pt)
                        </div>
                    </div>
                </div>
            }
        </div>

        <!-- Coluna direita: próximos jogos -->
        <div class="lib-sidebar">
            <div class="lib-sidebar-title">
                Jogos
                @if (rodadaAtual > 0)
                {
                    <span class="lib-rodada-badge">Rodada @rodadaAtual</span>
                }
            </div>

            @if (!proximosJogos.Any())
            {
                <div class="lib-empty" style="padding:1.5rem;">
                    Nenhum jogo encontrado.
                </div>
            }
            else
            {
                @foreach (var jogo in proximosJogos)
                {
                    bool realizado = jogo.PlacarCasa.HasValue && jogo.PlacarVisitante.HasValue;

                    <div class="lib-jogo-card">
                        <div class="lib-jogo-header">
                            <span>@ControleFutebolWeb.Helpers.DateHelper.FormatarData(jogo.Data, "dd/MM/yyyy HH:mm")</span>
                            @if (!string.IsNullOrEmpty(jogo.Grupo))
                            {
                                <span class="lib-grupo-tag">Grupo @LetraGrupo(jogo.Grupo)</span>
                            }
                        </div>
                        <div class="lib-jogo-body">
                            <div class="lib-jogo-teams">
                                <div class="lib-jogo-team">
                                    @if (!string.IsNullOrEmpty(jogo.TimeCasa?.EscudoUrl))
                                    {
                                        <img src="@Url.Action("Imagem", "MediaProxy", new { url = jogo.TimeCasa.EscudoUrl })" alt="@jogo.TimeCasa.Nome" />
                                    }
                                    <a href="/Times/Details/@jogo.TimeCasa?.Id" style="font-size:11px;font-weight:500;color:#374151;text-align:center;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:90px;text-decoration:none;">@jogo.TimeCasa?.Nome</a>
                                </div>

                                <div class="lib-vs">
                                    @if (realizado)
                                    {
                                        <span class="lib-score">@jogo.PlacarCasa x @jogo.PlacarVisitante</span>
                                        @if (jogo.PenaltisCasa.HasValue && jogo.PenaltisVisitante.HasValue)
                                        {
                                            <span class="lib-pen">(@jogo.PenaltisCasa-@jogo.PenaltisVisitante pên.)</span>
                                        }
                                    }
                                    else
                                    {
                                        <span>vs</span>
                                    }
                                </div>

                                <div class="lib-jogo-team">
                                    @if (!string.IsNullOrEmpty(jogo.TimeVisitante?.EscudoUrl))
                                    {
                                        <img src="@Url.Action("Imagem", "MediaProxy", new { url = jogo.TimeVisitante.EscudoUrl })" alt="@jogo.TimeVisitante.Nome" />
                                    }
                                    <a href="/Times/Details/@jogo.TimeVisitante?.Id" style="font-size:11px;font-weight:500;color:#374151;text-align:center;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:90px;text-decoration:none;">@jogo.TimeVisitante?.Nome</a>
                                </div>
                            </div>

                            <div class="lib-jogo-footer">
                                @if (realizado)
                                {
                                    <span style="color:#22c55e;font-weight:600;">✔ Realizado</span>
                                }
                                else
                                {
                                    <span class="lib-badge-agendado">Agendado</span>
                                }
                                <a asp-controller="Jogos" asp-action="Analisar" asp-route-id="@jogo.Id"
                                   class="lib-analisar-btn">
                                    Analisar →
                                </a>
                            </div>
                        </div>
                    </div>
                }
            }
        </div>

                </div>
            </div>
        }

        @{
            var inv = System.Globalization.CultureInfo.InvariantCulture;
            Func<string?, string> catPos = (p) =>
            {
                var s = (p ?? "").Trim().ToLowerInvariant();
                if (s.Contains("gol") || s == "gl") return "Goleiro";
                if (s.Contains("zag") || s.Contains("def") || s.Contains("lat") || s == "zg") return "Defensor";
                if (s.Contains("mei") || s.Contains("vol") || s == "mc") return "Meia";
                if (s.Contains("ata") || s.Contains("pon") || s.Contains("cen") || s == "at") return "Atacante";
                return "Outros";
            };
            var categoriasPos = new[] { "Goleiro", "Defensor", "Meia", "Atacante", "Outros" }
                .Where(c => Model.PoolJogadores.Any(j => catPos(j.Posicao) == c))
                .ToList();
        }
        <div class="cdm-panel" data-cdm-panel="selecao">
            @if (TempData["SelecaoSalva"] != null)
            {
                <div class="sel-msg">✅ @TempData["SelecaoSalva"]</div>
            }
            @if (!Model.Formacoes.Any())
            {
                <div class="sel-empty">Cadastre formações em <strong>Formações</strong> para montar sua seleção.</div>
            }
            else
            {
                <div class="sel-bar">
                    <label>Seleção:</label>
                    <select id="sel-lista" onchange="selTrocarSelecao(this.value)">
                        @foreach (var sel in Model.Selecoes)
                        {
                            <option value="@sel.Id" selected="@(!Model.ModoNovaSelecao && sel.Id == Model.SelecaoAtualId)">@(string.IsNullOrWhiteSpace(sel.Nome) ? "Seleção" : sel.Nome)</option>
                        }
                        <option value="nova" selected="@Model.ModoNovaSelecao">➕ Nova seleção</option>
                    </select>
                    @if (Model.SelecaoAtualId != null)
                    {
                        <form method="post" asp-action="ExcluirSelecao" asp-controller="CopaDoMundo" style="display:inline"
                              onsubmit="return confirm('Excluir esta seleção?')">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="selId" value="@Model.SelecaoAtualId" />
                            <input type="hidden" name="temporada" value="@Model.Temporada" />
                            <button type="submit" class="sel-del">🗑️ Excluir</button>
                        </form>
                    }
                </div>

                <form method="post" asp-action="SalvarSelecao" asp-controller="CopaDoMundo" id="sel-form">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="temporada" value="@Model.Temporada" />
                    <input type="hidden" name="selId" value="@Model.SelecaoAtualId" />

                    <div class="sel-bar">
                        <label>Nome:</label>
                        <input type="text" name="nome" id="sel-nome-input" class="sel-nome" value="@Model.SelecaoAtualNome" placeholder="Ex.: 1ª fase, Final" oninput="selAtualizarTitulo()" />
                        <label>Formação:</label>
                        <select name="formacaoId" id="sel-formacao" onchange="selTrocarFormacao(this.value)">
                            @foreach (var f in Model.Formacoes)
                            {
                                <option value="@f.Id" selected="@(f.Id == Model.SelecaoFormacaoId)">@f.Nome</option>
                            }
                        </select>
                        <button type="submit" class="sel-save">💾 Salvar seleção</button>
                    </div>

                    <div class="sel-titulo" id="sel-titulo">⭐ @(string.IsNullOrWhiteSpace(Model.SelecaoAtualNome) ? "Nova seleção" : Model.SelecaoAtualNome)</div>

                    <div class="sel-pitch">
                        @for (int i = 0; i < Model.SelecaoSlots.Count; i++)
                        {
                            var s = Model.SelecaoSlots[i];
                            ControleFutebolWeb.Models.Jogador? jog = null;
                            if (s.JogadorId.HasValue) Model.JogadoresPorId.TryGetValue(s.JogadorId.Value, out jog);
                            var fotoSlot = jog != null && !string.IsNullOrEmpty(jog.FotoUrl)
                                ? Url.Action("Imagem", "MediaProxy", new { url = jog.FotoUrl }) : null;
                            <div class="sel-slot @(jog != null ? "filled" : "")"
                                 style="left:@s.X.ToString(inv)%; top:@s.Y.ToString(inv)%;"
                                 data-idx="@i" onclick="selAbrirPicker(@i)">
                                <div class="sel-slot-photo">
                                    @if (fotoSlot != null)
                                    {
                                        <img src="@fotoSlot" alt="@jog!.Nome" />
                                    }
                                    else
                                    {
                                        <span class="sel-slot-plus">+</span>
                                    }
                                </div>
                                <div class="sel-slot-name">@(jog?.Nome ?? "Escolher")</div>
                            </div>
                            <input type="hidden" name="slots[@i].X" value="@s.X.ToString(inv)" />
                            <input type="hidden" name="slots[@i].Y" value="@s.Y.ToString(inv)" />
                            <input type="hidden" name="slots[@i].JogadorId" id="sel-slot-jog-@i" value="@(s.JogadorId)" />
                        }
                    </div>
                </form>

                <div id="sel-picker" class="sel-picker-overlay" onclick="selFecharPicker(event)">
                    <div class="sel-picker-box" onclick="event.stopPropagation()">
                        <div class="sel-picker-head">
                            <input type="text" id="sel-picker-search" placeholder="Buscar jogador..." autocomplete="off" />
                            <select id="sel-picker-pos" onchange="selFiltrarPicker()">
                                <option value="">Todas</option>
                                @foreach (var c in categoriasPos)
                                {
                                    <option value="@c">@c</option>
                                }
                            </select>
                            <button type="button" class="sel-picker-close" onclick="selFecharPicker()">✕</button>
                        </div>
                        <div class="sel-picker-list" id="sel-picker-list">
                            <div class="sel-pick-item sel-pick-remove" data-id="" data-busca="">— Remover jogador —</div>
                            @foreach (var j in Model.PoolJogadores)
                            {
                                var foto = !string.IsNullOrEmpty(j.FotoUrl)
                                    ? Url.Action("Imagem", "MediaProxy", new { url = j.FotoUrl }) : "";
                                var timeNome = j.Selecao?.Nome ?? j.Time?.Nome ?? "";
                                <div class="sel-pick-item" data-id="@j.Id" data-nome="@j.Nome" data-foto="@foto"
                                     data-pos="@catPos(j.Posicao)"
                                     data-busca="@((j.Nome + " " + timeNome).ToLower())">
                                    <div class="sel-pick-photo">
                                        @if (!string.IsNullOrEmpty(foto))
                                        {
                                            <img src="@foto" alt="" />
                                        }
                                        else
                                        {
                                            <span>👤</span>
                                        }
                                    </div>
                                    <div class="sel-pick-info">
                                        <span class="sel-pick-nome">@j.Nome</span>
                                        <span class="sel-pick-meta">@j.Posicao@(string.IsNullOrEmpty(timeNome) ? "" : " · " + timeNome)@(Model.NotaMediaPorJogador.TryGetValue(j.Id, out var notaMed) ? " · ⭐ " + notaMed.ToString("0.0", inv) : "")</span>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>

    <script>
        (function () {
            var root = document.querySelector('.cdm-bracket');
            if (!root) return;
            root.querySelectorAll('.cdm-tab').forEach(function (tab) {
                tab.addEventListener('click', function () {
                    var idx = tab.getAttribute('data-cdm-tab');
                    root.querySelectorAll('.cdm-tab').forEach(function (t) { t.classList.remove('active'); });
                    root.querySelectorAll('[data-cdm-panel]').forEach(function (p) { p.classList.remove('active'); });
                    tab.classList.add('active');
                    var panel = root.querySelector('[data-cdm-panel="' + idx + '"]');
                    if (panel) panel.classList.add('active');
                });
            });

            // Auto-abre uma aba via ?aba=selecao (ex.: ao voltar de salvar a seleção).
            var aba = new URLSearchParams(location.search).get('aba');
            if (aba) {
                var alvo = root.querySelector('.cdm-tab[data-cdm-tab="' + aba + '"]');
                if (alvo) alvo.click();
            }
        })();
    </script>

    <script>
        // ── Aba Seleção: escolher jogador por slot (clique) ─────────────
        var selSlotAtual = null;

        function selTrocarFormacao(id) {
            var p = new URLSearchParams(location.search);
            p.set('selFormacaoId', id);
            p.set('aba', 'selecao');
            location.search = p.toString();
        }

        function selAtualizarTitulo() {
            var inp = document.getElementById('sel-nome-input');
            var t = document.getElementById('sel-titulo');
            if (!t) return;
            var v = inp ? inp.value.trim() : '';
            t.textContent = '⭐ ' + (v || 'Nova seleção');
        }

        function selTrocarSelecao(v) {
            var p = new URLSearchParams(location.search);
            p.delete('selFormacaoId'); // usa a formação própria da seleção escolhida
            p.set('aba', 'selecao');
            if (v === 'nova') { p.delete('selId'); p.set('nova', 'true'); }
            else { p.set('selId', v); p.delete('nova'); }
            location.search = p.toString();
        }

        function selAbrirPicker(idx) {
            selSlotAtual = idx;
            var ov = document.getElementById('sel-picker');
            if (!ov) return;
            ov.classList.add('open');
            var s = document.getElementById('sel-picker-search');
            if (s) { s.value = ''; setTimeout(function () { s.focus(); }, 50); }
            selFiltrarPicker();
        }

        function selFecharPicker() {
            var ov = document.getElementById('sel-picker');
            if (ov) ov.classList.remove('open');
        }

        function selFiltrarPicker() {
            var termo = (document.getElementById('sel-picker-search')?.value || '').trim().toLowerCase();
            var pos = document.getElementById('sel-picker-pos')?.value || '';
            document.querySelectorAll('#sel-picker-list .sel-pick-item').forEach(function (it) {
                if (it.classList.contains('sel-pick-remove')) return;
                var okNome = termo === '' || (it.getAttribute('data-busca') || '').indexOf(termo) !== -1;
                var okPos = pos === '' || (it.getAttribute('data-pos') || '') === pos;
                it.style.display = (okNome && okPos) ? '' : 'none';
            });
        }

        function selAtribuir(idx, id, nome, foto) {
            var hidden = document.getElementById('sel-slot-jog-' + idx);
            if (hidden) hidden.value = id;
            var slot = document.querySelector('.sel-slot[data-idx="' + idx + '"]');
            if (!slot) return;
            var photo = slot.querySelector('.sel-slot-photo');
            var name = slot.querySelector('.sel-slot-name');
            if (id) {
                photo.innerHTML = foto ? '<img src="' + foto + '" alt="">' : '<span class="sel-slot-plus">+</span>';
                if (name) name.textContent = nome;
                slot.classList.add('filled');
            } else {
                photo.innerHTML = '<span class="sel-slot-plus">+</span>';
                if (name) name.textContent = 'Escolher';
                slot.classList.remove('filled');
            }
        }

        (function () {
            var search = document.getElementById('sel-picker-search');
            if (search) search.addEventListener('input', function () { selFiltrarPicker(); });

            document.querySelectorAll('#sel-picker-list .sel-pick-item').forEach(function (it) {
                it.addEventListener('click', function () {
                    if (selSlotAtual === null) return;
                    selAtribuir(selSlotAtual,
                        it.getAttribute('data-id') || '',
                        it.getAttribute('data-nome') || '',
                        it.getAttribute('data-foto') || '');
                    selFecharPicker();
                });
            });
        })();
    </script>
}
