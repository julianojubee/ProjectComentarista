        /* Card de confronto */
        .bkt-match {
            width: 100%; background: #fff; border: 1px solid #e5e7eb; border-radius: 10px;
            overflow: hidden; box-shadow: 0 1px 3px rgba(0,0,0,.04); position: relative; z-index: 1;
        }
        .bkt-match.done { border-color: #bbf7d0; }
        .bkt-match-no {
            display: flex; justify-content: space-between; align-items: center;
            background: linear-gradient(90deg,#006400,#228B22); color: #fde68a;
            font-size: 9px; font-weight: 700; padding: 3px 8px; letter-spacing: .3px;
        }
        .bkt-team {
            display: flex; align-items: center; gap: 6px; padding: 6px 8px;
            border-bottom: 1px solid #f3f4f6;
        }
        .bkt-team:last-of-type { border-bottom: none; }
        .bkt-team img { width: 20px; height: 20px; object-fit: contain; border-radius: 50%; border: .5px solid #e5e7eb; background: #f9f9f9; flex-shrink: 0; }
        .bkt-flag-ph { width: 20px; height: 20px; border-radius: 50%; background: repeating-linear-gradient(45deg,#f3f4f6,#f3f4f6 4px,#e5e7eb 4px,#e5e7eb 8px); flex-shrink: 0; }
        .bkt-tname { flex: 1; min-width: 0; font-size: 12px; font-weight: 600; color: #111827; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
        .bkt-tname.placeholder { font-weight: 500; font-style: italic; color: #9ca3af; }
        .bkt-tname.prov { color: #6b7280; }
        .bkt-team.win .bkt-tname { color: #15803d; }
        .bkt-team.win { background: rgba(34,139,34,.06); }
        .bkt-score { font-size: 13px; font-weight: 800; color: #111827; min-width: 18px; text-align: center; flex-shrink: 0; }
        .bkt-foot {
            display: flex; justify-content: space-between; align-items: center; gap: 6px;
            padding: 4px 8px; border-top: 1px solid #f3f4f6; background: #fafafa;
        }
        .bkt-date { font-size: 9px; color: #9ca3af; }
        .bkt-analisar {
            font-size: 9px; padding: 2px 8px; border-radius: 5px; border: 1px solid #15803d;
            color: #15803d; background: transparent; text-decoration: none; font-weight: 700;
            transition: background .15s,color .15s; white-space: nowrap;
        }
        .bkt-analisar:hover { background: #15803d; color: #fff; text-decoration: none; }

        /* Conectores — lado esquerdo (linhas saem à direita) */
        .bkt-left .bkt-col:not(.bkt-sf) .bkt-cell::after {
            content: ''; position: absolute; top: 50%; right: 0;
            width: var(--bkt-gap); height: 2px; background: var(--bkt-line);
            transform: translate(100%,-50%);
        }
        .bkt-left .bkt-col:not(.bkt-sf) .bkt-cell:nth-child(odd)::before {
            content: ''; position: absolute; top: 50%; right: calc(-1 * var(--bkt-gap));
            width: 2px; height: 100%; background: var(--bkt-line);
        }
        /* Conectores — lado direito (linhas saem à esquerda) */
        .bkt-right .bkt-col:not(.bkt-sf) .bkt-cell::after {
            content: ''; position: absolute; top: 50%; left: 0;
            width: var(--bkt-gap); height: 2px; background: var(--bkt-line);
            transform: translate(-100%,-50%);
        }
        .bkt-right .bkt-col:not(.bkt-sf) .bkt-cell:nth-child(odd)::before {
            content: ''; position: absolute; top: 50%; left: calc(-1 * var(--bkt-gap));
            width: 2px; height: 100%; background: var(--bkt-line);
        }
        /* Semifinais → Final (stubs apontando ao centro) */
        .bkt-left .bkt-sf .bkt-cell::after {
            content: ''; position: absolute; top: 50%; right: 0;
            width: calc(var(--bkt-gap) + 8px); height: 2px; background: var(--bkt-line);
            transform: translate(100%,-50%);
        }
        .bkt-right .bkt-sf .bkt-cell::after {
            content: ''; position: absolute; top: 50%; left: 0;
            width: calc(var(--bkt-gap) + 8px); height: 2px; background: var(--bkt-line);
            transform: translate(-100%,-50%);
        }

        /* Centro: Final + disputa de 3º lugar */
        .bkt-center { width: var(--bkt-w); display: flex; flex-direction: column; }
        .bkt-center .bkt-col-label { color: #b45309; }
        .bkt-final-wrap { flex: 1; display: flex; flex-direction: column; justify-content: center; align-items: center; gap: 8px; }
        .bkt-center .bkt-cell { flex: 0 0 auto; min-height: 0; width: 100%; }
        .bkt-trophy { font-size: 30px; line-height: 1; filter: drop-shadow(0 2px 6px rgba(0,0,0,.2)); }
        .bkt-final-cell .bkt-match { border-color: #fbbf24; box-shadow: 0 2px 10px rgba(251,191,36,.25); }
        .bkt-final-cell .bkt-match-no { background: linear-gradient(90deg,#b45309,#f59e0b); color: #fff; }
        .bkt-bronze-label { font-size: 10px; font-weight: 700; color: #b45309; text-transform: uppercase; letter-spacing: .5px; margin-top: 4px; }
        .bkt-bronze-cell .bkt-match-no { background: linear-gradient(90deg,#92400e,#d97706); }

        @@media (max-width: 700px) {
            .bkt-tree { --bkt-w: 168px; --bkt-gap: 26px; }
        }
    </style>

    <div class="cdm-bracket">
        <div class="cdm-bracket-head">
            <h3>🏆 Fase de Grupos &amp; Mata-Mata</h3>
            <small>Selecione uma aba para ver a classificação dos grupos ou o chaveamento do mata-mata.</small>
        </div>

        <div class="cdm-tabs" role="tablist">
            @if (temGrupos)
            {
                <button type="button" class="cdm-tab active" data-cdm-tab="grupos">📊 Grupos</button>
            }
            @if (temChave)
            {
                <button type="button" class="cdm-tab @(!temGrupos ? "active" : "")" data-cdm-tab="chave">⚔️ Mata-Mata</button>
            }
        </div>

        @if (temChave)
        {
            <div class="cdm-panel @(!temGrupos ? "active" : "")" data-cdm-panel="chave">
                <div class="bkt-legend">
                    <span><span class="bkt-leg-dot" style="background:#15803d;"></span>Vencedor / classificado</span>
                    <span><span class="bkt-leg-box prov"></span>Confronto provisório (grupos/fase em andamento)</span>
                    <span><span class="bkt-leg-box"></span>A definir</span>
                </div>

                <div class="bkt-scroll">
                    <div class="bkt-tree">
                        <!-- ── Lado esquerdo ── -->
                        <div class="bkt-side bkt-left">
                            <div class="bkt-colwrap">
                                <div class="bkt-col-label">1/16</div>
                                <div class="bkt-col bkt-r32">
                                    @foreach (var n in colR32E) { <div class="bkt-cell">@renderMatch(confrontoPorNumero[n])</div> }
                                </div>
                            </div>
                            <div class="bkt-colwrap">
                                <div class="bkt-col-label">1/8</div>
                                <div class="bkt-col bkt-r16">
                                    @foreach (var n in colR16E) { <div class="bkt-cell">@renderMatch(confrontoPorNumero[n])</div> }
                                </div>
                            </div>
                            <div class="bkt-colwrap">
                                <div class="bkt-col-label">Quartas</div>
                                <div class="bkt-col bkt-qf">
                                    @foreach (var n in colQFE) { <div class="bkt-cell">@renderMatch(confrontoPorNumero[n])</div> }
                                </div>
                            </div>
                            <div class="bkt-colwrap">
                                <div class="bkt-col-label">Semi</div>
                                <div class="bkt-col bkt-sf">
                                    @foreach (var n in colSFE) { <div class="bkt-cell">@renderMatch(confrontoPorNumero[n])</div> }
                                </div>
                            </div>
                        </div>

                        <!-- ── Centro: Final + 3º lugar ── -->
                        <div class="bkt-center">
                            <div class="bkt-col-label">Final</div>
                            <div class="bkt-final-wrap">
                                <div class="bkt-trophy">🏆</div>
                                <div class="bkt-cell bkt-final-cell">@renderMatch(confrontoPorNumero[104])</div>
                                <div class="bkt-bronze-label">Disputa de 3º Lugar</div>
                                <div class="bkt-cell bkt-bronze-cell">@renderMatch(confrontoPorNumero[103])</div>
                            </div>
                        </div>

                        <!-- ── Lado direito ── -->
                        <div class="bkt-side bkt-right">
                            <div class="bkt-colwrap">
                                <div class="bkt-col-label">Semi</div>
                                <div class="bkt-col bkt-sf">
                                    @foreach (var n in colSFD) { <div class="bkt-cell">@renderMatch(confrontoPorNumero[n])</div> }
                                </div>
                            </div>
                            <div class="bkt-colwrap">
                                <div class="bkt-col-label">Quartas</div>
                                <div class="bkt-col bkt-qf">
                                    @foreach (var n in colQFD) { <div class="bkt-cell">@renderMatch(confrontoPorNumero[n])</div> }
                                </div>
                            </div>
                            <div class="bkt-colwrap">
                                <div class="bkt-col-label">1/8</div>
                                <div class="bkt-col bkt-r16">
                                    @foreach (var n in colR16D) { <div class="bkt-cell">@renderMatch(confrontoPorNumero[n])</div> }
                                </div>
                            </div>
                            <div class="bkt-colwrap">
                                <div class="bkt-col-label">1/16</div>
                                <div class="bkt-col bkt-r32">
                                    @foreach (var n in colR32D) { <div class="bkt-cell">@renderMatch(confrontoPorNumero[n])</div> }
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }

        @if (temGrupos)
        {
            <div class="cdm-panel active" data-cdm-panel="grupos">
                <div class="lib-layout">

        <!-- Coluna esquerda: grupos -->
        <div>
            <!-- Legenda -->
            <div class="lib-legenda">
                <span><span class="lib-leg-dot" style="background:#7c3aed;"></span>Classificado (1º/2º lugar)</span>
                <span><span class="lib-leg-dot" style="background:#f59e0b;"></span>Disputa vaga (3º lugar)</span>
                <span><span class="lib-leg-dot" style="background:#d1d5db;"></span>Eliminado</span>
            </div>

            <div class="lib-grupos">
                @foreach (var grupo in grupos)
                {
                    <div class="lib-grupo-card">
                        <div class="lib-grupo-header">
                            <img src="~/images/background/copadomundo.png" alt="CopaDoMundo" />
                            Grupo @LetraGrupo(grupo.Nome)
                        </div>

                        @if (!grupo.Times.Any())
                        {
                            <div style="padding:14px;font-size:12px;color:#9ca3af;text-align:center;">
                                Nenhum jogo realizado ainda neste grupo.
                            </div>
                        }
                        else
                        {
                            <div style="overflow-x:auto;">
                            <table class="lib-table">
                                <thead>
                                    <tr>
                                        <th style="width:20px;">#</th>
                                        <th>Time</th>
                                        <th title="Jogos">J</th>
                                        <th title="Vitórias">V</th>
                                        <th title="Empates">E</th>
                                        <th title="Derrotas">D</th>
                                        <th title="Saldo de Gols">SG</th>
                                        <th title="Pontos">Pts</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var time in grupo.Times)
                                    {
                                        string posClass = time.Posicao switch
                                        {
                                            1 => "lib-pos-1",
                                            2 => "lib-pos-2",
                                            3 => "lib-pos-3",
                                            _ => "lib-pos-default"
                                        };

                                        <tr>
                                            <td>
                                                <span class="lib-pos @posClass">@time.Posicao</span>
                                            </td>
                                            <td>
                                                <div class="lib-team-cell">
                                                    @if (!string.IsNullOrEmpty(time.Time?.EscudoUrl))
                                                    {
                                                        <img src="@Url.Action("Imagem", "MediaProxy", new { url = time.Time.EscudoUrl })" alt="@time.Time.Nome" />
                                                    }
                                                    <a href="/Times/Details/@time.Time?.Id" style="color:inherit;text-decoration:none;font-size:12px;font-weight:500;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:130px;">@time.Time?.Nome</a>
                                                </div>
                                            </td>
                                            <td>@time.Jogos</td>
                                            <td>@time.Vitorias</td>
                                            <td>@time.Empates</td>
                                            <td>@time.Derrotas</td>
                                            <td>@time.SaldoGols</td>
                                            <td class="lib-pts">@time.Pontos</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                            </div>
                        }
                    </div>
                }
            </div>

            @if (terceirosColocados.Any())
            {
                <!-- Tabela de 3ºs colocados -->
                <div style="margin-top:20px;">
                    <div style="display:flex;align-items:center;gap:10px;margin-bottom:10px;">
                        <div style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:#6b7280;">🏅 Classificação dos 3ºs Colocados</div>
                        <div style="flex:1;height:1px;background:#e5e7eb;"></div>
                        <span style="font-size:10px;color:#6b7280;background:#f3f4f6;border:0.5px solid #e5e7eb;border-radius:20px;padding:2px 9px;">Os 8 melhores avançam</span>
                    </div>
                    <div style="background:#fff;border:0.5px solid #e5e7eb;border-radius:12px;overflow:hidden;">
                        <div style="background:linear-gradient(90deg,#92400e,#d97706);color:#fff;padding:8px 14px;font-size:12px;font-weight:700;display:flex;align-items:center;gap:8px;">
                            <img src="~/images/background/copadomundo.png" alt="Copa" style="width:16px;height:16px;object-fit:contain;" />
                            Melhores Terceiros Colocados — Disputa de Vagas
                        </div>
                        <div style="overflow-x:auto;">
                        <table class="lib-table">
                            <thead>
                                <tr>
                                    <th style="width:20px;">#</th>
                                    <th>Seleção</th>
                                    <th title="Grupo">Gr</th>
                                    <th title="Jogos">J</th>
                                    <th title="Vitórias">V</th>
                                    <th title="Empates">E</th>
                                    <th title="Derrotas">D</th>
                                    <th title="Gols Pró">GP</th>
                                    <th title="Gols Contra">GC</th>
                                    <th title="Saldo de Gols">SG</th>
                                    <th title="Fair Play (menor = melhor)">FP</th>
                                    <th title="Pontos">Pts</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var time in terceirosColocados)
                                {
                                    bool classificado = time.Posicao <= 8;
                                    string rowStyle = classificado ? "background:rgba(245,158,11,0.06);" : "";
                                    <tr style="@rowStyle">
                                        <td>
                                            @if (classificado)
                                            {
                                                <span class="lib-pos lib-pos-3">@time.Posicao</span>
                                            }
                                            else
                                            {
                                                <span class="lib-pos lib-pos-default">@time.Posicao</span>
                                            }
                                        </td>
                                        <td>
                                            <div class="lib-team-cell">
                                                @if (!string.IsNullOrEmpty(time.Time?.EscudoUrl))
                                                {
                                                    <img src="@Url.Action("Imagem", "MediaProxy", new { url = time.Time.EscudoUrl })" alt="@time.Time.Nome" />
                                                }
                                                <a href="/Times/Details/@time.Time?.Id" style="color:inherit;text-decoration:none;font-size:12px;font-weight:500;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:130px;">@time.Time?.Nome</a>
                                            </div>
                                        </td>
                                        <td style="font-weight:700;color:#d97706;">@time.Grupo</td>
                                        <td>@time.Jogos</td>
                                        <td>@time.Vitorias</td>
                                        <td>@time.Empates</td>
                                        <td>@time.Derrotas</td>
                                        <td>@time.GolsPro</td>
                                        <td>@time.GolsContra</td>
                                        <td>@time.SaldoGols</td>
                                        <td style="color:#6b7280;font-size:11px;">@time.FairPlay</td>
                                        <td class="lib-pts">@time.Pontos</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                        </div>
                        <div style="padding:8px 14px;font-size:10px;color:#9ca3af;border-top:0.5px solid #f3f4f6;">
                            Critérios: Pontos → Saldo de Gols → Gols Pró → Fair Play (amarelo=1pt · vermelho direto=3pt · 2º amarelo+vermelho=4pt)
                        </div>
                    </div>
                </div>
            }
        </div>

        <!-- Coluna direita: próximos jogos -->
        <div class="lib-sidebar">
            <div class="lib-sidebar-title">
                Jogos
                @if (rodadaAtual > 0)
                {
                    <span class="lib-rodada-badge">Rodada @rodadaAtual</span>
                }
            </div>

            @if (!proximosJogos.Any())
            {
                <div class="lib-empty" style="padding:1.5rem;">
                    Nenhum jogo encontrado.
                </div>
            }
            else
            {
                @foreach (var jogo in proximosJogos)
                {
                    bool realizado = jogo.PlacarCasa.HasValue && jogo.PlacarVisitante.HasValue;

                    <div class="lib-jogo-card">
                        <div class="lib-jogo-header">
                            <span>@ControleFutebolWeb.Helpers.DateHelper.FormatarData(jogo.Data, "dd/MM/yyyy HH:mm")</span>
                            @if (!string.IsNullOrEmpty(jogo.Grupo))
                            {
                                <span class="lib-grupo-tag">Grupo @LetraGrupo(jogo.Grupo)</span>
                            }
                        </div>
                        <div class="lib-jogo-body">
                            <div class="lib-jogo-teams">
                                <div class="lib-jogo-team">
                                    @if (!string.IsNullOrEmpty(jogo.TimeCasa?.EscudoUrl))
                                    {
                                        <img src="@Url.Action("Imagem", "MediaProxy", new { url = jogo.TimeCasa.EscudoUrl })" alt="@jogo.TimeCasa.Nome" />
                                    }
                                    <a href="/Times/Details/@jogo.TimeCasa?.Id" style="font-size:11px;font-weight:500;color:#374151;text-align:center;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:90px;text-decoration:none;">@jogo.TimeCasa?.Nome</a>
                                </div>

                                <div class="lib-vs">
                                    @if (realizado)
                                    {
                                        <span class="lib-score">@jogo.PlacarCasa x @jogo.PlacarVisitante</span>
                                    }
                                    else
                                    {
                                        <span>vs</span>
                                    }
                                </div>

                                <div class="lib-jogo-team">
                                    @if (!string.IsNullOrEmpty(jogo.TimeVisitante?.EscudoUrl))
                                    {
                                        <img src="@Url.Action("Imagem", "MediaProxy", new { url = jogo.TimeVisitante.EscudoUrl })" alt="@jogo.TimeVisitante.Nome" />
                                    }
                                    <a href="/Times/Details/@jogo.TimeVisitante?.Id" style="font-size:11px;font-weight:500;color:#374151;text-align:center;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:90px;text-decoration:none;">@jogo.TimeVisitante?.Nome</a>
                                </div>
                            </div>

                            <div class="lib-jogo-footer">
                                @if (realizado)
                                {
                                    <span style="color:#22c55e;font-weight:600;">✔ Realizado</span>
                                }
                                else
                                {
                                    <span class="lib-badge-agendado">Agendado</span>
                                }
                                <a asp-controller="Jogos" asp-action="Analisar" asp-route-id="@jogo.Id"
                                   class="lib-analisar-btn">
                                    Analisar →
                                </a>
                            </div>
                        </div>
                    </div>
                }
            }
        </div>

                </div>
            </div>
        }
    </div>

    <script>
        (function () {
            var root = document.querySelector('.cdm-bracket');
            if (!root) return;
            root.querySelectorAll('.cdm-tab').forEach(function (tab) {
                tab.addEventListener('click', function () {
                    var idx = tab.getAttribute('data-cdm-tab');
                    root.querySelectorAll('.cdm-tab').forEach(function (t) { t.classList.remove('active'); });
                    root.querySelectorAll('[data-cdm-panel]').forEach(function (p) { p.classList.remove('active'); });
                    tab.classList.add('active');
                    var panel = root.querySelector('[data-cdm-panel="' + idx + '"]');
                    if (panel) panel.classList.add('active');
                });
            });
        })();
    </script>
}
