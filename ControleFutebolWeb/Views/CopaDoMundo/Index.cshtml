@{
    bool temGrupos = grupos.Any();
    bool temChave = chaveamento.Fases.Any();

    // Mapa nº-da-partida → confronto e nome curto da fase (template fixo FIFA 73–104).
    var confrontoPorNumero = chaveamento.Fases
        .SelectMany(f => f.Confrontos)
        .GroupBy(c => c.Numero)
        .ToDictionary(g => g.Key, g => g.First());
    var numeroParaFase = chaveamento.Fases
        .SelectMany(f => f.Confrontos.Select(c => new { c.Numero, f.NomeCurto }))
        .GroupBy(x => x.Numero)
        .ToDictionary(g => g.Key, g => g.First().NomeCurto);

    // Ordem (de cima para baixo) de cada coluna do chaveamento — lados esquerdo (E) e direito (D).
    var colR32E = new[] { 74, 77, 73, 75, 83, 84, 81, 82 };
    var colR16E = new[] { 89, 90, 93, 94 };
    var colQFE = new[] { 97, 98 };
    var colSFE = new[] { 101 };
    var colR32D = new[] { 76, 78, 79, 80, 86, 88, 85, 87 };
    var colR16D = new[] { 91, 92, 95, 96 };
    var colQFD = new[] { 99, 100 };
    var colSFD = new[] { 102 };

    // Renderiza um card de confronto do chaveamento (com botão Analisar quando há jogo real).
    Func<ConfrontoCopaViewModel, Microsoft.AspNetCore.Html.IHtmlContent> renderMatch = @<text>
        @{
            var c = item;
            bool rz = c.Realizado;
            bool cV = false, vV = false;
            if (rz)
            {
                if (c.PlacarCasa > c.PlacarVisitante) { cV = true; }
                else if (c.PlacarVisitante > c.PlacarCasa) { vV = true; }
                else if (c.TevePenaltis)
                {
                    if (c.PenaltisCasa > c.PenaltisVisitante) { cV = true; }
                    else if (c.PenaltisVisitante > c.PenaltisCasa) { vV = true; }
                }
            }
            var faseNome = numeroParaFase.TryGetValue(c.Numero, out var fn) ? fn : "";
        }
        <div class="bkt-match @(rz ? "done" : "")">
            <div class="bkt-match-no">
                <span>M@(c.Numero)</span>
                <span>@faseNome</span>
            </div>
            @foreach (var lado in new[]
            {
                (Slot: c.Casa, Placar: c.PlacarCasa, Pen: c.PenaltisCasa, Venceu: cV),
                (Slot: c.Visitante, Placar: c.PlacarVisitante, Pen: c.PenaltisVisitante, Venceu: vV)
            })
            {
                <div class="bkt-team @(lado.Venceu ? "win" : "")">
                    @if (lado.Slot.Definido)
                    {
                        @if (!string.IsNullOrEmpty(lado.Slot.Time?.EscudoUrl))
                        {
                            <img src="@Url.Action("Imagem", "MediaProxy", new { url = lado.Slot.Time.EscudoUrl })" alt="@lado.Slot.Time.Nome" />
                        }
                        else
                        {
                            <span class="bkt-flag-ph"></span>
                        }
                        <span class="bkt-tname @(lado.Slot.Provisorio ? "prov" : "")">@lado.Slot.Time?.Nome</span>
                    }
                    else
                    {
                        <span class="bkt-flag-ph"></span>
                        <span class="bkt-tname placeholder">@lado.Slot.Rotulo</span>
                    }
                    @if (rz)
                    {
                        <span class="bkt-score">@lado.Placar@(lado.Pen.HasValue ? $" ({lado.Pen})" : "")</span>
                    }
                </div>
            }
            <div class="bkt-foot">
                <span class="bkt-date">@(c.Data.HasValue ? ControleFutebolWeb.Helpers.DateHelper.FormatarData(c.Data, "dd/MM HH:mm") : "—")</span>
                @if (c.JogoId.HasValue)
                {
                    <a href="@Url.Action("Analisar", "Jogos", new { id = c.JogoId })" class="bkt-analisar">Analisar →</a>
                }
            </div>
        </div>
    </text>;
}

