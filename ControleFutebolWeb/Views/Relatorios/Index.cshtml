    <!-- ══ SEÇÃO: TIMES ════════════════════════════════════════════════════ -->
    <div id="sec-times" class="rpt-section">
        <div class="rpt-grid">

            <!-- Mais pontos -->
            <div class="rpt-card">
                <div class="rpt-card-header">
                    <div class="rpt-card-icon" style="background:#fef3c7;">🏆</div>
                    <div>
                        <h3 class="rpt-card-title">Mais Pontos</h3>
                        <p class="rpt-card-sub">Classificação geral de pontos</p>
                    </div>
                </div>
                @{ var maxPts = Model.TimesMaisPontos.Any() ? Model.TimesMaisPontos.Max(t => t.Pontos) : 1; }
                @for (int i = 0; i < Model.TimesMaisPontos.Count; i++)
                {
                    var t = Model.TimesMaisPontos[i];
                    var w = Math.Round((double)t.Pontos / maxPts * 100, 1);
                    <div class="rpt-row">
                        <span class="rpt-rank @(i==0?"gold":i==1?"silver":i==2?"bronze":"")">@(i+1)</span>
                        @if (!string.IsNullOrEmpty(t.Time.EscudoUrl))
                        {
                            <img src="@Url.Action("Imagem", "MediaProxy", new { url = t.Time.EscudoUrl })" class="rpt-team-badge" />
                        }
                        <div class="rpt-name">
                            @t.Time.Nome
                            <small>@t.Jogos J · @t.Vitorias V · @t.Empates E · @t.Derrotas D</small>
                        </div>
                        <div class="rpt-bar-wrap" style="max-width:70px;">
                            <div class="rpt-bar-bg">
                                <div class="rpt-bar-fill" style="width:@w%;background:#f59e0b;"></div>
                            </div>
                        </div>
                        <span class="rpt-badge-value" style="background:#fffbeb;color:#d97706;">@t.Pontos pts</span>
                    </div>
                }
            </div>

            <!-- Mais gols -->
            <div class="rpt-card">
                <div class="rpt-card-header">
                    <div class="rpt-card-icon" style="background:#f0fdf4;">⚽</div>
                    <div>
                        <h3 class="rpt-card-title">Mais Gols Marcados</h3>
                        <p class="rpt-card-sub">Times com maior poder ofensivo</p>
                    </div>
                </div>
                @{ var maxGT = Model.TimesGols.Any() ? Model.TimesGols.Max(t => t.GolsPro) : 1; }
                @for (int i = 0; i < Model.TimesGols.Count; i++)
                {
                    var t = Model.TimesGols[i];
                    var w = Math.Round((double)t.GolsPro / maxGT * 100, 1);
                    <div class="rpt-row">
                        <span class="rpt-rank @(i==0?"gold":i==1?"silver":i==2?"bronze":"")">@(i+1)</span>
                        @if (!string.IsNullOrEmpty(t.Time.EscudoUrl))
                        {
                            <img src="@Url.Action("Imagem", "MediaProxy", new { url = t.Time.EscudoUrl })" class="rpt-team-badge" />
                        }
                        <div class="rpt-name">
                            @t.Time.Nome
                            <small>Saldo: @(t.SaldoGols >= 0 ? "+" : "")@t.SaldoGols · @t.Jogos jogo(s)</small>
                        </div>
                        <div class="rpt-bar-wrap" style="max-width:70px;">
                            <div class="rpt-bar-bg">
                                <div class="rpt-bar-fill" style="width:@w%;background:#22c55e;"></div>
                            </div>
                        </div>
                        <span class="rpt-badge-value" style="background:#dcfce7;color:#15803d;">@t.GolsPro ⚽</span>
                    </div>
                }
            </div>

            <!-- Mais vitórias -->
            <div class="rpt-card">
                <div class="rpt-card-header">
                    <div class="rpt-card-icon" style="background:#eff6ff;">🥇</div>
                    <div>
                        <h3 class="rpt-card-title">Mais Vitórias</h3>
                        <p class="rpt-card-sub">Times com melhor desempenho</p>
                    </div>
                </div>
                @{ var maxV = Model.TimesVitorias.Any() ? Model.TimesVitorias.Max(t => t.Vitorias) : 1; }
                @for (int i = 0; i < Model.TimesVitorias.Count; i++)
                {
                    var t = Model.TimesVitorias[i];
                    var w = Math.Round((double)t.Vitorias / maxV * 100, 1);
                    <div class="rpt-row">
                        <span class="rpt-rank @(i==0?"gold":i==1?"silver":i==2?"bronze":"")">@(i+1)</span>
                        @if (!string.IsNullOrEmpty(t.Time.EscudoUrl))
                        {
                            <img src="@Url.Action("Imagem", "MediaProxy", new { url = t.Time.EscudoUrl })" class="rpt-team-badge" />
                        }
                        <div class="rpt-name">
                            @t.Time.Nome
                            <small>@t.Aproveitamento% aprov. · @t.Jogos jogo(s)</small>
                        </div>
                        <div class="rpt-bar-wrap" style="max-width:70px;">
                            <div class="rpt-bar-bg">
                                <div class="rpt-bar-fill" style="width:@w%;background:#3b82f6;"></div>
                            </div>
                        </div>
                        <span class="rpt-badge-value" style="background:#eff6ff;color:#1d4ed8;">@t.Vitorias V</span>
                    </div>
                }
            </div>

            <!-- Menos gols sofridos -->
            <div class="rpt-card">
                <div class="rpt-card-header">
                    <div class="rpt-card-icon" style="background:#fdf4ff;">🛡️</div>
                    <div>
                        <h3 class="rpt-card-title">Menos Gols Sofridos</h3>
                        <p class="rpt-card-sub">Defesas mais sólidas (mín. 2 jogos)</p>
                    </div>
                </div>
                @for (int i = 0; i < Model.TimesMenosGolsSofridos.Count; i++)
                {
                    var t = Model.TimesMenosGolsSofridos[i];
                    <div class="rpt-row">
                        <span class="rpt-rank @(i==0?"gold":i==1?"silver":i==2?"bronze":"")">@(i+1)</span>
                        @if (!string.IsNullOrEmpty(t.Time.EscudoUrl))
                        {
                            <img src="@Url.Action("Imagem", "MediaProxy", new { url = t.Time.EscudoUrl })" class="rpt-team-badge" />
                        }
                        <div class="rpt-name">
                            @t.Time.Nome
                            <small>@(Math.Round((double)t.GolsContra / t.Jogos, 1)) gols/jogo · @t.Jogos jogo(s)</small>
                        </div>
                        <span class="rpt-badge-value" style="background:#fdf4ff;color:#7e22ce;">@t.GolsContra sofridos</span>
                    </div>
                }
            </div>

            <!-- Aproveitamento -->
            <div class="rpt-card">
                <div class="rpt-card-header">
                    <div class="rpt-card-icon" style="background:#fff7ed;">📊</div>
                    <div>
                        <h3 class="rpt-card-title">Melhor Aproveitamento</h3>
                        <p class="rpt-card-sub">% de pontos sobre possível (mín. 2 jogos)</p>
                    </div>
                </div>
                @for (int i = 0; i < Model.TimesAproveitamento.Count; i++)
                {
                    var t = Model.TimesAproveitamento[i];
                    <div class="rpt-row">
                        <span class="rpt-rank @(i==0?"gold":i==1?"silver":i==2?"bronze":"")">@(i+1)</span>
                        @if (!string.IsNullOrEmpty(t.Time.EscudoUrl))
                        {
                            <img src="@Url.Action("Imagem", "MediaProxy", new { url = t.Time.EscudoUrl })" class="rpt-team-badge" />
                        }
                        <div class="rpt-name">
                            @t.Time.Nome
                            <small>@t.Pontos pts · @t.Jogos jogo(s)</small>
                        </div>
                        <div class="rpt-bar-wrap" style="max-width:80px;">
                            <div class="rpt-bar-bg">
                                <div class="rpt-bar-fill" style="width:@t.Aproveitamento%;background:linear-gradient(90deg,#f97316,#fbbf24);"></div>
                            </div>
                        </div>
                        <span class="rpt-badge-value" style="background:#fff7ed;color:#c2410c;">@t.Aproveitamento%</span>
                    </div>
                }
            </div>

            <!-- Vitórias em Casa -->
            <div class="rpt-card">
                <div class="rpt-card-header" style="border-left:4px solid #16a34a;">
                    <div class="rpt-card-icon" style="background:#dcfce7;color:#16a34a;">🏠</div>
                    <div>
                        <h3 class="rpt-card-title">Mais Vitórias em Casa</h3>
                        <p class="rpt-card-sub">Times imbatíveis no seu estádio</p>
                    </div>
                </div>
                @{ var maxVC = Model.TimesVitoriasCasa.Any() ? Model.TimesVitoriasCasa.Max(t => t.VitoriasCasa) : 1; }
                @for (int i = 0; i < Model.TimesVitoriasCasa.Count; i++)
                {
                    var t = Model.TimesVitoriasCasa[i];
                    var w = Math.Round((double)t.VitoriasCasa / maxVC * 100, 1);
                    <div class="rpt-row">
                        <span class="rpt-rank @(i==0?"gold":i==1?"silver":i==2?"bronze":"")">@(i+1)</span>
                        @if (!string.IsNullOrEmpty(t.Time.EscudoUrl))
                        {
                            <img src="@Url.Action("Imagem", "MediaProxy", new { url = t.Time.EscudoUrl })" class="rpt-team-badge" />
                        }
                        <div class="rpt-name">
                            @t.Time.Nome
                            <small>@t.VitoriasCasa vitória(s) em casa</small>
                        </div>
                        <div class="rpt-bar-wrap">
                            <div class="rpt-bar-bg">
                                <div class="rpt-bar-fill" style="width:@w%;background:linear-gradient(90deg,#16a34a,#4ade80);"></div>
                            </div>
                        </div>
                        <span class="rpt-badge-value" style="background:#dcfce7;color:#15803d;">@t.VitoriasCasa</span>
                    </div>
                }
            </div>

            <!-- Vitórias Fora de Casa -->
            <div class="rpt-card">
                <div class="rpt-card-header" style="border-left:4px solid #7c3aed;">
                    <div class="rpt-card-icon" style="background:#ede9fe;color:#7c3aed;">✈️</div>
                    <div>
                        <h3 class="rpt-card-title">Mais Vitórias Fora</h3>
                        <p class="rpt-card-sub">Times que vencem longe de casa</p>
                    </div>
                </div>
                @{ var maxVF = Model.TimesVitoriasVisitante.Any() ? Model.TimesVitoriasVisitante.Max(t => t.VitoriasVisitante) : 1; }
                @for (int i = 0; i < Model.TimesVitoriasVisitante.Count; i++)
                {
                    var t = Model.TimesVitoriasVisitante[i];
                    var w = Math.Round((double)t.VitoriasVisitante / maxVF * 100, 1);
                    <div class="rpt-row">
                        <span class="rpt-rank @(i==0?"gold":i==1?"silver":i==2?"bronze":"")">@(i+1)</span>
                        @if (!string.IsNullOrEmpty(t.Time.EscudoUrl))
                        {
                            <img src="@Url.Action("Imagem", "MediaProxy", new { url = t.Time.EscudoUrl })" class="rpt-team-badge" />
                        }
                        <div class="rpt-name">
                            @t.Time.Nome
                            <small>@t.VitoriasVisitante vitória(s) fora</small>
                        </div>
                        <div class="rpt-bar-wrap">
                            <div class="rpt-bar-bg">
                                <div class="rpt-bar-fill" style="width:@w%;background:linear-gradient(90deg,#7c3aed,#a78bfa);"></div>
                            </div>
                        </div>
                        <span class="rpt-badge-value" style="background:#ede9fe;color:#6d28d9;">@t.VitoriasVisitante</span>
                    </div>
                }
            </div>

            @{
                var statsCards = new[]
                {
                    (icone:"🎯", titulo:"Mais Finalizações/Jogo",    sub:"Média de chutes totais por partida",       cor:"#fef3c7", barCor:"#f59e0b", bgVal:"#fffbeb", fgVal:"#d97706", sufixo:"fin/j",   lista:Model.TimesFinalizacoes),
                    (icone:"⚡", titulo:"Mais Chutes no Gol/Jogo",   sub:"Média de finalizações certas por partida", cor:"#dcfce7", barCor:"#22c55e", bgVal:"#dcfce7", fgVal:"#15803d", sufixo:"no gol",  lista:Model.TimesFinalizacoesNoGol),
                    (icone:"🏳️", titulo:"Mais Escanteios/Jogo",      sub:"Média de escanteios por partida",          cor:"#eff6ff", barCor:"#3b82f6", bgVal:"#eff6ff", fgVal:"#1d4ed8", sufixo:"esc/j",   lista:Model.TimesEscanteios),
                    (icone:"🎮", titulo:"Mais Passes Certos/Jogo",   sub:"Média de passes precisos por partida",     cor:"#fdf4ff", barCor:"#a855f7", bgVal:"#fdf4ff", fgVal:"#7e22ce", sufixo:"passes",  lista:Model.TimesPassesCertos),
                    (icone:"⚽", titulo:"Maior Posse de Bola",        sub:"Média de posse de bola por partida",       cor:"#fff1f2", barCor:"#f43f5e", bgVal:"#fff1f2", fgVal:"#be123c", sufixo:"%",       lista:Model.TimesPosseBola),
                };
            }
            @foreach (var sc in statsCards)
            {
                if (!sc.lista.Any()) { continue; }
                var maxVal = sc.lista.Max(x => x.Valor);
                <div class="rpt-card">
                    <div class="rpt-card-header">
                        <div class="rpt-card-icon" style="background:@sc.cor;">@sc.icone</div>
                        <div>
                            <h3 class="rpt-card-title">@sc.titulo</h3>
                            <p class="rpt-card-sub">@sc.sub</p>
                        </div>
                    </div>
                    @for (int i = 0; i < sc.lista.Count; i++)
                    {
                        var s = sc.lista[i];
                        var w = maxVal > 0 ? Math.Round(s.Valor / maxVal * 100, 1) : 0;
                        <div class="rpt-row">
                            <span class="rpt-rank @(i==0?"gold":i==1?"silver":i==2?"bronze":"")">@(i+1)</span>
                            @if (!string.IsNullOrEmpty(s.Time.EscudoUrl))
                            {
                                <img src="@Url.Action("Imagem", "MediaProxy", new { url = s.Time.EscudoUrl })" class="rpt-team-badge" />
                            }
                            <div class="rpt-name">
                                @s.Time.Nome
                                <small>@s.Jogos jogo(s) analisado(s)</small>
                            </div>
                            <div class="rpt-bar-wrap" style="max-width:70px;">
                                <div class="rpt-bar-bg">
                                    <div class="rpt-bar-fill" style="width:@w%;background:@sc.barCor;"></div>
                                </div>
                            </div>
                            <span class="rpt-badge-value" style="background:@sc.bgVal;color:@sc.fgVal;">@s.Valor @sc.sufixo</span>
                        </div>
                    }
                </div>
            }

        </div>
    </div>

    <!-- ══ SEÇÃO: RODADAS ══════════════════════════════════════════════════ -->
    <div id="sec-rodadas" class="rpt-section">
        @if (!Model.GolsPorRodada.Any())
        {
            <div class="rpt-card">
                <div style="padding:2rem;text-align:center;color:var(--text-muted);font-size:13px;">
                    Nenhum dado de rodada disponível.
                </div>
            </div>
        }
        else
        {
            <div class="rpt-card">
                <div class="rpt-card-header">
                    <div class="rpt-card-icon" style="background:#fef3c7;">📈</div>
                    <div>
                        <h3 class="rpt-card-title">Gols por Rodada</h3>
                        <p class="rpt-card-sub">Volume de gols e média por partida</p>
                    </div>
                </div>
                @{
                    var maxGR = Model.GolsPorRodada.Any() ? Model.GolsPorRodada.Max(r => r.TotalGols) : 1;
                }
                <div class="rodada-chart">
                    <div class="rodada-bars">
                        @foreach (var r in Model.GolsPorRodada)
                        {
                            var pct = maxGR > 0 ? (double)r.TotalGols / maxGR * 90 : 0;
                            <div class="rodada-bar-col">
                                <div class="rodada-bar-val">@r.TotalGols</div>
                                <div class="rodada-bar" style="height:@(Math.Max(4, pct))px;" title="Rodada @r.Rodada: @r.TotalGols gols em @r.Jogos jogo(s)"></div>
                                <div class="rodada-bar-label">R@r.Rodada</div>
                            </div>
                        }
                    </div>
                </div>

                <div style="overflow-x:auto;">
                    <table style="width:100%;border-collapse:collapse;font-size:12px;">
                        <thead>
                            <tr style="background:var(--surface-2);color:var(--text-muted);font-size:10px;text-transform:uppercase;">
                                <th style="padding:7px 16px;text-align:left;">Rodada</th>
                                <th style="padding:7px;text-align:center;">Jogos</th>
                                <th style="padding:7px;text-align:center;">Total Gols</th>
                                <th style="padding:7px;text-align:center;">Média / Jogo</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var r in Model.GolsPorRodada)
                            {
                                <tr style="border-bottom:.5px solid var(--border-subtle);">
                                    <td style="padding:8px 16px;font-weight:600;">Rodada @r.Rodada</td>
                                    <td style="text-align:center;">@r.Jogos</td>
                                    <td style="text-align:center;font-weight:700;color:#f59e0b;">@r.TotalGols</td>
                                    <td style="text-align:center;">@r.MediaGols</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    </div>

    <div id="sec-estat-jogadores" class="rpt-section">
        @{
            var rankingsEstat = new (string Titulo, string Sub, string Icone, string Cor, string Unidade, IEnumerable<ControleFutebolWeb.Models.ViewModels.RankingEstatJogador> Lista)[]
            {
                ("Média de Finalizações no Alvo", "Chutes que exigiram o goleiro por partida", "🎯", "#3b82f6", "/jogo", Model.RankFinalizacoesNoGol),
                ("Média de Passes-Chave",          "Passes que geraram chances claras por partida", "🎯", "#8b5cf6", "/jogo", Model.RankPassesChave),
                ("Média de Desarmes",              "Disputas defensivas vencidas por partida",      "⚔️", "#f59e0b", "/jogo", Model.RankDesarmes),
                ("Média de Bloqueios",             "Chutes/passes bloqueados por partida",          "🛡️", "#0ea5e9", "/jogo", Model.RankBloqueios),
                ("Média de Interceptações",        "Bolas interceptadas por partida",               "✋", "#10b981", "/jogo", Model.RankInterceptacoes),
                ("Média de Dribles Certos",        "Dribles bem-sucedidos por partida",             "💨", "#f97316", "/jogo", Model.RankDrilesCertos),
                ("Média de Impedimentos",          "Posições irregulares registradas por partida",  "🚩", "#ef4444", "/jogo", Model.RankImpedimentos),
                ("Pênaltis Defendidos",            "Total de pênaltis defendidos",                  "🧤", "#6366f1", "total", Model.RankPenaltisDefendidos),
            };
        }

        @if (!rankingsEstat.Any(r => r.Lista.Any()))
        {
            <div class="rpt-card">
                <div style="padding:2rem;text-align:center;color:var(--text-muted);font-size:13px;">
                    Nenhuma estatística individual disponível para os filtros selecionados.<br>
                    <small>As estatísticas são importadas via API ao analisar cada jogo.</small>
                </div>
            </div>
        }
        else
        {
            <div class="rpt-grid">
                @foreach (var (titulo, sub, icone, cor, unidade, lista) in rankingsEstat)
                {
                    <div class="rpt-card">
                        <div class="rpt-card-header">
                            <div class="rpt-card-icon" style="background:@(cor)22; font-size:18px;">@icone</div>
                            <div>
                                <h3 class="rpt-card-title">@titulo</h3>
                                <p class="rpt-card-sub">@sub</p>
                            </div>
                        </div>
                        @if (!lista.Any())
                        {
                            <div style="padding:1rem 0;text-align:center;color:var(--text-muted);font-size:12px;">Sem dados</div>
                        }
                        else
                        {
                            var maxVal = lista.Max(r => unidade == "total" ? r.Total : r.Media);
                            <ol style="list-style:none;padding:0;margin:0;">
                                @foreach (var item in lista)
                                {
                                    var val = unidade == "total" ? item.Total : item.Media;
                                    var bar = maxVal > 0 ? val / maxVal * 100 : 0;
                                    <li style="display:flex;align-items:center;gap:8px;padding:7px 0;border-bottom:.5px solid var(--border-subtle);">
                                        @{
                                            // Usa a seleção quando a competição filtrada é de seleções OU quando filtrado pela própria seleção
                                            bool usarSelecao = item.Jogador.Selecao != null
                                                && (Model.ExibirSelecao || (item.Jogador.SelecaoId.HasValue && Model.TimeIdsFiltro.Contains(item.Jogador.SelecaoId.Value)));
                                            var logoUrl = usarSelecao ? item.Jogador.Selecao?.EscudoUrl : item.Jogador.Time?.EscudoUrl;
                                            var nomeAbrev = usarSelecao ? item.Jogador.Selecao?.Nome : item.Jogador.Time?.Nome;
                                        }
                                        <div style="width:26px;height:26px;border-radius:50%;overflow:hidden;border:1px solid var(--border);background:var(--surface-3);flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:9px;font-weight:600;color:var(--text-muted);">
                                            @if (!string.IsNullOrWhiteSpace(logoUrl))
                                            {
                                                <img src="@Url.Action("Imagem", "MediaProxy", new { url = logoUrl })" style="width:100%;height:100%;object-fit:contain;" />
                                            }
                                            else
                                            {
                                                @(nomeAbrev?.Length >= 3 ? nomeAbrev[..3].ToUpper() : nomeAbrev)
                                            }
                                        </div>
                                        <div style="flex:1;min-width:0;">
                                            <div style="font-size:12px;font-weight:600;color:inherit;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">
                                                <a asp-controller="Jogadores" asp-action="Estatisticas" asp-route-id="@item.Jogador.Id" style="color:inherit;text-decoration:none;">@item.Jogador.Nome</a>
                                            </div>
                                            <div style="height:4px;background:var(--surface-3);border-radius:2px;margin-top:3px;">
                                                <div style="height:100%;width:@(bar.ToString("F1", System.Globalization.CultureInfo.InvariantCulture))%;background:@cor;border-radius:2px;"></div>
                                            </div>
                                        </div>
                                        <div style="text-align:right;flex-shrink:0;">
                                            <div style="font-size:14px;font-weight:700;color:@cor;">@(unidade == "total" ? val.ToString("F0") : val.ToString("F2"))</div>
                                            <div style="font-size:10px;color:var(--text-muted);">@(unidade == "total" ? $"{item.Partidas} jogo(s)" : $"{item.Partidas} jogo(s)")</div>
                                        </div>
                                    </li>
                                }
                            </ol>
                        }
                    </div>
                }
            </div>
        }
    </div>

    <!-- ══ SEÇÃO: ESTATÍSTICAS COMPETIÇÕES ══════════════════════════════════ -->
    <div id="sec-estat-competicoes" class="rpt-section">
        @if (!Model.EstatisticasCompeticoes.Any())
        {
            <p style="text-align:center;color:var(--text-muted);padding:2rem;">Nenhuma competição com jogos analisados.</p>
        }
        else
        {
            foreach (var ec in Model.EstatisticasCompeticoes)
            {
                <div style="background:#0f172a;border:1px solid #1e293b;border-radius:16px;padding:1.5rem;margin-bottom:1.5rem;">
                    <!-- Cabeçalho da competição -->
                    <div style="display:flex;align-items:center;gap:.75rem;margin-bottom:1.25rem;border-bottom:1px solid #1e293b;padding-bottom:1rem;">
                        <div>
                            <div style="font-family:'Barlow Condensed',sans-serif;font-size:20px;font-weight:800;color:#f1f5f9;letter-spacing:.5px;">@ec.Competicao.Nome</div>
                            <div style="font-size:12px;color:#94a3b8;">@ec.TotalJogos jogo(s) · @ec.JogosAnalisados analisado(s)</div>
                        </div>
                    </div>

                    <!-- Grid de estatísticas -->
                    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(180px,1fr));gap:1rem;margin-bottom:1.25rem;">
                        @{
                            void StatBox(string label, string valor, string cor, string icone)
                            {
                                <div style="background:#1e293b;border-radius:10px;padding:.9rem 1rem;">
                                    <div style="font-size:11px;color:#94a3b8;text-transform:uppercase;letter-spacing:1px;margin-bottom:.3rem;">@icone @label</div>
                                    <div style="font-size:22px;font-weight:800;font-family:'Barlow Condensed',sans-serif;color:@cor;">@valor</div>
                                </div>
                            }
                        }
                        @{ StatBox("Gols", ec.TotalGols.ToString(), "#22c55e", "⚽"); }
                        @{ StatBox("Gols contra", ec.TotalGolsContra.ToString(), "#ef4444", "🙈"); }
                        @{ StatBox("Média gols/jogo", ec.MediaGolsPorJogo.ToString("F2"), "#f59e0b", "📊"); }
                        @{ StatBox("Cartões amarelos", ec.TotalCartaoAmarelo.ToString(), "#fbbf24", "🟨"); }
                        @{ StatBox("Cartões vermelhos", ec.TotalCartaoVermelho.ToString(), "#ef4444", "🟥"); }
                        @{ StatBox("Média cartões/jogo", ec.MediaCartoesPorJogo.ToString("F2"), "#94a3b8", "📋"); }
                    </div>

                    <!-- Resultados: vitórias mandante / empate / visitante -->
                    <div style="margin-bottom:1.25rem;">
                        <div style="font-size:11px;color:#94a3b8;text-transform:uppercase;letter-spacing:1px;margin-bottom:.6rem;">Resultados</div>
                        <div style="display:flex;gap:0;border-radius:8px;overflow:hidden;height:36px;">
                            @if (ec.TotalJogos > 0)
                            {
                                <div style="flex:@ec.PctVitoriasMandante;background:#22c55e;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:700;color:#fff;min-width:30px;" title="Mandante @ec.PctVitoriasMandante%">
                                    @ec.PctVitoriasMandante%
                                </div>
                                <div style="flex:@ec.PctEmpates;background:#6b7280;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:700;color:#fff;min-width:30px;" title="Empates @ec.PctEmpates%">
                                    @ec.PctEmpates%
                                </div>
                                <div style="flex:@ec.PctVitoriasVisitante;background:#3b82f6;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:700;color:#fff;min-width:30px;" title="Visitante @ec.PctVitoriasVisitante%">
                                    @ec.PctVitoriasVisitante%
                                </div>
                            }
                        </div>
                        <div style="display:flex;gap:1.5rem;margin-top:.5rem;">
                            <span style="font-size:11px;color:#22c55e;">🟢 Mandante: @ec.VitoriasMandante</span>
                            @* Bloco sempre-escuro: cinza fixo, não usa token (no tema claro o token escurece) *@
                            <span style="font-size:11px;color:#9ca3af;">⬜ Empates: @ec.Empates</span>
                            <span style="font-size:11px;color:#3b82f6;">🔵 Visitante: @ec.VitoriasVisitante</span>
                        </div>
                    </div>

                    <!-- Destaques: artilheiro, assistente, time, jogo -->
                    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:.75rem;">
                        @if (!string.IsNullOrEmpty(ec.ArtilheiroNome))
                        {
                            <div style="background:#1e293b;border-radius:10px;padding:.8rem 1rem;">
                                <div style="font-size:10px;color:#94a3b8;text-transform:uppercase;letter-spacing:1px;">⚽ Artilheiro</div>
                                <div style="display:flex;align-items:center;gap:.4rem;margin-top:.25rem;">
                                    @if (!string.IsNullOrEmpty(ec.ArtilheiroEscudoUrl))
                                    {
                                        <img src="@Url.Action("Imagem", "MediaProxy", new { url = ec.ArtilheiroEscudoUrl })" alt="" style="width:20px;height:20px;object-fit:contain;flex-shrink:0;" />
                                    }
                                    <a asp-controller="Jogadores" asp-action="Estatisticas" asp-route-id="@ec.ArtilheiroId"
                                       style="font-size:14px;font-weight:700;color:#f1f5f9;text-decoration:none;">@ec.ArtilheiroNome</a>
                                </div>
                                <div style="font-size:12px;color:#22c55e;">@ec.ArtilheiroGols gol(s)</div>
                            </div>
                        }
                        @if (!string.IsNullOrEmpty(ec.AssistenteNome))
                        {
                            <div style="background:#1e293b;border-radius:10px;padding:.8rem 1rem;">
                                <div style="font-size:10px;color:#94a3b8;text-transform:uppercase;letter-spacing:1px;">🎯 Mais assistências</div>
                                <div style="display:flex;align-items:center;gap:.4rem;margin-top:.25rem;">
                                    @if (!string.IsNullOrEmpty(ec.AssistenteEscudoUrl))
                                    {
                                        <img src="@Url.Action("Imagem", "MediaProxy", new { url = ec.AssistenteEscudoUrl })" alt="" style="width:20px;height:20px;object-fit:contain;flex-shrink:0;" />
                                    }
                                    <a asp-controller="Jogadores" asp-action="Estatisticas" asp-route-id="@ec.AssistenteId"
                                       style="font-size:14px;font-weight:700;color:#f1f5f9;text-decoration:none;">@ec.AssistenteNome</a>
                                </div>
                                <div style="font-size:12px;color:#3b82f6;">@ec.AssistenciasTotal assist.</div>
                            </div>
                        }
                        @if (!string.IsNullOrEmpty(ec.TimeMaisVitorias))
                        {
                            <div style="background:#1e293b;border-radius:10px;padding:.8rem 1rem;">
                                <div style="font-size:10px;color:#94a3b8;text-transform:uppercase;letter-spacing:1px;">🏆 Mais vitórias</div>
                                <div style="display:flex;align-items:center;gap:.4rem;margin-top:.25rem;">
                                    @if (!string.IsNullOrEmpty(ec.TimeMaisVitoriasEscudoUrl))
                                    {
                                        <img src="@Url.Action("Imagem", "MediaProxy", new { url = ec.TimeMaisVitoriasEscudoUrl })" alt="" style="width:20px;height:20px;object-fit:contain;flex-shrink:0;" />
                                    }
                                    <span style="font-size:14px;font-weight:700;color:#f1f5f9;">@ec.TimeMaisVitorias</span>
                                </div>
                                <div style="font-size:12px;color:#f59e0b;">@ec.TimeMaisVitoriasQtd vitória(s)</div>
                            </div>
                        }
                        @if (!string.IsNullOrEmpty(ec.JogoMaisGols))
                        {
                            <div style="background:#1e293b;border-radius:10px;padding:.8rem 1rem;">
                                <div style="font-size:10px;color:#94a3b8;text-transform:uppercase;letter-spacing:1px;">🔥 Jogo com mais gols</div>
                                <div style="font-size:13px;font-weight:700;color:#f1f5f9;margin-top:.25rem;">@ec.JogoMaisGols</div>
                                <div style="font-size:12px;color:#ef4444;">@ec.JogoMaisGolsTotal gol(s)</div>
                            </div>
                        }
                    </div>
                </div>
            }
        }
    </div>

    </div><!-- /.rpt-main -->
</div><!-- /.rpt-root -->

<script>
    function showSection(name) {
        document.querySelectorAll('.rpt-section').forEach(s => s.classList.remove('visible'));
        document.querySelectorAll('.rpt-tab').forEach(t => t.classList.remove('active'));
        document.getElementById('sec-' + name)?.classList.add('visible');
        event.currentTarget.classList.add('active');
    }
</script>
