                            <div class="rpt-avatar"><img src="@Url.Action("Imagem", "MediaProxy", new { url = a.Jogador.FotoUrl })" /></div>
                        }
                        else { <div class="rpt-avatar">@(a.Jogador.Nome.Length >= 2 ? a.Jogador.Nome.Substring(0,2).ToUpper() : "?")</div> }
