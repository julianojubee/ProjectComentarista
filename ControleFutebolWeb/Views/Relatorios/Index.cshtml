                    <div style="padding:1.5rem;text-align:center;color:var(--text-muted);font-size:13px;">Nenhuma escalação registrada.</div>
                }
                @{
                    var maxP = Model.MaisPartidas.Any() ? Model.MaisPartidas.Max(a => a.Valor) : 1;
                }
                @for (int i = 0; i < Model.MaisPartidas.Count; i++)
                {
                    var a = Model.MaisPartidas[i];
                    var w = Math.Round((double)a.Valor / maxP * 100, 1);
                    <div class="rpt-row">
                        <span class="rpt-rank @(i==0?"gold":i==1?"silver":i==2?"bronze":"")">@(i+1)</span>
