    <!-- ══ SEÇÃO: NOTAS ══════════════════════════════════════════════════════ -->
    <div id="sec-notas" class="rpt-section visible">

        <!-- Explicação da métrica -->
        <div class="rpt-metric-box">
            <div class="rpt-metric-icon">📐</div>
            <div class="rpt-metric-text">
                <h4>Como a Nota Final é calculada</h4>
                <p>
                    Cada jogador começa com <strong>4 pontos</strong> de base.<br />
                    A isso se somam as <strong>ações avaliadas</strong> no jogo
                    (passes, dribles, gols, etc.), cada uma multiplicada pelo peso definido em
                    <strong>Cadastros &gt; Critérios de Nota</strong>.
                    Goleiros e defensores ganham ainda <strong>+2 pts</strong> quando o time não sofre gol.
                    Nota final limitada entre 4 e 10.
                </p>
            </div>
        </div>

        <div class="rpt-grid">
            <!-- Ranking de Notas -->
            <div class="rpt-card" style="grid-column: 1 / -1;">
                <div class="rpt-card-header">
                    <div class="rpt-card-icon" style="background:#fef3c7;">⭐</div>
                    <div>
                        <h3 class="rpt-card-title">Ranking de Desempenho</h3>
                        <p class="rpt-card-sub">Top 20 jogadores por média das notas finais (base 4 + ações, mínima 4)</p>
                    </div>
                </div>

                @if (!Model.RankingNotas.Any())
                {
                    <div style="padding:2rem;text-align:center;color:var(--text-muted);font-size:13px;">
                        Nenhuma avaliação registrada ainda. Avalie jogadores na tela de análise de jogo.
                    </div>
                }
                else
                {
                    <div style="overflow-x:auto;">
                        <table style="width:100%;border-collapse:collapse;">
                            <thead>
                                <tr style="background:var(--surface-2);font-size:10px;color:var(--text-muted);text-transform:uppercase;letter-spacing:.5px;">
                                    <th style="padding:8px 16px;text-align:left;width:32px;">#</th>
                                    <th style="padding:8px 8px;text-align:left;">Jogador</th>
                                    <th style="padding:8px;text-align:center;">Nota</th>
                                    <th style="padding:8px;text-align:center;min-width:120px;">Decomposição</th>
                                    <th style="padding:8px;text-align:center;">J</th>
                                    <th style="padding:8px;text-align:center;">V</th>
                                    <th style="padding:8px;text-align:center;">E</th>
                                    <th style="padding:8px;text-align:center;">D</th>
                                </tr>
                            </thead>
                            <tbody>
                                @for (int i = 0; i < Model.RankingNotas.Count; i++)
                                {
                                    var item = Model.RankingNotas[i];
                                    var pos = item.Jogador.Posicao ?? "";
                                    var posCls = pos.ToUpper() switch {
                                        "GL" => "pos-GL",
                                        "ZG" or "ZG." => "pos-ZG",
                                        "MC" => "pos-MC",
                                        "AT" => "pos-AT",
                                        var s when s.Contains("GOL") => "pos-GL",
                                        var s when s.Contains("ZAG") || s.Contains("LAT") || s.Contains("DEF") => "pos-ZG",
                                        var s when s.Contains("MEI") || s.Contains("VOL") => "pos-MC",
                                        var s when s.Contains("ATA") || s.Contains("PON") || s.Contains("CEN") => "pos-AT",
                                        _ => "pos-xx"
                                    };
                                    <tr style="border-bottom:.5px solid var(--border-subtle);font-size:12px;" onmouseover="this.style.background='var(--hover-warm)'" onmouseout="this.style.background=''">
                                        <td style="padding:9px 16px;font-weight:700;color:@(i==0?"#f59e0b":i==1?"#9ca3af":i==2?"#b45309":"#d1d5db");">
                                            @(i + 1)
                                        </td>
                                        <td style="padding:9px 8px;">
                                            <div style="display:flex;align-items:center;gap:8px;">
                                                @if (!string.IsNullOrEmpty(item.Jogador.FotoUrl))
                                                {
                                                    <img src="@Url.Action("Imagem", "MediaProxy", new { url = item.Jogador.FotoUrl })" style="width:30px;height:30px;border-radius:50%;object-fit:cover;border:.5px solid var(--border);" />
                                                }
                                                else
                                                {
                                                    <div style="width:30px;height:30px;border-radius:50%;background:var(--surface-3);border:.5px solid var(--border);display:flex;align-items:center;justify-content:center;font-size:11px;color:var(--text-muted);">👤</div>
                                                }
                                                <div>
                                                    <a asp-controller="Jogadores" asp-action="Estatisticas" asp-route-id="@item.Jogador.Id"
                                                       style="font-weight:600;color:inherit;text-decoration:none;">@item.Jogador.Nome</a>
                                                    <div style="display:flex;gap:4px;margin-top:2px;">
                                                        <span class="pos-badge @posCls">@(string.IsNullOrEmpty(pos) ? "—" : pos)</span>
                                                        @{ var teRank = TimeExibicao(item.Jogador); }
                                                        @if (!string.IsNullOrEmpty(teRank.Nome))
                                                        {
                                                            <span style="font-size:10px;color:var(--text-muted);display:inline-flex;align-items:center;gap:3px;">
                                                                @if (!string.IsNullOrEmpty(teRank.Escudo))
                                                                {
                                                                    <img src="@Url.Action("Imagem", "MediaProxy", new { url = teRank.Escudo })" style="width:12px;height:12px;border-radius:50%;object-fit:cover;" />
                                                                }
                                                                @teRank.Nome
                                                            </span>
                                                        }
                                                    </div>
                                                </div>
                                            </div>
                                        </td>
                                        <td style="padding:9px 8px;text-align:center;">
                                            <div class="nota-circle" style="color:@item.NotaColor;margin:0 auto;">
                                                <span class="nota-num">@item.NotaFinal.ToString("0.0")</span>
                                                <span class="nota-lbl">@item.NotaLabel</span>
                                            </div>
                                        </td>
                                        <td style="padding:9px 12px;min-width:160px;">
                                            <div style="font-size:10px;color:var(--text-muted);display:flex;flex-direction:column;gap:2px;">
                                                <div style="display:flex;justify-content:space-between;font-weight:700;color:inherit;">
                                                    <span>Nota</span>
                                                    <span>@item.NotaFinal.ToString("0.00")</span>
                                                </div>
                                            </div>
                                        </td>
                                        <td style="text-align:center;font-weight:600;">@item.Partidas</td>
                                        <td style="text-align:center;color:#16a34a;font-weight:600;">@item.Vitorias</td>
                                        <td style="text-align:center;color:#d97706;font-weight:600;">@item.Empates</td>
                                        <td style="text-align:center;color:#dc2626;font-weight:600;">@item.Derrotas</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>

            <!-- Rankings por posição -->
            @{
                var rankingsPosicao = new[]
                {
                    (icone: "🧤", titulo: "Melhores Goleiros",   cor: "#dbeafe", lista: Model.RankingGoleiros),
                    (icone: "🛡️", titulo: "Melhores Defensores", cor: "#dcfce7", lista: Model.RankingDefensores),
                    (icone: "⚙️",  titulo: "Melhores Meias",      cor: "#fef9c3", lista: Model.RankingMeias),
                    (icone: "⚡",  titulo: "Melhores Atacantes",  cor: "#fee2e2", lista: Model.RankingAtacantes),
                };
            }
            @foreach (var rp in rankingsPosicao)
            {
                if (!rp.lista.Any()) { continue; }
                <div class="rpt-card">
                    <div class="rpt-card-header">
                        <div class="rpt-card-icon" style="background:@rp.cor;">@rp.icone</div>
                        <div>
                            <h3 class="rpt-card-title">@rp.titulo</h3>
                            <p class="rpt-card-sub">Top 10 por nota média</p>
                        </div>
                    </div>
                    @for (int i = 0; i < rp.lista.Count; i++)
                    {
                        var item = rp.lista[i];
                        <div class="rpt-row">
                            <div style="width:20px;font-size:11px;font-weight:700;color:@(i==0?"#f59e0b":i==1?"#9ca3af":i==2?"#b45309":"#d1d5db");">@(i+1)</div>
                            @if (!string.IsNullOrEmpty(item.Jogador.FotoUrl))
                            {
                                <img src="@Url.Action("Imagem", "MediaProxy", new { url = item.Jogador.FotoUrl })" style="width:26px;height:26px;border-radius:50%;object-fit:cover;border:.5px solid var(--border);flex-shrink:0;" />
                            }
                            else
                            {
                                <div style="width:26px;height:26px;border-radius:50%;background:var(--surface-3);display:flex;align-items:center;justify-content:center;font-size:10px;color:var(--text-muted);flex-shrink:0;">👤</div>
                            }
                            <div style="flex:1;min-width:0;">
                                <a asp-controller="Jogadores" asp-action="Estatisticas" asp-route-id="@item.Jogador.Id"
                                   style="font-size:12px;font-weight:600;color:inherit;text-decoration:none;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;display:block;">
                                    @item.Jogador.Nome
                                </a>
                                @{ var teItem = TimeExibicao(item.Jogador); }
                                @if (!string.IsNullOrEmpty(teItem.Nome))
                                {
                                    <div style="font-size:10px;color:var(--text-muted);">
                                        @if (!string.IsNullOrEmpty(teItem.Escudo))
                                        {
                                            <img src="@Url.Action("Imagem", "MediaProxy", new { url = teItem.Escudo })" style="width:12px;height:12px;border-radius:50%;object-fit:cover;vertical-align:middle;margin-right:3px;" />
                                        }
                                        @teItem.Nome · @item.Partidas j
                                    </div>
                                }
                            </div>
                            <div class="nota-circle" style="color:@item.NotaColor;width:38px;height:38px;flex-shrink:0;">
                                <span class="nota-num" style="font-size:13px;">@item.NotaFinal.ToString("0.0")</span>
                                <span class="nota-lbl">@item.NotaLabel</span>
                            </div>
                        </div>
                    }
                </div>
            }

            <!-- Médias por posição -->
            @if (Model.MediasPorPosicao.Any())
            {
                <div class="rpt-card">
                    <div class="rpt-card-header">
                        <div class="rpt-card-icon" style="background:#f0fdf4;">🧩</div>
                        <div>
                            <h3 class="rpt-card-title">Média por Posição</h3>
                            <p class="rpt-card-sub">Desempenho médio agrupado por função</p>
                        </div>
                    </div>
                    @foreach (var mp in Model.MediasPorPosicao)
                    {
                        var barWidth = Math.Round((mp.Media / 10.0) * 100, 1);
                        <div class="rpt-row">
                            <div style="width:90px;font-size:12px;font-weight:600;color:var(--text-2);">@mp.Posicao</div>
                            <div class="rpt-bar-wrap">
                                <div class="rpt-bar-bg">
                                    <div class="rpt-bar-fill" style="width:@barWidth%;background:linear-gradient(90deg,#f59e0b,#fbbf24);"></div>
                                </div>
                            </div>
                            <div style="font-size:13px;font-weight:700;color:inherit;min-width:36px;text-align:right;">@mp.Media</div>
                            <div style="font-size:10px;color:var(--text-muted);min-width:40px;text-align:right;">@mp.TotalJogadores jog.</div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>

    <!-- ══ SEÇÃO: GOLS ══════════════════════════════════════════════════════ -->
    <div id="sec-gols" class="rpt-section">
        <div class="rpt-grid">

            <!-- Artilheiros -->
