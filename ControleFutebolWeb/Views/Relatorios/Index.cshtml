                                <div class="rpt-bar-fill" style="width:@w%;background:#3b82f6;"></div>
                            </div>
                        </div>
                        <span class="rpt-badge-value" style="background:#eff6ff;color:#1d4ed8;">@a.Valor</span>
                    </div>
                }
            </div>
        </div>
    </div>

