@* ControleFutebolWeb/Views/Relatorios/Index.cshtml *@
@model ControleFutebolWeb.Models.ViewModels.RelatoriosViewModel
@removeTagHelper Microsoft.AspNetCore.Mvc.TagHelpers.OptionTagHelper, Microsoft.AspNetCore.Mvc.TagHelpers
@{
    ViewData["Title"] = "Relatórios";
}

@functions {
    // Retorna nome e escudo do time a exibir: seleção quando a competição filtrada é de seleções, senão o clube
    (string Nome, string? Escudo) TimeExibicao(ControleFutebolWeb.Models.Jogador? j)
    {
        if (j == null) return ("", null);
        if (Model.ExibirSelecao && j.Selecao != null)
            return (j.Selecao.Nome, j.Selecao.EscudoUrl);
        return (j.Time?.Nome ?? "", j.Time?.EscudoUrl);
    }
}

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;600;700;800;900&family=Barlow:wght@400;500;600&display=swap');

    /* ── Reset ─────────────────────────────────────────────────────────── */
    .rpt-root * { box-sizing: border-box; }

    /* Página sempre no tema escuro/dourado (mesmo padrão das telas já
       convertidas — Home, Times, Jogadores, Jogos, Competições), independente
       do toggle claro/escuro do site. O tom âmbar continua sendo a identidade
       desta tela específica (Central de Dados). */
    .rpt-root {
        margin: 0 -12px;
        background: #0f0f0f;
        border-radius: 14px;
        overflow: hidden;
        color: #e5e7eb;
        font-family: 'Barlow', Arial, sans-serif;

        --hover-warm: rgba(245, 158, 11, .08);
        --amber-text: #fbbf24;
        --surface: #161616;
        --surface-2: #1a1a1a;
        --surface-3: #222222;
        --border: #262626;
        --border-strong: #333333;
        --border-subtle: #1e1e1e;
        --text: #f1f5f9;
        --text-2: #e5e7eb;
        --text-muted: #6b7280;
        --input-bg: #1a1a1a;
    }

    /* ── Hero ──────────────────────────────────────────────────────────── */
    .rpt-hero {
        position: relative;
        background: linear-gradient(135deg, #0a1628 0%, #111e35 55%, #0a1628 100%);
        padding: 44px 2.5rem 38px;
        overflow: hidden;
    }
    .rpt-hero-stripe { position: absolute; left: 0; top: 0; bottom: 0; width: 4px; background: #d4a520; }
    .rpt-hero-fade { position: absolute; bottom: 0; left: 0; right: 0; height: 60px; background: linear-gradient(to top, #0f0f0f, transparent); pointer-events: none; }
    .rpt-hero::before {
        content: "";
        position: absolute;
        inset: 0;
        opacity: .07;
        background-image:
            radial-gradient(circle at 50% 50%, transparent 28%, #fff 28.5%, #fff 29.2%, transparent 29.8%),
            linear-gradient(90deg, transparent 49.5%, #fff 49.5%, #fff 50.5%, transparent 50.5%),
            linear-gradient(transparent 49.5%, #fff 49.5%, #fff 50.5%, transparent 50.5%);
    }
    .rpt-hero-content { position: relative; z-index: 1; text-align: center; }
    .rpt-hero-badge {
        display: inline-block;
        background: rgba(245,158,11,.15);
        color: #fbbf24;
        font-family: 'Barlow Condensed', sans-serif;
        font-size: 11px; font-weight: 700; letter-spacing: 1.5px; text-transform: uppercase;
        padding: 4px 14px; border-radius: 999px;
        border: 1px solid rgba(245,158,11,.3);
        margin-bottom: .8rem;
    }
    .rpt-hero h1 {
        font-family: 'Barlow Condensed', sans-serif;
        font-size: 2.4rem; font-weight: 900; color: #fff;
        letter-spacing: -.3px; margin: 0 0 .4rem;
    }
    .rpt-hero p { color: rgba(255,255,255,.55); margin: 0; font-size: .9rem; }

    /* ── Filtro ─────────────────────────────────────────────────────────── */
    .rpt-filter {
        display: flex; align-items: center; gap: 10px; flex-wrap: wrap;
        margin-bottom: 1.4rem;
        padding: .85rem 1rem;
        background: var(--surface); border: .5px solid var(--border); border-radius: 12px;
    }
    .rpt-filter label { font-size: 12px; font-weight: 600; color: var(--text-2); }
    .rpt-filter select {
        border: 1px solid var(--border-strong); border-radius: 8px;
        padding: 7px 12px; font-size: 13px; color: var(--text);
        background: var(--input-bg);
    }
    .rpt-filter button {
        padding: 8px 16px; border-radius: 8px;
        background: #f59e0b; color: #fff; border: none;
        font-size: 13px; font-weight: 600; cursor: pointer;
    }
    .rpt-filter button:hover { background: #d97706; }
    .rpt-filter .rpt-clear {
        background: var(--surface-3); color: var(--text-2); border: .5px solid var(--border);
        font-weight: 500;
    }
    .rpt-filter .rpt-clear:hover { background: var(--border); }
    .rpt-check-wrap {
        display: flex; align-items: center; gap: 7px;
        padding: 6px 12px; border-radius: 8px;
        border: 1px solid var(--border); background: var(--surface-2);
        cursor: pointer; user-select: none;
        transition: border-color .15s, background .15s;
    }
    .rpt-check-wrap:hover { border-color: #f59e0b; background: var(--hover-warm); }
    .rpt-check-wrap input[type=checkbox] { accent-color: #f59e0b; width: 15px; height: 15px; cursor: pointer; }
    .rpt-check-wrap span { font-size: 12px; font-weight: 600; color: var(--text-2); }

    /* ── Toolbar (alertas, scout, filtros) ───────────────────────────────── */
    .rpt-toolbar { padding: 20px 2.5rem 0; }
    .rpt-toolbar .alert-success {
        background: rgba(34,197,94,.1); border: 1px solid rgba(34,197,94,.3); color: #4ade80;
    }
    .rpt-toolbar .alert-success .btn-close { filter: invert(1); }

    /* ── Totalizadores ───────────────────────────────────────────────────── */
    .rpt-totals-bar { background: #111; border-bottom: 1px solid #1a1a1a; padding: 0 2.5rem; }
    .rpt-totals {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));
        max-width: 1544px; margin: 0 auto;
    }
    .rpt-total-card {
        background: none; border: none; border-right: 1px solid #1a1a1a;
        border-radius: 0; padding: 16px 12px; text-align: center;
    }
    .rpt-total-num {
        font-family: 'Barlow Condensed', sans-serif;
        font-size: 1.7rem; font-weight: 800; color: #fbbf24;
        line-height: 1; margin-bottom: 3px;
    }
    .rpt-total-label { font-size: .6rem; color: rgba(255,255,255,.35); text-transform: uppercase; letter-spacing: .1em; font-weight: 700; }

    /* ── Tabs ────────────────────────────────────────────────────────────── */
    .rpt-tabs-bar {
        background: #111; border-bottom: 1px solid #1e1e1e; padding: 0 2.5rem;
        position: sticky; top: 62px; z-index: 50;
    }
    .rpt-tabs {
        display: flex; gap: 0; overflow-x: auto; max-width: 1544px; margin: 0 auto;
    }
    .rpt-tab {
        padding: 14px 18px; border-radius: 0;
        border: none; background: transparent; border-bottom: 2px solid transparent;
        font-size: .8rem; font-weight: 600; color: var(--text-muted);
        cursor: pointer; transition: color .15s; user-select: none; white-space: nowrap;
    }
    .rpt-tab:hover { color: var(--amber-text); }
    .rpt-tab.active {
        background: transparent; color: var(--amber-text); font-weight: 700;
        border-bottom-color: var(--amber-text); box-shadow: none;
    }

    /* ── Conteúdo ────────────────────────────────────────────────────────── */
    .rpt-main { padding: 24px 2.5rem 48px; max-width: 1544px; margin: 0 auto; }

    /* ── Seções ──────────────────────────────────────────────────────────── */
    .rpt-section { display: none; }
    .rpt-section.visible { display: block; }

    /* ── Grid de cards ───────────────────────────────────────────────────── */
    .rpt-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
        gap: 14px;
    }

    /* ── Card ────────────────────────────────────────────────────────────── */
    .rpt-card {
        background: var(--surface); border: .5px solid var(--border);
        border-radius: 14px; overflow: hidden;
    }
    .rpt-card-header {
        padding: 12px 16px 10px;
        border-bottom: .5px solid var(--border-subtle);
        display: flex; align-items: center; gap: 8px;
    }
    .rpt-card-icon {
        width: 28px; height: 28px; border-radius: 8px;
        display: flex; align-items: center; justify-content: center;
        font-size: 14px; flex-shrink: 0;
    }
    .rpt-card-title {
        font-family: 'Barlow Condensed', sans-serif;
        font-size: 1rem; font-weight: 700; color: var(--text);
        text-transform: uppercase; letter-spacing: .5px;
        margin: 0;
    }
    .rpt-card-sub { font-size: 11px; color: var(--text-muted); margin: 0; }

    /* ── Linha de ranking ────────────────────────────────────────────────── */
    .rpt-row {
        display: flex; align-items: center; gap: 10px;
        padding: 9px 16px; border-bottom: .5px solid var(--border-subtle);
        font-size: 13px; transition: background .12s;
    }
    .rpt-row:last-child { border-bottom: none; }
    .rpt-row:hover { background: var(--hover-warm); }

    .rpt-rank {
        width: 22px; font-size: 11px; font-weight: 700;
        color: var(--text-muted); text-align: center; flex-shrink: 0;
    }
    .rpt-rank.gold   { color: #f59e0b; }
    .rpt-rank.silver { color: #9ca3af; }
    .rpt-rank.bronze { color: #b45309; }

    .rpt-avatar {
        width: 32px; height: 32px; border-radius: 50%;
        background: var(--surface-3); border: .5px solid var(--border);
        display: flex; align-items: center; justify-content: center;
        font-size: 10px; font-weight: 700; color: var(--text-muted);
        overflow: hidden; flex-shrink: 0;
    }
    .rpt-avatar img { width: 100%; height: 100%; object-fit: cover; }

    .rpt-name { flex: 1; font-weight: 500; color: var(--text); min-width: 0; }
    .rpt-name small { display: block; font-size: 11px; color: var(--text-muted); font-weight: 400; }

    .rpt-badge-value {
        padding: 3px 10px; border-radius: 6px;
        font-size: 12px; font-weight: 700;
        flex-shrink: 0;
    }

    /* ── Nota badge ──────────────────────────────────────────────────────── */
    .nota-circle {
        width: 44px; height: 44px; border-radius: 50%;
        display: flex; flex-direction: column; align-items: center; justify-content: center;
        font-family: 'Barlow Condensed', sans-serif;
        flex-shrink: 0;
        border: 2px solid currentColor;
    }
    .nota-num  { font-size: 15px; font-weight: 800; line-height: 1; }
    .nota-lbl  { font-size: 8px; font-weight: 600; opacity: .7; letter-spacing: .3px; }

    /* ── Barra de progresso ──────────────────────────────────────────────── */
    .rpt-bar-wrap { flex: 1; }
    .rpt-bar-bg { background: var(--surface-3); border-radius: 4px; height: 6px; overflow: hidden; }
    .rpt-bar-fill { height: 100%; border-radius: 4px; transition: width .4s; }

    /* ── Nota breakdown row ───────────────────────────────────────────────── */
    .nota-meta {
        display: flex; gap: 12px; flex-wrap: wrap;
        font-size: 10px; color: var(--text-muted); margin-top: 2px;
    }
    .nota-meta span { display: flex; align-items: center; gap: 3px; }

    /* ── Time row ─────────────────────────────────────────────────────────── */
    .rpt-team-badge {
        width: 26px; height: 26px; border-radius: 50%;
        border: .5px solid var(--border); background: var(--surface-2);
        object-fit: contain; flex-shrink: 0;
    }

    /* ── Métrica explicativa ──────────────────────────────────────────────── */
    .rpt-metric-box {
        background: rgba(245,158,11,.08);
        border: 1px solid rgba(245,158,11,.25); border-radius: 12px;
        padding: 1rem 1.2rem; margin-bottom: 1.2rem;
        display: flex; gap: 12px; align-items: flex-start;
    }
    .rpt-metric-icon { font-size: 24px; flex-shrink: 0; line-height: 1; }
    .rpt-metric-text h4 { font-size: 13px; font-weight: 700; color: #fbbf24; margin: 0 0 4px; }
    .rpt-metric-text p  { font-size: 12px; color: rgba(255,255,255,.6); margin: 0; line-height: 1.5; }
    .rpt-chip {
        display: inline-flex; align-items: center; gap: 4px;
        padding: 2px 8px; border-radius: 999px;
        font-size: 11px; font-weight: 600;
    }

    /* ── Gols por rodada ─────────────────────────────────────────────────── */
    .rodada-chart { padding: 14px 16px; }
    .rodada-bars { display: flex; gap: 4px; align-items: flex-end; height: 100px; }
    .rodada-bar-col { flex: 1; display: flex; flex-direction: column; align-items: center; gap: 3px; }
    .rodada-bar {
        width: 100%; min-height: 4px; border-radius: 3px 3px 0 0;
        background: linear-gradient(180deg, #f59e0b, #d97706);
        transition: height .3s;
    }
    .rodada-bar-label { font-size: 9px; color: var(--text-muted); }
    .rodada-bar-val   { font-size: 10px; font-weight: 700; color: var(--text-2); }

    /* ── Posição badge ───────────────────────────────────────────────────── */
    .pos-badge {
        font-size: 10px; font-weight: 700; padding: 2px 7px;
        border-radius: 5px; text-transform: uppercase; letter-spacing: .3px;
    }
    .pos-GL { background: rgba(59,130,246,.15); color: #60a5fa; }
    .pos-ZG { background: rgba(34,197,94,.15); color: #4ade80; }
    .pos-MC { background: rgba(168,85,247,.15); color: #c084fc; }
    .pos-AT { background: rgba(249,115,22,.15); color: #fb923c; }
    .pos-xx { background: var(--surface-2); color: var(--text-muted); }

    @@media (max-width: 600px) {
        .rpt-grid { grid-template-columns: 1fr; }
        .rpt-hero { padding: 1.6rem 1rem 1.4rem; }
        .rpt-hero h1 { font-size: 1.7rem; }
        .rpt-filter { flex-direction: column; align-items: stretch; }
        .rpt-filter select,
        .rpt-filter button { width: 100%; }
        .rpt-totals { grid-template-columns: repeat(2, 1fr); }
        .rpt-tabs { gap: 4px; }
        .rpt-tab { padding: 6px 10px; font-size: 11px; }
        .nota-circle { width: 36px; height: 36px; }
        .nota-num { font-size: 13px; }
    }
</style>

<div class="rpt-root">

    <!-- Hero -->
    <div class="rpt-hero">
        <div class="rpt-hero-stripe"></div>
        <div class="rpt-hero-fade"></div>
        <div class="rpt-hero-content">
            <div class="rpt-hero-badge">📊 Central de Dados</div>
            <h1>Relatórios</h1>
            <p>Estatísticas completas de jogadores e times com avaliação de desempenho.</p>
        </div>
    </div>

    <div class="rpt-toolbar">
    @if (TempData["Sucesso"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show mb-3" role="alert">
            @TempData["Sucesso"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Scout + Manutenção -->
    <div style="text-align:right;margin-bottom:8px;display:flex;gap:8px;justify-content:flex-end;flex-wrap:wrap;">
        <a asp-action="Scout" asp-controller="Relatorios"
           style="display:inline-flex;align-items:center;gap:6px;padding:6px 14px;border-radius:8px;border:1px solid rgba(124,58,237,.4);background:rgba(124,58,237,.12);color:#c084fc;font-size:13px;font-weight:600;text-decoration:none;">
            🔍 Scout de Jogadores
        </a>
    </div>

    <!-- Filtros -->
    <style>
        .ms-wrap { position: relative; min-width: 240px; }
        .ms-box {
            display: flex; flex-wrap: wrap; gap: 5px; align-items: center;
            min-height: 38px; padding: 4px 30px 4px 8px; cursor: pointer;
            border: 1px solid var(--border-strong); border-radius: 8px; background: var(--input-bg); font-size: 13px;
        }
        .ms-box::after {
            content: "▾"; position: absolute; right: 10px; top: 50%; transform: translateY(-50%);
            color: var(--text-muted); pointer-events: none;
        }
        .ms-placeholder { color: var(--text-muted); }
        .ms-chip {
            display: inline-flex; align-items: center; gap: 4px;
            background: rgba(245,158,11,.12); color: #fbbf24; border: 1px solid rgba(245,158,11,.3);
            border-radius: 6px; padding: 2px 6px; font-size: 12px; font-weight: 600;
        }
        .ms-chip-x { cursor: pointer; font-weight: 700; line-height: 1; opacity: .7; }
        .ms-chip-x:hover { opacity: 1; }
        .ms-panel {
            position: absolute; top: calc(100% + 4px); left: 0; right: 0; z-index: 50;
            background: var(--surface); border: 1px solid var(--border-strong); border-radius: 8px;
            box-shadow: 0 8px 24px rgba(0,0,0,.12); max-height: 280px; overflow-y: auto;
            display: none; padding: 4px;
        }
        .ms-panel.open { display: block; }
        .ms-opt {
            display: flex; align-items: center; gap: 8px; padding: 7px 10px;
            border-radius: 6px; cursor: pointer; font-size: 13px; color: var(--text);
        }
        .ms-opt:hover { background: var(--surface-3); }
        .ms-opt input { cursor: pointer; }
        .ms-search {
            width: 100%; box-sizing: border-box; padding: 7px 10px; margin-bottom: 4px;
            border: 1px solid var(--border-strong); border-radius: 6px; font-size: 13px; outline: none;
            position: sticky; top: 0; background: var(--input-bg);
        }
        .ms-search:focus { border-color: #6366f1; }
    </style>

    <form method="get" asp-action="Index" asp-controller="Relatorios" class="rpt-filter">
        <label>Competições:</label>
        <div class="ms-wrap" id="compMulti">
            <div class="ms-box" id="compBox" tabindex="0"></div>
            <div class="ms-panel" id="compPanel">
                @foreach (var c in Model.Competicoes)
                {
                    <label class="ms-opt">
                        <input type="checkbox" name="competicaoIds" value="@c.Id"
                               data-nome="@c.Nome"
                               @(Model.CompeticaoIdsFiltro.Contains(c.Id) ? "checked" : "") />
                        <span>@c.Nome</span>
                    </label>
                }
            </div>
        </div>

        <label>Times:</label>
        <div class="ms-wrap" id="timeMulti">
            <div class="ms-box" id="timeBox" tabindex="0"></div>
            <div class="ms-panel" id="timePanel">
                <input type="text" class="ms-search" id="timeSearch" placeholder="Buscar time…" autocomplete="off" />
                <div id="timeOptions">
                    @foreach (var t in Model.Times)
                    {
                        <label class="ms-opt">
                            <input type="checkbox" name="timeIds" value="@t.Id"
                                   data-nome="@t.Nome"
                                   @(Model.TimeIdsFiltro.Contains(t.Id) ? "checked" : "") />
                            <span>@t.Nome</span>
                        </label>
                    }
                </div>
            </div>
        </div>

        @if (Model.TemporadasDisponiveis.Any())
        {
            <label for="temporadaFilter">Temporada:</label>
            <select id="temporadaFilter" name="temporada" onchange="this.form.submit()">
                @foreach (var temp in Model.TemporadasDisponiveis)
                {
                    <option value="@temp" @(Model.TemporadaFiltro == temp ? "selected" : "")>@temp</option>
                }
            </select>
        }

        <label class="rpt-check-wrap" title="Inclui jogos com placar mas ainda não analisados">
            <input type="checkbox" name="incluirNaoAnalisados" value="true"
                   @(Model.IncluirNaoAnalisados ? "checked" : "") />
            <span>Incluir não analisados</span>
        </label>

        <label class="rpt-check-wrap" title="Na aba Estatísticas Jogadores, só lista quem tem 10 jogos ou mais">
            <input type="checkbox" name="apenas10Jogos" value="true"
                   @(Model.Apenas10Jogos ? "checked" : "") />
            <span>Apenas com 10+ jogos</span>
        </label>

        <button type="submit">Filtrar</button>
        @if (Model.CompeticaoIdsFiltro.Any() || Model.TimeIdsFiltro.Any() || Model.IncluirNaoAnalisados)
        {
            <a asp-action="Index" asp-controller="Relatorios" class="rpt-filter rpt-clear"
               style="text-decoration:none; padding:8px 16px; border-radius:8px; font-size:13px;">✕ Limpar filtro</a>
        }
    </form>

    <script>
    (function () {
        // Tag selector genérico: renderiza chips a partir dos checkboxes de um painel
        function initMulti(wrapId, boxId, panelId, placeholder, onChange) {
            var wrap  = document.getElementById(wrapId);
            var box   = document.getElementById(boxId);
            var panel = document.getElementById(panelId);
            if (!wrap) return null;

            function render() {
                var checks = panel.querySelectorAll('input[type=checkbox]');
                var marcados = Array.prototype.filter.call(checks, function (c) { return c.checked; });
                box.innerHTML = '';
                if (marcados.length === 0) {
                    var ph = document.createElement('span');
                    ph.className = 'ms-placeholder';
                    ph.textContent = placeholder;
                    box.appendChild(ph);
                    return;
                }
                marcados.forEach(function (c) {
                    var chip = document.createElement('span');
                    chip.className = 'ms-chip';
                    var txt = document.createElement('span');
                    txt.textContent = c.dataset.nome;
                    var x = document.createElement('span');
                    x.className = 'ms-chip-x';
                    x.textContent = '×';
                    x.addEventListener('click', function (e) {
                        e.stopPropagation();
                        c.checked = false;
                        render();
                    });
                    chip.appendChild(txt);
                    chip.appendChild(x);
                    box.appendChild(chip);
                });
            }

            function bindChecks() {
                panel.querySelectorAll('input[type=checkbox]').forEach(function (c) {
                    c.addEventListener('change', function () { render(); if (onChange) onChange(); });
                });
            }

            box.addEventListener('click', function () { panel.classList.toggle('open'); });
            box.addEventListener('keydown', function (e) {
                if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); panel.classList.toggle('open'); }
            });
            document.addEventListener('click', function (e) {
                if (!wrap.contains(e.target)) panel.classList.remove('open');
            });

            bindChecks();
            render();
            return { render: render, bindChecks: bindChecks, panel: panel };
        }

        var timeCtl = initMulti('timeMulti', 'timeBox', 'timePanel', 'Todos os times');

        // Ao mudar as competições, recarrega os times disponíveis (união das competições selecionadas)
        function recarregarTimes() {
            var compChecks = document.querySelectorAll('#compPanel input[type=checkbox]:checked');
            var ids = Array.prototype.map.call(compChecks, function (c) { return c.value; });
            if (!timeCtl) return;

            // preserva seleção atual de times
            var selecionados = Array.prototype.map.call(
                timeCtl.panel.querySelectorAll('input[type=checkbox]:checked'),
                function (c) { return c.value; });

            var qs = ids.length ? ids.map(function (id) { return 'competicaoIds=' + id; }).join('&') : '';
            fetch('/Jogos/TimesPorCompeticoes?' + qs)
                .then(function (r) { return r.json(); })
                .then(function (times) {
                    var opts = document.getElementById('timeOptions');
                    opts.innerHTML = '';
                    times.forEach(function (t) {
                        var lbl = document.createElement('label');
                        lbl.className = 'ms-opt';
                        var inp = document.createElement('input');
                        inp.type = 'checkbox';
                        inp.name = 'timeIds';
                        inp.value = t.id;
                        inp.dataset.nome = t.nome;
                        if (selecionados.indexOf(String(t.id)) !== -1) inp.checked = true;
                        var sp = document.createElement('span');
                        sp.textContent = t.nome;
                        lbl.appendChild(inp);
                        lbl.appendChild(sp);
                        opts.appendChild(lbl);
                    });
                    timeCtl.bindChecks();
                    timeCtl.render();
                    filtrarBuscaTimes();
                });
        }

        // Busca/filtro de times pelo nome dentro do painel
        function filtrarBuscaTimes() {
            var input = document.getElementById('timeSearch');
            if (!input) return;
            var termo = input.value.trim().toLowerCase();
            document.querySelectorAll('#timeOptions .ms-opt').forEach(function (lbl) {
                var nome = (lbl.querySelector('span')?.textContent || '').toLowerCase();
                lbl.style.display = (termo === '' || nome.indexOf(termo) !== -1) ? '' : 'none';
            });
        }
        var timeSearchEl = document.getElementById('timeSearch');
        if (timeSearchEl) {
            timeSearchEl.addEventListener('input', filtrarBuscaTimes);
            // impede que clicar/digitar na busca feche o painel
            timeSearchEl.addEventListener('click', function (e) { e.stopPropagation(); });
        }

        initMulti('compMulti', 'compBox', 'compPanel', 'Todas as competições', recarregarTimes);
    })();
    </script>
