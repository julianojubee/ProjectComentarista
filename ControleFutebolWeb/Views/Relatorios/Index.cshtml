                <div class="rpt-card-header">
                    <div class="rpt-card-icon" style="background:#f0fdf4;">⚽</div>
                    <div>
                        <h3 class="rpt-card-title">Artilheiros</h3>
                        <p class="rpt-card-sub">Jogadores com mais gols marcados</p>
                    </div>
                </div>
                @if (!Model.Artilheiros.Any())
                {
                    <div style="padding:1.5rem;text-align:center;color:var(--text-muted);font-size:13px;">Nenhum gol registrado.</div>
                }
                @{
                    var maxGols = Model.Artilheiros.Any() ? Model.Artilheiros.Max(a => a.Valor) : 1;
                }
                @for (int i = 0; i < Model.Artilheiros.Count; i++)
                {
                    var a = Model.Artilheiros[i];
                    var w = Math.Round((double)a.Valor / maxGols * 100, 1);
