                @if (!Model.Assistencias.Any())
                {
                    <div style="padding:1.5rem;text-align:center;color:var(--text-muted);font-size:13px;">Nenhuma assistência registrada.</div>
                }
                @{
                    var maxAssist = Model.Assistencias.Any() ? Model.Assistencias.Max(a => a.Valor) : 1;
                }
                @for (int i = 0; i < Model.Assistencias.Count; i++)
                {
                    var a = Model.Assistencias[i];
                    var w = Math.Round((double)a.Valor / maxAssist * 100, 1);
                    <div class="rpt-row">
                        <span class="rpt-rank @(i==0?"gold":i==1?"silver":i==2?"bronze":"")">@(i+1)</span>
                        @if (!string.IsNullOrEmpty(a.Jogador.FotoUrl))
                        {
                            <div class="rpt-avatar"><img src="@Url.Action("Imagem", "MediaProxy", new { url = a.Jogador.FotoUrl })" /></div>
                        }
                        else { <div class="rpt-avatar">@(a.Jogador.Nome.Length >= 2 ? a.Jogador.Nome.Substring(0,2).ToUpper() : "?")</div> }
                        <div class="rpt-name">
                            <a asp-controller="Jogadores" asp-action="Estatisticas" asp-route-id="@a.Jogador.Id"
                               style="color:inherit;text-decoration:none;font-weight:500;">@a.Jogador.Nome</a>
                            <small>
                                @a.Jogador.Posicao ·
                                @{ var teA = TimeExibicao(a.Jogador); }
                                @if (!string.IsNullOrEmpty(teA.Escudo))
                                {
                                    <img src="@Url.Action("Imagem", "MediaProxy", new { url = teA.Escudo })" style="width:12px;height:12px;border-radius:50%;object-fit:cover;vertical-align:middle;margin-right:3px;" />
                                }
                                @teA.Nome
                            </small>
                        </div>
                        <div class="rpt-bar-wrap" style="max-width:80px;">
                            <div class="rpt-bar-bg">
                                <div class="rpt-bar-fill" style="width:@w%;background:#3b82f6;"></div>
                            </div>
                        </div>
                        <span class="rpt-badge-value" style="background:#dbeafe;color:#1d4ed8;">@a.Valor 🎯</span>
                    </div>
                }
            </div>

            <!-- Gols Contra -->
            @if (Model.GolsContraRanking.Any())
            {
                <div class="rpt-card">
                    <div class="rpt-card-header">
                        <div class="rpt-card-icon" style="background:#fef2f2;">🔴</div>
                        <div>
                            <h3 class="rpt-card-title">Gols Contra</h3>
                            <p class="rpt-card-sub">Gols marcados na própria rede</p>
                        </div>
                    </div>
                    @for (int i = 0; i < Model.GolsContraRanking.Count; i++)
