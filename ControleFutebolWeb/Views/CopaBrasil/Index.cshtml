@using ControleFutebolWeb.Controllers
@removeTagHelper Microsoft.AspNetCore.Mvc.TagHelpers.OptionTagHelper, Microsoft.AspNetCore.Mvc.TagHelpers
@{
    ViewData["Title"] = "Copa do Brasil";
    var vm = ViewBag.Vm as CopaBrasilViewModel ?? new CopaBrasilViewModel();
    var temporadasCb = ViewBag.TemporadasDisponiveis as List<int> ?? new List<int>();
    var temporadaCbSel = ViewBag.Temporada as int?;
}

<style>
    /* Mesmo padrão visual de Competicoes/Detalhes (tema escuro, acento dourado
       de mata-mata) — mantém a Copa do Brasil consistente com as demais telas
       de competição. */
    .cb-root, .cb-root *, .cb-root *::before, .cb-root *::after { box-sizing: border-box; }
    .cb-root { margin: 0 -12px; background: #0f0f0f; border-radius: 14px; overflow: hidden; color: #e5e7eb; font-family: 'Barlow', Arial, sans-serif; }
    .cb-root a { text-decoration: none; color: inherit; }

    /* ── Hero ── */
    .cb-hero { position: relative; overflow: hidden; background: linear-gradient(135deg, #1a1200 0%, #2a1e00 55%, #1a1200 100%); padding: 38px 2.5rem 32px; }
    .cb-hero-stripe { position: absolute; left: 0; top: 0; bottom: 0; width: 4px; background: #d4a520; }
    .cb-hero-fade { position: absolute; bottom: 0; left: 0; right: 0; height: 60px; background: linear-gradient(to top, #0f0f0f, transparent); pointer-events: none; }
    .cb-hero-inner { position: relative; z-index: 1; display: flex; align-items: center; gap: 20px; flex-wrap: wrap; }
    .cb-hero-icon { width: 64px; height: 64px; border-radius: 50%; background: rgba(255,255,255,.08); border: 2px solid #d4a52048; display: flex; align-items: center; justify-content: center; overflow: hidden; flex-shrink: 0; }
    .cb-hero-icon img { width: 78%; height: 78%; object-fit: contain; }
    .cb-kicker { display: flex; align-items: center; gap: 10px; margin-bottom: 8px; }
    .cb-kicker-line { height: 2px; width: 24px; background: #d4a520; }
    .cb-kicker span { font-size: .65rem; font-weight: 700; letter-spacing: .24em; color: #d4a520; text-transform: uppercase; }
    .cb-hero h1 { font-family: 'Barlow Condensed', Arial, sans-serif; font-size: 3rem; font-weight: 800; color: #f1f5f9; margin: 0 0 6px; line-height: 1; }
    .cb-hero-sub { color: #9ca3af; font-size: .85rem; margin: 0; }
    .cb-hero-temporada { display: flex; align-items: center; gap: 6px; margin-left: auto; }
    .cb-hero-temporada label { color: #9ca3af; font-size: .75rem; font-weight: 600; }
    .cb-hero-temporada select { appearance: none; padding: 5px 10px; border-radius: 7px; border: 1px solid #2a2a2a; background: #1a1a1a; color: #9ca3af; font-size: .8rem; font-weight: 600; cursor: pointer; }

    /* ── Conteúdo ── */
    .cb-content { padding: 24px 2.5rem 64px; max-width: 1500px; margin: 0 auto; }

    /* ── Navegação de fases ── */
    .cb-nav { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 1.5rem; }
    .cb-nav-btn { font-size: .75rem; padding: 5px 14px; background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.12); border-radius: 999px; color: #9ca3af; font-weight: 600; transition: border-color .15s, color .15s; }
    .cb-nav-btn:hover { border-color: #d4a520; color: #d4a520; }
    .cb-nav-btn.active { background: #d4a5201a; border-color: #d4a52080; color: #d4a520; font-weight: 700; }

    /* ── Cabeçalho da fase ── */
    .cb-fase-header { display: flex; align-items: center; gap: 10px; margin-bottom: 1.2rem; }
    .cb-fase-title { font-family: 'Barlow Condensed', Arial, sans-serif; font-size: 1.5rem; font-weight: 800; color: #f1f5f9; text-transform: uppercase; letter-spacing: .04em; margin: 0; }
    .cb-fase-badge { background: #d4a5201a; border: 1px solid #d4a52048; color: #d4a520; font-size: .68rem; font-weight: 700; padding: 3px 10px; border-radius: 999px; }

    /* ── Grid de confrontos ── */
    .cb-confrontos { display: grid; grid-template-columns: repeat(auto-fill, minmax(340px, 1fr)); gap: 14px; }

    /* ── Card de confronto ── */
    .cb-card { background: #161616; border: 1px solid #262626; border-radius: 14px; overflow: hidden; transition: border-color .15s; }
    .cb-card:hover { border-color: #3a3a3a; }
    .cb-card-header { background: #111; border-bottom: 1px solid #1e1e1e; padding: 8px 14px; display: flex; justify-content: space-between; align-items: center; }
    .cb-card-header-left { font-family: 'Barlow Condensed', Arial, sans-serif; font-size: .85rem; font-weight: 700; color: #d4a520; letter-spacing: .06em; text-transform: uppercase; }
    .cb-card-header-right { font-size: .64rem; color: #6b7280; }
    .cb-card-header-right .ok { color: #22c55e; }

    /* Agregado */
    .cb-agregado { padding: 12px 14px; display: flex; justify-content: center; align-items: center; gap: 14px; border-bottom: 1px solid #1e1e1e; }
    .cb-agg-time { display: flex; align-items: center; gap: 7px; flex: 1; min-width: 0; }
    .cb-agg-time.right { justify-content: flex-end; flex-direction: row-reverse; }
    .cb-agg-time img { width: 28px; height: 28px; object-fit: contain; border-radius: 50%; border: 1px solid #2a2a2a; background: #0f0f0f; flex-shrink: 0; }
    .cb-agg-name { font-size: .8rem; font-weight: 600; color: #e5e7eb; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .cb-agg-name:hover { text-decoration: underline; }
    .cb-agg-score { display: flex; align-items: center; gap: 4px; flex-shrink: 0; }
    .cb-agg-num { font-family: 'Barlow Condensed', Arial, sans-serif; font-size: 1.7rem; font-weight: 800; line-height: 1; color: #f1f5f9; min-width: 22px; text-align: center; }
    .cb-agg-num.leader { color: #22c55e; }
    .cb-agg-num.loser { color: #4b5563; }
    .cb-agg-sep { font-size: 18px; color: #374151; font-weight: 300; line-height: 1; }
    .cb-agg-vs { font-size: .72rem; color: #6b7280; font-weight: 600; }

    /* Classificado */
    .cb-classificado-wrap { padding: 6px 14px; text-align: center; border-bottom: 1px solid #1e1e1e; }
    .cb-classificado { font-size: .66rem; font-weight: 700; padding: 2px 10px; border-radius: 999px; background: #d4a5201a; border: 1px solid #d4a52048; color: #d4a520; white-space: nowrap; }
    .cb-classificado.pendente { background: rgba(255,255,255,0.06); border-color: rgba(255,255,255,0.12); color: #9ca3af; }

    /* Jogos ida/volta */
    .cb-jogos { padding: 10px 14px; display: flex; flex-direction: column; gap: 8px; }
    .cb-jogo-row { display: flex; align-items: center; gap: 8px; padding: 7px 10px; border-radius: 8px; background: #111; border: 1px solid #1e1e1e; font-size: .75rem; transition: border-color .15s; }
    .cb-jogo-row:hover { border-color: #3a3a3a; }
    .cb-jogo-label { font-size: .6rem; font-weight: 700; color: #0f0f0f; background: #d4a520; padding: 2px 7px; border-radius: 4px; flex-shrink: 0; }
    .cb-jogo-label.volta { background: #374151; color: #e5e7eb; }
    .cb-jogo-date { font-family: 'Barlow Condensed', Arial, sans-serif; font-size: .68rem; font-weight: 700; color: #4b5563; flex-shrink: 0; }
    .cb-jogo-times { display: flex; align-items: center; gap: 5px; flex: 1; justify-content: center; color: #9ca3af; min-width: 0; }
    .cb-jogo-times .nome { font-weight: 500; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .cb-jogo-result { font-family: 'Barlow Condensed', Arial, sans-serif; font-weight: 700; font-size: .85rem; background: #262626; color: #f1f5f9; padding: 1px 8px; border-radius: 5px; flex-shrink: 0; }
    .cb-jogo-pen { font-size: .62rem; color: #9ca3af; font-weight: 500; }
    .cb-jogo-pending { font-size: .62rem; color: #6b7280; background: #1a1a1a; padding: 2px 8px; border-radius: 5px; flex-shrink: 0; }
    .cb-jogo-analisar { font-size: .68rem; color: #d4a520; font-weight: 700; flex-shrink: 0; border: 1px solid #d4a52048; padding: 2px 9px; border-radius: 5px; transition: background .15s, color .15s; }
    .cb-jogo-analisar:hover { background: #d4a520; color: #0f0f0f; }
    .cb-jogo-vazio { justify-content: flex-start; color: #6b7280; }
    .cb-jogo-vazio span.txt { font-size: .68rem; margin-left: 4px; }

    /* Sem dados */
    .cb-empty { text-align: center; padding: 3.5rem 1rem; color: #6b7280; font-size: .8rem; background: #161616; border: 1px solid #262626; border-radius: 14px; }
    .cb-trophy { font-size: 2.5rem; margin-bottom: 10px; }
</style>

<div class="cb-root">

    <!-- ── Hero ── -->
    <div class="cb-hero">
        <div class="cb-hero-stripe"></div>
        <div class="cb-hero-fade"></div>
        <div class="cb-hero-inner">
            <div class="cb-hero-icon">
                <img src="~/images/background/copadobrasil.png" alt="Copa do Brasil"
                     onerror="this.parentElement.style.display='none'" />
            </div>
            <div>
                <div class="cb-kicker">
                    <div class="cb-kicker-line"></div>
                    <span>Competição Nacional · Mata-Mata</span>
                </div>
                <h1>Copa do Brasil</h1>
                <p class="cb-hero-sub">Fase atual · Confrontos de ida e volta</p>
            </div>
            @if (temporadasCb.Count > 1)
            {
                <form method="get" class="cb-hero-temporada">
                    <label>Temporada</label>
                    <select name="temporada" onchange="this.form.submit()">
                        @foreach (var temp in temporadasCb)
                        {
                            <option value="@temp" @(temporadaCbSel == temp ? "selected" : "")>@temp</option>
                        }
                    </select>
                </form>
            }
        </div>
    </div>

    <div class="cb-content">

        @if (vm.FaseAtual == "Sem dados" || !vm.Confrontos.Any())
        {
            <div class="cb-empty">
                <div class="cb-trophy">🏆</div>
                Nenhum jogo da Copa do Brasil encontrado.<br />
                <small>Importe os jogos com <strong>CompeticaoId = 3</strong> para ver os confrontos.</small>
            </div>
        }
        else
        {
            <!-- ── Navegação de fases ── -->
            @if (vm.RodasDisponiveis.Count > 1)
            {
                <div class="cb-nav">
                    @foreach (var r in vm.RodasDisponiveis)
                    {
                        var nomeR = r switch
                        {
                            1 => "1ª Fase",
                            2 => "2ª Fase",
                            3 => "3ª Fase",
                            4 => "Oitavas",
                            5 => "Quartas",
                            6 => "Semifinal",
                            7 => "Final",
                            _ => $"Rodada {r}"
                        };
                        <a asp-action="Index" asp-controller="CopaBrasil"
                           asp-route-rodada="@r"
                           asp-route-temporada="@temporadaCbSel"
                           class="cb-nav-btn @(r == vm.RodadaAtual ? "active" : "")">
                            @nomeR
                        </a>
                    }
                </div>
            }

            <!-- ── Cabeçalho da fase ── -->
            <div class="cb-fase-header">
                <h3 class="cb-fase-title">@vm.FaseAtual</h3>
                <span class="cb-fase-badge">@vm.Confrontos.Count confronto(s)</span>
            </div>

            <!-- ── Confrontos ── -->
            <div class="cb-confrontos">
                @foreach (var c in vm.Confrontos)
                {
                    bool idaRealizada = c.JogoIda?.PlacarCasa.HasValue == true;
                    bool voltaRealizada = c.JogoVolta?.PlacarCasa.HasValue == true;
                    bool ambosRealizados = idaRealizada && voltaRealizada;

                    bool aLiderando = c.GolsTimeA > c.GolsTimeB;
                    bool bLiderando = c.GolsTimeB > c.GolsTimeA;

                    <div class="cb-card">
                        <!-- Header do card -->
                        <div class="cb-card-header">
                            <span class="cb-card-header-left">@c.FaseName</span>
                            <span class="cb-card-header-right">
                                @if (ambosRealizados)
                                {
                                    <span class="ok">✔ Encerrado</span>
                                }
                                else if (idaRealizada)
                                {
                                    <span>Aguardando volta</span>
                                }
                                else
                                {
                                    <span>A realizar</span>
                                }
                            </span>
                        </div>

                        <!-- Placar agregado -->
                        <div class="cb-agregado">
                            <!-- Time A -->
                            <div class="cb-agg-time">
                                @if (!string.IsNullOrEmpty(c.TimeA.EscudoUrl))
                                {
                                    <img src="@Url.Action("Imagem", "MediaProxy", new { url = c.TimeA.EscudoUrl })" alt="@c.TimeA.Nome" />
                                }
                                <a class="cb-agg-name" title="@c.TimeA.Nome"
                                   href="@Url.Action("Details", "Times", new { id = c.TimeA.Id })">@c.TimeA.Nome</a>
                            </div>

                            <!-- Placar agregado central -->
                            <div class="cb-agg-score">
                                @if (idaRealizada)
                                {
                                    <span class="cb-agg-num @(aLiderando ? "leader" : (bLiderando ? "loser" : ""))">
                                        @c.GolsTimeA
                                    </span>
                                    <span class="cb-agg-sep">–</span>
                                    <span class="cb-agg-num @(bLiderando ? "leader" : (aLiderando ? "loser" : ""))">
                                        @c.GolsTimeB
                                    </span>
                                }
                                else
                                {
                                    <span class="cb-agg-vs">vs</span>
                                }
                            </div>

                            <!-- Time B -->
                            <div class="cb-agg-time right">
                                @if (!string.IsNullOrEmpty(c.TimeB.EscudoUrl))
                                {
                                    <img src="@Url.Action("Imagem", "MediaProxy", new { url = c.TimeB.EscudoUrl })" alt="@c.TimeB.Nome" />
                                }
                                <a class="cb-agg-name" title="@c.TimeB.Nome"
                                   href="@Url.Action("Details", "Times", new { id = c.TimeB.Id })">@c.TimeB.Nome</a>
                            </div>
                        </div>

                        <!-- Badge classificado (se encerrado) -->
                        @if (c.Classificado != null)
                        {
                            <div class="cb-classificado-wrap">
                                <span class="cb-classificado">🏆 @c.Classificado.Nome classificado</span>
                            </div>
                        }
                        else if (ambosRealizados && c.GolsTimeA == c.GolsTimeB)
                        {
                            <div class="cb-classificado-wrap">
                                <span class="cb-classificado pendente">⚽ Pênaltis / definição pendente</span>
                            </div>
                        }

                        <!-- Jogos de ida e volta -->
                        <div class="cb-jogos">

                            @* ── Jogo de Ida ── *@
                            @if (c.JogoIda != null)
                            {
                                <div class="cb-jogo-row">
                                    <span class="cb-jogo-label">IDA</span>
                                    <span class="cb-jogo-date">
                                        @ControleFutebolWeb.Helpers.DateHelper.FormatarData(c.JogoIda.Data, "dd/MM HH:mm")
                                    </span>

                                    <div class="cb-jogo-times">
                                        <span class="nome">@c.JogoIda.TimeCasa?.Nome</span>
                                        @if (c.JogoIda.PlacarCasa.HasValue)
                                        {
                                            <span class="cb-jogo-result">
                                                @c.JogoIda.PlacarCasa x @c.JogoIda.PlacarVisitante
                                                @if (c.JogoIda.PenaltisCasa.HasValue && c.JogoIda.PenaltisVisitante.HasValue)
                                                {
                                                    <span class="cb-jogo-pen">(@c.JogoIda.PenaltisCasa-@c.JogoIda.PenaltisVisitante pên.)</span>
                                                }
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="cb-jogo-pending">vs</span>
                                        }
                                        <span class="nome">@c.JogoIda.TimeVisitante?.Nome</span>
                                    </div>
                                    <a asp-controller="Jogos" asp-action="Analisar" asp-route-id="@c.JogoIda.Id"
                                       class="cb-jogo-analisar">→</a>
                                </div>
                            }
                            else
                            {
                                <div class="cb-jogo-row cb-jogo-vazio">
                                    <span class="cb-jogo-label">IDA</span>
                                    <span class="txt">Jogo de ida não cadastrado</span>
                                </div>
                            }

                            @* ── Jogo de Volta ── *@
                            @if (c.JogoVolta != null)
                            {
                                <div class="cb-jogo-row">
                                    <span class="cb-jogo-label volta">VOLTA</span>
                                    <span class="cb-jogo-date">
                                        @ControleFutebolWeb.Helpers.DateHelper.FormatarData(c.JogoVolta.Data, "dd/MM HH:mm")
                                    </span>

                                    <div class="cb-jogo-times">
                                        <span class="nome">@c.JogoVolta.TimeCasa?.Nome</span>
                                        @if (c.JogoVolta.PlacarCasa.HasValue)
                                        {
                                            <span class="cb-jogo-result">
                                                @c.JogoVolta.PlacarCasa x @c.JogoVolta.PlacarVisitante
                                                @if (c.JogoVolta.PenaltisCasa.HasValue && c.JogoVolta.PenaltisVisitante.HasValue)
                                                {
                                                    <span class="cb-jogo-pen">(@c.JogoVolta.PenaltisCasa-@c.JogoVolta.PenaltisVisitante pên.)</span>
                                                }
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="cb-jogo-pending">A jogar</span>
                                        }
                                        <span class="nome">@c.JogoVolta.TimeVisitante?.Nome</span>
                                    </div>
                                    <a asp-controller="Jogos" asp-action="Analisar" asp-route-id="@c.JogoVolta.Id"
                                       class="cb-jogo-analisar">→</a>
                                </div>
                            }
                            else
                            {
                                <div class="cb-jogo-row cb-jogo-vazio">
                                    <span class="cb-jogo-label volta">VOLTA</span>
                                    <span class="txt">Jogo de volta ainda não cadastrado</span>
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>
