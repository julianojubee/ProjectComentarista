@model ControleFutebolWeb.Models.AnotacaoTime
@{
    var time = (ControleFutebolWeb.Models.Time)ViewBag.Time;
    var isEdicao = Model.Id > 0;
    var action = isEdicao ? "Editar" : "Nova";
}

<link rel="stylesheet" href="~/fonts/barlow/barlow.css" asp-append-version="true" />

<style>
    .af * { box-sizing: border-box; }
    .af {
        background: #0f0f0f; color: #e5e7eb; font-family: 'Barlow', Arial, sans-serif;
        border-radius: 14px; padding: 2rem; margin: 0 -12px;
    }
    .af-card { background: #161616; border: 1px solid #262626; border-radius: 14px; padding: 1.8rem 2rem; max-width: 720px; margin: 0 auto; }
    .af-title { font-family: 'Barlow Condensed', Arial, sans-serif; font-size: 1.5rem; font-weight: 800; color: #f1f5f9; margin-bottom: 1.5rem; }
    .af-field { margin-bottom: 1.25rem; }
    .af-label { font-size: 0.68rem; font-weight: 700; color: #6b7280; text-transform: uppercase; letter-spacing: 0.1em; display: block; margin-bottom: .5rem; }
    .af-input, .af-textarea, .af-select {
        width: 100%; background: #0f0f0f; border: 1px solid #2a2a2a;
        border-radius: 8px; color: #f1f5f9; font-size: 0.87rem;
        padding: .65rem .85rem; outline: none; font-family: inherit;
    }
    .af-input:focus, .af-textarea:focus, .af-select:focus { border-color: #d4a520; }
    .af-textarea { resize: vertical; min-height: 200px; line-height: 1.6; }
    .af-select { appearance: none; cursor: pointer; }
    .af-actions { display: flex; gap: .75rem; margin-top: 1.5rem; }
    .af-save { background: #d4a520; color: #141414; border: none; border-radius: 8px; padding: .65rem 1.5rem; font-size: 0.85rem; font-weight: 800; cursor: pointer; letter-spacing: 0.03em; }
    .af-save:hover { background: #c49918; }
    .af-cancel { background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); color: #9ca3af; border-radius: 8px; padding: .65rem 1.2rem; font-size: 0.85rem; font-weight: 700; cursor: pointer; text-decoration: none; display: inline-flex; align-items: center; }
    .af-cancel:hover { border-color: #d4a520; color: #d4a520; }
    .af-hint { font-size: 0.68rem; color: #4b5563; margin-top: .4rem; }
</style>

<div class="af">
    <div class="af-card">
        <div class="af-title">
            @(isEdicao ? "✏️ Editar anotação" : "📝 Nova anotação") — @time.Nome
        </div>

        <form asp-action="@action" asp-route-id="@(isEdicao ? Model.Id : null)" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="TimeId" />

            <div class="af-field">
                <label class="af-label">Título *</label>
                <input asp-for="Titulo" class="af-input" placeholder="Ex: Sondagem por Gabigol, Demissão do técnico…" autofocus />
                <span asp-validation-for="Titulo" class="text-danger" style="font-size:12px;"></span>
            </div>

            <div class="af-field">
                <label class="af-label">Categoria</label>
                <select asp-for="Categoria" class="af-select">
                    <option value="">— Sem categoria —</option>
                    <option value="Sondagem">Sondagem</option>
                    <option value="Demissão">Demissão</option>
                    <option value="Informação">Informação</option>
                    <option value="Curiosidade">Curiosidade</option>
                </select>
            </div>

            <div class="af-field">
                <label class="af-label">Conteúdo *</label>
                <textarea asp-for="Conteudo" class="af-textarea" placeholder="Escreva livremente…"></textarea>
                <div class="af-hint">Suporta texto livre com quebras de linha.</div>
                <span asp-validation-for="Conteudo" class="text-danger" style="font-size:12px;"></span>
            </div>

            <div class="af-actions">
                <button type="submit" class="af-save">💾 Salvar</button>
                <a asp-action="Index" asp-route-timeId="@Model.TimeId" class="af-cancel">Cancelar</a>
            </div>
        </form>
    </div>
</div>
