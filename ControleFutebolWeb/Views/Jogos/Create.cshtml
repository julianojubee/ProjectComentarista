@model ControleFutebolWeb.Models.Jogo

<h2>Cadastrar Novo Jogo</h2>

<form id="jogoForm" asp-action="Create" method="post">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="form-group">
        <label asp-for="Data" class="control-label"></label>
        <input asp-for="Data" type="date" class="form-control" />
        <span asp-validation-for="Data" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="Rodada" class="control-label"></label>
        <input asp-for="Rodada" type="number" min="1" class="form-control" />
        <span asp-validation-for="Rodada" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="TimeCasaId" class="control-label">Time da Casa</label>
        <select asp-for="TimeCasaId" class="form-control" asp-items="ViewBag.TimeCasaId"></select>
        <span asp-validation-for="TimeCasaId" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="PlacarCasa" class="control-label">Placar Casa</label>
        <input asp-for="PlacarCasa" type="number" min="0" class="form-control" />
        <span asp-validation-for="PlacarCasa" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="TimeVisitanteId" class="control-label">Time Visitante</label>
        <select asp-for="TimeVisitanteId" class="form-control" asp-items="ViewBag.TimeVisitanteId"></select>
        <span asp-validation-for="TimeVisitanteId" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="PlacarVisitante" class="control-label">Placar Visitante</label>
        <input asp-for="PlacarVisitante" type="number" min="0" class="form-control" />
        <span asp-validation-for="PlacarVisitante" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="FormacaoCasaId" class="control-label">Formação Time da Casa</label>
        <select asp-for="FormacaoCasaId" class="form-control"
                asp-items="ViewBag.FormacaoCasaId"></select>
    </div>

    <div class="form-group">
        <label asp-for="FormacaoVisitanteId" class="control-label">Formação Time Visitante</label>
        <select asp-for="FormacaoVisitanteId" class="form-control"
                asp-items="ViewBag.FormacaoVisitanteId"></select>
    </div>


    <button id="btnCadastrar" type="submit" class="btn btn-primary">Cadastrar</button>
    <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}