@using ControleFutebolWeb.Helpers
@model ControleFutebolWeb.Models.TimeDetalhesViewModel


<h2>@Model.Time.Nome</h2>
<img src="@Url.Action("Imagem", "MediaProxy", new { url = Model.Time.EscudoUrl })" alt="@Model.Time.Nome" width="100" />

<h3>Elenco Atual</h3>
<div class="table-responsive">
<table class="table table-striped">
    <thead>
        <tr>
            <th>Nome</th>
            <th>Posição</th>
            <th>Nacionalidade</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var jogador in Model.Time.Jogadores)
        {
            <tr>
                <td>@jogador.Nome</td>
                <td>@PosicaoJogadorHelper.Sigla(jogador.Posicao)</td>
                <td>@jogador.Nacionalidade?.Nome</td>
            </tr>
        }
    </tbody>
</table>
</div>

<h3>Jogos do Time</h3>
<div class="table-responsive">
<table class="table table-bordered">
    <thead>
        <tr>
            <th>Data</th>
            <th>Rodada</th>
            <th>Mandante</th>
            <th>Visitante</th>
            <th>Placar</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var jogo in Model.Jogos)
        {
            <tr>
                <td>@ControleFutebolWeb.Helpers.DateHelper.FormatarData(jogo.Data, "dd/MM/yyyy HH:mm")</td>
                <td>@jogo.Rodada</td>
                <td>@jogo.TimeCasa?.Nome</td>
                <td>@jogo.TimeVisitante?.Nome</td>
                <td>
                    @if (jogo.PlacarCasa >= 0 && jogo.PlacarVisitante >= 0)
                    {
                        <strong>@jogo.PlacarCasa x @jogo.PlacarVisitante</strong>
                        @if (jogo.PenaltisCasa.HasValue && jogo.PenaltisVisitante.HasValue)
                        {
                            <span class="text-muted">(@jogo.PenaltisCasa-@jogo.PenaltisVisitante pên.)</span>
                        }
                    }
                    else
                    {
                        <span>Agendado</span>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>
</div>