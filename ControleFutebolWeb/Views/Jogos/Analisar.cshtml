<!-- ── FORM PRINCIPAL (id fixo para o JS encontrar com segurança) ── -->
<form id="formSalvarEscalacao" method="post" asp-action="SalvarEscalacao" asp-controller="Jogos">
    <input type="hidden" name="id" value="@Model.Id" />
    <input type="hidden" name="formacaoCasaId" value="@ViewBag.FormacaoCasaSelecionada" />
    <input type="hidden" name="formacaoVisitanteId" value="@ViewBag.FormacaoVisitanteSelecionada" />
    <input type="hidden" name="faseEscalacao" value="@faseAtual" />
    <input type="hidden" id="observacoesComTags" name="observacoesComTags" value="" />

    <div class="row">

        <!-- ===== TIME DA CASA ===== -->
        <div class="col-md-6">
            <div class="row">
                <!-- Lista de jogadores -->
                <div class="col-5 scroll-panel">
                    @{
                        var treinadorCasa = ViewBag.TreinadorCasa as ControleFutebolWeb.Models.Treinador;
                    }
                    @if (treinadorCasa != null)
                    {
                        <div class="d-flex align-items-center gap-2 px-1 py-1 mb-1"
                             style="background:#f0f4ff;border-radius:7px;border:1px solid #dce4f5;">
                            @if (!string.IsNullOrWhiteSpace(treinadorCasa.FotoUrl))
                            {
                                <img src="@Url.Action("Imagem", "MediaProxy", new { url = treinadorCasa.FotoUrl })"
                                     alt="@treinadorCasa.Nome"
                                     style="width:24px;height:24px;border-radius:50%;object-fit:cover;flex-shrink:0;" />
                            }
                            else
                            {
                                <span style="font-size:16px;">🧑‍💼</span>
                            }
                            <div>
                                <div style="font-size:9px;color:#6b7280;text-transform:uppercase;line-height:1;">Treinador</div>
                                <div style="font-size:12px;font-weight:600;color:#1e3a5f;">@treinadorCasa.Nome</div>
                            </div>
                        </div>
                    }
                    <table class="table table-sm table-striped">
                        <thead><tr><th></th><th>Nome</th><th>Pos</th></tr></thead>
                        <tbody id="listaCasa">
                            @foreach (var jogador in (List<ControleFutebolWeb.Models.Jogador>)ViewBag.JogadoresCasa)
                            {
                                <tr class="jogador-row"
                                    id="jogador-casa-@jogador.Id"
                                    draggable="true"
                                    ondragstart="dragJogador(event, @jogador.Id, '@jogador.Nome', '@jogador.NumeroCamisa', '', 'casa')">
                                    <td>
                                        <div class="player-circle player-circle-casa" style="width:28px;height:28px;font-size:11px;">
                                            @(jogador.NumeroCamisa?.ToString() ?? "")
                                        </div>
                                    </td>
                                    <td>
                                        @jogador.Nome
                                        @if (!faseEhInicial && jogadoresSairamCasa.Contains(jogador.Id))
                                        {
                                            <span class="sub-badge-out" title="Jogador saiu">↓</span>
                                        }
                                    </td>
                                    <td>@jogador.Posicao</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <!-- Campinho casa -->
                <div class="col-7">
                    <div id="campoCasa" class="campo"
                         ondrop="dropNoCampo(event, 'campoCasa')"
                         ondragover="allowDrop(event)">
                        @{
                            var idxCasa = 0;
                        }
                        @foreach (var esc in (List<ControleFutebolWeb.Models.Escalacao>)ViewBag.EscalacoesCasa)
                        {
                            <div class="posicao-drop"
                                 data-index="casa_@idxCasa"
                                 data-posicao="@esc.Posicao"
                                 data-campo="casa"
                                 draggable="true"
                                 ondragstart="dragPosicao(event, 'casa_@idxCasa')"
                                 ondrop="dropEscalacao(event, 'casa_@idxCasa')"
                                 ondragover="allowDrop(event)"
                                 style="left:@esc.PosicaoX%; top:@esc.PosicaoY%;">
                                @if (esc.Jogador != null)
                                {
                                    <div class="player-circle player-circle-casa">@(esc.Jogador.NumeroCamisa?.ToString() ?? "")</div>
                                    <div class="player-name">
                                        @esc.Jogador.Nome
                                        @if (!faseEhInicial && jogadoresEntraramCasa.Contains(esc.Jogador.Id))
                                        {
                                            <span class="sub-chip-in" title="Jogador entrou">↑</span>
                                        }
                                    </div>
                                    <button type="button"
                                            class="btn-avaliar"
                                            onclick="abrirAvaliacao(@esc.Jogador.Id, '@esc.Jogador.Nome', '@esc.Posicao', event)">
                                        +
                                    </button>
                                }
                                else
                                {
                                    <div class="player-circle player-circle-empty"></div>
                                }
                            </div>
                            <input type="hidden" name="escalacaoCasa[@idxCasa].Id" value="@esc.Id" />
                            <input type="hidden" name="escalacaoCasa[@idxCasa].PosicaoId" value="@esc.Id" />
                            <input type="hidden" id="escalacaoCasa_@(idxCasa)__JogadorId" name="escalacaoCasa[@idxCasa].JogadorId" value="@esc.JogadorId" />
                            <input type="hidden" id="escalacaoCasa_@(idxCasa)__PosicaoX" name="escalacaoCasa[@idxCasa].PosicaoX" value="@esc.PosicaoX" />
                            <input type="hidden" id="escalacaoCasa_@(idxCasa)__PosicaoY" name="escalacaoCasa[@idxCasa].PosicaoY" value="@esc.PosicaoY" />
                            idxCasa++;
                        }
                    </div>

                    @if (mostrarBancoReservas)
                    {
                        <!-- Banco de reservas casa -->
                        <div class="banco-label mt-2">🪑 Banco de reservas</div>
                        <div id="bancoCasa" class="banco"
                             ondrop="dropNoBanco(event, 'casa')"
                             ondragover="allowDrop(event)">
                            @{
                                var idxResCasa = 0;
                            }
                            @foreach (var esc in (List<ControleFutebolWeb.Models.Escalacao>)ViewBag.ReservasCasa)
                            {
                                <div class="reserva-card" id="reserva-casa-card-@idxResCasa">
                                    <span class="rem-btn" onclick="removerReserva('casa', @idxResCasa)">×</span>
                                    <div class="player-circle player-circle-casa" style="width:28px;height:28px;font-size:11px;">
                                        @(esc.Jogador?.NumeroCamisa?.ToString() ?? "")
                                    </div>
                                    <div style="max-width:54px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;font-size:11px;">
                                        @esc.Jogador?.Nome
                                    </div>
                                </div>
                                <!-- inputs das reservas JÁ SALVAS ficam dentro do form principal -->
                                <input type="hidden" name="reservasCasa[@idxResCasa].Id" value="@esc.Id" />
                                <input type="hidden" id="reservaCasa_@(idxResCasa)__JogadorId" name="reservasCasa[@idxResCasa].JogadorId" value="@esc.JogadorId" />
                                <input type="hidden" id="reservaCasa_@(idxResCasa)__PosicaoX" name="reservasCasa[@idxResCasa].PosicaoX" value="0" />
                                <input type="hidden" id="reservaCasa_@(idxResCasa)__PosicaoY" name="reservasCasa[@idxResCasa].PosicaoY" value="0" />
                                idxResCasa++;
                            }
                        </div>
                        <input type="hidden" id="totalReservasCasa" value="@idxResCasa" />
                    }
                </div>
            </div>
        </div>

        <!-- ===== TIME VISITANTE ===== -->
        <div class="col-md-6">
            @* <h4>
                <img src="@Model.TimeVisitante.EscudoUrl" width="24" />
                @Model.TimeVisitante.Nome
            </h4> *@
            <div class="row">
                <!-- Campinho visitante -->
                <div class="col-7">
                    <div id="campoVisitante" class="campo"
                         ondrop="dropNoCampo(event, 'campoVisitante')"
                         ondragover="allowDrop(event)">
                        @{
                            var idxVis = 0;
                        }
                        @foreach (var esc in (List<ControleFutebolWeb.Models.Escalacao>)ViewBag.EscalacoesVisitante)
                        {
                            <div class="posicao-drop"
                                 data-index="vis_@idxVis"
                                 data-posicao="@esc.Posicao"
                                 data-campo="vis"
                                 draggable="true"
                                 ondragstart="dragPosicao(event, 'vis_@idxVis')"
                                 ondrop="dropEscalacao(event, 'vis_@idxVis')"
                                 ondragover="allowDrop(event)"
                                 style="left:@esc.PosicaoX%; top:@esc.PosicaoY%;">
                                @if (esc.Jogador != null)
                                {
                                    <div class="player-circle player-circle-vis">@(esc.Jogador.NumeroCamisa?.ToString() ?? "")</div>
                                    <div class="player-name">
                                        @esc.Jogador.Nome
                                        @if (!faseEhInicial && jogadoresEntraramVisitante.Contains(esc.Jogador.Id))
                                        {
                                            <span class="sub-chip-in" title="Jogador entrou">↑</span>
                                        }
                                    </div>
                                    <button type="button"
                                            class="btn-avaliar"
                                            onclick="abrirAvaliacao(@esc.Jogador.Id, '@esc.Jogador.Nome', '@esc.Posicao', event)">
                                        +
                                    </button>
                                }
                                else
                                {
                                    <div class="player-circle player-circle-empty"></div>
                                }
                            </div>
                            <input type="hidden" name="escalacaoVisitante[@idxVis].Id" value="@esc.Id" />
                            <input type="hidden" name="escalacaoVisitante[@idxVis].PosicaoId" value="@esc.Id" />
                            <input type="hidden" id="escalacaoVisitante_@(idxVis)__JogadorId" name="escalacaoVisitante[@idxVis].JogadorId" value="@esc.JogadorId" />
                            <input type="hidden" id="escalacaoVisitante_@(idxVis)__PosicaoX" name="escalacaoVisitante[@idxVis].PosicaoX" value="@esc.PosicaoX" />
                            <input type="hidden" id="escalacaoVisitante_@(idxVis)__PosicaoY" name="escalacaoVisitante[@idxVis].PosicaoY" value="@esc.PosicaoY" />
                            idxVis++;
                        }
                    </div>

                    @if (mostrarBancoReservas)
                    {
                        <!-- Banco de reservas visitante -->
                        <div class="banco-label mt-2">🪑 Banco de reservas</div>
                        <div id="bancoVisitante" class="banco"
                             ondrop="dropNoBanco(event, 'vis')"
                             ondragover="allowDrop(event)">
                            @{
                                var idxResVis = 0;
                            }
                            @foreach (var esc in (List<ControleFutebolWeb.Models.Escalacao>)ViewBag.ReservasVisitante)
                            {
                                <div class="reserva-card" id="reserva-vis-card-@idxResVis">
                                    <span class="rem-btn" onclick="removerReserva('vis', @idxResVis)">×</span>
                                    <div class="player-circle player-circle-vis" style="width:28px;height:28px;font-size:11px;">
                                        @(esc.Jogador?.NumeroCamisa?.ToString() ?? "")
                                    </div>
                                    <div style="max-width:54px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;font-size:11px;">
                                        @esc.Jogador?.Nome
                                    </div>
                                </div>
                                <input type="hidden" name="reservasVisitante[@idxResVis].Id" value="@esc.Id" />
                                <input type="hidden" id="reservaVis_@(idxResVis)__JogadorId" name="reservasVisitante[@idxResVis].JogadorId" value="@esc.JogadorId" />
                                <input type="hidden" id="reservaVis_@(idxResVis)__PosicaoX" name="reservasVisitante[@idxResVis].PosicaoX" value="0" />
                                <input type="hidden" id="reservaVis_@(idxResVis)__PosicaoY" name="reservasVisitante[@idxResVis].PosicaoY" value="0" />
                                idxResVis++;
                            }
                        </div>
                        <input type="hidden" id="totalReservasVis" value="@idxResVis" />
                    }
                </div>

                <!-- Lista de jogadores visitante -->
                <div class="col-5 scroll-panel">
                    @{
                        var treinadorVis = ViewBag.TreinadorVisitante as ControleFutebolWeb.Models.Treinador;
                    }
                    @if (treinadorVis != null)
                    {
                        <div class="d-flex align-items-center gap-2 px-1 py-1 mb-1"
                             style="background:#f0f4ff;border-radius:7px;border:1px solid #dce4f5;">
                            @if (!string.IsNullOrWhiteSpace(treinadorVis.FotoUrl))
                            {
                                <img src="@Url.Action("Imagem", "MediaProxy", new { url = treinadorVis.FotoUrl })"
                                     alt="@treinadorVis.Nome"
                                     style="width:24px;height:24px;border-radius:50%;object-fit:cover;flex-shrink:0;" />
                            }
                            else
                            {
                                <span style="font-size:16px;">🧑‍💼</span>
                            }
                            <div>
                                <div style="font-size:9px;color:#6b7280;text-transform:uppercase;line-height:1;">Treinador</div>
                                <div style="font-size:12px;font-weight:600;color:#1e3a5f;">@treinadorVis.Nome</div>
                            </div>
                        </div>
                    }
                    <table class="table table-sm table-striped">
                        <thead><tr><th></th><th>Nome</th><th>Pos</th></tr></thead>
                        <tbody id="listaVisitante">
                            @foreach (var jogador in (List<ControleFutebolWeb.Models.Jogador>)ViewBag.JogadoresVisitante)
                            {
                                <tr class="jogador-row"
                                    id="jogador-vis-@jogador.Id"
                                    draggable="true"
                                    ondragstart="dragJogador(event, @jogador.Id, '@jogador.Nome', '@jogador.NumeroCamisa', '', 'vis')">
                                    <td>
                                        <div class="player-circle player-circle-vis" style="width:28px;height:28px;font-size:11px;">
                                            @(jogador.NumeroCamisa?.ToString() ?? "")
                                        </div>
                                    </td>
                                    <td>
                                        @jogador.Nome
                                        @if (!faseEhInicial && jogadoresSairamVisitante.Contains(jogador.Id))
                                        {
                                            <span class="sub-badge-out" title="Jogador saiu">↓</span>
                                        }
                                    </td>
                                    <td>@jogador.Posicao</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

    </div>

    @if (!faseEhInicial)
    {
        <div class="obs-box">
            <div class="obs-title">Observações da escalação final</div>
            <div id="obsRows"></div>
            <div class="obs-actions">
                <button type="button" class="obs-btn" onclick="adicionarLinhaObs('CASA', '')">+ Observação mandante</button>
                <button type="button" class="obs-btn" onclick="adicionarLinhaObs('VISITANTE', '')">+ Observação visitante</button>
            </div>
        </div>
    }

    <div class="text-center mt-3">
        <button type="submit" class="btn btn-success">Salvar Escalação @(faseEhInicial ? "Inicial" : "Final")</button>
    </div>
</form>

<form asp-action="LimparEscalacoes" asp-route-id="@Model.Id" asp-route-faseEscalacao="@faseAtual" method="post" class="mt-2">
    @Html.AntiForgeryToken()
    <div class="text-center">
        <button type="submit" class="btn btn-danger">🗑️ Limpar Escalação @(faseEhInicial ? "Inicial" : "Final")</button>
    </div>
</form>

</div>
<!-- fim #painelEscalacao -->

<div id="painelEstatisticas" style="display:none;">
    <div class="cf-card" style="padding:1.25rem;">
        @{
            var totalChutes = PegarStatNumero(statsCasa, "Total Shots") + PegarStatNumero(statsVis, "Total Shots");
            var possCasa = PegarStatNumero(statsCasa, "Ball Possession");
            var possVis = PegarStatNumero(statsVis, "Ball Possession");
            if (possCasa == 0 && possVis == 0) { possCasa = 50; possVis = 50; }
        }

        @if (statsCasa.Count == 0 && statsVis.Count == 0)
        {
            <div style="padding:1.5rem;text-align:center;color:#9ca3af;font-size:13px;">
                Estatísticas ainda não disponíveis para esta partida.
            </div>
        }
        else
        {
            <div style="display:flex;align-items:center;justify-content:center;gap:1.5rem;margin-bottom:1.5rem;">
                <div style="display:flex;align-items:center;gap:8px;">
                    <img src="@Url.Action("Imagem", "MediaProxy", new { url = Model.TimeCasa?.EscudoUrl })"
                         alt="@Model.TimeCasa?.Nome" style="width:28px;height:28px;object-fit:contain;" />
                    <span style="font-weight:700;color:#1e3a5f;">@Model.TimeCasa?.Nome</span>
                </div>
                <div style="font-size:12px;color:#6b7280;text-transform:uppercase;font-weight:600;">Posse de bola</div>
                <div style="display:flex;align-items:center;gap:8px;">
                    <span style="font-weight:700;color:#1e3a5f;">@Model.TimeVisitante?.Nome</span>
                    <img src="@Url.Action("Imagem", "MediaProxy", new { url = Model.TimeVisitante?.EscudoUrl })"
                         alt="@Model.TimeVisitante?.Nome" style="width:28px;height:28px;object-fit:contain;" />
                </div>
            </div>

            <div style="display:flex;align-items:center;height:10px;border-radius:6px;overflow:hidden;margin-bottom:0.25rem;background:#e5e7eb;">
                <div style="height:100%;background:#1e3a5f;width:@(possCasa)%;"></div>
                <div style="height:100%;background:#9ca3af;width:@(possVis)%;"></div>
            </div>
            <div style="display:flex;justify-content:space-between;font-size:13px;font-weight:700;color:#1e3a5f;margin-bottom:1.5rem;">
                <span>@(possCasa)%</span>
                <span style="color:#6b7280;">@(possVis)%</span>
            </div>

            @foreach (var (label, chave) in metricasEstatisticas)
            {
                var valCasaStr = PegarStat(statsCasa, chave);
                var valVisStr = PegarStat(statsVis, chave);
                var valCasaNum = PegarStatNumero(statsCasa, chave);
                var valVisNum = PegarStatNumero(statsVis, chave);
                var total = valCasaNum + valVisNum;
                var pctCasa = total > 0 ? (valCasaNum / total * 100) : 50;
                var pctVis = 100 - pctCasa;

                <div style="margin-bottom:1rem;">
                    <div style="display:flex;justify-content:space-between;font-size:13px;color:#374151;margin-bottom:4px;">
                        <span style="font-weight:700;">@valCasaStr</span>
                        <span style="color:#6b7280;">@label</span>
                        <span style="font-weight:700;">@valVisStr</span>
                    </div>
                    <div style="display:flex;align-items:center;height:8px;border-radius:5px;overflow:hidden;background:#e5e7eb;">
                        <div style="height:100%;background:#1e3a5f;width:@(pctCasa)%;"></div>
                        <div style="height:100%;background:#9ca3af;width:@(pctVis)%;"></div>
                    </div>
                </div>
            }
        }
    </div>
</div>

<script>
