        color: #cbd5e1;
        transition: background .15s;
        position: relative;
    }

        .mb-event:hover {
            background: rgba(255,255,255,.09);
        }

        .mb-event.casa {
            flex-direction: row;
        }

        .mb-event.vis {
            flex-direction: row-reverse;
            text-align: right;
        }

    .mb-event-min {
        font-size: 11px;
        font-weight: 700;
        color: rgba(255,255,255,.45);
        min-width: 28px;
        flex-shrink: 0;
    }

    .mb-event-icon {
        font-size: 14px;
        flex-shrink: 0;
    }

    .mb-event-text {
        flex: 1;
        line-height: 1.3;
    }

        .mb-event-text strong {
            color: #e2e8f0;
            font-weight: 600;
        }

        .mb-event-text small {
            color: rgba(255,255,255,.4);
            font-size: 11px;
            display: block;
        }

    .mb-event-del {
