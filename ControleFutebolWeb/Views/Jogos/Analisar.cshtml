                    <span style="display:block; font-size:10px; color:#6b7280;">Se preenchida, vale como nota final (ignora base + ações)</span>
                </label>
                <input type="number" id="av-nota-manual" min="0" max="10" step="0.1" placeholder="—"
                       style="width:70px; font-size:14px; text-align:center; border:1px solid #2a2a2a; border-radius:6px; padding:6px; background:#0f0f0f; color:#e5e7eb;">
            </div>
            <div style="margin-top:0.75rem;">
                <label style="font-size:12px; color:#9ca3af;">Observação:</label>
                <textarea id="av-obs" rows="2" style="width:100%; margin-top:4px; font-size:13px; border:1px solid #2a2a2a; border-radius:6px; padding:6px; resize:vertical; background:#0f0f0f; color:#e5e7eb;"></textarea>
            </div>
            <button type="button" onclick="salvarAvaliacao()" style="width:100%; margin-top:10px; padding:8px; background:#d4a520; color:#141414; border:none; border-radius:6px; font-size:14px; font-weight:700; cursor:pointer;">Salvar</button>
        </div>
    </div>
