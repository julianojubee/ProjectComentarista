@model ControleFutebolWeb.Models.ViewModels.AnalisarViewModel
@removeTagHelper Microsoft.AspNetCore.Mvc.TagHelpers.OptionTagHelper, Microsoft.AspNetCore.Mvc.TagHelpers
@using ControleFutebolWeb.Helpers
@using System.Text.Json
@{
    // Título da aba do navegador: app na frente + confronto, para diferenciar
    // várias análises abertas ao mesmo tempo (ex.: "Análise de Craque - Nova Zelândia x Bélgica").
    ViewData["TitleOverride"] = $"Análise de Craque - {Model.Jogo.TimeCasa?.Nome} x {Model.Jogo.TimeVisitante?.Nome}";

    var faseAtual = (Model.FaseEscalacaoAtual as string) ?? "INICIAL";
    var faseEhInicial = faseAtual == "INICIAL";
    var fasesTaticas = (Model.FasesTaticas as List<ControleFutebolWeb.Models.FaseTatica>) ?? new List<ControleFutebolWeb.Models.FaseTatica>();
    var mostrarBancoReservas = (Model.MostrarBancoReservas as bool?) ?? false;
    var jogadoresEntraramCasa = (Model.JogadoresEntraramCasa as List<int>) ?? new List<int>();
    var jogadoresEntraramVisitante = (Model.JogadoresEntraramVisitante as List<int>) ?? new List<int>();
    var jogadoresSairamCasa = (Model.JogadoresSairamCasa as List<int>) ?? new List<int>();
    var jogadoresSairamVisitante = (Model.JogadoresSairamVisitante as List<int>) ?? new List<int>();
    var entrouNoLugarDe = (Model.EntrouNoLugarDe as Dictionary<int, string>) ?? new Dictionary<int, string>();
    // Texto do tooltip da seta verde: com o registro da substituição mostra
    // "Entrou no lugar de {nome} ({min}')"; sem registro, o texto genérico.
    string TituloEntrou(int jogadorId) =>
        entrouNoLugarDe.TryGetValue(jogadorId, out var saiu)
            ? $"Entrou no lugar de {saiu}"
            : "Jogador entrou";
    var golsPorJogador = (Model.GolsPorJogador as Dictionary<int, int>) ?? new Dictionary<int, int>();
    var assistsPorJogador = (Model.AssistsPorJogador as Dictionary<int, int>) ?? new Dictionary<int, int>();

    // Abrevia pela primeira posição (pode ser composta: "Lateral Direito/Zagueiro")
    // e reconhece os nomes granulares vindos de PosicaoFormacao.
    string AbreviarPosicao(string? pos)
    {
        var p = (pos ?? "").Split('/')[0].Trim().ToLowerInvariant();
        if (p.Length == 0) return "";
        if (p.Contains("gol"))        return "GL";
        if (p.StartsWith("zag"))      return "ZG";
        if (p.StartsWith("lateral"))  return p.Contains("esq") ? "LE" : "LD";
        if (p.StartsWith("ala"))      return "AL";
        if (p.StartsWith("volante"))  return "VL";
        if (p.StartsWith("meia"))     return p.Contains("ofensiv") ? "MO" : "ME";
        if (p.StartsWith("ponta"))    return p.Contains("esq") ? "PE" : "PD";
        if (p.StartsWith("centro"))   return "CA";
        if (p.StartsWith("ata"))      return "AT";
        if (p.StartsWith("def"))      return "DF";
        return p.Length > 2 ? p[..2].ToUpperInvariant() : p.ToUpperInvariant();
    }

    // Estatísticas da partida (posse, finalizações, etc.) — ver Jogo.EstatisticasJson
    Dictionary<string, string> statsCasa = new();
    Dictionary<string, string> statsVis = new();
    if (!string.IsNullOrWhiteSpace(Model.Jogo.EstatisticasJson))
    {
        try
        {
            using var doc = JsonDocument.Parse(Model.Jogo.EstatisticasJson);
            foreach (var item in doc.RootElement.EnumerateArray())
            {
                var timeId = item.GetProperty("TimeId").GetInt32();
                var stats = new Dictionary<string, string>();
                if (item.TryGetProperty("Stats", out var statsEl))
                {
                    foreach (var prop in statsEl.EnumerateObject())
                        stats[prop.Name] = prop.Value.ValueKind == JsonValueKind.Null
                            ? "0" : (prop.Value.GetString() ?? "0");
                }

                if (timeId == Model.Jogo.TimeCasa?.IdApi) statsCasa = stats;
                else if (timeId == Model.Jogo.TimeVisitante?.IdApi) statsVis = stats;
            }
        }
        catch { /* JSON inválido/antigo — ignora */ }
    }

    string PegarStat(Dictionary<string, string> stats, string chave) =>
        stats.TryGetValue(chave, out var v) ? v : "0";

    double PegarStatNumero(Dictionary<string, string> stats, string chave)
    {
        var raw = PegarStat(stats, chave).Replace("%", "").Trim();
        return double.TryParse(raw, System.Globalization.CultureInfo.InvariantCulture, out var n) ? n : 0;
    }

    var metricasEstatisticas = new List<(string label, string chave)>
    {
        ("Finalizações totais", "Total Shots"),
        ("Finalizações no gol", "Shots on Goal"),
        ("Finalizações para fora", "Shots off Goal"),
        ("Finalizações bloqueadas", "Blocked Shots"),
        ("Escanteios", "Corner Kicks"),
        ("Impedimentos", "Offsides"),
        ("Faltas", "Fouls"),
        ("Cartões amarelos", "Yellow Cards"),
        ("Cartões vermelhos", "Red Cards"),
        ("Defesas do goleiro", "Goalkeeper Saves"),
        ("Passes certos", "Passes accurate"),
        ("Precisão de passe", "Passes %"),
    };
}

<div id="jogador-tooltip"></div>

<div class="an-root">
<style>
    :root {
        --cor-camisa-casa: #@(string.IsNullOrWhiteSpace(Model.Jogo.CorCamisaCasa) ? "dc3545" : Model.Jogo.CorCamisaCasa);
        --cor-numero-casa: #@(string.IsNullOrWhiteSpace(Model.Jogo.CorNumeroCasa) ? "ffffff" : Model.Jogo.CorNumeroCasa);
        --cor-camisa-vis:  #@(string.IsNullOrWhiteSpace(Model.Jogo.CorCamisaVisitante) ? "0d6efd" : Model.Jogo.CorCamisaVisitante);
        --cor-numero-vis:  #@(string.IsNullOrWhiteSpace(Model.Jogo.CorNumeroVisitante) ? "ffffff" : Model.Jogo.CorNumeroVisitante);
    }

    /* ── Página sempre no tema escuro/dourado (mesmo padrão das telas já
       convertidas — Home, Times, Jogadores, Jogos, Competições, Relatórios,
       Estatísticas). Full-bleed: ocupa a largura toda, ignorando o gutter
       do .container do layout. ── */
    .an-root {
        margin: 0 -12px;
        background: #0f0f0f;
        border-radius: 14px;
        overflow: hidden;
        padding: 20px 2.5rem 48px;
        color: #e5e7eb;
        font-family: 'Barlow', Arial, sans-serif;
    }
    .an-root * { box-sizing: border-box; }

    /* Bootstrap genérico usado nesta tela → reskin dark */
    .an-root .form-select, .an-root .form-control {
        background: #1a1a1a !important; border: 1px solid #2a2a2a !important;
        color: #e5e7eb !important; border-radius: 8px !important;
        font-family: 'Barlow', Arial, sans-serif !important;
    }
    .an-root .form-select:focus, .an-root .form-control:focus { border-color: #d4a520 !important; box-shadow: none !important; }
    .an-root .form-select option { background: #1a1a1a; }
    .an-root label, .an-root .form-label, .an-root .fw-bold { color: #9ca3af !important; }
    .an-root .text-muted { color: #6b7280 !important; }

    .an-root .nav-tabs { border-bottom: 2px solid #222; }
    .an-root .nav-tabs .nav-link {
        color: #6b7280; border: none; border-bottom: 2px solid transparent;
        font-size: .85rem; font-weight: 600; margin-bottom: -2px; background: transparent;
    }
    .an-root .nav-tabs .nav-link:hover { color: #d4a520; border-color: transparent; }
    .an-root .nav-tabs .nav-link.active {
        color: #d4a520; background: transparent; border-color: transparent transparent #d4a520; font-weight: 700;
    }

    .an-root .btn-outline-primary {
        color: #60a5fa; border-color: rgba(59,130,246,.4); background: rgba(59,130,246,.08);
    }
    .an-root .btn-outline-primary:hover { background: rgba(59,130,246,.18); color: #93c5fd; border-color: rgba(59,130,246,.5); }
    .an-root .btn-outline-warning {
        color: #d4a520; border-color: rgba(212,165,32,.5); background: rgba(212,165,32,.08);
    }
    .an-root .btn-outline-warning:hover { background: rgba(212,165,32,.18); color: #f0c04a; }
    .an-root .btn-primary { background: #d4a520; border-color: #d4a520; color: #141414; }
    .an-root .btn-primary:hover { background: #c49918; border-color: #c49918; }
    .an-root .badge.bg-secondary { background: #374151 !important; }

    .an-root .cf-card { background: #161616; border: 1px solid #262626; border-radius: 12px; }

    /* Tabelas Bootstrap (listas de jogadores) → reskin dark */
    .an-root .table { color: #e5e7eb; margin-bottom: 0; }
    .an-root .table > :not(caption) > * > * { background-color: transparent; border-color: #1e1e1e; color: #e5e7eb; box-shadow: none; }
    .an-root .table-striped > tbody > tr:nth-of-type(odd) > * { background-color: rgba(255,255,255,0.03); }
    .an-root .table thead th { color: #6b7280; font-size: 10px; text-transform: uppercase; letter-spacing: .06em; border-bottom: 1px solid #262626; font-weight: 700; }
    .an-root .table-sm td, .an-root .table-sm th { padding: .35rem .5rem; }

    /* ── Campo: substitui a textura antiga (campo.png) pelo gramado plano
       do novo layout, com as marcações desenhadas em divs (igual ao mock). ── */
    .an-root .campo {
        background: linear-gradient(180deg, #14532d 0%, #166534 100%) !important;
        border: 2px solid rgba(255,255,255,.15) !important;
        border-radius: 10px !important;
        max-height: none !important;
        height: auto !important;
    }
    .campo-linha-meio { position: absolute; left: 0; right: 0; top: 50%; height: 1px; background: rgba(255,255,255,.22); pointer-events: none; }
    .campo-circulo { position: absolute; left: 50%; top: 50%; width: 22%; aspect-ratio: 1; border: 1.5px solid rgba(255,255,255,.2); border-radius: 50%; transform: translate(-50%,-50%); pointer-events: none; }
    .campo-area-sup, .campo-area-inf { position: absolute; left: 20%; right: 20%; height: 14%; border: 1.5px solid rgba(255,255,255,.2); pointer-events: none; }
    .campo-area-sup { top: -1px; border-top: none; }
    .campo-area-inf { bottom: -1px; border-bottom: none; }
    .campo-gol-sup, .campo-gol-inf { position: absolute; left: 30%; right: 30%; height: 6%; border: 1.5px solid rgba(255,255,255,.2); background: rgba(255,255,255,.04); pointer-events: none; }
    .campo-gol-sup { top: -1px; border-top: none; }
    .campo-gol-inf { bottom: -1px; border-bottom: none; }

    /* ── Larguras do layout: lista de jogadores fixa em 190px, campo flexível
       (igual ao grid 190px 1fr 1fr 190px do novo layout) ── */
    .an-root #painelEscalacao .col-5.scroll-panel { flex: 0 0 190px; max-width: 190px; width: 190px; }
    .an-root #painelEscalacao .col-7 { flex: 1 1 0%; max-width: 100%; width: auto; }

    /* ── Painel de jogadores (cabeçalho com escudo + nome + lista) ── */
    .jog-panel {
        background: #161616; border: 1px solid #262626; border-radius: 10px; overflow: hidden;
    }
    .jog-panel-header {
        display: flex; align-items: center; gap: 6px; padding: 8px 10px;
        background: #111; border-bottom: 1px solid #1e1e1e;
        font-size: .72rem; font-weight: 700;
        color: #6b7280; text-transform: uppercase; letter-spacing: .1em;
    }
    .jog-panel-header img { width: 14px; height: 14px; object-fit: contain; flex-shrink: 0; }
    .jog-panel .filtro-jogador { margin: 6px 8px 4px; width: calc(100% - 16px); }
    .jog-panel table { table-layout: fixed; width: 100%; }
    .an-root .jog-panel table th, .an-root .jog-panel table td { padding: .3rem .25rem !important; }
    .an-root .jog-panel table th:first-child, .an-root .jog-panel table td:first-child { width: 32px; padding: .3rem .25rem .3rem 0 !important; }
    .jog-panel table td:nth-child(2) { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; font-size: 0.8rem; }
    .an-root .jog-panel table th:last-child, .an-root .jog-panel table td:last-child { width: 34px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; text-align: left; padding: .3rem 0 .3rem 2px !important; }
    .jog-panel table td:last-child { font-size: 0.68rem; color: #6b7280; font-weight: 700; letter-spacing: .04em; }
    .an-root .scroll-panel::-webkit-scrollbar { width: 5px; }
    .an-root .scroll-panel::-webkit-scrollbar-track { background: #111; }
    .an-root .scroll-panel::-webkit-scrollbar-thumb { background: #333; border-radius: 3px; }

    .posicao-drop {
        position: absolute;
        text-align: center;
        cursor: grab;
        color: white;
        font-size: 11px;
        text-shadow: 1px 1px 2px black;
        transform: translate(-50%, -50%);
    }

    /* ── Setas de movimentação dos jogadores ── */
    .setas-svg {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        pointer-events: none;
    }

        .setas-svg line {
            stroke: #facc15;
            stroke-width: 3;
            stroke-linecap: round;
            filter: drop-shadow(0 1px 1px rgba(0,0,0,.5));
            pointer-events: none;
        }

    body.modo-seta .setas-svg line {
        pointer-events: stroke;
        cursor: pointer;
    }

    /* ── Mapa de calor: canvas inserido como primeiro filho do .campo, então
       fica atrás das linhas do campo e dos jogadores (que vêm depois no DOM) ── */
    .heatmap-overlay {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        pointer-events: none;
        display: none;
        opacity: .85;
    }

    body.modo-seta .campo { cursor: crosshair; }
    body.modo-seta .posicao-drop { cursor: pointer; }

    /* No modo seta os botões +/ℹ não podem roubar o clique do slot */
    body.modo-seta .btn-avaliar,
    body.modo-seta .btn-info-jogador { pointer-events: none; opacity: .25; }

    .posicao-drop.seta-origem .player-circle {
        outline: 3px solid #facc15;
        outline-offset: 2px;
    }

    #btnModoSeta.ativo {
        background: #facc15;
        border-color: #facc15;
        color: #111;
        font-weight: 700;
    }

        /* Botões +/ℹ, a seta ↑ e o selo de cartão vermelho ficam fora do
           pointer-events:none: precisam receber clique/hover. IMPORTANTE: os
           :not() elevam a especificidade desta regra acima dos estilos dos
           próprios botões — qualquer novo elemento interativo dentro do slot
           precisa ser adicionado aqui também. */
        .posicao-drop *:not(.btn-avaliar):not(.btn-info-jogador):not(.sub-chip-in):not(.card-vermelho-badge) {
            pointer-events: none;
        }

    .scroll-panel {
        height: 600px;
        overflow-y: auto;
        overflow-x: hidden;
    }

    .filtro-jogador {
        width: 100%;
        padding: 4px 8px;
        margin-bottom: 4px;
        font-size: 12px;
        border: 1px solid #2a2a2a;
        border-radius: 6px;
        background: #1a1a1a;
        color: #e5e7eb;
        box-sizing: border-box;
        position: sticky;
        top: 0;
        z-index: 5;
    }
    .filtro-jogador:focus { border-color: #d4a520; outline: none; }
    .filtro-jogador::placeholder { color: #6b7280; }

    .jogador-row {
        cursor: grab;
    }

        .jogador-row.usado {
            display: none;
        }

    .banco {
        min-height: 100px;
        border: 2px dashed #333;
        border-radius: 6px;
        padding: 8px;
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
        align-items: flex-start;
        background: #111;
        margin-top: 8px;
    }

        .banco.drag-over {
            border-color: #d4a520;
            background: rgba(212,165,32,0.06);
        }

    .reserva-card {
        display: flex;
        flex-direction: column;
        align-items: center;
        font-size: 11px;
        color: #9ca3af;
        width: 56px;
        cursor: pointer;
        position: relative;
    }

        .reserva-card .rem-btn {
            position: absolute;
            top: -4px;
            right: -4px;
            width: 16px;
            height: 16px;
            background: #dc3545;
            color: white;
            border-radius: 50%;
            font-size: 10px;
            line-height: 16px;
            text-align: center;
            cursor: pointer;
            pointer-events: all;
            z-index: 10;
        }

    .banco-label {
        font-size: 12px;
        color: #6b7280;
        margin-bottom: 4px;
        font-weight: 500;
    }

    .btn-avaliar {
        position: absolute;
        top: -6px;
        right: -6px;
        width: 16px;
        height: 16px;
        border-radius: 50%;
        background: #f5c400;
        border: none;
        font-size: 12px;
        font-weight: 700;
        color: #333;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        line-height: 1;
        z-index: 10;
        pointer-events: all;
    }

    .btn-info-jogador {
        position: absolute;
        top: -6px;
        left: -6px;
        width: 16px;
        height: 16px;
        border-radius: 50%;
        background: #38bdf8;
        border: none;
        font-size: 10px;
        font-weight: 700;
        color: #0c1a2e;
        cursor: default;
        display: flex;
        align-items: center;
        justify-content: center;
        line-height: 1;
        z-index: 10;
        pointer-events: all;
    }

    #jogador-tooltip {
        display: none;
        position: fixed;
        z-index: 9999;
        background: #1e293b;
        border: 1px solid #38bdf8;
        border-radius: 8px;
        padding: 8px 12px;
        font-size: 12px;
        color: #e2e8f0;
        min-width: 170px;
        max-width: 240px;
        pointer-events: none;
        box-shadow: 0 4px 16px rgba(0,0,0,0.5);
        line-height: 1.6;
    }

    #jogador-tooltip .tt-header {
        display: flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 6px;
    }

    #jogador-tooltip .tt-foto {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        object-fit: cover;
        border: 2px solid #38bdf8;
        flex-shrink: 0;
    }

    #jogador-tooltip .tt-nome {
        font-weight: 700;
        font-size: 13px;
        color: #38bdf8;
        line-height: 1.3;
    }

    #jogador-tooltip .tt-meta {
        display: flex;
        flex-wrap: wrap;
        gap: 6px 10px;
        margin-bottom: 4px;
        font-size: 11px;
        color: #cbd5e1;
    }

    #jogador-tooltip .tt-stats {
        display: flex;
        gap: 10px;
        margin-top: 6px;
        padding-top: 6px;
        border-top: 1px solid #334155;
    }

    #jogador-tooltip .tt-stat-gol  { color: #4ade80; font-weight: 600; }
    #jogador-tooltip .tt-stat-ast  { color: #fb923c; font-weight: 600; }

    #jogador-tooltip .tt-obs {
        margin-top: 6px;
        padding-top: 6px;
        border-top: 1px solid #334155;
        color: #94a3b8;
        white-space: pre-wrap;
    }

    .posicao-drop *:not(.btn-avaliar):not(.btn-info-jogador):not(.sub-chip-in):not(.card-vermelho-badge) {
        pointer-events: none;
    }

    .sub-badge-in {
        color: #198754;
        font-size: 12px;
        font-weight: 700;
        margin-left: 6px;
    }

    .sub-badge-out {
        color: #dc3545;
        font-size: 12px;
        font-weight: 700;
        margin-left: 6px;
    }

    /* Seta verde de "entrou": posicionada de forma absoluta no canto inferior
       direito do círculo do jogador. Antes ficava DENTRO de .player-name, que
       tem max-width:64px + overflow:hidden — nomes longos truncados cortavam a
       seta junto (por isso ela "sumia às vezes"). */
    .sub-chip-in {
        position: absolute;
        top: 24px;              /* borda inferior do círculo de 36px */
        left: 50%;
        margin-left: 9px;       /* metade do círculo (18px) - metade do chip */
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 16px;
        height: 16px;
        border-radius: 50%;
        background: #16a34a;
        color: #fff;
        font-size: 10px;
        line-height: 1;
        border: 1.5px solid #fff;
        box-shadow: 0 1px 3px rgba(0,0,0,.45);
        z-index: 3;
        pointer-events: auto; /* recebe hover para o tooltip */
        cursor: help;
    }

    /* Jogador expulso (cartão vermelho): botão em campo fica cinza/desabilitado
       e não pode mais ser arrastado (ver draggable="false" no HTML do slot). */
    .posicao-drop.expulso {
        cursor: not-allowed;
    }
    .posicao-drop.expulso .player-circle {
        filter: grayscale(1);
        opacity: .55;
    }
    .card-vermelho-badge {
        position: absolute;
        top: -4px;
        left: 50%;
        margin-left: 9px;      /* mesmo cálculo do .sub-chip-in: metade do círculo de 36px */
        width: 11px;
        height: 15px;
        background: #dc2626;
        border: 1.5px solid #fff;
        border-radius: 2px;
        box-shadow: 0 1px 3px rgba(0,0,0,.45);
        z-index: 3;
        pointer-events: auto;
        cursor: help;
    }

    .obs-box {
        margin-top: 14px;
        border: 1px solid #262626;
        border-radius: 10px;
        padding: 10px;
        background: #161616;
    }

    .obs-title {
        font-size: 13px;
        font-weight: 600;
        color: #9ca3af;
        margin-bottom: 8px;
    }

    .obs-row {
        display: grid;
        grid-template-columns: 180px 1fr;
        gap: 8px;
        margin-bottom: 8px;
        align-items: start;
    }

    .obs-team-pick {
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .obs-team-icon {
        width: 20px;
        height: 20px;
        object-fit: contain;
        border-radius: 50%;
        border: 1px solid #2a2a2a;
        background: #1a1a1a;
    }

    .obs-row textarea {
        width: 100%;
        min-height: 38px;
        border: 1px solid #2a2a2a;
        border-radius: 8px;
        padding: 8px 10px;
        font-size: 13px;
        resize: none;
        overflow: hidden;
        line-height: 1.35;
        background: #0f0f0f;
        color: #e5e7eb;
    }
    .obs-row textarea:focus { border-color: #d4a520; outline: none; }

    .obs-actions {
        display: flex;
