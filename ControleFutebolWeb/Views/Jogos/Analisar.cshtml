@model ControleFutebolWeb.Models.Jogo
@removeTagHelper Microsoft.AspNetCore.Mvc.TagHelpers.OptionTagHelper, Microsoft.AspNetCore.Mvc.TagHelpers
@functions {
    string ObterCamisa(ControleFutebolWeb.Models.Jogo jogo, ControleFutebolWeb.Models.Time time)
    {
        bool eTimeCasa = jogo.TimeCasaId == time.Id;
        if (eTimeCasa)
            return time.CamisaUrl ?? "";
        return time.CamisaVisitanteUrl ?? time.CamisaUrl ?? "";
    }
}
@{
    var faseAtual = (ViewBag.FaseEscalacaoAtual as string) ?? "INICIAL";
    var faseEhInicial = faseAtual == "INICIAL";
    var mostrarBancoReservas = (ViewBag.MostrarBancoReservas as bool?) ?? false;
    var jogadoresEntraramCasa = (ViewBag.JogadoresEntraramCasa as List<int>) ?? new List<int>();
    var jogadoresEntraramVisitante = (ViewBag.JogadoresEntraramVisitante as List<int>) ?? new List<int>();
    var jogadoresSairamCasa = (ViewBag.JogadoresSairamCasa as List<int>) ?? new List<int>();
    var jogadoresSairamVisitante = (ViewBag.JogadoresSairamVisitante as List<int>) ?? new List<int>();
}

<style>
    .posicao-drop {
        position: absolute;
        text-align: center;
        cursor: grab;
        color: white;
        font-size: 11px;
        text-shadow: 1px 1px 2px black;
        transform: translate(-50%, -50%);
    }

        .posicao-drop * {
            pointer-events: none;
        }

    .scroll-panel {
        max-height: 700px;
        overflow-y: auto;
    }

    .jogador-row {
        cursor: grab;
    }

        .jogador-row.usado {
            display: none;
        }

    .banco {
        min-height: 100px;
        border: 2px dashed #aaa;
        border-radius: 6px;
        padding: 8px;
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
        align-items: flex-start;
        background: #f9f9f9;
        margin-top: 8px;
    }

        .banco.drag-over {
            border-color: #198754;
            background: #e8f5e9;
        }

    .reserva-card {
        display: flex;
        flex-direction: column;
        align-items: center;
        font-size: 11px;
        color: #333;
        width: 56px;
        cursor: pointer;
        position: relative;
    }

        .reserva-card .rem-btn {
            position: absolute;
            top: -4px;
            right: -4px;
            width: 16px;
            height: 16px;
            background: #dc3545;
            color: white;
            border-radius: 50%;
            font-size: 10px;
            line-height: 16px;
            text-align: center;
            cursor: pointer;
            pointer-events: all;
            z-index: 10;
        }

    .banco-label {
        font-size: 12px;
        color: #666;
        margin-bottom: 4px;
        font-weight: 500;
    }

    .btn-avaliar {
        position: absolute;
        top: -6px;
        right: -6px;
        width: 16px;
        height: 16px;
        border-radius: 50%;
        background: #f5c400;
        border: none;
        font-size: 12px;
        font-weight: 700;
        color: #333;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        line-height: 1;
        z-index: 10;
        pointer-events: all;
    }

    .posicao-drop *:not(.btn-avaliar) {
        pointer-events: none;
    }

    .sub-badge-in {
        color: #198754;
        font-size: 12px;
        font-weight: 700;
        margin-left: 6px;
    }

    .sub-badge-out {
        color: #dc3545;
        font-size: 12px;
        font-weight: 700;
        margin-left: 6px;
    }

    .sub-chip-in {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 16px;
        height: 16px;
        border-radius: 50%;
        background: #16a34a;
        color: #fff;
        font-size: 10px;
        margin-left: 6px;
        line-height: 1;
    }

    .obs-box {
        margin-top: 14px;
        border: 1px solid #d1d5db;
        border-radius: 10px;
        padding: 10px;
        background: #fafafa;
    }

    .obs-title {
        font-size: 13px;
        font-weight: 600;
        color: #374151;
        margin-bottom: 8px;
    }

    .obs-row {
        display: grid;
        grid-template-columns: 180px 1fr;
        gap: 8px;
        margin-bottom: 8px;
        align-items: start;
    }

    .obs-team-pick {
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .obs-team-icon {
        width: 20px;
        height: 20px;
        object-fit: contain;
        border-radius: 50%;
        border: 1px solid #e5e7eb;
        background: #fff;
    }

    .obs-row textarea {
        width: 100%;
        min-height: 38px;
        border: 1px solid #d1d5db;
        border-radius: 8px;
        padding: 8px 10px;
        font-size: 13px;
        resize: none;
        overflow: hidden;
        line-height: 1.35;
    }

    .obs-actions {
        display: flex;
        gap: 8px;
        margin-top: 6px;
    }

    .obs-btn {
        border: 1px solid #d1d5db;
        background: #fff;
        color: #374151;
        border-radius: 8px;
        padding: 5px 9px;
        font-size: 12px;
        cursor: pointer;
    }

    .cf-comp-hero {
        position: relative;
        border-radius: 14px;
        padding: 1.5rem 1.6rem;
        margin-bottom: 1rem;
        overflow: hidden;
        background: linear-gradient(135deg, #0b5f2a 0%, #1f8f45 55%, #0d6d30 100%);
    }

    .cf-comp-hero::before {
        content: "";
        position: absolute;
        inset: 0;
        opacity: 0.12;
        background-image: radial-gradient(circle at 50% 50%, transparent 28%, #fff 28.5%, #fff 29.2%, transparent 29.8%), linear-gradient(90deg, transparent 49.5%, #fff 49.5%, #fff 50.5%, transparent 50.5%), linear-gradient(transparent 49.5%, #fff 49.5%, #fff 50.5%, transparent 50.5%);
    }

    .cf-comp-hero-content {
        position: relative;
        z-index: 1;
    }

    .cf-comp-badge {
        display: inline-block;
        background: rgba(255, 255, 255, 0.16);
        color: #e6f7eb;
        font-size: 10px;
        font-weight: 700;
        letter-spacing: 0.8px;
        text-transform: uppercase;
        padding: 4px 11px;
        border-radius: 999px;
        margin-bottom: 0.55rem;
    }

    .cf-comp-title {
        color: #fff;
        font-size: 1.35rem;
        font-weight: 700;
        margin: 0 0 0.2rem;
    }

    .cf-comp-title-wrap {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 0.2rem;
    }

    .cf-comp-logo {
        width: 34px;
        height: 34px;
        object-fit: contain;
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.12);
        padding: 2px;
    }

    .cf-comp-sub {
        color: rgba(255, 255, 255, 0.85);
        font-size: 0.92rem;
        margin: 0;
    }
    /* ── Placar board ─────────────────────────────────────── */
    .match-board {
        background: linear-gradient(160deg, #0d1b2a 0%, #1b2e44 60%, #0d1b2a 100%);
        border-radius: 16px;
        padding: 1.25rem 1.5rem 1rem;
        margin-bottom: 1.2rem;
        position: relative;
        overflow: hidden;
        box-shadow: 0 4px 24px rgba(0,0,0,.35);
    }

        .match-board::before {
            content: "";
            position: absolute;
            inset: 0;
            background-image: radial-gradient(circle at 20% 50%, rgba(55,138,221,.08) 0%, transparent 55%), radial-gradient(circle at 80% 50%, rgba(55,138,221,.08) 0%, transparent 55%);
            pointer-events: none;
        }

    /* ── Linha de times + placar ─────────────────────────── */
    .mb-scoreline {
        display: grid;
        grid-template-columns: 1fr auto 1fr;
        align-items: center;
        gap: 1rem;
    }

    .mb-team {
        display: flex;
        align-items: center;
        gap: 10px;
    }

        .mb-team.away {
            flex-direction: row-reverse;
        }

        .mb-team img {
            width: 42px;
            height: 42px;
            object-fit: contain;
            filter: drop-shadow(0 2px 4px rgba(0,0,0,.5));
            flex-shrink: 0;
        }

    .mb-team-name {
        font-size: .9rem;
        font-weight: 600;
        color: #e2e8f0;
        line-height: 1.2;
    }

    .mb-score {
        display: flex;
        align-items: center;
        gap: 10px;
        justify-content: center;
    }

    .mb-score-box {
        background: rgba(255,255,255,.07);
        border: 1px solid rgba(255,255,255,.15);
        border-radius: 10px;
        min-width: 52px;
        height: 52px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.9rem;
        font-weight: 700;
        color: #fff;
        cursor: pointer;
        transition: background .15s, transform .1s;
        user-select: none;
    }

        .mb-score-box:hover {
            background: rgba(255,255,255,.13);
            transform: scale(1.04);
        }

    .mb-score-sep {
        font-size: 1.4rem;
        color: rgba(255,255,255,.35);
        font-weight: 300;
    }

    /* ── Toolbar de eventos ───────────────────────────────── */
    .mb-toolbar {
        display: flex;
        gap: 8px;
        justify-content: center;
        margin-top: .9rem;
        flex-wrap: wrap;
    }

    .mb-btn {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 6px 13px;
        border-radius: 999px;
        border: 1px solid rgba(255,255,255,.18);
        background: rgba(255,255,255,.07);
        color: rgba(255,255,255,.8);
        font-size: 12px;
        font-weight: 500;
        cursor: pointer;
        transition: background .15s, color .15s, border-color .15s;
    }

        .mb-btn:hover {
            background: rgba(255,255,255,.16);
            color: #fff;
        }

        .mb-btn.gol {
            border-color: rgba(34,197,94,.5);
            color: #4ade80;
        }

            .mb-btn.gol:hover {
                background: rgba(34,197,94,.15);
            }

        .mb-btn.cartao-amarelo {
            border-color: rgba(250,204,21,.5);
            color: #fde047;
        }

            .mb-btn.cartao-amarelo:hover {
                background: rgba(250,204,21,.12);
            }

        .mb-btn.cartao-vermelho {
            border-color: rgba(239,68,68,.5);
            color: #f87171;
        }

            .mb-btn.cartao-vermelho:hover {
                background: rgba(239,68,68,.12);
            }

    /* ── Timeline de eventos ─────────────────────────────── */
    .mb-timeline {
        margin-top: .85rem;
        display: flex;
        flex-direction: column;
        gap: 5px;
        max-height: 220px;
        overflow-y: auto;
        padding-right: 4px;
    }

        .mb-timeline::-webkit-scrollbar {
            width: 4px;
        }

        .mb-timeline::-webkit-scrollbar-track {
            background: transparent;
        }

        .mb-timeline::-webkit-scrollbar-thumb {
            background: rgba(255,255,255,.2);
            border-radius: 4px;
        }

    .mb-event {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 5px 8px;
        border-radius: 8px;
        background: rgba(255,255,255,.05);
        font-size: 12px;
        color: #cbd5e1;
        transition: background .15s;
        position: relative;
    }

        .mb-event:hover {
            background: rgba(255,255,255,.09);
        }

        .mb-event.casa {
            flex-direction: row;
        }

        .mb-event.vis {
            flex-direction: row-reverse;
            text-align: right;
        }

    .mb-event-min {
        font-size: 11px;
        font-weight: 700;
        color: rgba(255,255,255,.45);
        min-width: 28px;
        flex-shrink: 0;
    }

    .mb-event-icon {
        font-size: 14px;
        flex-shrink: 0;
    }

    .mb-event-text {
        flex: 1;
        line-height: 1.3;
    }

        .mb-event-text strong {
            color: #e2e8f0;
            font-weight: 600;
        }

        .mb-event-text small {
            color: rgba(255,255,255,.4);
            font-size: 11px;
            display: block;
        }

    .mb-event-del {
        width: 18px;
        height: 18px;
        border-radius: 50%;
        background: rgba(239,68,68,.25);
        color: #f87171;
        border: none;
        cursor: pointer;
        font-size: 11px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        opacity: 0;
        transition: opacity .15s;
    }

    .mb-event:hover .mb-event-del {
        opacity: 1;
    }

    /* ── Modal de evento ─────────────────────────────────── */
    #modal-evento {
        display: none;
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,.6);
        z-index: 9998;
        align-items: center;
        justify-content: center;
    }

    .modal-evento-box {
        background: #1e293b;
        border: 1px solid rgba(255,255,255,.12);
        border-radius: 16px;
        padding: 1.4rem;
        width: 360px;
        max-width: 95vw;
        box-shadow: 0 20px 60px rgba(0,0,0,.5);
        color: #e2e8f0;
    }

        .modal-evento-box h5 {
            font-size: 15px;
            font-weight: 700;
            margin: 0 0 1rem;
            color: #fff;
        }

    .mev-field {
        margin-bottom: .9rem;
    }

        .mev-field label {
            display: block;
            font-size: 11px;
            font-weight: 600;
            color: rgba(255,255,255,.5);
            text-transform: uppercase;
            letter-spacing: .5px;
            margin-bottom: 5px;
        }

        .mev-field select,
        .mev-field input {
            width: 100%;
            background: rgba(255,255,255,.07);
            border: 1px solid rgba(255,255,255,.15);
            border-radius: 9px;
            padding: 8px 12px;
            font-size: 13px;
            color: #e2e8f0;
        }

            .mev-field select option {
                background: #1e293b;
            }

    .mev-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 10px;
    }

    .mev-actions {
        display: flex;
        gap: 8px;
        margin-top: 1.1rem;
    }

    .mev-save {
        flex: 1;
        background: #2563eb;
        color: #fff;
        border: none;
        border-radius: 9px;
        padding: 9px;
        font-size: 13px;
        font-weight: 600;
        cursor: pointer;
        transition: background .15s;
    }

        .mev-save:hover {
            background: #1d4ed8;
        }

    .mev-cancel {
        background: rgba(255,255,255,.07);
        color: rgba(255,255,255,.6);
        border: 1px solid rgba(255,255,255,.12);
        border-radius: 9px;
        padding: 9px 16px;
        font-size: 13px;
        cursor: pointer;
    }

        .mev-cancel:hover {
            background: rgba(255,255,255,.12);
        }

    .mev-tipo-badge {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 4px 12px;
        border-radius: 999px;
        font-size: 12px;
        font-weight: 600;
        margin-bottom: .8rem;
    }
</style>

@if (Model.CompeticaoId == 1)
{
    <div class="cf-comp-hero">
        <div class="cf-comp-hero-content">
            <span class="cf-comp-badge">Competição nacional</span>
            <div class="cf-comp-title-wrap">
                <img src="~/images/background/campeonatobrasileiro.png" alt="Escudo Campeonato Brasileiro" class="cf-comp-logo" />
                <h2 class="cf-comp-title">Campeonato Brasileiro</h2>
            </div>
            <p class="cf-comp-sub">Análise tática da partida com foco em escalação inicial e final.</p>
        </div>
    </div>
}


<!-- ══ PLACAR BOARD ══════════════════════════════════════════════════════ -->
<div class="match-board">
    <div class="mb-scoreline">
        <!-- Time Casa -->
        <div class="mb-team home">
            @if (!string.IsNullOrEmpty(Model.TimeCasa?.EscudoUrl))
            {
                <img src="@Model.TimeCasa.EscudoUrl" alt="@Model.TimeCasa.Nome" />
            }
            <span class="mb-team-name">@Model.TimeCasa?.Nome</span>
        </div>

        <!-- Placar -->
        <div class="mb-score">
            <div class="mb-score-box" id="placarCasaBox"
                 title="Clique para editar"
                 onclick="editarPlacar()">
                @(Model.PlacarCasa?.ToString() ?? "–")
            </div>
            <span class="mb-score-sep">×</span>
            <div class="mb-score-box" id="placarVisBox"
                 title="Clique para editar"
                 onclick="editarPlacar()">
                @(Model.PlacarVisitante?.ToString() ?? "–")
            </div>
        </div>

        <!-- Time Visitante -->
        <div class="mb-team away">
            @if (!string.IsNullOrEmpty(Model.TimeVisitante?.EscudoUrl))
            {
                <img src="@Model.TimeVisitante.EscudoUrl" alt="@Model.TimeVisitante.Nome" />
            }
            <span class="mb-team-name">@Model.TimeVisitante?.Nome</span>
        </div>
    </div>

    <!-- Toolbar -->
    <div class="mb-toolbar">
        <button type="button" class="mb-btn gol"
                onclick="abrirModalEvento('gol', 'casa')">
            ⚽ Gol Mandante
        </button>
        <button type="button" class="mb-btn gol"
                onclick="abrirModalEvento('gol', 'vis')">
            ⚽ Gol Visitante
        </button>
        <button type="button" class="mb-btn cartao-amarelo"
                onclick="abrirModalEvento('amarelo', 'casa')">
            🟨 Cartão Casa
        </button>
        <button type="button" class="mb-btn cartao-amarelo"
                onclick="abrirModalEvento('amarelo', 'vis')">
            🟨 Cartão Visit.
        </button>
        <button type="button" class="mb-btn cartao-vermelho"
                onclick="abrirModalEvento('vermelho', 'casa')">
            🟥 Vermelho Casa
        </button>
        <button type="button" class="mb-btn cartao-vermelho"
                onclick="abrirModalEvento('vermelho', 'vis')">
            🟥 Vermelho Visit.
        </button>
    </div>

    <!-- Timeline de eventos -->
    <div class="mb-timeline" id="mbTimeline"></div>
</div>

<!-- ══ MODAL DE EVENTO ══════════════════════════════════════════════════ -->
<div id="modal-evento">
    <div class="modal-evento-box">
        <h5 id="mev-titulo">Registrar Evento</h5>

        <div id="mev-tipo-badge-wrap"></div>

        <div class="mev-row">
            <div class="mev-field">
                <label>Minuto</label>
                <input type="number" id="mev-minuto" min="1" max="120" placeholder="Ex: 45" />
            </div>
            <div class="mev-field" id="mev-acrescimo-wrap">
                <label>Acréscimo</label>
                <input type="number" id="mev-acrescimo" min="0" max="30" placeholder="0" />
            </div>
        </div>

        <div class="mev-field" id="mev-jogador-wrap">
            <label>Jogador</label>
            <select id="mev-jogador">
                <option value="">Selecione...</option>
            </select>
        </div>

        <div class="mev-field" id="mev-assistencia-wrap" style="display:none;">
            <label>Assistência (opcional)</label>
            <select id="mev-assistencia">
                <option value="">Nenhuma</option>
            </select>
        </div>

        <div class="mev-field" id="mev-tipo-cartao-wrap" style="display:none;">
            <label>Tipo de Cartão</label>
            <select id="mev-tipo-cartao">
                <option value="Amarelo">🟨 Amarelo</option>
                <option value="Vermelho">🟥 Vermelho</option>
            </select>
        </div>

        <div class="mev-actions">
            <button type="button" class="mev-cancel" onclick="fecharModalEvento()">Cancelar</button>
            <button type="button" class="mev-save" onclick="salvarEvento()">Salvar</button>
        </div>
    </div>
</div>

<!-- ══ MODAL EDITAR PLACAR ══════════════════════════════════════════════ -->
<div id="modal-placar" style="display:none; position:fixed; inset:0; background:rgba(0,0,0,.6); z-index:9998; align-items:center; justify-content:center;">
    <div class="modal-evento-box">
        <h5>Editar Placar</h5>
        <div class="mev-row">
            <div class="mev-field">
                <label>@Model.TimeCasa?.Nome</label>
                <input type="number" id="edit-placar-casa" min="0" max="99" />
            </div>
            <div class="mev-field">
                <label>@Model.TimeVisitante?.Nome</label>
                <input type="number" id="edit-placar-vis" min="0" max="99" />
            </div>
        </div>
        <div class="mev-actions">
            <button type="button" class="mev-cancel" onclick="document.getElementById('modal-placar').style.display='none'">Cancelar</button>
            <button type="button" class="mev-save" onclick="salvarPlacar()">Salvar</button>
        </div>
    </div>
</div>


<!-- Seleção de Formações -->
<div class="row mb-3">
    <div class="col-md-6">
        <form method="get" asp-action="Analisar" asp-controller="Jogos">
            <input type="hidden" name="id" value="@Model.Id" />
            <input type="hidden" name="formacaoVisitanteId" value="@ViewBag.FormacaoVisitanteSelecionada" />
            <input type="hidden" name="faseEscalacao" value="@faseAtual" />
            <label class="fw-bold">Formação @Model.TimeCasa.Nome:</label>
            <select name="formacaoCasaId" class="form-select" onchange="this.form.submit()">
                @foreach (var f in (IEnumerable<SelectListItem>)ViewBag.FormacoesCasa)
                {
                    <option value="@f.Value" @(f.Selected ? "selected" : "")>@f.Text</option>
                }
            </select>
        </form>
    </div>
    <div class="col-md-6">
        <form method="get" asp-action="Analisar" asp-controller="Jogos">
            <input type="hidden" name="id" value="@Model.Id" />
            <input type="hidden" name="formacaoCasaId" value="@ViewBag.FormacaoCasaSelecionada" />
            <input type="hidden" name="faseEscalacao" value="@faseAtual" />
            <label class="fw-bold">Formação @Model.TimeVisitante.Nome:</label>
            <select name="formacaoVisitanteId" class="form-select" onchange="this.form.submit()">
                @foreach (var f in (IEnumerable<SelectListItem>)ViewBag.FormacoesVisitante)
                {
                    <option value="@f.Value" @(f.Selected ? "selected" : "")>@f.Text</option>
                }
            </select>
        </form>
    </div>
</div>

<div class="mb-3">
    <ul class="nav nav-tabs">
        <li class="nav-item">
            <a class="nav-link @(faseEhInicial ? "active" : "")"
               asp-action="Analisar"
               asp-route-id="@Model.Id"
               asp-route-formacaoCasaId="@ViewBag.FormacaoCasaSelecionada"
               asp-route-formacaoVisitanteId="@ViewBag.FormacaoVisitanteSelecionada"
               asp-route-faseEscalacao="INICIAL">
                Escalação Inicial
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link @(!faseEhInicial ? "active" : "")"
               asp-action="Analisar"
               asp-route-id="@Model.Id"
               asp-route-formacaoCasaId="@ViewBag.FormacaoCasaSelecionada"
               asp-route-formacaoVisitanteId="@ViewBag.FormacaoVisitanteSelecionada"
               asp-route-faseEscalacao="FINAL">
                Escalação Final
            </a>
        </li>
    </ul>
</div>

<!-- ── FORM PRINCIPAL (id fixo para o JS encontrar com segurança) ── -->
<form id="formSalvarEscalacao" method="post" asp-action="SalvarEscalacao" asp-controller="Jogos">
    <input type="hidden" name="id" value="@Model.Id" />
    <input type="hidden" name="formacaoCasaId" value="@ViewBag.FormacaoCasaSelecionada" />
    <input type="hidden" name="formacaoVisitanteId" value="@ViewBag.FormacaoVisitanteSelecionada" />
    <input type="hidden" name="faseEscalacao" value="@faseAtual" />
    <input type="hidden" id="observacoesComTags" name="observacoesComTags" value="" />

    <div class="row">

        <!-- ===== TIME DA CASA ===== -->
        <div class="col-md-6">
            @* <h4>
                <img src="@Model.TimeCasa.EscudoUrl" width="24" />
                @Model.TimeCasa.Nome
            </h4> *@
            <div class="row">
                <!-- Lista de jogadores -->
                <div class="col-5 scroll-panel">
                    <table class="table table-sm table-striped">
                        <thead><tr><th></th><th>Nome</th><th>Pos</th></tr></thead>
                        <tbody id="listaCasa">
                            @foreach (var jogador in (List<ControleFutebolWeb.Models.Jogador>)ViewBag.JogadoresCasa)
                            {
                                // ✅ Depois
                                var camisaCasa = Url.Content(ObterCamisa(Model, Model.TimeCasa));
                                <tr class="jogador-row"
                                    id="jogador-casa-@jogador.Id"
                                    draggable="true"
                                    ondragstart="dragJogador(event, @jogador.Id, '@jogador.Nome', '@jogador.NumeroCamisa', '@camisaCasa', 'casa')">
                                    <td>
                                        @if (!string.IsNullOrEmpty(camisaCasa))
                                        {
                                            <img src="@camisaCasa" width="32" height="32" />
                                        }
                                        else
                                        {
                                            <span style="font-size:20px;">👕</span>
                                        }
                                    </td>
                                    <td>
                                        @jogador.Nome
                                        @if (!faseEhInicial && jogadoresSairamCasa.Contains(jogador.Id))
                                        {
                                            <span class="sub-badge-out" title="Jogador saiu">↓</span>
                                        }
                                    </td>
                                    <td>@jogador.Posicao</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <!-- Campinho casa -->
                <div class="col-7">
                    <div id="campoCasa" class="campo"
                         ondrop="dropNoCampo(event, 'campoCasa')"
                         ondragover="allowDrop(event)">
                        @{
                            var idxCasa = 0;
                        }
                        @foreach (var esc in (List<ControleFutebolWeb.Models.Escalacao>)ViewBag.EscalacoesCasa)
                        {
                            <div class="posicao-drop"
                                 data-index="casa_@idxCasa"
                                 data-posicao="@esc.Posicao"
                                 data-campo="casa"
                                 draggable="true"
                                 ondragstart="dragPosicao(event, 'casa_@idxCasa')"
                                 ondrop="dropEscalacao(event, 'casa_@idxCasa')"
                                 ondragover="allowDrop(event)"
                                 style="left:@esc.PosicaoX%; top:@esc.PosicaoY%;">
                                <span>@esc.Posicao</span>
                                @if (esc.Jogador != null)
                                {
                                    <div>
                                        
                                        <img src="@ObterCamisa(Model, Model.TimeCasa)" width="40" style="display:block;margin:0 auto;" />
                                        <div style="font-size:11px;max-width:60px;margin:0 auto;">
                                            @esc.Jogador.Nome
                                            @if (!faseEhInicial && jogadoresEntraramCasa.Contains(esc.Jogador.Id))
                                            {
                                                <span class="sub-chip-in" title="Jogador entrou">↑</span>
                                            }
                                        </div>
                                    </div>
                                    <button type="button"
                                            class="btn-avaliar"
                                            onclick="abrirAvaliacao(@esc.Jogador.Id, '@esc.Jogador.Nome', '@esc.Posicao', event)">
                                        +
                                    </button>
                                }
                            </div>
                            <input type="hidden" name="escalacaoCasa[@idxCasa].Id" value="@esc.Id" />
                            <input type="hidden" name="escalacaoCasa[@idxCasa].PosicaoId" value="@esc.Id" />
                            <input type="hidden" id="escalacaoCasa_@(idxCasa)__JogadorId" name="escalacaoCasa[@idxCasa].JogadorId" value="@esc.JogadorId" />
                            <input type="hidden" id="escalacaoCasa_@(idxCasa)__PosicaoX" name="escalacaoCasa[@idxCasa].PosicaoX" value="@esc.PosicaoX" />
                            <input type="hidden" id="escalacaoCasa_@(idxCasa)__PosicaoY" name="escalacaoCasa[@idxCasa].PosicaoY" value="@esc.PosicaoY" />
                            idxCasa++;
                        }
                    </div>

                    @if (mostrarBancoReservas)
                    {
                        <!-- Banco de reservas casa -->
                        <div class="banco-label mt-2">🪑 Banco de reservas</div>
                        <div id="bancoCasa" class="banco"
                             ondrop="dropNoBanco(event, 'casa')"
                             ondragover="allowDrop(event)">
                            @{
                                var idxResCasa = 0;
                            }
                            @foreach (var esc in (List<ControleFutebolWeb.Models.Escalacao>)ViewBag.ReservasCasa)
                            {
                                <div class="reserva-card" id="reserva-casa-card-@idxResCasa">
                                    <span class="rem-btn" onclick="removerReserva('casa', @idxResCasa)">×</span>
                                    @if (!string.IsNullOrEmpty(Model.TimeCasa.CamisaUrl))
                                    {
                                        <img src="@Model.TimeCasa.CamisaUrl" width="36" />
                                    }
                                    <div style="max-width:54px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">
                                        @esc.Jogador?.Nome
                                    </div>
                                </div>
                                <!-- inputs das reservas JÁ SALVAS ficam dentro do form principal -->
                                <input type="hidden" name="reservasCasa[@idxResCasa].Id" value="@esc.Id" />
                                <input type="hidden" id="reservaCasa_@(idxResCasa)__JogadorId" name="reservasCasa[@idxResCasa].JogadorId" value="@esc.JogadorId" />
                                <input type="hidden" id="reservaCasa_@(idxResCasa)__PosicaoX" name="reservasCasa[@idxResCasa].PosicaoX" value="0" />
                                <input type="hidden" id="reservaCasa_@(idxResCasa)__PosicaoY" name="reservasCasa[@idxResCasa].PosicaoY" value="0" />
                                idxResCasa++;
                            }
                        </div>
                        <input type="hidden" id="totalReservasCasa" value="@idxResCasa" />
                    }
                </div>
            </div>
        </div>

        <!-- ===== TIME VISITANTE ===== -->
        <div class="col-md-6">
            @* <h4>
                <img src="@Model.TimeVisitante.EscudoUrl" width="24" />
                @Model.TimeVisitante.Nome
            </h4> *@
            <div class="row">
                <!-- Campinho visitante -->
                <div class="col-7">
                    <div id="campoVisitante" class="campo"
                         ondrop="dropNoCampo(event, 'campoVisitante')"
                         ondragover="allowDrop(event)">
                        @{
                            var idxVis = 0;
                        }
                        @foreach (var esc in (List<ControleFutebolWeb.Models.Escalacao>)ViewBag.EscalacoesVisitante)
                        {
                            <div class="posicao-drop"
                                 data-index="vis_@idxVis"
                                 data-posicao="@esc.Posicao"
                                 data-campo="vis"
                                 draggable="true"
                                 ondragstart="dragPosicao(event, 'vis_@idxVis')"
                                 ondrop="dropEscalacao(event, 'vis_@idxVis')"
                                 ondragover="allowDrop(event)"
                                 style="left:@esc.PosicaoX%; top:@esc.PosicaoY%;">
                                <span>@esc.Posicao</span>
                                @if (esc.Jogador != null)
                                {
                                    <div>
                                        
                                        <img src="@ObterCamisa(Model, Model.TimeVisitante)" width="40" style="display:block;margin:0 auto;" />
                                        <div style="font-size:11px;max-width:60px;margin:0 auto;">
                                            @esc.Jogador.Nome
                                            @if (!faseEhInicial && jogadoresEntraramVisitante.Contains(esc.Jogador.Id))
                                            {
                                                <span class="sub-chip-in" title="Jogador entrou">↑</span>
                                            }
                                        </div>
                                    </div>
                                    <button type="button"
                                            class="btn-avaliar"
                                            onclick="abrirAvaliacao(@esc.Jogador.Id, '@esc.Jogador.Nome', '@esc.Posicao', event)">
                                        +
                                    </button>
                                }
                            </div>
                            <input type="hidden" name="escalacaoVisitante[@idxVis].Id" value="@esc.Id" />
                            <input type="hidden" name="escalacaoVisitante[@idxVis].PosicaoId" value="@esc.Id" />
                            <input type="hidden" id="escalacaoVisitante_@(idxVis)__JogadorId" name="escalacaoVisitante[@idxVis].JogadorId" value="@esc.JogadorId" />
                            <input type="hidden" id="escalacaoVisitante_@(idxVis)__PosicaoX" name="escalacaoVisitante[@idxVis].PosicaoX" value="@esc.PosicaoX" />
                            <input type="hidden" id="escalacaoVisitante_@(idxVis)__PosicaoY" name="escalacaoVisitante[@idxVis].PosicaoY" value="@esc.PosicaoY" />
                            idxVis++;
                        }
                    </div>

                    @if (mostrarBancoReservas)
                    {
                        <!-- Banco de reservas visitante -->
                        <div class="banco-label mt-2">🪑 Banco de reservas</div>
                        <div id="bancoVisitante" class="banco"
                             ondrop="dropNoBanco(event, 'vis')"
                             ondragover="allowDrop(event)">
                            @{
                                var idxResVis = 0;
                            }
                            @foreach (var esc in (List<ControleFutebolWeb.Models.Escalacao>)ViewBag.ReservasVisitante)
                            {
                                <div class="reserva-card" id="reserva-vis-card-@idxResVis">
                                    <span class="rem-btn" onclick="removerReserva('vis', @idxResVis)">×</span>
                                    @{
                                        var camisaBancoVis = ObterCamisa(Model, Model.TimeVisitante);
                                    }
                                    @if (!string.IsNullOrEmpty(camisaBancoVis))
                                    {
                                        <img src="@camisaBancoVis" width="36" />
                                    }
                                    <div style="max-width:54px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">
                                        @esc.Jogador?.Nome
                                    </div>
                                </div>
                                <input type="hidden" name="reservasVisitante[@idxResVis].Id" value="@esc.Id" />
                                <input type="hidden" id="reservaVis_@(idxResVis)__JogadorId" name="reservasVisitante[@idxResVis].JogadorId" value="@esc.JogadorId" />
                                <input type="hidden" id="reservaVis_@(idxResVis)__PosicaoX" name="reservasVisitante[@idxResVis].PosicaoX" value="0" />
                                <input type="hidden" id="reservaVis_@(idxResVis)__PosicaoY" name="reservasVisitante[@idxResVis].PosicaoY" value="0" />
                                idxResVis++;
                            }
                        </div>
                        <input type="hidden" id="totalReservasVis" value="@idxResVis" />
                    }
                </div>

                <!-- Lista de jogadores visitante -->
                <div class="col-5 scroll-panel">
                    <table class="table table-sm table-striped">
                        <thead><tr><th></th><th>Nome</th><th>Pos</th></tr></thead>
                        <tbody id="listaVisitante">
                            @foreach (var jogador in (List<ControleFutebolWeb.Models.Jogador>)ViewBag.JogadoresVisitante)
                            {
                                // ✅ Depois
                                var camisaVisitante = Url.Content(ObterCamisa(Model, Model.TimeVisitante));
                                <tr class="jogador-row"
                                    id="jogador-vis-@jogador.Id"
                                    draggable="true"
                                    ondragstart="dragJogador(event, @jogador.Id, '@jogador.Nome', '@jogador.NumeroCamisa', '@camisaVisitante', 'vis')">
                                    <td>
                                        @if (!string.IsNullOrEmpty(camisaVisitante))
                                        {
                                            <img src="@camisaVisitante" width="32" height="32" />
                                        }
                                        else
                                        {
                                            <span style="font-size:20px;">👕</span>
                                        }
                                    </td>
                                    <td>
                                        @jogador.Nome
                                        @if (!faseEhInicial && jogadoresSairamVisitante.Contains(jogador.Id))
                                        {
                                            <span class="sub-badge-out" title="Jogador saiu">↓</span>
                                        }
                                    </td>
                                    <td>@jogador.Posicao</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

    </div>

    @if (!faseEhInicial)
    {
        <div class="obs-box">
            <div class="obs-title">Observações da escalação final</div>
            <div id="obsRows"></div>
            <div class="obs-actions">
                <button type="button" class="obs-btn" onclick="adicionarLinhaObs('CASA', '')">+ Observação mandante</button>
                <button type="button" class="obs-btn" onclick="adicionarLinhaObs('VISITANTE', '')">+ Observação visitante</button>
            </div>
        </div>
