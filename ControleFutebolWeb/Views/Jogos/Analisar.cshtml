                        <input type="hidden" id="totalReservasVis" value="@idxResVis" />
                    }
                </div>

                <!-- Lista de jogadores visitante -->
                <div class="col-5 scroll-panel">
                    @{
                        var treinadorVis = Model.TreinadorVisitante as ControleFutebolWeb.Models.Treinador;
                    }
                    @if (treinadorVis != null)
                    {
                        <div class="d-flex align-items-center gap-2 px-1 py-1 mb-1"
                             style="background:#161616;border-radius:7px;border:1px solid #262626;">
                            @if (!string.IsNullOrWhiteSpace(treinadorVis.FotoUrl))
                            {
                                <img src="@Url.FotoSrc(treinadorVis.FotoUrl)"
                                     alt="@treinadorVis.Nome"
                                     style="width:24px;height:24px;border-radius:50%;object-fit:cover;flex-shrink:0;" />
                            }
                            else
                            {
                                <span style="font-size:16px;">🧑‍💼</span>
                            }
                            <div>
                                <div style="font-size:9px;color:#6b7280;text-transform:uppercase;line-height:1;">Treinador</div>
                                <div style="font-size:12px;font-weight:600;color:#f1f5f9;">@treinadorVis.Nome</div>
                            </div>
                        </div>
                    }
                    <div class="jog-panel">
                    <div class="jog-panel-header">
                        @if (!string.IsNullOrEmpty(Model.Jogo.TimeVisitante?.EscudoUrl))
                        {
                            <img src="@Url.Action("Imagem", "MediaProxy", new { url = Model.Jogo.TimeVisitante.EscudoUrl })" alt="" />
                        }
                        @Model.Jogo.TimeVisitante?.Nome
                    </div>
                    <input type="text" id="filtroVis" class="filtro-jogador" placeholder="🔍 Buscar por nome ou número..." oninput="filtrarLista('listaVisitante', this.value)" />
                    <table class="table table-sm table-striped">
                        <thead><tr><th></th><th>Nome</th><th>Pos</th></tr></thead>
                        <tbody id="listaVisitante">
                            @foreach (var jogador in (List<ControleFutebolWeb.Models.Jogador>)Model.JogadoresVisitante)
                            {
                                <tr class="jogador-row"
                                    id="jogador-vis-@jogador.Id"
                                    draggable="true"
                                    ondragstart="dragJogador(event, @jogador.Id, '@jogador.Nome', '@jogador.NumeroCamisa', '', 'vis')">
                                    <td>
                                        <div class="player-circle player-circle-vis" style="width:28px;height:28px;font-size:11px;">
                                            @(jogador.NumeroCamisa?.ToString() ?? "")
                                        </div>
                                    </td>
                                    <td>
                                        @jogador.Nome
                                        @if (!faseEhInicial && jogadoresSairamVisitante.Contains(jogador.Id))
                                        {
                                            <span class="sub-badge-out" title="Jogador saiu">↓</span>
                                        }
                                    </td>
                                    <td>@AbreviarPosicao(jogador.Posicao)</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                    </div><!-- /.jog-panel -->
                </div>
            </div>
        </div>

    </div>

    <div class="obs-box">
        <div class="obs-title">Observações do jogo (mandante, visitante, competição, jogador, marcos históricos…)</div>
        <div id="obsTagList">
            @foreach (var o in Model.ObservacoesTag)
            {
                var rotulo = o.Tipo switch
                {
                    "MANDANTE" => "Mandante",
                    "VISITANTE" => "Visitante",
                    "COMPETICAO" => "Competição",
                    "JOGADOR" => "Jogador",
                    "MARCO" => "Marco",
                    _ => o.Tipo
                };
                <div class="obs-tag-row" data-id="@o.Id">
                    <span class="obs-tag-badge obs-tag-badge-@o.Tipo.ToLowerInvariant()">@rotulo</span>
                    @if (o.Tipo == "JOGADOR" && o.Jogador != null)
                    {
                        <span class="obs-tag-jogador-nome">@o.Jogador.NomeExibicao</span>
                    }
                    <span class="obs-tag-texto">@o.Texto</span>
                    <span class="obs-tag-remover" onclick="removerObservacaoTag(@o.Id, this)" title="Remover">&times;</span>
                </div>
            }
        </div>
        <div class="obs-actions" style="flex-wrap:wrap;">
            <select id="obsTagTipo" class="form-select form-select-sm" style="width:auto;" onchange="atualizarSeletorJogadorObs()">
                <option value="MANDANTE">Mandante (@Model.Jogo.TimeCasa.Nome)</option>
                <option value="VISITANTE">Visitante (@Model.Jogo.TimeVisitante.Nome)</option>
                <option value="COMPETICAO">Competição</option>
                <option value="JOGADOR">Jogador</option>
                <option value="MARCO">Marco histórico</option>
            </select>
            <select id="obsTagJogador" class="form-select form-select-sm" style="width:auto; display:none;">
                <option value="">Selecione o jogador…</option>
                @foreach (var j in Model.JogadoresEscalados)
                {
                    <option value="@j.Id">@j.NomeExibicao</option>
                }
            </select>
            <textarea id="obsTagTexto" class="form-control form-control-sm obs-tag-input" rows="1"
                      oninput="autoResizeObsTagTexto(this)"
                      placeholder="Ex.: primeiro gol do jogador em mata-mata da competição / jogo mil do clube / título histórico após 41 anos…"></textarea>
            <button type="button" class="obs-btn" onclick="adicionarObservacaoTag()">+ Adicionar observação</button>
        </div>
    </div>

    <div class="text-center mt-3">
        <button type="submit" class="btn btn-success">Salvar Escalação @(faseEhInicial ? "Inicial" : "Final")</button>
    </div>
</form>

<form asp-action="LimparEscalacoes" asp-route-id="@Model.Jogo.Id" asp-route-faseEscalacao="@faseAtual" method="post" class="mt-2">
    @Html.AntiForgeryToken()
    <div class="text-center">
        <button type="submit" class="btn btn-danger">🗑️ Limpar Escalação @(faseEhInicial ? "Inicial" : "Final")</button>
    </div>
</form>

</div>
<!-- fim #painelEscalacao -->

<div id="painelEstatisticas" style="display:none;">
    <div class="cf-card" style="padding:1.25rem;">
        @{
            var totalChutes = PegarStatNumero(statsCasa, "Total Shots") + PegarStatNumero(statsVis, "Total Shots");
            var possCasa = PegarStatNumero(statsCasa, "Ball Possession");
            var possVis = PegarStatNumero(statsVis, "Ball Possession");
            if (possCasa == 0 && possVis == 0) { possCasa = 50; possVis = 50; }
        }

        @if (statsCasa.Count == 0 && statsVis.Count == 0)
        {
            <div style="padding:1.5rem;text-align:center;color:#9ca3af;font-size:13px;">
                Estatísticas ainda não disponíveis para esta partida.
            </div>
        }
        else
        {
            <div style="display:flex;align-items:center;justify-content:center;gap:1.5rem;margin-bottom:1.5rem;">
                <div style="display:flex;align-items:center;gap:8px;">
                    <img src="@Url.Action("Imagem", "MediaProxy", new { url = Model.Jogo.TimeCasa?.EscudoUrl })"
                         alt="@Model.Jogo.TimeCasa?.Nome" style="width:28px;height:28px;object-fit:contain;" />
                    <span style="font-weight:700;color:#f1f5f9;">@Model.Jogo.TimeCasa?.Nome</span>
                </div>
                <div style="font-size:12px;color:#6b7280;text-transform:uppercase;font-weight:600;">Posse de bola</div>
                <div style="display:flex;align-items:center;gap:8px;">
                    <span style="font-weight:700;color:#f1f5f9;">@Model.Jogo.TimeVisitante?.Nome</span>
                    <img src="@Url.Action("Imagem", "MediaProxy", new { url = Model.Jogo.TimeVisitante?.EscudoUrl })"
                         alt="@Model.Jogo.TimeVisitante?.Nome" style="width:28px;height:28px;object-fit:contain;" />
                </div>
            </div>

            <div style="display:flex;align-items:center;height:10px;border-radius:6px;overflow:hidden;margin-bottom:0.25rem;background:#222;">
                <div style="height:100%;background:#dc2626;width:@(possCasa)%;"></div>
                <div style="height:100%;background:#2563eb;width:@(possVis)%;"></div>
            </div>
            <div style="display:flex;justify-content:space-between;font-size:13px;font-weight:700;color:#f1f5f9;margin-bottom:1.5rem;">
                <span>@(possCasa)%</span>
                <span style="color:#6b7280;">@(possVis)%</span>
            </div>

            @foreach (var (label, chave) in metricasEstatisticas)
            {
                var valCasaStr = PegarStat(statsCasa, chave);
                var valVisStr = PegarStat(statsVis, chave);
                var valCasaNum = PegarStatNumero(statsCasa, chave);
                var valVisNum = PegarStatNumero(statsVis, chave);
                var total = valCasaNum + valVisNum;
                var pctCasa = total > 0 ? (valCasaNum / total * 100) : 50;
                var pctVis = 100 - pctCasa;

                <div style="margin-bottom:1rem;">
                    <div style="display:flex;justify-content:space-between;font-size:13px;color:#e5e7eb;margin-bottom:4px;">
                        <span style="font-weight:700;">@valCasaStr</span>
                        <span style="color:#6b7280;">@label</span>
                        <span style="font-weight:700;">@valVisStr</span>
                    </div>
                    <div style="display:flex;align-items:center;height:8px;border-radius:5px;overflow:hidden;background:#222;">
                        <div style="height:100%;background:#dc2626;width:@(pctCasa)%;"></div>
                        <div style="height:100%;background:#2563eb;width:@(pctVis)%;"></div>
                    </div>
                </div>
            }
        }
    </div>
</div>

<script>
    function mostrarPainel(painel) {
        var estatisticas = painel === 'estatisticas';
        document.getElementById('painelEscalacao').style.display = estatisticas ? 'none' : '';
        document.getElementById('painelEstatisticas').style.display = estatisticas ? '' : 'none';
        if (estatisticas) {
            document.getElementById('tabBtnEscalacaoInicial').classList.remove('active');
            document.getElementById('tabBtnEscalacaoFinal').classList.remove('active');
        }
    }
</script>

<input type="hidden" id="jogoId" value="@Model.Jogo.Id" />
<!-- Modal de Avaliação -->
