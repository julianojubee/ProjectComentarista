<!-- ══ PLACAR BOARD ══════════════════════════════════════════════════════ -->
<div class="match-board">
    <div class="mb-scoreline">
        <!-- Time Casa -->
        <div class="mb-team home">
            @if (!string.IsNullOrEmpty(Model.TimeCasa?.EscudoUrl))
            {
                <img src="@Url.Action("Imagem", "MediaProxy", new { url = Model.TimeCasa.EscudoUrl })" alt="@Model.TimeCasa.Nome" />
            }
            <span class="mb-team-name">@Model.TimeCasa?.Nome</span>
        </div>

        <!-- Placar -->
        <div class="mb-score">
            <div class="mb-score-box" id="placarCasaBox"
                 title="Clique para editar"
                 onclick="editarPlacar()">
                @(Model.PlacarCasa?.ToString() ?? "–")
            </div>
            <span class="mb-score-sep">×</span>
            <div class="mb-score-box" id="placarVisBox"
                 title="Clique para editar"
                 onclick="editarPlacar()">
                @(Model.PlacarVisitante?.ToString() ?? "–")
            </div>
        </div>

        <!-- Time Visitante -->
        <div class="mb-team away">
            @if (!string.IsNullOrEmpty(Model.TimeVisitante?.EscudoUrl))
            {
                <img src="@Url.Action("Imagem", "MediaProxy", new { url = Model.TimeVisitante.EscudoUrl })" alt="@Model.TimeVisitante.Nome" />
            }
            <span class="mb-team-name">@Model.TimeVisitante?.Nome</span>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.Estadio) || !string.IsNullOrWhiteSpace(Model.Arbitro))
    {
        <div class="mb-meta">
            @if (!string.IsNullOrWhiteSpace(Model.Estadio))
            {
                <span class="mb-meta-item">
                    <span class="mb-meta-icon">🏟️</span>
                    <span>@Model.Estadio</span>
                </span>
            }
            @if (!string.IsNullOrWhiteSpace(Model.Arbitro))
            {
                <span class="mb-meta-item">
                    <span class="mb-meta-icon">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" style="vertical-align:middle">
                            <!-- cabeça -->
                            <circle cx="12" cy="5.5" r="3" fill="rgba(255,255,255,0.85)"/>
                            <!-- corpo listrado preto e branco (árbitro) -->
                            <path d="M7 10 Q7 8.5 12 8.5 Q17 8.5 17 10 L17 18 Q17 19 16 19 L8 19 Q7 19 7 18 Z" fill="rgba(255,255,255,0.85)"/>
                            <rect x="7" y="11.5" width="10" height="2" fill="rgba(0,0,0,0.45)"/>
                            <rect x="7" y="15" width="10" height="2" fill="rgba(0,0,0,0.45)"/>
                            <!-- pernas -->
                            <path d="M9 19 L8.5 23 L10.5 23 L12 20.5 L13.5 23 L15.5 23 L15 19 Z" fill="rgba(255,255,255,0.85)"/>
                        </svg>
                    </span>
                    <span>@Model.Arbitro</span>
                </span>
            }
        </div>
    }

    <!-- Timeline de gols (sempre visível) -->
    <div class="mb-timeline" id="mbTimelineGols"></div>

    <!-- Barra de ações: três botões lado a lado -->
    <div style="display:flex; gap:8px; justify-content:center; margin-top:.9rem; flex-wrap:wrap;">
        <div class="mb-toolbar-toggle" id="mbToolbarToggle" onclick="toggleToolbarEventos()" style="margin:0;">
            <span>➕ Adicionar evento</span>
            <span id="mbToolbarToggleIcon" style="transition:transform .15s;">▾</span>
        </div>
        <div class="mb-toolbar-toggle" id="mbOutrosToggle" onclick="toggleOutrosEventos()" style="margin:0;">
            <span>📋 Outros eventos</span>
            <span id="mbOutrosToggleIcon" style="transition:transform .15s;">▾</span>
        </div>
        <div class="mb-toolbar-toggle" id="mbEstatisticasToggle" onclick="toggleEstatisticasPanel()" style="margin:0;">
            <span>📊 Estatísticas</span>
            <span id="mbEstatisticasToggleIcon" style="transition:transform .15s;">▾</span>
        </div>
        <div class="mb-toolbar-toggle" id="mbH2HToggle" onclick="abrirH2H(@Model.Id)" style="margin:0; cursor:pointer;">
            <span>⚔️ Últimos confrontos</span>
        </div>
    </div>

    <div class="mb-toolbar" id="mbToolbar" style="display:none;">
        <button type="button" class="mb-btn gol"
                onclick="abrirModalEvento('gol', 'casa')">
            ⚽ Gol Mandante
        </button>
        <button type="button" class="mb-btn gol"
                onclick="abrirModalEvento('gol', 'vis')">
            ⚽ Gol Visitante
        </button>
        <button type="button" class="mb-btn cartao-amarelo"
                onclick="abrirModalEvento('amarelo', 'casa')">
            🟨 Cartão Casa
        </button>
        <button type="button" class="mb-btn cartao-amarelo"
                onclick="abrirModalEvento('amarelo', 'vis')">
            🟨 Cartão Visit.
        </button>
        <button type="button" class="mb-btn cartao-vermelho"
                onclick="abrirModalEvento('vermelho', 'casa')">
            🟥 Vermelho Casa
        </button>
        <button type="button" class="mb-btn cartao-vermelho"
                onclick="abrirModalEvento('vermelho', 'vis')">
            🟥 Vermelho Visit.
        </button>
    </div>

    <div class="mb-timeline" id="mbTimelineOutros" style="display:none;"></div>

    <script>
        function toggleToolbarEventos() {
            var toolbar = document.getElementById('mbToolbar');
            var icon = document.getElementById('mbToolbarToggleIcon');
            var aberto = toolbar.style.display !== 'none';
            toolbar.style.display = aberto ? 'none' : '';
            icon.style.transform = aberto ? 'rotate(0deg)' : 'rotate(180deg)';
        }

        function toggleOutrosEventos() {
            var tl = document.getElementById('mbTimelineOutros');
            var icon = document.getElementById('mbOutrosToggleIcon');
            var aberto = tl.style.display !== 'none';
            tl.style.display = aberto ? 'none' : '';
            icon.style.transform = aberto ? 'rotate(0deg)' : 'rotate(180deg)';
        }

        function toggleEstatisticasPanel() {
            var painel = document.getElementById('painelEstatisticas');
            var icon = document.getElementById('mbEstatisticasToggleIcon');
            var escalacao = document.getElementById('painelEscalacao');
            if (!painel) return;
            var aberto = painel.style.display !== 'none';
            painel.style.display = aberto ? 'none' : '';
            if (!aberto) escalacao.style.display = 'none';
            else escalacao.style.display = '';
            icon.style.transform = aberto ? 'rotate(0deg)' : 'rotate(180deg)';
            // Sincroniza com o tab btn legado
            if (document.getElementById('tabBtnEstatisticas')) {
                document.getElementById('tabBtnEstatisticas').classList.toggle('active', !aberto);
            }
        }
    </script>
</div>

<!-- ── Status de Análise ───────────────────────────────────────────── -->
<div style="display:flex; align-items:center; gap:12px; margin-bottom:1rem;
            padding:.85rem 1.2rem; background:#fff; border:.5px solid #e5e7eb;
            border-radius:12px;">
    <div style="display:flex; align-items:center; gap:10px; flex:1;">
        <div id="statusIcon" style="width:36px; height:36px; border-radius:50%;
             display:flex; align-items:center; justify-content:center; font-size:18px;
             background:@(Model.Analisado == 1 ? "#dcfce7" : "#f3f4f6");
             border:2px solid @(Model.Analisado == 1 ? "#22c55e" : "#e5e7eb");">
            @(Model.Analisado == 1 ? "✅" : "⏳")
        </div>
        <div>
            <div id="statusLabel" style="font-size:13px; font-weight:600;
                 color:@(Model.Analisado == 1 ? "#15803d" : "#374151");">
                @(Model.Analisado == 1 ? "Jogo analisado" : "Aguardando análise")
            </div>
            <div style="font-size:11px; color:#9ca3af;">
                Marque como analisado após revisar escalação final e eventos
            </div>
        </div>
    </div>

    <label style="display:flex; align-items:center; gap:8px; cursor:pointer;
                  padding:8px 14px; border-radius:8px; border:1px solid #e5e7eb;
                  background:#f9fafb; user-select:none;"
           title="Marcar/desmarcar jogo como analisado">
        <input type="checkbox"
               id="chkAnalisado"
               style="width:16px; height:16px; cursor:pointer; accent-color:#22c55e;"
               @(Model.Analisado == 1 ? "checked" : "")
               onchange="toggleAnalisado(this)" />
        <span style="font-size:13px; font-weight:500; color:#374151;">Marcar como analisado</span>
    </label>

    @if (!string.IsNullOrWhiteSpace(Model.LinkDetalhes))
    {
        <form asp-action="ReimportarEscalacao" asp-controller="Jogos" asp-route-id="@Model.Id"
              method="post" style="margin:0;"
              onsubmit="return confirm('Re-importar escalação do Transfermarkt?\n\nIsso vai apagar todas as escalações, gols, cartões e assistências deste jogo e reimportar do zero.')">
            @Html.AntiForgeryToken()
            <button type="submit"
                    style="display:flex; align-items:center; gap:6px; padding:8px 14px;
                           border-radius:8px; border:1px solid #f59e0b; background:#fffbeb;
                           color:#92400e; font-size:13px; font-weight:500; cursor:pointer;
                           white-space:nowrap;"
                    title="Apaga e re-importa escalação, gols e cartões do Transfermarkt (corrige posições erradas)">
                🔄 Re-importar Transfermarkt
            </button>
        </form>
    }


    @* --- Grupo atual + botão de busca --- *@
    <div class="d-flex align-items-center gap-2 mt-2">

        @* Badge mostrando o grupo atual (ou aviso se vazio) *@
        @if (!string.IsNullOrWhiteSpace(Model.Grupo))
        {
            <span class="badge bg-success">
                <i class="ti ti-tag me-1" aria-hidden="true"></i>@Model.Grupo
            </span>
        }
        else
        {
            <span class="badge bg-secondary text-white">
                <i class="ti ti-tag-off me-1" aria-hidden="true"></i>Sem grupo
            </span>
        }

        @* Botão só aparece quando há link do Transfermarkt *@
        @if (!string.IsNullOrWhiteSpace(Model.LinkDetalhes))
        {
            <form asp-action="BuscarGrupo" asp-route-id="@Model.Id" method="post" class="d-inline">
                @Html.AntiForgeryToken()
                <button type="submit"
                        class="btn btn-sm btn-outline-primary"
                        onclick="this.disabled=true; this.innerHTML='<span class=\'spinner-border spinner-border-sm\'></span> Buscando...'; this.form.submit();">
                    <i class="ti ti-world-search" aria-hidden="true"></i>
                    Buscar grupo
                </button>
            </form>
        }
        else
        {
            <span class="text-muted small" title="Sem link do Transfermarkt — não é possível buscar automaticamente">
                <i class="ti ti-info-circle" aria-hidden="true"></i> sem link TM
            </span>
        }
    </div>
</div>

