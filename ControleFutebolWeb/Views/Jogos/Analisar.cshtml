                </div>
            </div>
        </div>

        <!-- ===== TIME VISITANTE ===== -->
        <div class="col-md-6">
            @* <h4>
                <img src="@Model.Jogo.TimeVisitante.EscudoUrl" width="24" />
                @Model.Jogo.TimeVisitante.Nome
            </h4> *@
            <div class="row">
                <!-- Campinho visitante -->
                <div class="col-7">
                    <div id="campoVisitante" class="campo"
                         ondrop="dropNoCampo(event, 'campoVisitante')"
                         ondragover="allowDrop(event)">
                        <div class="campo-linha-meio"></div>
                        <div class="campo-circulo"></div>
                        <div class="campo-area-sup"></div>
                        <div class="campo-area-inf"></div>
                        <div class="campo-gol-sup"></div>
                        <div class="campo-gol-inf"></div>
                        <svg class="setas-svg" data-campo-svg="campoVisitante">
                            <defs>
                                <marker id="setaHeadVis" markerWidth="12" markerHeight="10" refX="10" refY="5"
                                        orient="auto" markerUnits="userSpaceOnUse">
                                    <path d="M0,0 L12,5 L0,10 z" fill="#facc15" />
                                </marker>
                            </defs>
                        </svg>
                        @{
                            var idxVis = 0;
                        }
                        @foreach (var esc in (List<ControleFutebolWeb.Models.Escalacao>)Model.EscalacoesVisitante)
                        {
                            bool expulsoVis = esc.Jogador != null && Model.JogadoresComCartaoVermelho.Contains(esc.Jogador.Id);
                            <div class="posicao-drop @(expulsoVis ? "expulso" : "")"
                                 data-index="vis_@idxVis"
                                 data-posicao="@esc.Posicao"
                                 data-campo="vis"
                                 data-escid="@esc.Id"
                                 data-temjogador="@(esc.Jogador != null ? "1" : "0")"
                                 draggable="@(expulsoVis ? "false" : "true")"
                                 ondragstart="dragPosicao(event, 'vis_@idxVis')"
                                 ondrop="dropEscalacao(event, 'vis_@idxVis')"
                                 ondragover="allowDrop(event)"
                                 style="left:@esc.PosicaoX%; top:@esc.PosicaoY%;">
                                @if (esc.Jogador != null)
                                {
                                    <div class="player-circle player-circle-vis">@(esc.Jogador.NumeroCamisa?.ToString() ?? "")</div>
                                    @if (expulsoVis)
                                    {
                                        <span class="card-vermelho-badge" title="Expulso (cartão vermelho)"></span>
                                    }
                                    @if (!faseEhInicial && jogadoresEntraramVisitante.Contains(esc.Jogador.Id))
                                    {
                                        <span class="sub-chip-in" title="@TituloEntrou(esc.Jogador.Id)">↑</span>
                                    }
                                    <div class="player-name">@esc.Jogador.Nome</div>
                                    <button type="button"
                                            id="btn-avaliar-@esc.Jogador.Id"
                                            class="btn-avaliar"
                                            onclick="abrirAvaliacao(@esc.Jogador.Id, '@esc.Jogador.Nome', '@esc.Posicao', event)">
                                        +
                                    </button>
                                    <button type="button" class="btn-info-jogador"
                                            onmouseenter="mostrarInfoJogador(this, {nome:'@Html.Raw(esc.Jogador.NomeExibicao.Replace("'","&#39;"))',foto:'@(esc.Jogador.FotoUrl ?? "")',posicao:'@esc.Jogador.Posicao',numero:@(esc.Jogador.NumeroCamisa?.ToString() ?? "null"),idade:@(esc.Jogador.Idade > 0 ? esc.Jogador.Idade.ToString() : "null"),nac:'@(esc.Jogador.Nacionalidade?.Nome ?? "")',gols:@(golsPorJogador.TryGetValue(esc.Jogador.Id, out var _g) ? _g : 0),assists:@(assistsPorJogador.TryGetValue(esc.Jogador.Id, out var _a) ? _a : 0),obs:'@Html.Raw((esc.Jogador.Observacoes ?? "").Replace("'","&#39;").Replace("\n","\\n"))'} )"
                                            onmouseleave="esconderInfoJogador()">
                                        ℹ
                                    </button>
                                }
                                else
                                {
                                    <div class="player-circle player-circle-empty"></div>
                                }
                            </div>
                            <input type="hidden" name="escalacaoVisitante[@idxVis].Id" value="@esc.Id" />
                            <input type="hidden" name="escalacaoVisitante[@idxVis].PosicaoId" value="@esc.Id" />
                            <input type="hidden" id="escalacaoVisitante_@(idxVis)__JogadorId" name="escalacaoVisitante[@idxVis].JogadorId" value="@esc.JogadorId" />
                            <input type="hidden" id="escalacaoVisitante_@(idxVis)__PosicaoX" name="escalacaoVisitante[@idxVis].PosicaoX" value="@esc.PosicaoX" />
                            <input type="hidden" id="escalacaoVisitante_@(idxVis)__PosicaoY" name="escalacaoVisitante[@idxVis].PosicaoY" value="@esc.PosicaoY" />
                            idxVis++;
                        }
                    </div>

                    @if (mostrarBancoReservas)
                    {
                        <!-- Banco de reservas visitante -->
                        <div class="banco-label mt-2">🪑 Banco de reservas</div>
