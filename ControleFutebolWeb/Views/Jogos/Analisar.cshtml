<!-- Seleção de Formações -->
<div class="row mb-3">
    <div class="col-md-6">
        <form method="get" asp-action="Analisar" asp-controller="Jogos">
            <input type="hidden" name="id" value="@Model.Jogo.Id" />
            <input type="hidden" name="formacaoVisitanteId" value="@Model.FormacaoVisitanteSelecionada" />
            <input type="hidden" name="faseEscalacao" value="@faseAtual" />
            <label class="fw-bold">Formação @Model.Jogo.TimeCasa.Nome:</label>
            @* requestSubmit (e não submit): dispara o listener de submit que serializa
               as observações — submit() programático pulava a serialização e o post
               vazio apagava as observações salvas. *@
            <select name="formacaoCasaId" class="form-select" onchange="this.form.requestSubmit()">
                @foreach (var f in (IEnumerable<SelectListItem>)Model.FormacoesCasa)
                {
                    <option value="@f.Value" @(f.Selected ? "selected" : "")>@f.Text</option>
                }
            </select>
        </form>
    </div>
    <div class="col-md-6">
        <form method="get" asp-action="Analisar" asp-controller="Jogos">
            <input type="hidden" name="id" value="@Model.Jogo.Id" />
            <input type="hidden" name="formacaoCasaId" value="@Model.FormacaoCasaSelecionada" />
            <input type="hidden" name="faseEscalacao" value="@faseAtual" />
            <label class="fw-bold">Formação @Model.Jogo.TimeVisitante.Nome:</label>
            <select name="formacaoVisitanteId" class="form-select" onchange="this.form.requestSubmit()">
                @foreach (var f in (IEnumerable<SelectListItem>)Model.FormacoesVisitante)
                {
                    <option value="@f.Value" @(f.Selected ? "selected" : "")>@f.Text</option>
                }
            </select>
        </form>
    </div>
</div>

<!-- ── Fase tática da partida ─────────────────────────────────────── -->
<div class="d-flex align-items-center gap-2 mb-2 p-2"
     style="background:#0f172a; border-radius:8px; color:#e2e8f0; flex-wrap:wrap;">
    <button type="button" id="btnModoSeta" class="btn btn-sm btn-outline-warning"
            onclick="toggleModoSeta()"
            title="Ligue, clique num jogador e depois no ponto do campo para onde ele se movimentou. Clique duplo numa seta para removê-la.">
        ➹ Setas
    </button>
    <span id="modoSetaHint" style="font-size:11px; color:#facc15; display:none;">
        clique no jogador e depois no destino · duplo clique na seta remove · Esc sai
    </span>
    <div class="ms-auto d-flex align-items-center gap-1">
        <label style="font-size:11px; color:#94a3b8;">nome</label>
        <input type="text" id="faseNome" maxlength="60" placeholder="ex: Fase de ataque"
               class="form-control form-control-sm" style="width:180px;" />
        <label style="font-size:11px; color:#94a3b8;">min</label>
        <input type="number" id="faseMinuto" min="0" max="130" value="0"
               class="form-control form-control-sm" style="width:64px;" />
        <button type="button" class="btn btn-sm btn-primary" onclick="salvarFaseTatica()" title="Salva a escalação atual como uma fase tática no minuto informado">
            💾 Salvar fase
        </button>
    </div>
</div>

<!-- ── Mapa de calor ───────────────────────────────────────────────── -->
<div class="d-flex align-items-center gap-2 mb-2 p-2"
     style="background:#0f172a; border-radius:8px; color:#e2e8f0; flex-wrap:wrap;">
    <label style="font-size:11px; color:#94a3b8;">🔥 Mapa de calor</label>
    <select id="heatmapAlvo" class="form-select form-select-sm" style="width:220px;" onchange="mostrarMapaCalor()">
        <option value="">— selecione —</option>
        <optgroup label="@Model.Jogo.TimeCasa.Nome">
            <option value="casa">🔥 Todo o time</option>
            @foreach (var j in (List<ControleFutebolWeb.Models.Jogador>)Model.JogadoresCasa)
            {
                <option value="j-@(j.Id)-casa">@j.Nome</option>
            }
        </optgroup>
        <optgroup label="@Model.Jogo.TimeVisitante.Nome">
            <option value="visitante">🔥 Todo o time</option>
            @foreach (var j in (List<ControleFutebolWeb.Models.Jogador>)Model.JogadoresVisitante)
            {
                <option value="j-@(j.Id)-vis">@j.Nome</option>
            }
        </optgroup>
    </select>
    <button type="button" class="btn btn-sm btn-outline-danger" onclick="ocultarMapaCalor()">Ocultar</button>
    <span style="font-size:11px; color:#64748b;">baseado em todas as escalações salvas neste jogo (inicial, final e fases táticas)</span>
</div>

<div class="mb-3">
    <ul class="nav nav-tabs">
        <li class="nav-item">
            <a class="nav-link @(faseAtual == "INICIAL" ? "active" : "")"
               id="tabBtnEscalacaoInicial"
               asp-action="Analisar"
               asp-route-id="@Model.Jogo.Id"
               asp-route-formacaoCasaId="@Model.FormacaoCasaSelecionada"
               asp-route-formacaoVisitanteId="@Model.FormacaoVisitanteSelecionada"
               asp-route-faseEscalacao="INICIAL">
                Escalação Inicial
            </a>
        </li>
        @for (int fi = 0; fi < fasesTaticas.Count; fi++)
        {
            var f = fasesTaticas[fi];
            var fim = fi < fasesTaticas.Count - 1 ? (int?)(fasesTaticas[fi + 1].MinutoInicio - 1) : null;
            var faixa = fim.HasValue ? $"{f.MinutoInicio}'–{fim}'" : $"{f.MinutoInicio}'→";
            var rotulo = string.IsNullOrWhiteSpace(f.Nome) ? faixa : $"{f.Nome} ({faixa})";
            <li class="nav-item">
                <a class="nav-link @(faseAtual == f.Chave ? "active" : "")"
                   asp-action="Analisar"
                   asp-route-id="@Model.Jogo.Id"
                   asp-route-formacaoCasaId="@Model.FormacaoCasaSelecionada"
                   asp-route-formacaoVisitanteId="@Model.FormacaoVisitanteSelecionada"
                   asp-route-faseEscalacao="@f.Chave"
                   title="Fase tática (@faixa)">
                    @rotulo
                    @if (faseAtual == f.Chave)
                    {
                        <span style="cursor:pointer; margin-left:6px; color:#dc3545;"
                              onclick="event.preventDefault(); excluirFaseTatica('@f.Chave');"
                              title="Excluir esta fase">&times;</span>
                    }
                </a>
            </li>
        }
        <li class="nav-item">
            <a class="nav-link @(faseAtual == "FINAL" ? "active" : "")"
               id="tabBtnEscalacaoFinal"
               asp-action="Analisar"
               asp-route-id="@Model.Jogo.Id"
               asp-route-formacaoCasaId="@Model.FormacaoCasaSelecionada"
               asp-route-formacaoVisitanteId="@Model.FormacaoVisitanteSelecionada"
               asp-route-faseEscalacao="FINAL">
                Escalação Final
            </a>
        </li>
    </ul>
</div>

<div id="painelEscalacao">

<!-- ── FORM PRINCIPAL (id fixo para o JS encontrar com segurança) ── -->
<form id="formSalvarEscalacao" method="post" asp-action="SalvarEscalacao" asp-controller="Jogos">
    <input type="hidden" name="id" value="@Model.Jogo.Id" />
    <input type="hidden" name="formacaoCasaId" value="@Model.FormacaoCasaSelecionada" />
    <input type="hidden" name="formacaoVisitanteId" value="@Model.FormacaoVisitanteSelecionada" />
    <input type="hidden" name="faseEscalacao" value="@faseAtual" />

    <div class="row">

        <!-- ===== TIME DA CASA ===== -->
        <div class="col-md-6">
            <div class="row">
                <!-- Lista de jogadores -->
                <div class="col-5 scroll-panel">
                    @{
                        var treinadorCasa = Model.TreinadorCasa as ControleFutebolWeb.Models.Treinador;
                    }
                    @if (treinadorCasa != null)
                    {
                        <div class="d-flex align-items-center gap-2 px-1 py-1 mb-1"
                             style="background:#161616;border-radius:7px;border:1px solid #262626;">
                            @if (!string.IsNullOrWhiteSpace(treinadorCasa.FotoUrl))
                            {
                                <img src="@Url.FotoSrc(treinadorCasa.FotoUrl)"
                                     alt="@treinadorCasa.Nome"
                                     style="width:24px;height:24px;border-radius:50%;object-fit:cover;flex-shrink:0;" />
                            }
                            else
                            {
                                <span style="font-size:16px;">🧑‍💼</span>
                            }
                            <div>
                                <div style="font-size:9px;color:#6b7280;text-transform:uppercase;line-height:1;">Treinador</div>
                                <div style="font-size:12px;font-weight:600;color:#f1f5f9;">@treinadorCasa.Nome</div>
                            </div>
                        </div>
                    }
                    <div class="jog-panel">
                    <div class="jog-panel-header">
                        @if (!string.IsNullOrEmpty(Model.Jogo.TimeCasa?.EscudoUrl))
                        {
                            <img src="@Url.Action("Imagem", "MediaProxy", new { url = Model.Jogo.TimeCasa.EscudoUrl })" alt="" />
                        }
                        @Model.Jogo.TimeCasa?.Nome
                    </div>
                    <input type="text" id="filtroCasa" class="filtro-jogador" placeholder="🔍 Buscar por nome ou número..." oninput="filtrarLista('listaCasa', this.value)" />
                    <table class="table table-sm table-striped">
                        <thead><tr><th></th><th>Nome</th><th>Pos</th></tr></thead>
                        <tbody id="listaCasa">
                            @foreach (var jogador in (List<ControleFutebolWeb.Models.Jogador>)Model.JogadoresCasa)
                            {
                                <tr class="jogador-row"
                                    id="jogador-casa-@jogador.Id"
                                    draggable="true"
                                    ondragstart="dragJogador(event, @jogador.Id, '@jogador.Nome', '@jogador.NumeroCamisa', '', 'casa')">
                                    <td>
                                        <div class="player-circle player-circle-casa" style="width:28px;height:28px;font-size:11px;">
                                            @(jogador.NumeroCamisa?.ToString() ?? "")
                                        </div>
                                    </td>
                                    <td>
                                        @jogador.Nome
                                        @if (!faseEhInicial && jogadoresSairamCasa.Contains(jogador.Id))
                                        {
                                            <span class="sub-badge-out" title="Jogador saiu">↓</span>
                                        }
                                    </td>
                                    <td>@AbreviarPosicao(jogador.Posicao)</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                    </div><!-- /.jog-panel -->
                </div>

                <!-- Campinho casa -->
                <div class="col-7">
                    <div id="campoCasa" class="campo"
                         ondrop="dropNoCampo(event, 'campoCasa')"
                         ondragover="allowDrop(event)">
                        <div class="campo-linha-meio"></div>
                        <div class="campo-circulo"></div>
                        <div class="campo-area-sup"></div>
                        <div class="campo-area-inf"></div>
                        <div class="campo-gol-sup"></div>
                        <div class="campo-gol-inf"></div>
                        <svg class="setas-svg" data-campo-svg="campoCasa">
                            <defs>
                                <marker id="setaHeadCasa" markerWidth="12" markerHeight="10" refX="10" refY="5"
                                        orient="auto" markerUnits="userSpaceOnUse">
                                    <path d="M0,0 L12,5 L0,10 z" fill="#facc15" />
                                </marker>
                            </defs>
                        </svg>
                        @{
                            var idxCasa = 0;
                        }
                        @foreach (var esc in (List<ControleFutebolWeb.Models.Escalacao>)Model.EscalacoesCasa)
                        {
                            bool expulsoCasa = esc.Jogador != null && Model.JogadoresComCartaoVermelho.Contains(esc.Jogador.Id);
                            <div class="posicao-drop @(expulsoCasa ? "expulso" : "")"
                                 data-index="casa_@idxCasa"
                                 data-posicao="@esc.Posicao"
                                 data-campo="casa"
                                 data-escid="@esc.Id"
                                 data-temjogador="@(esc.Jogador != null ? "1" : "0")"
                                 draggable="@(expulsoCasa ? "false" : "true")"
                                 ondragstart="dragPosicao(event, 'casa_@idxCasa')"
                                 ondrop="dropEscalacao(event, 'casa_@idxCasa')"
                                 ondragover="allowDrop(event)"
                                 style="left:@esc.PosicaoX%; top:@esc.PosicaoY%;">
                                @if (esc.Jogador != null)
                                {
                                    <div class="player-circle player-circle-casa">@(esc.Jogador.NumeroCamisa?.ToString() ?? "")</div>
                                    @if (expulsoCasa)
                                    {
                                        <span class="card-vermelho-badge" title="Expulso (cartão vermelho)"></span>
                                    }
                                    @* Fora de .player-name: o overflow:hidden dela cortava a seta em nomes longos *@
                                    @if (!faseEhInicial && jogadoresEntraramCasa.Contains(esc.Jogador.Id))
                                    {
                                        <span class="sub-chip-in" title="@TituloEntrou(esc.Jogador.Id)">↑</span>
                                    }
                                    <div class="player-name">@esc.Jogador.Nome</div>
                                    <button type="button"
                                            id="btn-avaliar-@esc.Jogador.Id"
                                            class="btn-avaliar"
                                            onclick="abrirAvaliacao(@esc.Jogador.Id, '@esc.Jogador.Nome', '@esc.Posicao', event)">
                                        +
                                    </button>
                                    <button type="button" class="btn-info-jogador"
                                            onmouseenter="mostrarInfoJogador(this, {nome:'@Html.Raw(esc.Jogador.NomeExibicao.Replace("'","&#39;"))',foto:'@(esc.Jogador.FotoUrl ?? "")',posicao:'@esc.Jogador.Posicao',numero:@(esc.Jogador.NumeroCamisa?.ToString() ?? "null"),idade:@(esc.Jogador.Idade > 0 ? esc.Jogador.Idade.ToString() : "null"),nac:'@(esc.Jogador.Nacionalidade?.Nome ?? "")',gols:@(golsPorJogador.TryGetValue(esc.Jogador.Id, out var _g) ? _g : 0),assists:@(assistsPorJogador.TryGetValue(esc.Jogador.Id, out var _a) ? _a : 0),obs:'@Html.Raw((esc.Jogador.Observacoes ?? "").Replace("'","&#39;").Replace("\n","\\n"))'} )"
                                            onmouseleave="esconderInfoJogador()">
                                        ℹ
                                    </button>
                                }
                                else
                                {
                                    <div class="player-circle player-circle-empty"></div>
                                }
                            </div>
                            <input type="hidden" name="escalacaoCasa[@idxCasa].Id" value="@esc.Id" />
                            <input type="hidden" name="escalacaoCasa[@idxCasa].PosicaoId" value="@esc.Id" />
                            <input type="hidden" id="escalacaoCasa_@(idxCasa)__JogadorId" name="escalacaoCasa[@idxCasa].JogadorId" value="@esc.JogadorId" />
                            <input type="hidden" id="escalacaoCasa_@(idxCasa)__PosicaoX" name="escalacaoCasa[@idxCasa].PosicaoX" value="@esc.PosicaoX" />
                            <input type="hidden" id="escalacaoCasa_@(idxCasa)__PosicaoY" name="escalacaoCasa[@idxCasa].PosicaoY" value="@esc.PosicaoY" />
                            idxCasa++;
                        }
                    </div>

                    @if (mostrarBancoReservas)
                    {
                        <!-- Banco de reservas casa -->
                        <div class="banco-label mt-2">🪑 Banco de reservas</div>
                        <div id="bancoCasa" class="banco"
                             ondrop="dropNoBanco(event, 'casa')"
                             ondragover="allowDrop(event)">
                            @{
                                var idxResCasa = 0;
                            }
                            @foreach (var esc in (List<ControleFutebolWeb.Models.Escalacao>)Model.ReservasCasa)
                            {
                                <div class="reserva-card" id="reserva-casa-card-@idxResCasa">
                                    <span class="rem-btn" onclick="removerReserva('casa', @idxResCasa)">×</span>
