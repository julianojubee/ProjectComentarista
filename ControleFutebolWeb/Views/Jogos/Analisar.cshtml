        flex-shrink: 0;
        opacity: 0;
        transition: opacity .15s;
    }

    .mb-event:hover .mb-event-del {
        opacity: 1;
    }

    .mb-event-sub {
        opacity: 0.82;
        border-left: 3px solid #22c55e;
    }
    .mb-event-sub .mb-event-text small {
        color: #ef4444;
    }

    /* ── Modal de evento ─────────────────────────────────── */
    #modal-evento {
        display: none;
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,.6);
        z-index: 9998;
        align-items: center;
        justify-content: center;
    }

    .modal-evento-box {
        background: #1e293b;
        border: 1px solid rgba(255,255,255,.12);
        border-radius: 16px;
        padding: 1.4rem;
        width: 360px;
        max-width: 95vw;
        box-shadow: 0 20px 60px rgba(0,0,0,.5);
        color: #e2e8f0;
    }

        .modal-evento-box h5 {
            font-size: 15px;
            font-weight: 700;
            margin: 0 0 1rem;
            color: #fff;
        }

    .mev-field {
        margin-bottom: .9rem;
    }

        .mev-field label {
            display: block;
            font-size: 11px;
            font-weight: 600;
            color: rgba(255,255,255,.5);
            text-transform: uppercase;
            letter-spacing: .5px;
            margin-bottom: 5px;
        }

        .mev-field select,
        .mev-field input {
            width: 100%;
            background: rgba(255,255,255,.07);
            border: 1px solid rgba(255,255,255,.15);
            border-radius: 9px;
            padding: 8px 12px;
            font-size: 13px;
            color: #e2e8f0;
        }

            .mev-field select option {
                background: #1e293b;
            }

    .mev-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 10px;
    }

    .mev-actions {
        display: flex;
        gap: 8px;
        margin-top: 1.1rem;
    }

    .mev-save {
        flex: 1;
        background: #2563eb;
        color: #fff;
        border: none;
        border-radius: 9px;
        padding: 9px;
        font-size: 13px;
        font-weight: 600;
        cursor: pointer;
        transition: background .15s;
    }

        .mev-save:hover {
            background: #1d4ed8;
        }

    .mev-cancel {
        background: rgba(255,255,255,.07);
        color: rgba(255,255,255,.6);
        border: 1px solid rgba(255,255,255,.12);
        border-radius: 9px;
        padding: 9px 16px;
        font-size: 13px;
        cursor: pointer;
    }

        .mev-cancel:hover {
            background: rgba(255,255,255,.12);
        }

    .mev-tipo-badge {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 4px 12px;
        border-radius: 999px;
        font-size: 12px;
        font-weight: 600;
        margin-bottom: .8rem;
    }
</style>

