                                        @(esc.Jogador?.NumeroCamisa?.ToString() ?? "")
                                    </div>
                                    <div style="max-width:54px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;font-size:11px;">
                                        @esc.Jogador?.Nome
