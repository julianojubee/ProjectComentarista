                <div style="font-size:11px; font-weight:600; color:#60a5fa; text-transform:uppercase; letter-spacing:0.5px; margin-bottom:6px;">⚡ Bônus automáticos</div>
                <div id="av-bonus-linhas" style="display:flex; flex-direction:column; gap:4px;"></div>
