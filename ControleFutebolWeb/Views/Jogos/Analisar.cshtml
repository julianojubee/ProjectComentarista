                <span style="color:#9ca3af; font-size:13px;">Pontuação total</span>
                <div style="display:flex; align-items:center; gap:10px;">
                    <span id="av-total" style="font-size:22px; font-weight:600; color:#f1f5f9;">0</span>
                    <span id="av-nota" style="padding:3px 10px; border-radius:20px; font-size:12px; font-weight:500;">Regular</span>
                </div>
