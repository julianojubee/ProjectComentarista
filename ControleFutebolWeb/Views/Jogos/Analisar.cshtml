    <div style="background:#1a1a1a; border:1px solid #2a2a2a; color:#e5e7eb; border-radius:12px; width:360px; max-width:95vw; max-height:90vh; display:flex; flex-direction:column; overflow:hidden; box-shadow: 0 8px 32px rgba(0,0,0,0.5);">
