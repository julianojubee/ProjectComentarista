@model ControleFutebolWeb.Models.Jogo

<h2>Editar Jogo</h2>

<form asp-action="Edit" method="post">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <input type="hidden" asp-for="Id" />

    <div class="form-group">
        <label asp-for="Data" class="control-label">Data do Jogo</label>
        <input asp-for="Data" type="datetime-local" class="form-control" step="1" />
        <span asp-validation-for="Data" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="TimeCasaId" class="control-label">Time da Casa</label>
        <select asp-for="TimeCasaId" class="form-control" asp-items="ViewBag.TimeCasaId"></select>
    </div>

    <div class="form-group">
        <label asp-for="FormacaoCasaId" class="control-label">Formação Casa</label>
        <select asp-for="FormacaoCasaId" class="form-control"
                asp-items="ViewBag.FormacaoCasaId"></select>
        <span asp-validation-for="FormacaoCasaId" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="FormacaoVisitanteId" class="control-label">Formação Visitante</label>
        <select asp-for="FormacaoVisitanteId" class="form-control"
                asp-items="ViewBag.FormacaoVisitanteId"></select>
        <span asp-validation-for="FormacaoVisitanteId" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="TimeVisitanteId" class="control-label">Time Visitante</label>
        <select asp-for="TimeVisitanteId" class="form-control" asp-items="ViewBag.TimeVisitanteId"></select>
    </div>



    <div class="form-group mt-2">
        <input type="submit" value="Salvar Alterações" class="btn btn-primary" />
        <a asp-action="Index" class="btn btn-secondary">Voltar</a>
    </div>
</form>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
