@model List<ControleFutebolWeb.Models.Jogo>
@using ControleFutebolWeb.Helpers
@{
    ViewData["Title"] = "Jogos de Hoje";
    var jogosAnalisadosIds = (HashSet<int>)(ViewBag.JogosAnalisadosIds ?? new HashSet<int>());

    var diaAtual    = (DateTime)(ViewBag.DiaAtual ?? DateTime.Today);
    var diaAnterior = (DateTime)(ViewBag.DiaAnterior ?? DateTime.Today.AddDays(-1));
    var diaSeguinte = (DateTime)(ViewBag.DiaSeguinte ?? DateTime.Today.AddDays(1));
    bool ehHoje = (bool)(ViewBag.EhHoje ?? true);
    var ptBR = new System.Globalization.CultureInfo("pt-BR");

    var fusoHorarioBrasil = TimeZoneInfo.FindSystemTimeZoneById("America/Sao_Paulo");
    var agoraBrasil = TimeZoneInfo.ConvertTimeFromUtc(DateTime.UtcNow, fusoHorarioBrasil);

    // Estimativa do minuto ao vivo a partir do horário de início: não há sincronização
    // em tempo real com a API, então assume 1º tempo de 45min + 15min de intervalo.
    // É só uma aproximação (não considera acréscimos reais).
    // IMPORTANTE: jogo.Data fica salvo em UTC — precisa converter pra Brasília antes de
    // comparar com agoraBrasil, senão a diferença de fuso (3h) derruba a conta toda.
    string MinutoAoVivo(DateTime kickoffUtc)
    {
        var kickoff = DateHelper.ParaBrasilia(kickoffUtc) ?? kickoffUtc;
        var decorridos = (int)(agoraBrasil - kickoff).TotalMinutes;
        if (decorridos < 0) return "";
        if (decorridos <= 45) return $"1T {decorridos}'";
        if (decorridos <= 60) return "Intervalo";
        if (decorridos <= 105) return $"2T {decorridos - 60}'";
        return "2T 45+'";
    }

    Func<int?, (string bg, string border, string text)> corComp = (id) => id switch
    {
        1 => ("rgba(34,197,94,0.12)", "rgba(34,197,94,0.3)", "#4ade80"),
        2 => ("rgba(59,130,246,0.12)", "rgba(59,130,246,0.3)", "#60a5fa"),
        3 => ("rgba(212,165,32,0.12)", "rgba(212,165,32,0.3)", "#fbbf24"),
        4 => ("rgba(249,115,22,0.12)", "rgba(249,115,22,0.3)", "#fb923c"),
        5 => ("rgba(168,85,247,0.12)", "rgba(168,85,247,0.3)", "#c084fc"),
        _ => ("rgba(107,114,128,0.12)", "rgba(107,114,128,0.3)", "#9ca3af"),
    };

    var vivos = new List<ControleFutebolWeb.Models.Jogo>();
    var agendados = new List<ControleFutebolWeb.Models.Jogo>();
    var encerrados = new List<ControleFutebolWeb.Models.Jogo>();

    foreach (var jogo in Model.OrderBy(j => j.Data))
    {
        bool realizado = jogo.PlacarCasa.HasValue && jogo.PlacarVisitante.HasValue;
        if (realizado)
        {
            encerrados.Add(jogo);
        }
        else if (jogo.Data.HasValue && DateHelper.ParaBrasilia(jogo.Data) is DateTime kickoffBrasil
                 && kickoffBrasil <= agoraBrasil && agoraBrasil <= kickoffBrasil.AddHours(2.5))
        {
            vivos.Add(jogo);
        }
        else
        {
            agendados.Add(jogo);
        }
    }

    var grupos = new List<(string label, string icone, string cor, List<ControleFutebolWeb.Models.Jogo> jogos)>
    {
        ("Ao Vivo", "🔴", "#f87171", vivos),
        ("Agendados", "⏳", "#60a5fa", agendados),
        ("Encerrados", "✓", "#4ade80", encerrados),
    };
}

<style>
    .hj-root, .hj-root *, .hj-root *::before, .hj-root *::after { box-sizing: border-box; }

    .hj-root {
        margin: 0 -12px;
        background: #0f0f0f;
        border-radius: 14px;
        overflow: hidden;
        color: #e5e7eb;
        font-family: 'Barlow', Arial, sans-serif;
    }
    .hj-root a { text-decoration: none; color: inherit; }

    @@keyframes hjPulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.4; } }

    /* ── Hero ── */
    .hj-hero {
        position: relative; overflow: hidden;
        background: linear-gradient(135deg, #060d1a 0%, #0d1e35 55%, #060d1a 100%);
        padding: 40px 2.5rem 34px;
    }
    .hj-hero-stripe { position: absolute; left: 0; top: 0; bottom: 0; width: 4px; background: #d4a520; }
    .hj-hero-fade { position: absolute; bottom: 0; left: 0; right: 0; height: 50px; background: linear-gradient(to top, #0f0f0f, transparent); pointer-events: none; }
    .hj-hero-inner { position: relative; z-index: 1; display: flex; align-items: center; gap: 24px; flex-wrap: wrap; }
    .hj-hero-kicker { display: flex; align-items: center; gap: 10px; margin-bottom: 10px; }
    .hj-hero-dot { width: 10px; height: 10px; border-radius: 50%; background: #ef4444; animation: hjPulse 1.5s ease infinite; }
    .hj-hero-kicker span { font-size: .68rem; font-weight: 700; letter-spacing: .28em; color: #ef4444; text-transform: uppercase; }
    .hj-hero h1 { font-family: 'Barlow Condensed', Arial, sans-serif; font-size: 3rem; font-weight: 800; color: #f1f5f9; margin: 0 0 6px; line-height: 1; }
    .hj-hero p { font-size: .9rem; color: #6b7280; margin: 0; }

    .hj-nav { display: flex; gap: 8px; margin-top: 14px; flex-wrap: wrap; }
    .hj-nav-btn {
        display: inline-flex; align-items: center; gap: 4px;
        background: rgba(255,255,255,0.06); color: #e5e7eb;
        border: 1px solid rgba(255,255,255,0.14);
        border-radius: 8px; padding: 6px 13px;
        font-size: .78rem; font-weight: 600;
        transition: background .15s, border-color .15s;
    }
    .hj-nav-btn:hover { background: rgba(255,255,255,0.12); border-color: rgba(212,165,32,0.4); color: #e5e7eb; }
    .hj-nav-hoje { background: rgba(212,165,32,0.18); border-color: rgba(212,165,32,0.5); color: #d4a520; }

    .hj-stats { display: flex; gap: 20px; flex-shrink: 0; margin-left: auto; }
    .hj-stat { text-align: center; }
    .hj-stat-num { font-family: 'Barlow Condensed', Arial, sans-serif; font-size: 2rem; font-weight: 800; line-height: 1; display: flex; align-items: center; gap: 6px; justify-content: center; }
    .hj-stat-dot { width: 8px; height: 8px; border-radius: 50%; background: #ef4444; animation: hjPulse 1.5s ease infinite; display: inline-block; }
    .hj-stat-label { font-size: .62rem; color: #4b5563; text-transform: uppercase; letter-spacing: .1em; margin-top: 3px; }
    .hj-stat-sep { width: 1px; background: #1e2d45; align-self: stretch; }

    /* ── Conteúdo ── */
    .hj-content { padding: 28px 2.5rem 64px; max-width: 1300px; margin: 0 auto; display: flex; flex-direction: column; gap: 32px; }

    .hj-grupo-header { display: flex; align-items: center; gap: 12px; margin-bottom: 16px; }
    .hj-grupo-label { font-size: .65rem; font-weight: 700; letter-spacing: .18em; text-transform: uppercase; white-space: nowrap; }
    .hj-grupo-divider { flex: 1; height: 1px; background: #222; }
    .hj-grupo-count { font-size: .68rem; color: #4b5563; font-weight: 600; }

    .hj-lista { display: flex; flex-direction: column; gap: 8px; }

    .hj-card { background: #161616; border: 1px solid #262626; border-radius: 12px; padding: 16px 20px; transition: border-color .15s; }
    .hj-card.hj-live { border-color: rgba(239,68,68,0.25); box-shadow: 0 0 20px rgba(239,68,68,0.08); }
    .hj-card.hj-analisado { border-color: rgba(74,222,128,0.35); }

    .hj-card-top { display: flex; align-items: center; gap: 10px; margin-bottom: 12px; }
    .hj-comp-badge { display: inline-flex; align-items: center; padding: 2px 8px; border-radius: 5px; font-size: .65rem; font-weight: 700; letter-spacing: .04em; white-space: nowrap; }
    .hj-status-badge { font-size: .65rem; font-weight: 700; padding: 2px 8px; border-radius: 5px; }
    .hj-status-live { background: rgba(239,68,68,0.15); color: #f87171; border: 1px solid rgba(239,68,68,0.3); }
    .hj-status-enc { background: rgba(34,197,94,0.1); color: #4ade80; border: 1px solid rgba(34,197,94,0.25); }
    .hj-status-ag { background: rgba(96,165,250,0.1); color: #93c5fd; border: 1px solid rgba(96,165,250,0.25); }
    .hj-hora { font-size: .72rem; color: #4b5563; margin-left: auto; }

    .hj-times { display: flex; align-items: center; gap: 16px; }
    .hj-time-lado { flex: 1; display: flex; align-items: center; gap: 10px; min-width: 0; }
    .hj-time-lado.hj-casa { justify-content: flex-end; }
    .hj-escudo { width: 36px; height: 36px; border-radius: 50%; background: #0f0f0f; border: 1px solid #2a2a2a; display: flex; align-items: center; justify-content: center; overflow: hidden; flex-shrink: 0; font-size: .8rem; font-weight: 700; color: #6b7280; }
    .hj-escudo img { width: 80%; height: 80%; object-fit: contain; }
    .hj-time-nome { font-size: .95rem; font-weight: 500; color: #9ca3af; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; flex: 1; }
    .hj-time-nome.hj-casa { text-align: right; }
    .hj-time-nome.hj-vencedor { font-weight: 800; color: #f1f5f9; }
    .hj-placar { font-family: 'Barlow Condensed', Arial, sans-serif; font-size: 1.8rem; font-weight: 900; color: #f1f5f9; flex-shrink: 0; letter-spacing: .06em; min-width: 80px; text-align: center; }

    .hj-card-footer { display: flex; align-items: center; justify-content: space-between; margin-top: 12px; padding-top: 10px; border-top: 1px solid #1e1e1e; }
    .hj-estadio { font-size: .68rem; color: #4b5563; }
    .hj-btn-analisar { font-size: .72rem; padding: 4px 12px; background: rgba(212,165,32,0.1); border: 1px solid rgba(212,165,32,0.28); border-radius: 6px; color: #d4a520; font-weight: 700; }
    .hj-btn-analisar:hover { background: rgba(212,165,32,0.2); color: #d4a520; }
    .hj-status-analisado { font-size: .72rem; font-weight: 700; color: #4ade80; display: flex; align-items: center; gap: 4px; }

    .hj-empty { text-align: center; color: #6b7280; padding: 3rem 1rem; background: #141414; border: 1px dashed #262626; border-radius: 12px; }
</style>

<div class="hj-root">
    <!-- ── Hero ── -->
    <div class="hj-hero">
        <div class="hj-hero-stripe"></div>
        <div class="hj-hero-fade"></div>
        <div class="hj-hero-inner">
            <div>
                <div class="hj-hero-kicker">
                    <div class="hj-hero-dot"></div>
                    <span>Jogos · @(ehHoje ? "Hoje" : diaAtual.ToString("dd/MM", ptBR))</span>
                </div>
                <h1>@diaAtual.ToString("dddd, dd 'de' MMMM 'de' yyyy", ptBR)</h1>
                <p>@Model.Count jogo(s) programado(s) · @vivos.Count ao vivo</p>

                <div class="hj-nav">
                    <a class="hj-nav-btn" href="@Url.Action("Hoje", new { data = diaAnterior.ToString("yyyy-MM-dd") })">← @diaAnterior.ToString("dd/MM", ptBR)</a>
                    @if (!ehHoje)
                    {
                        <a class="hj-nav-btn hj-nav-hoje" href="@Url.Action("Hoje")">Hoje</a>
                    }
                    <a class="hj-nav-btn" href="@Url.Action("Hoje", new { data = diaSeguinte.ToString("yyyy-MM-dd") })">@diaSeguinte.ToString("dd/MM", ptBR) →</a>
                </div>
            </div>

            <div class="hj-stats">
                <div class="hj-stat">
                    <div class="hj-stat-num" style="color:#ef4444;"><span class="hj-stat-dot"></span>@vivos.Count</div>
                    <div class="hj-stat-label">Ao vivo</div>
                </div>
                <div class="hj-stat-sep"></div>
                <div class="hj-stat">
                    <div class="hj-stat-num" style="color:#60a5fa;">@agendados.Count</div>
                    <div class="hj-stat-label">Agendados</div>
                </div>
                <div class="hj-stat-sep"></div>
                <div class="hj-stat">
                    <div class="hj-stat-num" style="color:#4ade80;">@encerrados.Count</div>
                    <div class="hj-stat-label">Encerrados</div>
                </div>
            </div>
        </div>
    </div>

    <!-- ── Conteúdo ── -->
    <div class="hj-content">
        @if (!Model.Any())
        {
            <div class="hj-empty">Nenhum jogo encontrado para @diaAtual.ToString("dd/MM/yyyy", ptBR).</div>
        }
        else
        {
            foreach (var grupo in grupos)
            {
                if (!grupo.jogos.Any()) { continue; }

                <div>
                    <div class="hj-grupo-header">
                        <span class="hj-grupo-label" style="color:@grupo.cor;">@grupo.icone @grupo.label</span>
                        <div class="hj-grupo-divider"></div>
                        <span class="hj-grupo-count">@grupo.jogos.Count jogo(s)</span>
                    </div>

                    <div class="hj-lista">
                        @foreach (var jogo in grupo.jogos)
                        {
                            bool realizado = jogo.PlacarCasa.HasValue && jogo.PlacarVisitante.HasValue;
                            bool live = grupo.label == "Ao Vivo";
                            bool analisado = jogosAnalisadosIds.Contains(jogo.Id);
                            bool casaVenceu = realizado && jogo.PlacarCasa > jogo.PlacarVisitante;
                            bool visVenceu = realizado && jogo.PlacarVisitante > jogo.PlacarCasa;
                            var cc = corComp(jogo.Competicao?.Id);

                            <div class="hj-card @(live ? "hj-live" : "") @(analisado ? "hj-analisado" : "")">
                                <div class="hj-card-top">
                                    <span class="hj-comp-badge" style="background:@cc.bg; border:1px solid @cc.border; color:@cc.text;">@(jogo.Competicao?.Nome ?? "Sem competição")</span>
                                    <span class="hj-status-badge @(live ? "hj-status-live" : realizado ? "hj-status-enc" : "hj-status-ag")">
                                        @(live ? $"🔴 {MinutoAoVivo(jogo.Data!.Value)}" : realizado ? "✓ Encerrado" : $"⏳ {(jogo.Data.HasValue ? DateHelper.FormatarData(jogo.Data, "HH:mm") : "--:--")}")
                                    </span>
                                    <span class="hj-hora">@(jogo.Data.HasValue ? DateHelper.FormatarData(jogo.Data, "HH:mm") : "--:--")</span>
                                </div>

                                <div class="hj-times">
                                    <div class="hj-time-lado hj-casa">
                                        <span class="hj-time-nome hj-casa @(casaVenceu ? "hj-vencedor" : "")">@(jogo.TimeCasa?.Nome ?? "?")</span>
                                        <div class="hj-escudo">
                                            @if (!string.IsNullOrEmpty(jogo.TimeCasa?.EscudoUrl))
                                            {
                                                <img src="@Url.Action("Imagem", "MediaProxy", new { url = jogo.TimeCasa.EscudoUrl })" alt="" />
                                            }
                                            else
                                            {
                                                @(jogo.TimeCasa?.Nome?.Substring(0, 1) ?? "?")
                                            }
                                        </div>
                                    </div>

                                    <div class="hj-placar">
                                        @(realizado ? $"{jogo.PlacarCasa} – {jogo.PlacarVisitante}" : "– × –")
                                    </div>

                                    <div class="hj-time-lado">
                                        <div class="hj-escudo">
                                            @if (!string.IsNullOrEmpty(jogo.TimeVisitante?.EscudoUrl))
                                            {
                                                <img src="@Url.Action("Imagem", "MediaProxy", new { url = jogo.TimeVisitante.EscudoUrl })" alt="" />
                                            }
                                            else
                                            {
                                                @(jogo.TimeVisitante?.Nome?.Substring(0, 1) ?? "?")
                                            }
                                        </div>
                                        <span class="hj-time-nome @(visVenceu ? "hj-vencedor" : "")">@(jogo.TimeVisitante?.Nome ?? "?")</span>
                                    </div>
                                </div>

                                <div class="hj-card-footer">
                                    <span class="hj-estadio">🏟️ @(string.IsNullOrWhiteSpace(jogo.Estadio) ? "Local não informado" : jogo.Estadio)</span>
                                    @if (analisado)
                                    {
                                        <span class="hj-status-analisado">✓ Analisado</span>
                                    }
                                    else
                                    {
                                        <a asp-controller="Jogos" asp-action="Analisar" asp-route-id="@jogo.Id" class="hj-btn-analisar">Analisar →</a>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }
        }
    </div>
</div>
