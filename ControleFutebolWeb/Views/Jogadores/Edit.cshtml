@model ControleFutebolWeb.Models.Jogador

<h2>Editar Jogador</h2>

<form asp-action="Edit" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />

    <div class="form-group">
        <label asp-for="Nome" class="control-label"></label>
        <input asp-for="Nome" class="form-control" />
        <span asp-validation-for="Nome" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="Posicao" class="control-label"></label>
        <select asp-for="Posicao" class="form-control" asp-items="ViewBag.Posicoes"></select>
        <span asp-validation-for="Posicao" class="text-danger"></span>
    </div>


    <!-- Idade apenas exibida -->
    <div class="form-group">
        <label class="control-label">Idade</label>
        <input class="form-control" value="@Model.Idade" readonly />
    </div>

    <!-- Dropdown de Nacionalidade -->
    <div class="form-group">
        <label asp-for="NacionalidadeId" class="control-label">Nacionalidade</label>
        <select asp-for="NacionalidadeId" class="form-control" asp-items="ViewBag.NacionalidadeId"></select>
        <span asp-validation-for="NacionalidadeId" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="TimeId" class="control-label">Time</label>
        <select asp-for="TimeId" class="form-control" asp-items="ViewBag.TimeId"></select>
        <span asp-validation-for="TimeId" class="text-danger"></span>
    </div>

    <!-- DataNascimento formatado -->
    <div class="form-group">
        <label asp-for="DataNascimento" class="control-label">Data de Nascimento</label>
        <input asp-for="DataNascimento" class="form-control" type="date"
               value="@(Model.DataNascimento?.ToString("yyyy-MM-dd") ?? "")" />

        <span asp-validation-for="DataNascimento" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="Altura" class="control-label">Altura (cm)</label>
        <input asp-for="Altura" class="form-control" type="number" min="0" />
        <span asp-validation-for="Altura" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="Peso" class="control-label">Peso (kg)</label>
        <input asp-for="Peso" class="form-control" type="number" min="0" />
        <span asp-validation-for="Peso" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="Observacoes" class="control-label">Observações</label>
        <textarea asp-for="Observacoes" class="form-control" rows="4" placeholder="Anotações sobre o jogador (ex: gols na carreira, chegada ao clube...)"></textarea>
    </div>

    <div class="form-group">
        <label class="control-label">Foto (URL)</label>
        <input asp-for="FotoUrl" id="fotoUrl" class="form-control"
               placeholder="https://.../foto.png" />
        <small class="text-muted">
            Cole a URL da foto do jogador — útil quando a API não tem informações dele.
        </small>
        <div class="mt-2">
            <img id="fotoPreview"
                 src="@Model.FotoUrl"
                 alt="Pré-visualização da foto"
                 style="max-height:120px; border-radius:8px; border:1px solid #e5e7eb; @(string.IsNullOrWhiteSpace(Model.FotoUrl) ? "display:none;" : "")" />
        </div>
    </div>

    <div class="form-group mt-2">
        <input type="submit" value="Salvar" class="btn btn-primary" />
        <a asp-action="Index" class="btn btn-secondary">Voltar</a>
    </div>
</form>

<div asp-validation-summary="ModelOnly" class="text-danger"></div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (function () {
            var input = document.getElementById('fotoUrl');
            var preview = document.getElementById('fotoPreview');
            if (!input || !preview) return;
            input.addEventListener('input', function () {
                var url = this.value.trim();
                if (url) { preview.src = url; preview.style.display = ''; }
                else { preview.removeAttribute('src'); preview.style.display = 'none'; }
            });
            preview.addEventListener('error', function () { preview.style.display = 'none'; });
        })();
    </script>
}
