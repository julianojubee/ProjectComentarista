@model ControleFutebolWeb.Models.Jogador

<h2>Excluir Jogador</h2>

<div>
    <h4>Você tem certeza que deseja excluir este jogador?</h4>
    <dl class="row">
        <dt class="col-sm-2">Nome</dt>
        <dd class="col-sm-10">@Model.Nome</dd>
        <dt class="col-sm-2">Posição</dt>
        <dd class="col-sm-10">@Model.Posicao</dd>
        <dt class="col-sm-2">Número</dt>
        <dd class="col-sm-10">@Model.NumeroCamisa</dd>
        <dt class="col-sm-2">Time</dt>
        <dd class="col-sm-10">@Model.Time?.Nome</dd>
    </dl>
</div>

<form asp-action="Delete" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />
    <input type="submit" value="Excluir" class="btn btn-danger" />
    <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
</form>