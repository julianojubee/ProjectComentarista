@model ControleFutebolWeb.Models.ViewModels.JogadorEstatisticasViewModel
@using ControleFutebolWeb.Helpers
@{
    ViewData["Title"] = $"Estatísticas — {Model.Jogador.Nome}";

    string NotaCor(int nota) => nota switch
    {
        >= 8 => "#22c55e",
        >= 6 => "#f59e0b",
        >= 4 => "#f97316",
        _ => "#ef4444"
    };

    string NotaLabel(int nota) => nota switch
    {
        >= 9 => "Excepcional",
        >= 8 => "Ótimo",
        >= 7 => "Bom",
        >= 6 => "Regular",
        >= 5 => "Abaixo",
        _ => "Ruim"
    };
}

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;600;700;800&family=Barlow:wght@400;500&display=swap');

    :root {
        --verde: #16a34a;
        --verde2: #22c55e;
        --cinza1: #0f172a;
        --cinza2: #1e293b;
        --cinza3: #334155;
        --texto: #f1f5f9;
        --muted: #94a3b8;
        --accent: #facc15;
    }

    .estat-page {
        background: var(--cinza1);
        min-height: 100vh;
        color: var(--texto);
        font-family: 'Barlow', sans-serif;
        padding: 2rem 1rem 4rem;
    }

    /* ── Header do jogador ── */
    .jogador-header {
        display: flex;
        align-items: center;
        gap: 1.5rem;
        margin-bottom: 2rem;
        padding-bottom: 1.5rem;
        border-bottom: 1px solid var(--cinza3);
    }

    .jogador-escudo {
        width: 72px;
        height: 72px;
        object-fit: contain;
        filter: drop-shadow(0 2px 8px rgba(0,0,0,.5));
    }

    .jogador-nome {
        font-family: 'Barlow Condensed', sans-serif;
        font-size: 2.4rem;
        font-weight: 800;
        letter-spacing: .02em;
        line-height: 1;
        margin: 0;
    }

    .jogador-meta {
        font-size: .85rem;
        color: var(--muted);
        margin-top: .3rem;
        display: flex;
        gap: 1rem;
        flex-wrap: wrap;
    }

        .jogador-meta span {
            display: flex;
            align-items: center;
            gap: .3rem;
        }

    /* ── Cards de resumo ── */
    .resumo-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
        gap: 1rem;
        margin-bottom: 2rem;
    }

    .resumo-card {
        background: var(--cinza2);
        border: 1px solid var(--cinza3);
        border-radius: 12px;
        padding: 1.1rem 1rem;
        text-align: center;
        position: relative;
        overflow: hidden;
    }

        .resumo-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 3px;
            background: var(--accent-color, var(--verde2));
        }

    .resumo-valor {
        font-family: 'Barlow Condensed', sans-serif;
        font-size: 2.6rem;
        font-weight: 800;
        line-height: 1;
        color: var(--accent-color, var(--verde2));
    }

    .resumo-label {
        font-size: .75rem;
        color: var(--muted);
        text-transform: uppercase;
        letter-spacing: .08em;
        margin-top: .3rem;
    }

    /* ── Barra de média visual ── */
    .media-bar-wrap {
        background: var(--cinza2);
        border: 1px solid var(--cinza3);
        border-radius: 12px;
        padding: 1.2rem 1.5rem;
        margin-bottom: 2rem;
    }

    .media-bar-titulo {
        font-family: 'Barlow Condensed', sans-serif;
        font-size: 1rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .1em;
        color: var(--muted);
        margin-bottom: .8rem;
    }

    .media-bar-track {
        background: var(--cinza3);
        border-radius: 99px;
        height: 12px;
        position: relative;
        overflow: hidden;
    }

    .media-bar-fill {
        height: 100%;
        border-radius: 99px;
        transition: width .8s cubic-bezier(.4,0,.2,1);
        background: linear-gradient(90deg, var(--verde), var(--verde2));
    }

    .media-bar-labels {
        display: flex;
        justify-content: space-between;
        font-size: .75rem;
        color: var(--muted);
        margin-top: .4rem;
    }

    /* ── Tabela de jogos ── */
    .jogos-titulo {
        font-family: 'Barlow Condensed', sans-serif;
        font-size: 1.4rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .08em;
        margin-bottom: 1rem;
        display: flex;
        align-items: center;
        gap: .6rem;
    }

        .jogos-titulo::after {
            content: '';
            flex: 1;
            height: 1px;
            background: var(--cinza3);
        }

    .jogo-item {
        background: var(--cinza2);
        border: 1px solid var(--cinza3);
        border-radius: 10px;
        padding: .9rem 1.1rem;
        margin-bottom: .6rem;
        display: grid;
        grid-template-columns: 1fr auto auto;
        align-items: center;
        gap: 1rem;
        transition: border-color .2s;
    }

        .jogo-item:hover {
            border-color: var(--cinza3);
            background: #263245;
        }

    .jogo-adversario {
        font-size: .95rem;
        font-weight: 500;
    }

    .jogo-data {
        font-size: .75rem;
        color: var(--muted);
        margin-top: .2rem;
    }

    .jogo-gols {
        display: flex;
        align-items: center;
        gap: .35rem;
        font-size: .85rem;
        color: var(--verde2);
        font-weight: 600;
        min-width: 50px;
        justify-content: center;
    }

    .badge-nota {
        font-family: 'Barlow Condensed', sans-serif;
        font-size: 1.3rem;
        font-weight: 800;
        width: 42px;
        height: 42px;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #000;
    }

    .comentario-texto {
        font-size: .78rem;
        color: var(--muted);
        margin-top: .25rem;
        font-style: italic;
    }

    /* ── Vazio ── */
    .sem-dados {
        text-align: center;
        color: var(--muted);
        padding: 3rem;
        font-size: .95rem;
    }

    /* ── Voltar ── */
    .btn-voltar {
        display: inline-flex;
        align-items: center;
        gap: .4rem;
        background: var(--cinza2);
        border: 1px solid var(--cinza3);
        color: var(--texto);
        padding: .45rem 1rem;
        border-radius: 8px;
        font-size: .85rem;
        text-decoration: none;
        margin-bottom: 1.5rem;
        transition: background .2s;
    }

        .btn-voltar:hover {
            background: var(--cinza3);
            color: var(--texto);
        }

    .jogador-foto {
        width: 72px;
        height: 72px;
        object-fit: cover;
        border-radius: 12px;
        border: 2px solid var(--cinza3);
        filter: drop-shadow(0 2px 6px rgba(0,0,0,.4));
        background: var(--cinza2);
    }

</style>

<div class="estat-page">
    <div class="container" style="max-width:860px;">

        <a href="javascript:history.back()" class="btn-voltar">← Voltar</a>

        <!-- Header -->
        <div class="jogador-header">
            @if (Model.Jogador.Time?.EscudoUrl != null)
            {
                <img src="@Model.Jogador.Time.EscudoUrl" class="jogador-escudo" />
            }

            @if (!string.IsNullOrWhiteSpace(Model.Jogador.FotoUrl))
            {
                <img src="@Model.Jogador.FotoUrl" class="jogador-foto" />
            }
            else
            {
                <img src="/images/placeholder-jogador.png" class="jogador-foto" />
            }
            <div>
                <h1 class="jogador-nome">@Model.Jogador.Nome</h1>
                <div class="jogador-meta">
                    <span>🎽 @Model.Jogador.Posicao</span>
                    @if (Model.Jogador.NumeroCamisa.HasValue)
                    {
                        <span># @Model.Jogador.NumeroCamisa</span>
                    }
                    <span>📅 @Model.Jogador.Idade anos</span>
                    @if (Model.Jogador.Time != null)
                    {
                        <span>🏟️ @Model.Jogador.Time.Nome</span>
                    }
                    @if (Model.Jogador.Nacionalidade != null)
                    {
                        <span>🌍 @Model.Jogador.Nacionalidade.Nome</span>
                    }
                </div>
            </div>
        </div>

        <!-- Cards de resumo -->
        <div class="resumo-grid">
            <div class="resumo-card" style="--accent-color: #facc15;">
                <div class="resumo-valor">@Model.MediaNotas.ToString("0.0")</div>
                <div class="resumo-label">Média Geral</div>
            </div>
            <div class="resumo-card" style="--accent-color: #60a5fa;">
                <div class="resumo-valor">@Model.TotalJogos</div>
                <div class="resumo-label">Jogos Avaliados</div>
            </div>
            <div class="resumo-card" style="--accent-color: #22c55e;">
                <div class="resumo-valor">@Model.TotalGols</div>
                <div class="resumo-label">Gols</div>
            </div>
           @*  @if (Model.TotalGolsContra > 0)
            {
                <div class="resumo-card" style="--accent-color: #ef4444;">
                    <div class="resumo-valor">@Model.TotalGolsContra</div>
                    <div class="resumo-label">Gols Contra</div>
                </div>
            }
            <div class="resumo-card" style="--accent-color: #22c55e;">
                <div class="resumo-valor">@Model.MelhorNota</div>
                <div class="resumo-label">Melhor Nota</div>
            </div>
            <div class="resumo-card" style="--accent-color: #f97316;">
                <div class="resumo-valor">@Model.PiorNota</div>
                <div class="resumo-label">Pior Nota</div>
            </div> *@
        </div>

        <!-- Barra de média -->
        @if (Model.TotalJogos > 0)
        {
            <div class="media-bar-wrap">
                <div class="media-bar-titulo">Índice de Desempenho</div>
                <div class="media-bar-track">
                    <div class="media-bar-fill" style="width: @((Model.MediaNotas / 10.0 * 100).ToString(" 0", System.Globalization.CultureInfo.InvariantCulture))%"></div>
                </div>
                <div class="media-bar-labels">
                    <span>0</span>
                    <span style="color:var(--texto); font-weight:600;">
                        @Model.MediaNotas.ToString("0.0") / 10 — @NotaLabel((int)Math.Round(Model.MediaNotas))
                    </span>
                    <span>10</span>
                </div>
            </div>
        }

        <!-- Lista por jogo -->
        <div class="jogos-titulo">Histórico por Jogo</div>

        @if (!Model.NotasPorJogo.Any())
        {
            <div class="sem-dados">
                Nenhuma avaliação registrada para este jogador ainda.
            </div>
        }
        else
        {
            @foreach (var item in Model.NotasPorJogo)
            {
                var adversario = item.Jogo.TimeCasa?.Id == Model.Jogador.TimeId
                ? item.Jogo.TimeVisitante?.Nome
                : item.Jogo.TimeCasa?.Nome;

                var adversarioEscudo = item.Jogo.TimeCasa?.Id == Model.Jogador.TimeId
                ? item.Jogo.TimeVisitante?.EscudoUrl
                : item.Jogo.TimeCasa?.EscudoUrl;

                var placar = (item.Jogo.PlacarCasa.HasValue && item.Jogo.PlacarVisitante.HasValue)
                ? $"{item.GolsPro} x {item.GolsContra}"
                : "–";

                // Cores por resultado
                var resBg = item.Resultado == "V" ? "#16a34a" : item.Resultado == "E" ? "#b45309" : "#dc2626";
                var resLabel = item.Resultado == "V" ? "Vitória" : item.Resultado == "E" ? "Empate" : "Derrota";
                var bonusStr = item.BonusResultado >= 0
                ? $"+{item.BonusResultado:0.#}" : $"{item.BonusResultado:0.#}";

                // Cor da nota final
                string notaColor = item.NotaFinal switch
                {
                    >= 8.5 => "#f59e0b",
                    >= 7.5 => "#22c55e",
                    >= 6.5 => "#3b82f6",
                    >= 5.5 => "#6b7280",
                    >= 4.5 => "#f97316",
                    _ => "#ef4444"
                };
                string notaLabel = item.NotaFinal switch
                {
                    >= 8.5 => "Elite",
                    >= 7.5 => "Ótimo",
                    >= 6.5 => "Bom",
                    >= 5.5 => "Regular",
                    >= 4.5 => "Abaixo",
                    _ => "Fraco"
                };

                <div class="jogo-item" style="flex-direction:column; gap:0; padding:0; overflow:hidden;">

                    <!-- Cabeçalho do card -->
                    <div style="display:flex; align-items:center; gap:10px;
                            padding:.85rem 1.1rem; border-bottom:1px solid rgba(255,255,255,.06);">

                        <!-- Badge resultado -->
                        <div style="width:28px; height:28px; border-radius:6px;
                                background:@resBg; display:flex; align-items:center;
                                justify-content:center; font-size:11px; font-weight:800;
                                color:#fff; flex-shrink:0;">
                            @item.Resultado
                        </div>

                        <!-- Adversário + data -->
                        <div style="flex:1; min-width:0;">
                            <div style="display:flex; align-items:center; gap:7px;">
                                @if (!string.IsNullOrEmpty(adversarioEscudo))
                                {
                                    <img src="@adversarioEscudo"
                                         style="width:18px;height:18px;object-fit:contain;
                                                border-radius:50%;border:.5px solid rgba(255,255,255,.15);" />
                                }
                                <span class="jogo-adversario">
                                    vs @adversario
                                    <span style="color:rgba(255,255,255,.4); font-size:.8rem;
                                             margin-left:.4rem; font-weight:400;">@placar</span>
                                </span>
                                @if (item.Gols > 0)
                                {
                                    <span style="display:inline-flex;align-items:center;gap:3px;
                                                 background:rgba(34,197,94,.15);color:#4ade80;
                                                 font-size:11px;font-weight:600;
                                                 padding:1px 7px;border-radius:999px;">
                                        ⚽ @item.Gols
                                    </span>
                                }
                            </div>
                            <div class="jogo-data">
                                <td>@DateHelper.FormatarData(item.Jogo.Data, "dd/MM/yyyy") — Rodada @item.Jogo.Rodada</td>

                            </div>
                        </div>

                        <!-- Nota Final (círculo) -->
                        <div style="display:flex;flex-direction:column;align-items:center;
                                justify-content:center; width:52px; height:52px;
                                border-radius:50%; border:2px solid @notaColor;
                                color:@notaColor; flex-shrink:0;">
                            <span style="font-family:'Barlow Condensed',sans-serif;
                                     font-size:16px;font-weight:800;line-height:1;">
                                @item.NotaFinal.ToString("0.0")
                            </span>
                            <span style="font-size:8px;font-weight:600;opacity:.7;
                                     letter-spacing:.3px;">@notaLabel</span>
                        </div>
                    </div>

                    <!-- Decomposição da nota -->
                    <div style="display:flex; align-items:stretch; font-size:11px;
                            border-bottom:1px solid rgba(255,255,255,.05);">
                        <div style="flex:1; padding:.5rem 1.1rem; display:flex;
                                flex-direction:column; justify-content:center; gap:2px;">
                            <div style="color:rgba(255,255,255,.35); font-size:10px;
                                     letter-spacing:.4px; text-transform:uppercase;
                                     margin-bottom:2px;">
                                Composição da nota
                            </div>
                            <div style="display:flex; gap:16px; flex-wrap:wrap;">
                                <span style="color:rgba(255,255,255,.5);">
                                    Base <strong style="color:#e2e8f0;">5.0</strong>
                                </span>
                                <span style="color:rgba(255,255,255,.5);">
                                    Ações <strong style="color:@(item.Nota >= 0 ? "#4ade80" : "#f87171");">
                                        @(item.Nota >= 0 ? "+" : "")@item.Nota
                                    </strong>
                                </span>
                                <span style="color:rgba(255,255,255,.5);">
                                    Resultado
                                    <strong style="color:@(item.BonusResultado > 0 ? "#4ade80" : item.BonusResultado < 0 ? "#f87171" : "#94a3b8");">
                                        @bonusStr (@resLabel)
                                    </strong>
                                </span>
                                <span style="color:rgba(255,255,255,.5);">
                                    = <strong style="color:@notaColor;">@item.NotaFinal.ToString("0.00")</strong>
                                </span>
                            </div>
                        </div>
                    </div>

                    <!-- Detalhes das ações (se houver) -->
                    @if (item.Detalhes.Any())
                    {
                        <div style="padding:.6rem 1.1rem; display:flex; flex-wrap:wrap; gap:6px;">
                            @foreach (var d in item.Detalhes.Where(d => d.Quantidade > 0))
                            {
                                var dColor = d.Peso > 0 ? "#4ade80" : "#f87171";
                                var dBg = d.Peso > 0 ? "rgba(34,197,94,.1)" : "rgba(239,68,68,.1)";
                                var sinal = d.Peso > 0 ? "+" : "";
                                <span style="background:@dBg; color:@dColor; font-size:10px;
                                                 font-weight:600; padding:2px 9px; border-radius:999px;
                                                 border:1px solid @dColor + '33';">
                                    @d.AcaoLabel × @d.Quantidade
                                    <span style="opacity:.7;">(@sinal@(d.Peso* d.Quantidade) pts)</span>
                                </span>
                            }
                        </div>
                    }

                    <!-- Observação -->
                    @if (!string.IsNullOrWhiteSpace(item.Comentario))
                    {
                        <div class="comentario-texto" style="padding:.5rem 1.1rem .8rem;">
                            "@item.Comentario"
                        </div>
                    }

                </div>
            }
        }

    </div>
</div>
