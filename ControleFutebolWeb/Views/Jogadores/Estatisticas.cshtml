@model ControleFutebolWeb.Models.ViewModels.JogadorEstatisticasViewModel
@using ControleFutebolWeb.Helpers
@using ControleFutebolWeb.Models
@{
    ViewData["Title"] = $"Estatísticas — {Model.Jogador.NomeExibicao}";

    // Escala única de nota (mesma usada nos cards de jogo) — cor e rótulo.
    string CorNota(double nota) => nota switch
    {
        >= 8.5 => "#f59e0b",
        >= 7.5 => "#22c55e",
        >= 6.5 => "#3b82f6",
        >= 5.5 => "#6b7280",
        >= 4.5 => "#f97316",
        _      => "#ef4444"
    };

    string LabelNota(double nota) => nota switch
    {
        >= 8.5 => "Elite",
        >= 7.5 => "Ótimo",
        >= 6.5 => "Bom",
        >= 5.5 => "Regular",
        >= 4.5 => "Abaixo",
        _      => "Fraco"
    };

    // Escalacao.Posicao pode ser o genérico da API ("Goleiro", "Defensor", "Meia",
    // "Atacante"), o nome granular da formação ("Lateral Direito", "Ponta Esquerda")
    // ou siglas antigas (GL/ZG/MC/AT) — abrevia por palavra-chave.
    string SiglaPosicao(string pos)
    {
        var p = (pos ?? "").Trim().ToLowerInvariant();
        if (p.Length == 0) return "";
        if (p is "gl" or "zg" or "ld" or "le" or "mc" or "at") return p.ToUpperInvariant();
        if (p.Contains("gol"))        return "GL";
        if (p.StartsWith("zag"))      return "ZG";
        if (p.StartsWith("lateral"))  return p.Contains("esq") ? "LE" : "LD";
        if (p.StartsWith("ala"))      return "AL";
        if (p.StartsWith("volante"))  return "VL";
        if (p.StartsWith("meia"))     return p.Contains("ofensiv") ? "MO" : "ME";
        if (p.StartsWith("ponta"))    return p.Contains("esq") ? "PE" : "PD";
        if (p.StartsWith("centro"))   return "CA";
        if (p.StartsWith("ata"))      return "AT";
        if (p.StartsWith("def"))      return "DF";
        return p.Length > 3 ? p[..3].ToUpperInvariant() : p.ToUpperInvariant();
    }

    string NomePosicao(string p) => p switch
    {
        "GL" => "Goleiro",
        "ZG" => "Zagueiro",
        "LD" => "Lateral direito",
        "LE" => "Lateral esquerdo",
        "MC" => "Meia",
        "AT" => "Atacante",
        _ => p
    };

    var inv = System.Globalization.CultureInfo.InvariantCulture;

    var competicoes = ViewBag.Competicoes as List<Competicao> ?? new();
    var competicaoAtual = ViewBag.CompeticaoId as int?;
}

<link rel="stylesheet" href="~/fonts/barlow/barlow.css" asp-append-version="true" />
<style>
    .je, .je *, .je *::before, .je *::after { box-sizing: border-box; }

    .je {
        margin: 0 -12px;
        background: #0f0f0f;
        color: #e5e7eb;
        font-family: 'Barlow', Arial, sans-serif;
        border-radius: 14px;
        overflow: hidden;
    }
    .je a { text-decoration: none; color: inherit; }
    .je h1 { font-family: 'Barlow Condensed', Arial, sans-serif; }

    /* ── Voltar ── */
    .je-top { padding: 20px 2.5rem 0; }
    .je-voltar {
        display: inline-flex; align-items: center; gap: .4rem;
        font-size: .8rem; color: #6b7280; margin-bottom: 14px;
    }
    .je-voltar:hover { color: #d4a520; }

    /* ── Header do jogador ── */
    .je-header {
        background: linear-gradient(135deg, #090909 0%, #141414 100%);
        border-bottom: 1px solid #222;
        padding: 32px 2.5rem 28px;
    }
    .je-header-inner {
        max-width: 1100px; margin: 0 auto;
        display: flex; align-items: center; gap: 24px; flex-wrap: wrap;
    }

    .je-escudo-wrap {
        width: 64px; height: 64px; border-radius: 50%;
        background: #0f0f0f; border: 1px solid #2a2a2a;
        display: flex; align-items: center; justify-content: center;
        overflow: hidden; flex-shrink: 0;
    }
    .je-escudo-wrap img { width: 82%; height: 82%; object-fit: contain; }

    .je-foto-wrap {
        width: 72px; height: 72px; border-radius: 12px;
        background: #1e293b; border: 2px solid #2a3a52;
        display: flex; align-items: center; justify-content: center;
        overflow: hidden; flex-shrink: 0;
    }
    .je-foto-wrap img { width: 100%; height: 100%; object-fit: cover; }

    .je-info { flex: 1; min-width: 200px; }
    .je-nome {
        font-size: 2.4rem; font-weight: 800; color: #f1f5f9;
        margin: 0 0 6px; line-height: 1;
    }
    .je-meta { display: flex; align-items: center; gap: 14px; flex-wrap: wrap; }
    .je-pos-badge {
        display: inline-flex; align-items: center; padding: 3px 10px; border-radius: 6px;
        background: rgba(34,197,94,0.15); border: 1px solid rgba(34,197,94,0.35);
        color: #4ade80; font-size: .72rem; font-weight: 700; letter-spacing: .06em;
    }
    .je-meta-item { font-size: .8rem; color: #6b7280; display: flex; align-items: center; gap: 6px; }
    .je-meta-item img { width: 16px; height: 16px; object-fit: contain; }
    .je-meta-item.je-meta-clube { color: #9ca3af; }

    .je-actions { display: flex; align-items: center; gap: 10px; flex-shrink: 0; flex-wrap: wrap; }
    .je-select-wrap { position: relative; }
    .je-select {
        appearance: none; background: #1a1a1a; border: 1px solid #2a2a2a; border-radius: 8px;
        color: #9ca3af; font-size: .82rem; padding: 8px 28px 8px 12px; cursor: pointer; outline: none;
    }
    .je-select:focus { border-color: #d4a520; }
    .je-select-arrow { position: absolute; right: 8px; top: 50%; transform: translateY(-50%); color: #555; pointer-events: none; }
    .je-clear { font-size: .75rem; color: #6b7280; }
    .je-clear:hover { color: #d4a520; }

    .je-btn-semelhantes {
        display: flex; align-items: center; gap: 7px; padding: 8px 16px;
        background: rgba(34,197,94,0.1); border: 1px solid rgba(34,197,94,0.28); border-radius: 8px;
        color: #4ade80; font-size: .8rem; font-weight: 700; cursor: pointer;
    }
    .je-btn-semelhantes:hover { background: rgba(34,197,94,0.2); }

    /* ── Conteúdo principal ── */
    .je-main { padding: 28px 2.5rem 64px; max-width: 1244px; margin: 0 auto; }

    .je-resumo { display: grid; grid-template-columns: repeat(auto-fit, minmax(140px, 1fr)); gap: 12px; margin-bottom: 24px; }
    .je-resumo-card {
        background: #161616; border: 1px solid #262626; border-radius: 12px;
        padding: 18px 14px; text-align: center; position: relative; overflow: hidden;
    }
    .je-resumo-card::before {
        content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px;
        background: var(--je-cor, #22c55e);
    }
    .je-resumo-valor { font-size: 2.4rem; font-weight: 800; line-height: 1; color: var(--je-cor, #22c55e); }
    .je-resumo-label { font-size: .68rem; color: #4b5563; text-transform: uppercase; letter-spacing: .1em; font-weight: 700; margin-top: 4px; }

    .je-perf { background: #161616; border: 1px solid #262626; border-radius: 12px; padding: 20px 24px; margin-bottom: 24px; }
    .je-perf-top { display: flex; align-items: center; justify-content: space-between; margin-bottom: 10px; flex-wrap: wrap; gap: 6px; }
    .je-perf-label { font-size: .68rem; font-weight: 700; letter-spacing: .14em; color: #6b7280; text-transform: uppercase; }
    .je-perf-valor { font-size: 1rem; font-weight: 800; }
    .je-perf-track { background: #222; border-radius: 999px; height: 10px; overflow: hidden; }
    .je-perf-fill { height: 100%; border-radius: 999px; transition: width .8s ease; }
    .je-perf-escala { display: flex; justify-content: space-between; margin-top: 6px; font-size: .68rem; color: #374151; }

    .je-perfil-grid { display: grid; grid-template-columns: 280px 1fr 320px; gap: 16px; margin-bottom: 24px; align-items: start; }
    @@media (max-width: 1100px) { .je-perfil-grid { grid-template-columns: 1fr; } }

    .je-card { background: #161616; border: 1px solid #262626; border-radius: 12px; padding: 20px; }
    .je-card-titulo { font-size: .68rem; font-weight: 700; letter-spacing: .14em; color: #6b7280; text-transform: uppercase; margin-bottom: 16px; }

    .je-campo-row { display: flex; gap: 16px; align-items: flex-start; }
    .je-campo {
        position: relative; width: 130px; flex-shrink: 0; aspect-ratio: 2/3;
        background: linear-gradient(180deg, #14532d 0%, #166534 100%);
        border: 2px solid rgba(255,255,255,.2); border-radius: 8px; overflow: hidden;
    }
    .je-campo-linha { position: absolute; left: 0; right: 0; top: 50%; height: 1px; background: rgba(255,255,255,.2); }
    .je-campo-circulo {
        position: absolute; left: 50%; top: 50%; width: 44px; height: 44px;
        border: 1.5px solid rgba(255,255,255,.2); border-radius: 50%; transform: translate(-50%, -50%);
    }
    .je-campo-area-sup, .je-campo-area-inf {
        position: absolute; left: 22%; width: 56%; height: 15%; border: 1.5px solid rgba(255,255,255,.2);
    }
    .je-campo-area-sup { top: -1px; border-top: none; }
    .je-campo-area-inf { bottom: -1px; border-bottom: none; }
    .je-campo-dot {
        position: absolute; transform: translate(-50%, -50%); width: 28px; height: 28px; border-radius: 50%;
        color: #0f172a; display: flex; align-items: center; justify-content: center;
        font-size: 9px; font-weight: 800; border: 2px solid rgba(255,255,255,.7);
        box-shadow: 0 2px 6px rgba(0,0,0,.5); z-index: 1; background: #22c55e;
    }
    .je-campo-dot-principal { background: #facc15; z-index: 2; }

    .je-heatmap-badge {
        font-size: .6rem; font-weight: 700; padding: 2px 8px; border-radius: 999px;
        background: rgba(212,165,32,.12); color: #d4a520; border: 1px solid rgba(212,165,32,.25);
        text-transform: none; letter-spacing: 0;
    }
    .je-heatmap-body { display: flex; flex-direction: column; align-items: center; }
    .je-heatmap-pitch { position: relative; width: 100%; max-width: 210px; aspect-ratio: 68/105; border-radius: 6px; overflow: hidden; }
    .je-heatmap-legend { display: flex; align-items: center; justify-content: space-between; margin-top: 10px; width: 100%; max-width: 210px; }
    .je-heatmap-legend span { font-size: .6rem; color: #374151; font-weight: 600; }
    .je-heatmap-legend-bar { flex: 1; margin: 0 10px; height: 5px; border-radius: 3px; background: linear-gradient(90deg, #4ade80, #facc15, #f97316, #ef4444); }

    .je-pos-lista { flex: 1; min-width: 0; display: flex; flex-direction: column; gap: 8px; padding-top: 4px; }
    .je-pos-item { display: flex; align-items: center; gap: 8px; }
    .je-pos-sigla {
        flex-shrink: 0; width: 34px; text-align: center; padding: 2px 0; border-radius: 6px;
        font-size: .72rem; font-weight: 800; background: #334155; color: #f1f5f9;
    }
    .je-pos-item-principal .je-pos-sigla { background: #facc15; color: #0f172a; }
    .je-pos-nome { font-size: .82rem; font-weight: 600; color: #e5e7eb; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .je-pos-sub { font-size: .68rem; color: #6b7280; }

    .je-donuts { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 16px; margin-bottom: 20px; }
    .je-donut { text-align: center; min-width: 0; }
    .je-donut-ring { width: 74px; height: 74px; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto; }
    .je-donut-hole { width: 54px; height: 54px; border-radius: 50%; background: #1a1a1a; display: flex; align-items: center; justify-content: center; font-weight: 800; font-size: .9rem; color: #f1f5f9; }
    .je-donut-label { font-size: .82rem; font-weight: 600; color: #e5e7eb; margin-top: 6px; }
    .je-donut-sub { font-size: .68rem; color: #6b7280; margin-top: 2px; }

    .je-chips { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 8px; }
    @@media (max-width: 560px) { .je-chips { grid-template-columns: repeat(2, minmax(0, 1fr)); } }
    .je-chip { background: rgba(255,255,255,.03); border: 1px solid #222; border-radius: 10px; padding: 8px 4px; text-align: center; min-width: 0; }
    .je-chip-valor { font-size: 1.05rem; font-weight: 800; color: #f1f5f9; line-height: 1; }
    .je-chip-label { font-size: .56rem; color: #6b7280; text-transform: uppercase; letter-spacing: .04em; margin-top: 3px; overflow-wrap: break-word; }

    .je-section { margin-bottom: 24px; }
    .je-section-row { display: flex; align-items: center; gap: 14px; margin-bottom: 16px; cursor: pointer; background: none; border: none; width: 100%; padding: 0 0 16px; border-bottom: 1px solid transparent; }
    .je-section-row.je-com-linha { border-bottom-color: #222; }
    .je-section-titulo { font-size: .7rem; font-weight: 700; letter-spacing: .18em; color: #6b7280; text-transform: uppercase; white-space: nowrap; }
    .je-section-linha { flex: 1; height: 1px; background: #222; }
    .je-section-badge { font-size: .68rem; padding: 2px 10px; background: #1a1a1a; border: 1px solid #2a2a2a; border-radius: 999px; color: #6b7280; font-weight: 600; }
    .je-section-chevron { color: #6b7280; flex-shrink: 0; transition: transform .15s; }

    .je-season-selector { display: flex; align-items: center; gap: .5rem; margin-bottom: 1rem; flex-wrap: wrap; }
    .je-season-btn {
        background: #161616; border: 1px solid #262626; color: #9ca3af;
        font-size: .8rem; font-weight: 600; padding: 6px 14px; border-radius: 999px; cursor: pointer; transition: all .15s;
    }
    .je-season-btn.active, .je-season-btn:hover { background: #d4a520; border-color: #d4a520; color: #141414; }

    .je-temporada-grid { display: grid; gap: 1rem; }
    .je-temporada-card { background: #161616; border: 1px solid #262626; border-radius: 12px; overflow: hidden; }
    .je-temporada-header { display: flex; align-items: center; gap: .75rem; padding: 14px 20px; border-bottom: 1px solid #1e1e1e; background: #111; }
    .je-temporada-logo { width: 28px; height: 28px; object-fit: contain; }
    .je-temporada-nome { font-size: 1rem; font-weight: 700; color: #f1f5f9; flex: 1; min-width: 0; }
    .je-temporada-pais { font-size: .75rem; color: #6b7280; display: flex; align-items: center; gap: 5px; }
    .je-rating-badge {
        font-size: .9rem; font-weight: 800; padding: 2px 10px; border-radius: 999px;
        background: rgba(212,165,32,.12); color: #d4a520; border: 1px solid rgba(212,165,32,.25); flex-shrink: 0;
    }
    .je-temporada-stats { display: grid; grid-template-columns: repeat(auto-fill, minmax(90px, 1fr)); }
    .je-stat-box { padding: 14px 8px; text-align: center; border-right: 1px solid #1e1e1e; border-bottom: 1px solid #1e1e1e; }
    .je-stat-val { font-size: 1.5rem; font-weight: 800; line-height: 1; color: #f1f5f9; }
    .je-stat-lbl { font-size: .58rem; color: #4b5563; text-transform: uppercase; letter-spacing: .06em; margin-top: 3px; font-weight: 700; }
    .je-stat-val.hl-green  { color: #4ade80; }
    .je-stat-val.hl-blue   { color: #60a5fa; }
    .je-stat-val.hl-orange { color: #fb923c; }
    .je-stat-val.hl-yellow { color: #facc15; }
    .je-temporada-footer { display: flex; gap: .5rem; flex-wrap: wrap; padding: 10px 20px; background: rgba(0,0,0,.15); font-size: .72rem; color: #6b7280; }
    .je-temporada-chip { background: rgba(255,255,255,.06); border-radius: 999px; padding: 2px 10px; display: flex; align-items: center; gap: .3rem; }

    /* ── Histórico por jogo ── */
    .je-jogos-lista { display: flex; flex-direction: column; gap: 8px; }
    .je-jogo-card { background: #161616; border: 1px solid #262626; border-radius: 12px; overflow: hidden; transition: border-color .15s; }
    .je-jogo-card:hover { border-color: #2a2a2a; }
    .je-jogo-row { display: flex; align-items: center; gap: 14px; padding: 14px 18px; flex-wrap: wrap; cursor: pointer; }
    .je-jogo-row:hover .je-jogo-adv { color: #d4a520; }
    .je-jogo-badge { width: 28px; height: 28px; border-radius: 6px; display: flex; align-items: center; justify-content: center; font-size: 11px; font-weight: 800; color: #fff; flex-shrink: 0; }
    .je-jogo-info { flex: 1; min-width: 0; }
    .je-jogo-linha1 { display: flex; align-items: center; gap: 8px; margin-bottom: 3px; flex-wrap: wrap; }
    .je-jogo-escudo { width: 18px; height: 18px; object-fit: contain; flex-shrink: 0; border-radius: 50%; }
    .je-jogo-adv { font-size: .9rem; font-weight: 600; color: #f1f5f9; }
    .je-jogo-placar { font-size: .82rem; color: #4b5563; font-weight: 500; margin-left: .3rem; }
    .je-tag { display: inline-flex; align-items: center; gap: 3px; font-size: .68rem; font-weight: 700; padding: 1px 8px; border-radius: 999px; }
    .je-tag-gol { background: rgba(34,197,94,.12); color: #4ade80; border: 1px solid rgba(34,197,94,.25); }
    .je-tag-assist { background: rgba(251,146,60,.12); color: #fb923c; border: 1px solid rgba(251,146,60,.25); }
    .je-tag-auto { font-size: .62rem; font-weight: 600; color: #38bdf8; padding: 1px 8px; border-radius: 999px; background: rgba(56,189,248,.1); border: 1px solid rgba(56,189,248,.25); }
    .je-tag-sem { background: rgba(148,163,184,.12); color: #94a3b8; font-size: .62rem; font-weight: 600; padding: 1px 8px; border-radius: 999px; border: 1px solid rgba(148,163,184,.25); }
    .je-jogo-data { font-size: .68rem; color: #4b5563; }

    .je-nota-circle { width: 52px; height: 52px; border-radius: 50%; display: flex; flex-direction: column; align-items: center; justify-content: center; flex-shrink: 0; }
    .je-nota-val { font-size: 1rem; font-weight: 800; line-height: 1; }
    .je-nota-label { font-size: .52rem; font-weight: 600; opacity: .75; letter-spacing: .04em; margin-top: 1px; }

    .je-ver-analise {
        font-size: .7rem; padding: 6px 12px; background: #1a1a1a; border: 1px solid #2a2a2a; border-radius: 8px;
        color: #9ca3af; font-weight: 600; flex-shrink: 0; cursor: pointer;
    }
    .je-ver-analise:hover { border-color: #d4a520; color: #d4a520; }
    .je-ver-analise.aberto { border-color: #d4a520; color: #d4a520; }

    .je-stats-mini { display: flex; gap: 0; padding: 8px 18px; background: #111; border-top: 1px solid #1e1e1e; flex-wrap: wrap; }
    .je-stat-mini { flex: 1; text-align: center; padding: 0 4px; border-right: 1px solid #1e1e1e; min-width: 64px; }
    .je-stat-mini:last-child { border-right: none; }
    .je-stat-mini-val { font-size: 1rem; font-weight: 800; color: #f1f5f9; line-height: 1; }
    .je-stat-mini-lbl { font-size: .58rem; color: #4b5563; text-transform: uppercase; margin-top: 1px; }

    .je-analise-panel { display: none; border-top: 1px solid #1e1e1e; background: #111; }
    .je-analise-panel.aberto { display: block; }
    .je-analise-comp { display: flex; flex-wrap: wrap; gap: 16px; align-items: center; padding: 10px 18px; border-bottom: 1px solid #1e1e1e; font-size: 11px; }
    .je-analise-comp-titulo { color: rgba(255,255,255,.35); font-size: 10px; letter-spacing: .4px; text-transform: uppercase; width: 100%; margin-bottom: 2px; }
    .je-analise-comp span { color: rgba(255,255,255,.5); }
    .je-detalhes { padding: 10px 18px; display: flex; flex-wrap: wrap; gap: 6px; }
    .je-detalhe-chip { font-size: 10px; font-weight: 600; padding: 2px 9px; border-radius: 999px; border: 1px solid; }
    .je-comentario { padding: 0 18px 10px; font-size: .78rem; color: #6b7280; font-style: italic; }
    .je-obs { padding: 0 18px 10px; display: flex; flex-direction: column; gap: 4px; }
    .je-obs-item { font-size: 12.5px; color: #a7f3d0; background: rgba(5,150,105,.12); border: 1px solid rgba(5,150,105,.4); border-radius: 8px; padding: 6px 10px; }

    .je-historico-collapsed .je-jogo-card:nth-child(n+4) { display: none; }
    .je-btn-expand {
        display: block; width: 100%; background: #161616; border: 1px dashed #262626; border-radius: 10px;
        color: #6b7280; font-size: .85rem; padding: .65rem 1rem; cursor: pointer; text-align: center; margin-top: .4rem;
        transition: background .2s, color .2s;
    }
    .je-btn-expand:hover { background: #262626; color: #e5e7eb; }

    .je-sem-dados { text-align: center; color: #6b7280; padding: 3rem; font-size: .95rem; }

    /* ── Modal: jogadores semelhantes ── */
    .je-modal-overlay {
        position: fixed; inset: 0; background: rgba(0,0,0,.7); backdrop-filter: blur(3px);
        display: none; align-items: flex-start; justify-content: center; z-index: 1000; padding: 2rem 1rem; overflow-y: auto;
    }
    .je-modal-overlay.open { display: flex; }
    .je-modal-box { background: #0f0f0f; border: 1px solid #262626; border-radius: 16px; width: 100%; max-width: 720px; box-shadow: 0 20px 60px rgba(0,0,0,.6); overflow: hidden; font-family: 'Barlow', sans-serif; color: #e5e7eb; }
    .je-modal-header { display: flex; align-items: center; justify-content: space-between; gap: 1rem; padding: 1.1rem 1.4rem; border-bottom: 1px solid #262626; }
    .je-modal-titulo { font-size: 1.4rem; font-weight: 800; text-transform: uppercase; letter-spacing: .04em; margin: 0; }
    .je-modal-close { background: #161616; border: 1px solid #262626; color: #e5e7eb; width: 34px; height: 34px; border-radius: 8px; font-size: 1.1rem; cursor: pointer; flex-shrink: 0; }
    .je-modal-close:hover { background: #262626; }
    .je-modal-criterios { display: flex; flex-wrap: wrap; gap: .4rem; padding: .9rem 1.4rem; border-bottom: 1px solid #262626; background: rgba(0,0,0,.15); }
    .je-criterio-chip { background: rgba(34,197,94,.12); border: 1px solid rgba(34,197,94,.3); color: #4ade80; font-size: .72rem; font-weight: 600; padding: .2rem .65rem; border-radius: 999px; }
    .je-modal-body { padding: 1rem 1.4rem 1.4rem; display: grid; gap: .6rem; }
    .je-sem-card { display: flex; align-items: center; gap: .9rem; background: #161616; border: 1px solid #262626; border-radius: 12px; padding: .7rem .9rem; transition: border-color .2s, background .2s; }
    .je-sem-card:hover { border-color: #4ade80; background: #1c1c1c; }
    .je-sem-foto { width: 52px; height: 52px; border-radius: 10px; object-fit: cover; background: #262626; border: 1px solid #262626; flex-shrink: 0; }
    .je-sem-info { flex: 1; min-width: 0; }
    .je-sem-nome { font-size: 1.15rem; font-weight: 700; color: #f1f5f9; text-decoration: none; display: inline-flex; align-items: center; gap: .4rem; }
    .je-sem-nome:hover { color: #4ade80; text-decoration: underline; }
    .je-sem-meta { display: flex; flex-wrap: wrap; gap: .35rem .8rem; font-size: .75rem; color: #6b7280; margin-top: .2rem; }
    .je-sem-meta span { display: inline-flex; align-items: center; gap: .25rem; }
    .je-sem-stats { display: flex; gap: .4rem; flex-shrink: 0; justify-content: flex-end; flex-wrap: wrap; max-width: 190px; }
    .je-sem-stat { text-align: center; min-width: 36px; }
    .je-sem-stat-val { font-size: 1.2rem; font-weight: 800; line-height: 1; color: #f1f5f9; }
    .je-sem-stat-lbl { font-size: .6rem; text-transform: uppercase; color: #6b7280; letter-spacing: .05em; margin-top: .15rem; }
    .je-sem-escudo { width: 14px; height: 14px; object-fit: contain; vertical-align: middle; }

    /* ── Modal: comparar jogadores ── */
    .je-btn-comparar {
        display: flex; align-items: center; gap: 7px; padding: 8px 16px;
        background: rgba(96,165,250,0.1); border: 1px solid rgba(96,165,250,0.28); border-radius: 8px;
        color: #60a5fa; font-size: .8rem; font-weight: 700; cursor: pointer;
    }
    .je-btn-comparar:hover { background: rgba(96,165,250,0.2); }

    .je-cmp-box { max-width: 880px; }
    .je-cmp-box .je-modal-body { display: block; }
    .je-cmp-picker {
        padding: .9rem 1.4rem; border-bottom: 1px solid #262626; background: rgba(0,0,0,.15);
        display: flex; flex-wrap: wrap; align-items: center; gap: .6rem;
    }
    .je-cmp-picker .je-select { max-width: 210px; }
    .je-cmp-ou { font-size: .68rem; color: #4b5563; text-transform: uppercase; letter-spacing: .08em; font-weight: 700; }
    .je-cmp-busca-wrap { position: relative; flex: 1; min-width: 190px; }
    .je-cmp-busca {
        width: 100%; background: #1a1a1a; border: 1px solid #2a2a2a; border-radius: 8px;
        color: #e5e7eb; font-size: .82rem; padding: 8px 12px; outline: none; font-family: inherit;
    }
    .je-cmp-busca:focus { border-color: #60a5fa; }
    .je-cmp-busca-resultados {
        position: absolute; top: calc(100% + 4px); left: 0; right: 0; z-index: 10;
        background: #161616; border: 1px solid #2a2a2a; border-radius: 10px;
        max-height: 260px; overflow-y: auto; display: none; box-shadow: 0 12px 30px rgba(0,0,0,.5);
    }
    .je-cmp-busca-resultados.open { display: block; }
    .je-cmp-busca-item { display: flex; align-items: center; gap: .6rem; padding: .5rem .7rem; cursor: pointer; }
    .je-cmp-busca-item:hover { background: #1f1f1f; }
    .je-cmp-busca-item img { width: 30px; height: 30px; border-radius: 6px; object-fit: cover; background: #262626; flex-shrink: 0; }
    .je-cmp-busca-nome { font-size: .85rem; font-weight: 600; color: #f1f5f9; }
    .je-cmp-busca-sub { font-size: .68rem; color: #6b7280; }

    .je-cmp-vazio { text-align: center; color: #6b7280; padding: 2.5rem 1rem; font-size: .9rem; }

    .je-cmp-head { display: grid; grid-template-columns: 1fr auto 1fr; gap: .8rem; align-items: stretch; margin-bottom: 1rem; }
    @@media (max-width: 640px) { .je-cmp-head { grid-template-columns: 1fr; } .je-cmp-vs { text-align: center; } }
    .je-cmp-jog {
        background: #161616; border: 1px solid #262626; border-radius: 12px; padding: .8rem;
        display: flex; align-items: center; gap: .7rem; border-top: 3px solid var(--cor, #4b5563);
    }
    .je-cmp-jog img.foto { width: 52px; height: 52px; border-radius: 10px; object-fit: cover; background: #262626; flex-shrink: 0; }
    .je-cmp-jog-nome { font-size: 1.05rem; font-weight: 800; color: #f1f5f9; line-height: 1.15; }
    .je-cmp-jog-nome:hover { color: var(--cor, #d4a520); text-decoration: underline; }
    .je-cmp-jog-sub { font-size: .7rem; color: #6b7280; margin-top: .25rem; display: flex; flex-wrap: wrap; gap: .2rem .6rem; }
    .je-cmp-vs { align-self: center; font-size: 1rem; font-weight: 800; color: #4b5563; }

    .je-cmp-aviso {
        font-size: .74rem; color: #fbbf24; background: rgba(251,191,36,.08);
        border: 1px solid rgba(251,191,36,.25); border-radius: 8px; padding: .45rem .7rem; margin-bottom: .5rem;
    }
    .je-cmp-veredito {
        background: rgba(212,165,32,.08); border: 1px solid rgba(212,165,32,.3); border-radius: 12px;
        padding: .8rem 1rem; font-size: .88rem; color: #e5e7eb; margin-bottom: .8rem;
    }
    .je-cmp-veredito strong { color: #d4a520; }
    .je-cmp-insights { display: grid; gap: .5rem; margin-bottom: .6rem; }
    .je-cmp-insight {
        display: flex; gap: .6rem; align-items: flex-start; background: #161616;
        border: 1px solid #262626; border-left: 3px solid #4b5563; border-radius: 10px;
        padding: .6rem .8rem; font-size: .82rem; color: #cbd5e1; line-height: 1.45;
    }
    .je-cmp-insight.vence-a { border-left-color: #facc15; }
    .je-cmp-insight.vence-b { border-left-color: #60a5fa; }
    .je-cmp-insight strong { color: #f1f5f9; }

    .je-cmp-grupo-titulo { font-size: .68rem; font-weight: 700; letter-spacing: .14em; color: #6b7280; text-transform: uppercase; margin: 1.1rem 0 .5rem; }
    .je-cmp-row { display: grid; grid-template-columns: 64px 1fr 64px; gap: .7rem; align-items: center; padding: .3rem 0; }
    .je-cmp-val { font-size: .92rem; font-weight: 700; color: #6b7280; text-align: center; }
    .je-cmp-val.vence.lado-a { color: #facc15; }
    .je-cmp-val.vence.lado-b { color: #60a5fa; }
    .je-cmp-mid { min-width: 0; }
    .je-cmp-metrica-label { font-size: .72rem; color: #9ca3af; text-align: center; margin-bottom: .25rem; }
    .je-cmp-bar { display: flex; height: 7px; border-radius: 999px; overflow: hidden; background: #222; }
    .je-cmp-bar .seg-a { background: rgba(250,204,21,.3); }
    .je-cmp-bar .seg-b { background: rgba(96,165,250,.3); }
    .je-cmp-bar .seg-a.vence { background: #facc15; }
    .je-cmp-bar .seg-b.vence { background: #60a5fa; }
</style>

<div class="je">
    <div class="je-top">
        <a href="javascript:history.back()" class="je-voltar">← Voltar à lista</a>
    </div>

    <!-- ── Header do jogador ─────────────────────────────────────────── -->
    <div class="je-header">
        <div class="je-header-inner">

            @if (Model.Jogador.Time?.EscudoUrl != null)
            {
                <div class="je-escudo-wrap">
                    <img src="@Url.Action("Imagem", "MediaProxy", new { url = Model.Jogador.Time.EscudoUrl })" alt="" />
                </div>
            }

            <div class="je-foto-wrap">
                @if (!string.IsNullOrWhiteSpace(Model.Jogador.FotoUrl))
                {
                    <img src="@Url.FotoSrc(Model.Jogador.FotoUrl)" onerror="this.onerror=null; this.src='/images/placeholder-jogador.png'" />
                }
                else
                {
                    <img src="/images/placeholder-jogador.png" />
                }
            </div>

            <div class="je-info">
                <h1 class="je-nome">@Model.Jogador.NomeExibicao</h1>
                <div class="je-meta">
                    <span class="je-pos-badge">@PosicaoJogadorHelper.Sigla(Model.Jogador.Posicao)</span>
                    @if (Model.Jogador.NumeroCamisa.HasValue)
                    {
                        <span class="je-meta-item">Nº @Model.Jogador.NumeroCamisa</span>
                    }
                    <span class="je-meta-item">@Model.Jogador.Idade anos</span>
                    @if (Model.Jogador.Altura.HasValue)
                    {
                        <span class="je-meta-item">@Model.Jogador.Altura cm</span>
                    }
                    @if (Model.Jogador.Peso.HasValue)
                    {
                        <span class="je-meta-item">@Model.Jogador.Peso kg</span>
                    }
                    @if (Model.Jogador.Time != null)
                    {
                        <span class="je-meta-item je-meta-clube">
                            @if (!string.IsNullOrEmpty(Model.Jogador.Time.EscudoUrl))
                            {
                                <img src="@Url.Action("Imagem", "MediaProxy", new { url = Model.Jogador.Time.EscudoUrl })" alt="" />
                            }
                            @Model.Jogador.Time.Nome
                        </span>
                    }
                    @if (Model.Jogador.Nacionalidade != null)
                    {
                        var bandeiraUrl = FlagHelper.GetFlagImageUrl(Model.Jogador.Nacionalidade.Nome);
                        <span class="je-meta-item" title="País de nascimento: @Model.Jogador.Nacionalidade.Nome">
                            @if (bandeiraUrl != null)
                            {
                                <img src="@Url.Action("Imagem", "MediaProxy", new { url = bandeiraUrl })" alt="" />
                            }
                            @Model.Jogador.Nacionalidade.Nome
                        </span>
                    }
                    @if (Model.Jogador.Selecao != null)
                    {
                        <span class="je-meta-item je-meta-clube" title="Seleção que defende: @Model.Jogador.Selecao.Nome">
                            @if (!string.IsNullOrEmpty(Model.Jogador.Selecao.EscudoUrl))
                            {
                                <img src="@Url.Action("Imagem", "MediaProxy", new { url = Model.Jogador.Selecao.EscudoUrl })" alt="" />
                            }
                            @Model.Jogador.Selecao.Nome
                        </span>
                    }
                </div>
            </div>

            <div class="je-actions">
                @if (competicoes.Count > 1)
                {
                    <form method="get" style="display:flex; align-items:center; gap:8px;">
                        <input type="hidden" name="id" value="@Model.Jogador.Id" />
                        <div class="je-select-wrap">
                            <select name="competicaoId" class="je-select" onchange="this.form.submit()">
                                <option value="">Todas as competições</option>
                                @foreach (var c in competicoes)
                                {
                                    <option value="@c.Id" selected="@(competicaoAtual == c.Id)">@c.Nome</option>
                                }
                            </select>
                            <div class="je-select-arrow">
                                <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9" /></svg>
                            </div>
                        </div>
                    </form>
                    @if (competicaoAtual.HasValue)
                    {
                        <a href="/Jogadores/Estatisticas/@Model.Jogador.Id" class="je-clear">✕ limpar</a>
                    }
                }
                <button type="button" class="je-btn-semelhantes" onclick="abrirSemelhantes()">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8" /><line x1="21" y1="21" x2="16.65" y2="16.65" /></svg>
                    Semelhantes
                </button>
                <button type="button" class="je-btn-comparar" onclick="abrirComparar()">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="17 11 21 7 17 3" /><line x1="21" y1="7" x2="9" y2="7" /><polyline points="7 21 3 17 7 13" /><line x1="15" y1="17" x2="3" y2="17" /></svg>
                    Comparar com
                </button>
            </div>
        </div>
    </div>

    <!-- ── Conteúdo principal ────────────────────────────────────────── -->
    <div class="je-main">

        <!-- Cards de resumo -->
        <div class="je-resumo">
            <div class="je-resumo-card" style="--je-cor:#facc15;">
                <div class="je-resumo-valor">@Model.MediaNotas.ToString("0.0")</div>
                <div class="je-resumo-label">Média Geral</div>
            </div>
            <div class="je-resumo-card" style="--je-cor:#60a5fa;">
                <div class="je-resumo-valor">@Model.TotalJogosParticipados</div>
                <div class="je-resumo-label">Jogos</div>
            </div>
            <div class="je-resumo-card" style="--je-cor:#a78bfa;">
                <div class="je-resumo-valor">@Model.TotalJogos</div>
                <div class="je-resumo-label">Avaliados</div>
            </div>
            <div class="je-resumo-card" style="--je-cor:#22c55e;">
                <div class="je-resumo-valor">@Model.TotalGols</div>
                <div class="je-resumo-label">Gols</div>
            </div>
            @if (Model.TotalAssistencias > 0)
            {
                <div class="je-resumo-card" style="--je-cor:#fb923c;">
                    <div class="je-resumo-valor">@Model.TotalAssistencias</div>
                    <div class="je-resumo-label">Assistências</div>
                </div>
            }
        </div>

        <!-- Índice de desempenho -->
        @if (Model.TotalJogos > 0)
        {
            <div class="je-perf">
                <div class="je-perf-top">
                    <span class="je-perf-label">Índice de Desempenho</span>
                    <span class="je-perf-valor" style="color:@CorNota(Model.MediaNotas);">
                        @Model.MediaNotas.ToString("0.0") / 10 — @LabelNota(Model.MediaNotas)
                    </span>
                </div>
                <div class="je-perf-track">
                    <div class="je-perf-fill"
                         style="width:@((Model.MediaNotas / 10.0 * 100).ToString("0", inv))%; background: linear-gradient(90deg, #16a34a, @CorNota(Model.MediaNotas));"></div>
                </div>
                <div class="je-perf-escala">
                    <span>0</span><span>5</span><span>10</span>
                </div>
            </div>
        }

        <!-- Perfil tático: posições em campo + mapa de calor + médias por jogo -->
        @{
            var competicaoNomeAtual = competicaoAtual.HasValue
                ? competicoes.FirstOrDefault(c => c.Id == competicaoAtual)?.Nome
                : "Todas as competições";
        }
        @if (Model.PosicoesJogadas.Any() || Model.PontosHeatmap.Any() || Model.Medias != null)
        {
            <div class="je-perfil-grid">
                @if (Model.PosicoesJogadas.Any())
                {
                    <div class="je-card">
                        <div class="je-card-titulo">Posições em Campo</div>
                        <div class="je-campo-row">
                            <div class="je-campo">
                                <div class="je-campo-linha"></div>
                                <div class="je-campo-circulo"></div>
                                <div class="je-campo-area-sup"></div>
                                <div class="je-campo-area-inf"></div>
                                @foreach (var p in Model.PosicoesJogadas)
                                {
                                    var principal = p == Model.PosicoesJogadas[0];
                                    <div class="je-campo-dot @(principal ? "je-campo-dot-principal" : "")"
                                         style="left:@p.X.ToString("0.#", inv)%; top:@p.Y.ToString("0.#", inv)%;"
                                         title="@NomePosicao(p.Posicao) — @p.Jogos jogo(s) (@p.Pct%)">
                                        @SiglaPosicao(p.Posicao)
                                    </div>
                                }
                            </div>
                            <div class="je-pos-lista">
                                @foreach (var p in Model.PosicoesJogadas)
                                {
                                    var principal = p == Model.PosicoesJogadas[0];
                                    <div class="je-pos-item @(principal ? "je-pos-item-principal" : "")">
                                        <span class="je-pos-sigla">@SiglaPosicao(p.Posicao)</span>
                                        <div style="flex:1; min-width:0;">
                                            <div class="je-pos-nome">@NomePosicao(p.Posicao)</div>
                                            <div class="je-pos-sub">@p.Jogos jogos · @p.Pct%</div>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                }

                @if (Model.PontosHeatmap.Any())
                {
                    <div class="je-card">
                        <div class="je-card-titulo" style="display:flex; align-items:center; justify-content:space-between;">
                            <span>🔥 Mapa de Calor</span>
                            <span class="je-heatmap-badge">@competicaoNomeAtual</span>
                        </div>
                        <div class="je-heatmap-body">
                        <div id="jeHeatmapCampo" class="je-heatmap-pitch">
                            <svg viewBox="0 0 680 1050" xmlns="http://www.w3.org/2000/svg" style="position:absolute; inset:0; width:100%; height:100%;">
                                <rect width="680" height="1050" fill="#0d3d1f" />
                                <rect x="0" y="0" width="680" height="75" fill="#0e4221" opacity="0.5" />
                                <rect x="0" y="150" width="680" height="75" fill="#0e4221" opacity="0.5" />
                                <rect x="0" y="300" width="680" height="75" fill="#0e4221" opacity="0.5" />
                                <rect x="0" y="450" width="680" height="75" fill="#0e4221" opacity="0.5" />
                                <rect x="0" y="600" width="680" height="75" fill="#0e4221" opacity="0.5" />
                                <rect x="0" y="750" width="680" height="75" fill="#0e4221" opacity="0.5" />
                                <rect x="0" y="900" width="680" height="75" fill="#0e4221" opacity="0.5" />
                                <rect x="5" y="5" width="670" height="1040" rx="2" fill="none" stroke="rgba(255,255,255,0.4)" stroke-width="3" />
                                <line x1="5" y1="525" x2="675" y2="525" stroke="rgba(255,255,255,0.4)" stroke-width="2" />
                                <circle cx="340" cy="525" r="91.5" fill="none" stroke="rgba(255,255,255,0.4)" stroke-width="2" />
                                <circle cx="340" cy="525" r="4" fill="rgba(255,255,255,0.5)" />
                                <rect x="129" y="5" width="422" height="132" fill="none" stroke="rgba(255,255,255,0.4)" stroke-width="2" />
                                <rect x="229" y="5" width="222" height="55" fill="none" stroke="rgba(255,255,255,0.4)" stroke-width="2" />
                                <circle cx="340" cy="116" r="4" fill="rgba(255,255,255,0.5)" />
                                <path d="M 251 137 A 91.5 91.5 0 0 0 429 137" fill="none" stroke="rgba(255,255,255,0.4)" stroke-width="2" />
                                <rect x="273" y="0" width="134" height="18" fill="rgba(255,255,255,0.1)" stroke="rgba(255,255,255,0.35)" stroke-width="2" />
                                <rect x="129" y="913" width="422" height="132" fill="none" stroke="rgba(255,255,255,0.4)" stroke-width="2" />
                                <rect x="229" y="990" width="222" height="55" fill="none" stroke="rgba(255,255,255,0.4)" stroke-width="2" />
                                <circle cx="340" cy="934" r="4" fill="rgba(255,255,255,0.5)" />
                                <path d="M 251 913 A 91.5 91.5 0 0 1 429 913" fill="none" stroke="rgba(255,255,255,0.4)" stroke-width="2" />
                                <rect x="273" y="1032" width="134" height="18" fill="rgba(255,255,255,0.1)" stroke="rgba(255,255,255,0.35)" stroke-width="2" />
                            </svg>
                        </div>
                        <div class="je-heatmap-legend">
                            <span>Baixa</span>
                            <div class="je-heatmap-legend-bar"></div>
                            <span>Alta</span>
                        </div>
                        </div>
                    </div>
                }

                @if (Model.Medias != null)
                {
                    var m = Model.Medias;
                    <div class="je-card">
                        <div class="je-card-titulo">Médias por Jogo <span style="text-transform:none; letter-spacing:0; font-weight:400; color:#4b5563;">(@m.Jogos jogo@(m.Jogos == 1 ? "" : "s") com estatísticas importadas)</span></div>

                        <div class="je-donuts">
                            <div class="je-donut">
                                <div class="je-donut-ring" style="background: conic-gradient(#22c55e 0 @(m.FinalizacoesPct)%, #1e293b @(m.FinalizacoesPct)% 100%);">
                                    <div class="je-donut-hole">@m.FinalizacoesPct%</div>
                                </div>
                                <div class="je-donut-label">Finalizações</div>
                                <div class="je-donut-sub">@m.Finalizacoes.ToString("0.#")/jogo · % no gol</div>
                            </div>
                            <div class="je-donut">
                                <div class="je-donut-ring" style="background: conic-gradient(#60a5fa 0 @(m.DriblesPct)%, #1e293b @(m.DriblesPct)% 100%);">
                                    <div class="je-donut-hole">@m.DriblesPct%</div>
                                </div>
                                <div class="je-donut-label">Dribles</div>
                                <div class="je-donut-sub">@m.Dribles.ToString("0.#")/jogo · % certos</div>
                            </div>
                            <div class="je-donut">
                                <div class="je-donut-ring" style="background: conic-gradient(#facc15 0 @(m.DuelosPct)%, #1e293b @(m.DuelosPct)% 100%);">
                                    <div class="je-donut-hole">@m.DuelosPct%</div>
                                </div>
                                <div class="je-donut-label">Duelos</div>
                                <div class="je-donut-sub">@m.Duelos.ToString("0.#")/jogo · % vencidos</div>
                            </div>
                        </div>

                        <div class="je-chips">
                            <div class="je-chip"><div class="je-chip-valor">@m.Passes.ToString("0.#")</div><div class="je-chip-label">Passes</div></div>
                            <div class="je-chip"><div class="je-chip-valor">@m.PassesChave.ToString("0.#")</div><div class="je-chip-label">Passes-chave</div></div>
                            <div class="je-chip"><div class="je-chip-valor">@m.Desarmes.ToString("0.#")</div><div class="je-chip-label">Desarmes</div></div>
                            <div class="je-chip"><div class="je-chip-valor">@m.Interceptacoes.ToString("0.#")</div><div class="je-chip-label">Interceptações</div></div>
                            <div class="je-chip"><div class="je-chip-valor">@m.Bloqueios.ToString("0.#")</div><div class="je-chip-label">Bloqueios</div></div>
                            @if (m.Defesas > 0)
                            {
                                <div class="je-chip"><div class="je-chip-valor">@m.Defesas.ToString("0.#")</div><div class="je-chip-label">Defesas</div></div>
                            }
                            <div class="je-chip"><div class="je-chip-valor">@m.FaltasSofridas.ToString("0.#")</div><div class="je-chip-label">Faltas sofridas</div></div>
                            <div class="je-chip"><div class="je-chip-valor">@m.FaltasCometidas.ToString("0.#")</div><div class="je-chip-label">Faltas cometidas</div></div>
                        </div>
                    </div>
                }
            </div>
        }


        <!-- Histórico por Temporada -->
        @if (Model.Jogador.IdApi.HasValue)
        {
            <div class="je-section">
                <button type="button" class="je-section-row" onclick="toggleTemporada()" id="temporadaTitulo">
                    <span class="je-section-titulo">Histórico por Temporada</span>
                    <div class="je-section-linha"></div>
                    <svg id="temporadaChevron" class="je-section-chevron" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9" /></svg>
                </button>

                <div id="temporadaWrapper" style="display:none;">
                    <div class="je-season-selector" id="seasonSelector">
                        @{
                            var anoAtual = DateTime.Now.Year;
                        }
                        @for (int ano = anoAtual; ano >= anoAtual - 3; ano--)
                        {
                            <button class="je-season-btn @(ano == anoAtual ? "active" : "")"
                                    onclick="carregarTemporada(@Model.Jogador.Id, @ano, this)">
                                @ano
                            </button>
                        }
                    </div>

                    <div id="temporadaContainer"></div>
                </div>
            </div>
        }

        <!-- Histórico por Jogo -->
        <div class="je-section">
            <button type="button" class="je-section-row je-com-linha" onclick="toggleHistorico()" id="historicoTitulo">
                <span class="je-section-titulo">Histórico por Jogo</span>
                <div class="je-section-linha" style="background:transparent;"></div>
                <span class="je-section-badge">@Model.NotasPorJogo.Count jogos</span>
                <svg id="historicoChevron" class="je-section-chevron" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9" /></svg>
            </button>

            <div id="historicoWrapper" style="display:none;">

            @if (!Model.NotasPorJogo.Any())
            {
                <div class="je-sem-dados">
                    Nenhum jogo registrado para este jogador ainda.
                </div>
            }
            else
            {
                <div id="historicoLista" class="je-jogos-lista je-historico-collapsed">
                @{ var idx = 0; }
                @foreach (var item in Model.NotasPorJogo)
                {
                    // Lado do jogador NAQUELE jogo (vem da escalação da época, via item.IsCasa)
                    // — usar o time atual inverteria os jogos do clube antigo após uma transferência.
                    bool isCasaJogador = item.IsCasa;

                    var adversario = isCasaJogador
                        ? item.Jogo.TimeVisitante?.Nome
                        : item.Jogo.TimeCasa?.Nome;

                    var adversarioEscudo = isCasaJogador
                        ? item.Jogo.TimeVisitante?.EscudoUrl
                        : item.Jogo.TimeCasa?.EscudoUrl;

                    var placar = (item.Jogo.PlacarCasa.HasValue && item.Jogo.PlacarVisitante.HasValue)
                        ? $"{item.GolsPro} x {item.GolsContra}"
                        : "–";

                    var penaltis = (item.Jogo.PenaltisCasa.HasValue && item.Jogo.PenaltisVisitante.HasValue)
                        ? (isCasaJogador
                            ? $"({item.Jogo.PenaltisCasa}-{item.Jogo.PenaltisVisitante} pên.)"
                            : $"({item.Jogo.PenaltisVisitante}-{item.Jogo.PenaltisCasa} pên.)")
                        : null;

                    var resBg = item.Resultado switch
                    {
                        "V" => "#16a34a",
                        "E" => "#b45309",
                        "D" => "#dc2626",
                        _   => "#334155"
                    };

                    string notaColor = item.Analisado ? CorNota(item.NotaFinal) : "#334155";
                    string notaLabel = item.Analisado ? LabelNota(item.NotaFinal) : "Sem nota";

                    var temMinutagem = item.Minutos.HasValue;
                    var temPosicao = !string.IsNullOrWhiteSpace(item.Posicao);
                    var temAnalise = item.Analisado && (item.Detalhes.Any(d => d.Quantidade > 0) || !string.IsNullOrWhiteSpace(item.Comentario) || item.ObservacoesJogador.Any() || item.NotaManual.HasValue);

                    <div class="je-jogo-card" style="@(!item.Analisado ? "opacity:.75;" : "")">

                        <!-- Linha principal -->
                        <div class="je-jogo-row" onclick="irParaJogo(event, @item.Jogo.Id)" title="Ver jogo">
                            <div class="je-jogo-badge" style="background:@resBg;">@item.Resultado</div>

                            <div class="je-jogo-info">
                                <div class="je-jogo-linha1">
                                    @if (!string.IsNullOrEmpty(adversarioEscudo))
                                    {
                                        <img src="@Url.Action("Imagem", "MediaProxy", new { url = adversarioEscudo })" class="je-jogo-escudo" alt="" />
                                    }
                                    <span class="je-jogo-adv">vs @adversario<span class="je-jogo-placar">@placar @penaltis</span></span>
                                    @if (item.Gols > 0)
                                    {
                                        <span class="je-tag je-tag-gol">⚽ @item.Gols</span>
                                    }
                                    @if (item.Assistencias > 0)
                                    {
                                        <span class="je-tag je-tag-assist">🅰️ @item.Assistencias</span>
                                    }
                                    @if (!item.Analisado)
                                    {
                                        <span class="je-tag-sem">sem análise</span>
                                    }
                                    else if (!item.OrigemManual)
                                    {
                                        <span class="je-tag-auto">nota automática</span>
                                    }
                                </div>
                                <div class="je-jogo-data">
                                    @DateHelper.FormatarData(item.Jogo.Data, "dd/MM/yyyy")
                                    @if (item.Jogo.Rodada > 0) { <text> — Rodada @item.Jogo.Rodada</text> }
                                </div>
                            </div>

                            <div class="je-nota-circle" style="border:2px solid @notaColor; color:@notaColor;">
                                @if (item.Analisado)
                                {
                                    <span class="je-nota-val">@item.NotaFinal.ToString("0.0")</span>
                                    <span class="je-nota-label">@notaLabel</span>
                                }
                                else
                                {
                                    <span style="font-size:18px; opacity:.4;">–</span>
                                }
                            </div>

                            @if (temAnalise)
                            {
                                <button type="button" class="je-ver-analise" onclick="event.stopPropagation(); toggleAnalise(this, 'analise-@idx')">Ver análise</button>
                            }
                            <a class="je-ver-analise" style="text-decoration:none; text-align:center;"
                               href="@Url.Action("EstatisticasJogo", "Jogadores", new { id = Model.Jogador.Id, jogoId = item.Jogo.Id })"
                               onclick="event.stopPropagation();" title="Todas as ações e estatísticas deste jogador nesta partida">Estatísticas</a>
                        </div>

                        <!-- Stats resumidos -->
                        <div class="je-stats-mini">
                            <div class="je-stat-mini">
                                <div class="je-stat-mini-val">@(temPosicao ? PosicaoJogadorHelper.Sigla(item.Posicao) : "—")</div>
                                <div class="je-stat-mini-lbl">Posição</div>
                            </div>
                            <div class="je-stat-mini">
                                <div class="je-stat-mini-val">@(temMinutagem ? $"{item.Minutos}'" : "—")</div>
                                <div class="je-stat-mini-lbl">Minutos</div>
                            </div>
                            <div class="je-stat-mini">
                                <div class="je-stat-mini-val">@item.Gols</div>
                                <div class="je-stat-mini-lbl">Gols</div>
                            </div>
                            <div class="je-stat-mini">
                                <div class="je-stat-mini-val">@item.Assistencias</div>
                                <div class="je-stat-mini-lbl">Assistências</div>
                            </div>
                        </div>

                        @if (temAnalise)
                        {
                            <div class="je-analise-panel" data-analise="analise-@idx">
                                <div class="je-analise-comp">
                                    <div class="je-analise-comp-titulo">Composição da nota</div>
                                    @if (item.NotaManual.HasValue)
                                    {
                                        <span>Nota manual <strong style="color:@notaColor;">@item.NotaFinal.ToString("0.00")</strong></span>
                                        <span style="color:rgba(255,255,255,.35); font-size:10px;">ações registradas abaixo (sem peso na nota)</span>
                                    }
                                    else
                                    {
                                        <span>Base <strong style="color:#e2e8f0;">@item.NotaBaseFixa.ToString("0.0")</strong></span>
                                        <span>Ações <strong style="color:@(item.Nota >= 0 ? "#4ade80" : "#f87171");">@(item.Nota >= 0 ? "+" : "")@item.Nota.ToString("0.##")</strong></span>
                                        <span>= <strong style="color:@notaColor;">@item.NotaFinal.ToString("0.00")</strong></span>
                                    }
                                </div>

                                @if (item.Detalhes.Any(d => d.Quantidade > 0))
                                {
                                    <div class="je-detalhes">
                                        @foreach (var d in item.Detalhes.Where(d => d.Quantidade > 0))
                                        {
                                            var dColor = d.Peso > 0 ? "#4ade80" : "#f87171";
                                            var dBg = d.Peso > 0 ? "rgba(34,197,94,.1)" : "rgba(239,68,68,.1)";
                                            var sinal = d.Peso > 0 ? "+" : "";
                                            var pts = Math.Round(d.Peso * d.Quantidade, 2);
                                            <span class="je-detalhe-chip" style="background:@dBg; color:@dColor; border-color:@dColor;">
                                                @d.AcaoLabel × @d.Quantidade
                                                <span style="opacity:.7;">(@sinal@(pts.ToString("0.##", inv)) pts)</span>
                                            </span>
                                        }
                                    </div>
                                }

                                @if (!string.IsNullOrWhiteSpace(item.Comentario))
                                {
                                    <div class="je-comentario">"@item.Comentario"</div>
                                }

                                @if (item.ObservacoesJogador.Any())
                                {
                                    <div class="je-obs">
                                        @foreach (var obs in item.ObservacoesJogador)
                                        {
                                            <div class="je-obs-item">📌 @obs</div>
                                        }
                                    </div>
                                }
                            </div>
                        }

                    </div>
                    idx++;
                }
                </div>

                @if (Model.NotasPorJogo.Count > 3)
                {
                    <button class="je-btn-expand" id="btnExpandHistorico" onclick="expandirHistorico()">
                        Ver todos os @Model.NotasPorJogo.Count jogos ▼
                    </button>
                }
            }

            </div><!-- /#historicoWrapper -->
        </div>

    </div>
</div>

<!-- ── Modal: Jogadores semelhantes ─────────────────────────────────────── -->
<div class="je-modal-overlay" id="semelhantesModal" onclick="if(event.target===this)fecharSemelhantes()">
    <div class="je-modal-box">
        <div class="je-modal-header">
            <h2 class="je-modal-titulo">Jogadores semelhantes</h2>
            <button type="button" class="je-modal-close" onclick="fecharSemelhantes()">✕</button>
        </div>
        <div class="je-modal-criterios" id="semelhantesCriterios"></div>
        <div class="je-modal-body" id="semelhantesBody"></div>
    </div>
</div>

<!-- ── Modal: Comparar jogadores ────────────────────────────────────────── -->
<div class="je-modal-overlay" id="compararModal" onclick="if(event.target===this)fecharComparar()">
    <div class="je-modal-box je-cmp-box">
        <div class="je-modal-header">
            <h2 class="je-modal-titulo">Comparar jogadores</h2>
            <button type="button" class="je-modal-close" onclick="fecharComparar()">✕</button>
        </div>
        <div class="je-cmp-picker">
            <div class="je-select-wrap">
                <select id="cmpLiga" class="je-select">
                    <option value="">Carregando ligas...</option>
                </select>
                <div class="je-select-arrow">
                    <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9" /></svg>
                </div>
            </div>
            <div class="je-select-wrap">
                <select id="cmpTime" class="je-select" disabled>
                    <option value="">Time...</option>
                </select>
                <div class="je-select-arrow">
                    <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9" /></svg>
                </div>
            </div>
            <div class="je-select-wrap">
                <select id="cmpJogador" class="je-select" disabled>
                    <option value="">Jogador...</option>
                </select>
                <div class="je-select-arrow">
                    <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9" /></svg>
                </div>
            </div>
            <span class="je-cmp-ou">ou</span>
            <div class="je-cmp-busca-wrap">
                <input id="cmpBusca" class="je-cmp-busca" type="text" placeholder="Digite o nome do jogador..." autocomplete="off" />
                <div id="cmpBuscaResultados" class="je-cmp-busca-resultados"></div>
            </div>
        </div>
        <div class="je-modal-body" id="compararBody">
            <div class="je-cmp-vazio">Filtre por liga → time → jogador, ou digite um nome, para montar a comparação com <strong>@Model.Jogador.NomeExibicao</strong>.</div>
        </div>
    </div>
</div>

<script>
    @if (Model.PontosHeatmap.Any())
    {
        <text>
        // site.js (com desenharMapaCalor) carrega depois do RenderBody no _Layout,
        // então só existe no fim do carregamento — espera o load pra não chamar
        // uma função ainda indefinida.
        window.addEventListener('load', function () {
            desenharMapaCalor('jeHeatmapCampo', @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
                Model.PontosHeatmap.Select(p => new { x = p.X, y = p.Y, peso = p.Peso }))));
        });
        </text>
    }

    // ── Histórico por jogo colapsável ─────────────────────────────────────────
    function toggleHistorico() {
        const wrapper = document.getElementById('historicoWrapper');
        const chevron = document.getElementById('historicoChevron');
        const isVisible = wrapper.style.display !== 'none';
        wrapper.style.display = isVisible ? 'none' : 'block';
        chevron.style.transform = isVisible ? '' : 'rotate(180deg)';
    }

    function expandirHistorico() {
        const lista = document.getElementById('historicoLista');
        const btn = document.getElementById('btnExpandHistorico');
        if (lista) lista.classList.remove('je-historico-collapsed');
        if (btn) btn.style.display = 'none';
    }

    // ── Ir para a tela do jogo ao clicar no card ────────────────────────────
    function irParaJogo(e, jogoId) {
        if (e.target.closest('.je-ver-analise')) return;
        window.location.href = `/Jogos/Analisar/${jogoId}`;
    }

    // ── Ver análise (composição da nota) por jogo ───────────────────────────
    function toggleAnalise(btn, key) {
        const card = btn.closest('.je-jogo-card');
        if (!card) return;
        const painel = card.querySelector(`.je-analise-panel[data-analise="${key}"]`);
        if (!painel) return;
        const aberto = painel.classList.toggle('aberto');
        btn.classList.toggle('aberto', aberto);
        btn.textContent = aberto ? 'Ocultar análise' : 'Ver análise';
    }

    // ── Histórico por Temporada ───────────────────────────────────────────────
    const jogadorId = @Model.Jogador.Id;
    let temporadaCarregada = false;

    function toggleTemporada() {
        const wrapper = document.getElementById('temporadaWrapper');
        const chevron = document.getElementById('temporadaChevron');
        const isVisible = wrapper.style.display !== 'none';
        wrapper.style.display = isVisible ? 'none' : 'block';
        chevron.style.transform = isVisible ? '' : 'rotate(180deg)';
        if (!isVisible && !temporadaCarregada) {
            temporadaCarregada = true;
            carregarTemporada(jogadorId, @DateTime.Now.Year, document.querySelector('.je-season-btn.active'));
        }
    }

    function carregarTemporada(jogId, season, btnEl) {
        document.querySelectorAll('.je-season-btn').forEach(b => b.classList.remove('active'));
        if (btnEl) btnEl.classList.add('active');

        const container = document.getElementById('temporadaContainer');
        if (!container) return;
        container.innerHTML = '<div style="text-align:center;color:#6b7280;padding:2rem;font-size:.9rem;">Carregando...</div>';

        fetch(`/Jogadores/EstatisticasTemporada?id=${jogId}&season=${season}`)
            .then(r => r.json())
            .then(data => {
                if (!data || data.error || data.length === 0) {
                    container.innerHTML = '<div style="text-align:center;color:#6b7280;padding:2rem;font-size:.9rem;">Nenhuma estatística disponível para essa temporada.</div>';
                    return;
                }
                renderTemporada(data, container);
            })
            .catch(() => {
                container.innerHTML = '<div style="text-align:center;color:#f87171;padding:2rem;font-size:.9rem;">Erro ao carregar estatísticas.</div>';
            });
    }

    function statBox(val, label, cls) {
        cls = cls || '';
        const display = (val === null || val === undefined || val === 0 || val === '0') ? '<span style="opacity:.3">–</span>' : val;
        return `<div class="je-stat-box"><div class="je-stat-val ${cls}">${display}</div><div class="je-stat-lbl">${label}</div></div>`;
    }

    function renderTemporada(data, container) {
        const proxyBase = '/MediaProxy/Imagem?url=';

        const html = data.map(function(s) {
            const logoLeague = s.league.logo ? `<img src="${proxyBase}${encodeURIComponent(s.league.logo)}" class="je-temporada-logo" />` : '';
            const flag = s.league.flag ? `<img src="${proxyBase}${encodeURIComponent(s.league.flag)}" style="width:16px;height:12px;object-fit:cover;border-radius:2px;" />` : '';
            const logoTeam = s.team.logo ? `<img src="${proxyBase}${encodeURIComponent(s.team.logo)}" style="width:20px;height:20px;object-fit:contain;" />` : '';
            const rating = s.games.rating ? `<span class="je-rating-badge">${parseFloat(s.games.rating).toFixed(1)}</span>` : '';

            const duelPct = (s.duels.total > 0) ? Math.round(s.duels.won / s.duels.total * 100) + '%' : null;
            const dribPct = (s.dribbles.attempts > 0) ? Math.round(s.dribbles.success / s.dribbles.attempts * 100) + '%' : null;

            const chips = [];
            if (s.games.minutes > 0)   chips.push(`⏱️ ${s.games.minutes} min`);
            if (s.games.lineups > 0)   chips.push(`🏃 ${s.games.lineups} titulares`);
            if (s.substitutes.in > 0)  chips.push(`↗️ ${s.substitutes.in} entradas`);
            if (s.substitutes.out > 0) chips.push(`↘️ ${s.substitutes.out} saídas`);
            if (s.fouls.committed > 0) chips.push(`⚠️ ${s.fouls.committed} faltas`);
            if (s.cards.yellow > 0)    chips.push(`🟨 ${s.cards.yellow}`);
            if (s.cards.red > 0)       chips.push(`🟥 ${s.cards.red}`);

            const footerHtml = chips.length
                ? `<div class="je-temporada-footer">${chips.map(c => `<span class="je-temporada-chip">${c}</span>`).join('')}</div>`
                : '';

            return `
            <div class="je-temporada-card">
                <div class="je-temporada-header">
                    ${logoLeague}
                    <div style="flex:1;min-width:0;">
                        <div class="je-temporada-nome">${s.league.name}</div>
                        <div class="je-temporada-pais">${flag} ${s.league.country || ''} &nbsp;·&nbsp; ${logoTeam} ${s.team.name}</div>
                    </div>
                    ${rating}
                </div>
                <div class="je-temporada-stats">
                    ${statBox(s.games.appearences || null, 'Jogos', 'hl-blue')}
                    ${statBox(s.goals.total || null, 'Gols', 'hl-green')}
                    ${statBox(s.goals.assists || null, 'Assist.', 'hl-orange')}
                    ${statBox(s.shots.total || null, 'Finalizações', '')}
                    ${statBox(s.shots.on || null, 'No Alvo', '')}
                    ${statBox(s.passes.total || null, 'Passes', '')}
                    ${statBox(s.passes.key || null, 'P. Chave', 'hl-yellow')}
                    ${statBox(s.passes.accuracy ? s.passes.accuracy + '%' : null, 'Precisão', '')}
                    ${statBox(s.tackles.total || null, 'Desarmes', '')}
                    ${statBox(s.tackles.interceptions || null, 'Intercept.', '')}
                    ${statBox(duelPct, 'Duelos Ganhos', '')}
                    ${statBox(dribPct, 'Dribles %', '')}
                </div>
                ${footerHtml}
            </div>`;
        }).join('');

        container.innerHTML = `<div class="je-temporada-grid">${html}</div>`;
    }

    // ── Jogadores semelhantes ─────────────────────────────────────────────────
    let semelhantesCarregado = false;

    function abrirSemelhantes() {
        const modal = document.getElementById('semelhantesModal');
        modal.classList.add('open');
        document.body.style.overflow = 'hidden';
        if (!semelhantesCarregado) {
            semelhantesCarregado = true;
            carregarSemelhantes();
        }
    }

    function fecharSemelhantes() {
        document.getElementById('semelhantesModal').classList.remove('open');
        document.body.style.overflow = '';
    }

    document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape') { fecharSemelhantes(); fecharComparar(); }
    });

    function carregarSemelhantes() {
        const body = document.getElementById('semelhantesBody');
        const criterios = document.getElementById('semelhantesCriterios');
        body.innerHTML = '<div style="text-align:center;color:#6b7280;padding:2rem;font-size:.9rem;">Buscando jogadores semelhantes...</div>';
        criterios.innerHTML = '';

        fetch(`/Jogadores/JogadoresSemelhantes?id=${jogadorId}`)
            .then(r => r.json())
            .then(data => renderSemelhantes(data))
            .catch(() => {
                body.innerHTML = '<div style="text-align:center;color:#f87171;padding:2rem;font-size:.9rem;">Erro ao buscar jogadores semelhantes.</div>';
            });
    }

    // Espelha o helper Url.FotoSrc: fotos do api-sports.io passam pelo MediaProxy;
    // URLs manuais de outros hosts carregam direto (o proxy bloquearia por allowlist).
    function fotoSrc(url) {
        if (!url) return '/images/placeholder-jogador.png';
        let host = '';
        try { host = new URL(url).hostname; } catch (e) { host = ''; }
        return /(^|\.)api-sports\.io$/i.test(host)
            ? '/MediaProxy/Imagem?url=' + encodeURIComponent(url)
            : url;
    }

    function renderSemelhantes(data) {
        const body = document.getElementById('semelhantesBody');
        const criteriosEl = document.getElementById('semelhantesCriterios');
        const proxyBase = '/MediaProxy/Imagem?url=';

        // Chips dos critérios usados (já vêm prontos do servidor, conforme a posição)
        const chips = data.criterios || [];
        criteriosEl.innerHTML = chips.map(t => `<span class="je-criterio-chip">${t}</span>`).join('');

        const colunas = data.colunas || [];
        const jogadores = data.jogadores || [];
        if (jogadores.length === 0) {
            body.innerHTML = '<div style="text-align:center;color:#6b7280;padding:2rem;font-size:.9rem;">Nenhum jogador com perfil semelhante foi encontrado na base.</div>';
            return;
        }

        body.innerHTML = jogadores.map(function (p) {
            const foto = fotoSrc(p.fotoUrl);
            const escudo = p.escudoUrl
                ? `<img src="${proxyBase}${encodeURIComponent(p.escudoUrl)}" class="je-sem-escudo" />`
                : '';
            const clube = p.clube ? `${escudo} ${p.clube}` : '';
            const idade = p.idade > 0 ? `📅 ${p.idade} anos` : '';
            const pais = p.pais ? `🌍 ${p.pais}` : '';

            const metaParts = [];
            if (p.posicao) metaParts.push(`<span>🎽 ${p.posicao}</span>`);
            if (clube) metaParts.push(`<span>${clube}</span>`);
            if (idade) metaParts.push(`<span>${idade}</span>`);
            if (pais) metaParts.push(`<span>${pais}</span>`);

            const stats = p.stats || [];
            const statsHtml = colunas.map((label, i) =>
                `<div class="je-sem-stat"><div class="je-sem-stat-val">${stats[i] != null ? stats[i] : 0}</div><div class="je-sem-stat-lbl">${label}</div></div>`
            ).join('');

            return `
            <div class="je-sem-card">
                <img src="${foto}" class="je-sem-foto" onerror="this.onerror=null; this.src='/images/placeholder-jogador.png'" />
                <div class="je-sem-info">
                    <a class="je-sem-nome" href="/Jogadores/Estatisticas/${p.id}">${p.nome}</a>
                    <div class="je-sem-meta">${metaParts.join('')}</div>
                </div>
                <div class="je-sem-stats">${statsHtml}</div>
            </div>`;
        }).join('');
    }

    // ── Comparar com ──────────────────────────────────────────────────────────
    let cmpLigasCarregadas = false;
    let cmpBuscaTimer = null;

    function abrirComparar() {
        document.getElementById('compararModal').classList.add('open');
        document.body.style.overflow = 'hidden';
        if (!cmpLigasCarregadas) {
            cmpLigasCarregadas = true;
            fetch('/Jogadores/CompararLigas')
                .then(r => r.json())
                .then(ligas => {
                    const sel = document.getElementById('cmpLiga');
                    sel.innerHTML = '<option value="">Todas as ligas</option>' +
                        ligas.map(l => `<option value="${l.id}">${l.nome}</option>`).join('');
                    carregarTimesComparar('');
                });
        }
    }

    function fecharComparar() {
        document.getElementById('compararModal').classList.remove('open');
        document.body.style.overflow = '';
    }

    function carregarTimesComparar(competicaoId) {
        const selTime = document.getElementById('cmpTime');
        const selJog = document.getElementById('cmpJogador');
        selTime.disabled = true;
        selTime.innerHTML = '<option value="">Carregando times...</option>';
        selJog.disabled = true;
        selJog.innerHTML = '<option value="">Jogador...</option>';
        fetch('/Jogadores/CompararTimes' + (competicaoId ? `?competicaoId=${competicaoId}` : ''))
            .then(r => r.json())
            .then(times => {
                selTime.innerHTML = '<option value="">Time...</option>' +
                    times.map(t => `<option value="${t.id}">${t.nome}</option>`).join('');
                selTime.disabled = false;
            });
    }

    document.getElementById('cmpLiga').addEventListener('change', function () {
        carregarTimesComparar(this.value);
    });

    document.getElementById('cmpTime').addEventListener('change', function () {
        const selJog = document.getElementById('cmpJogador');
        if (!this.value) {
            selJog.disabled = true;
            selJog.innerHTML = '<option value="">Jogador...</option>';
            return;
        }
        selJog.disabled = true;
        selJog.innerHTML = '<option value="">Carregando...</option>';
        fetch(`/Jogadores/CompararJogadoresLista?timeId=${this.value}`)
            .then(r => r.json())
            .then(jogs => {
                selJog.innerHTML = '<option value="">Jogador...</option>' +
                    jogs.filter(j => j.id !== jogadorId)
                        .map(j => `<option value="${j.id}">${j.nome} (${j.posicao || '—'})</option>`).join('');
                selJog.disabled = false;
            });
    });

    document.getElementById('cmpJogador').addEventListener('change', function () {
        if (this.value) carregarComparacao(parseInt(this.value));
    });

    // Busca por nome com debounce (mínimo 3 letras)
    document.getElementById('cmpBusca').addEventListener('input', function () {
        const termo = this.value.trim();
        const box = document.getElementById('cmpBuscaResultados');
        clearTimeout(cmpBuscaTimer);
        if (termo.length < 3) { box.classList.remove('open'); box.innerHTML = ''; return; }
        cmpBuscaTimer = setTimeout(() => {
            fetch(`/Jogadores/CompararJogadoresLista?nome=${encodeURIComponent(termo)}`)
                .then(r => r.json())
                .then(jogs => {
                    jogs = jogs.filter(j => j.id !== jogadorId);
                    if (jogs.length === 0) {
                        box.innerHTML = '<div class="je-cmp-busca-item" style="cursor:default;"><span class="je-cmp-busca-sub">Nenhum jogador encontrado.</span></div>';
                    } else {
                        box.innerHTML = jogs.map(j => `
                            <div class="je-cmp-busca-item" onclick="carregarComparacao(${j.id})">
                                <img src="${fotoSrc(j.fotoUrl)}" onerror="this.onerror=null; this.src='/images/placeholder-jogador.png'" />
                                <div>
                                    <div class="je-cmp-busca-nome">${j.nome}</div>
                                    <div class="je-cmp-busca-sub">${[j.posicao, j.clube, j.idade > 0 ? j.idade + ' anos' : ''].filter(Boolean).join(' · ')}</div>
                                </div>
                            </div>`).join('');
                    }
                    box.classList.add('open');
                });
        }, 300);
    });

    // Fecha o dropdown da busca ao clicar fora dele
    document.addEventListener('click', function (e) {
        if (!e.target.closest('.je-cmp-busca-wrap'))
            document.getElementById('cmpBuscaResultados').classList.remove('open');
    });

    function carregarComparacao(outroId) {
        document.getElementById('cmpBuscaResultados').classList.remove('open');
        const body = document.getElementById('compararBody');
        body.innerHTML = '<div class="je-cmp-vazio">Montando comparação...</div>';
        fetch(`/Jogadores/CompararDados?id=${jogadorId}&comId=${outroId}`)
            .then(r => r.json())
            .then(data => {
                if (data.error) { body.innerHTML = `<div class="je-cmp-vazio">${data.error}</div>`; return; }
                renderComparacao(data);
            })
            .catch(() => {
                body.innerHTML = '<div class="je-cmp-vazio" style="color:#f87171;">Erro ao montar a comparação.</div>';
            });
    }

    function cmpCardJogador(p, cor) {
        const proxyBase = '/MediaProxy/Imagem?url=';
        const escudo = p.escudoUrl
            ? `<img src="${proxyBase}${encodeURIComponent(p.escudoUrl)}" style="width:13px;height:13px;object-fit:contain;vertical-align:middle;" /> `
            : '';
        const sub = [];
        if (p.posicao) sub.push(`🎽 ${p.posicao}`);
        if (p.clube) sub.push(`${escudo}${p.clube}`);
        if (p.idade > 0) sub.push(`📅 ${p.idade} anos`);
        sub.push(`🏟️ ${p.jogos} jogo${p.jogos === 1 ? '' : 's'}`);
        if (p.notaMedia != null) sub.push(`⭐ nota ${p.notaMedia.toLocaleString('pt-BR', { minimumFractionDigits: 2 })}`);
        else if (p.rating != null) sub.push(`⭐ rating ${p.rating.toLocaleString('pt-BR', { minimumFractionDigits: 2 })}`);
        return `
        <div class="je-cmp-jog" style="--cor:${cor};">
            <img class="foto" src="${fotoSrc(p.fotoUrl)}" onerror="this.onerror=null; this.src='/images/placeholder-jogador.png'" />
            <div style="min-width:0;">
                <a class="je-cmp-jog-nome" href="/Jogadores/Estatisticas/${p.id}">${p.nome}</a>
                <div class="je-cmp-jog-sub">${sub.map(s => `<span>${s}</span>`).join('')}</div>
            </div>
        </div>`;
    }

    function renderComparacao(data) {
        const body = document.getElementById('compararBody');

        const avisos = (data.avisos || []).map(t => `<div class="je-cmp-aviso">⚠️ ${t}</div>`).join('');

        const insights = (data.insights || []).map(i =>
            `<div class="je-cmp-insight ${i.vencedor === 'a' ? 'vence-a' : i.vencedor === 'b' ? 'vence-b' : ''}">
                <span>${i.emoji}</span><div>${i.html}</div>
            </div>`).join('');

        const grupos = (data.grupos || []).map(g => `
            <div class="je-cmp-grupo-titulo">${g.titulo}</div>
            ${g.metricas.map(m => `
                <div class="je-cmp-row">
                    <div class="je-cmp-val lado-a ${m.vencedor === 'a' ? 'vence' : ''}">${m.fa}</div>
                    <div class="je-cmp-mid">
                        <div class="je-cmp-metrica-label">${m.label}</div>
                        <div class="je-cmp-bar">
                            <div class="seg-a ${m.vencedor === 'a' ? 'vence' : ''}" style="width:${m.pctA}%"></div>
                            <div class="seg-b ${m.vencedor === 'b' ? 'vence' : ''}" style="width:${100 - m.pctA}%"></div>
                        </div>
                    </div>
                    <div class="je-cmp-val lado-b ${m.vencedor === 'b' ? 'vence' : ''}">${m.fb}</div>
                </div>`).join('')}
        `).join('');

        body.innerHTML = `
            <div class="je-cmp-head">
                ${cmpCardJogador(data.a, '#facc15')}
                <div class="je-cmp-vs">VS</div>
                ${cmpCardJogador(data.b, '#60a5fa')}
            </div>
            ${avisos}
            ${data.veredito ? `<div class="je-cmp-veredito">🏆 ${data.veredito}</div>` : ''}
            ${insights ? `<div class="je-cmp-insights">${insights}</div>` : ''}
            ${grupos}
        `;
    }
</script>
