@model ControleFutebolWeb.Models.Jogador

<h2>Cadastrar Novo Jogador</h2>

<form asp-action="Create" method="post">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="form-group">
        <label asp-for="Nome" class="control-label"></label>
        <input asp-for="Nome" class="form-control" />
        <span asp-validation-for="Nome" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="Posicao" class="control-label"></label>
        <input asp-for="Posicao" class="form-control" />
        <span asp-validation-for="Posicao" class="text-danger"></span>
    </div>

    <!-- Novo campo: Data de Nascimento -->
    <div class="form-group">
        <label asp-for="DataNascimento" class="control-label">Data de Nascimento</label>
        <input asp-for="DataNascimento" class="form-control" type="date" />
        <span asp-validation-for="DataNascimento" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="NumeroCamisa" class="control-label">Número da Camisa</label>
        <input asp-for="NumeroCamisa" class="form-control" type="number" />
        <span asp-validation-for="NumeroCamisa" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="NacionalidadeId" class="control-label">Nacionalidade</label>
        <select asp-for="NacionalidadeId" class="form-control" asp-items="ViewBag.NacionalidadeId"></select>
    </div>

    <div class="form-group">
        <label asp-for="TimeId" class="control-label">Time</label>
        <select asp-for="TimeId" class="form-control" asp-items="ViewBag.TimeId"></select>
    </div>

    <div class="form-group mt-2">
        <input type="submit" value="Salvar" class="btn btn-primary" />
        <a asp-action="Index" class="btn btn-secondary">Voltar</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}