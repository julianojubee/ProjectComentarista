@model IEnumerable<ControleFutebolWeb.Models.Jogador>
@using ControleFutebolWeb.Helpers
@{
    ViewData["Title"] = "Jogadores";
    @if (TempData["Sucesso"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Sucesso"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Erro"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["Erro"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
}

<style>
    /* Home identity (hero + cards) */
    .cf-hero {
        position: relative;
        background: linear-gradient(135deg, #0a1628 0%, #1a2f4e 55%, #0f2040 100%);
        border-radius: 14px;
        padding: 2.6rem 2rem;
        text-align: center;
        overflow: hidden;
        margin-bottom: 1.5rem;
        color: #fff;
    }

   

    .cf-hero-content { position: relative; z-index: 1; }

    .cf-hero-badge {
        display: inline-block;
        background: rgba(55, 138, 221, 0.2);
        color: #85b7eb;
        font-size: 11px;
        font-weight: 600;
        padding: 4px 14px;
        border-radius: 20px;
        border: 1px solid rgba(55, 138, 221, 0.35);
        letter-spacing: 1px;
        text-transform: uppercase;
        margin-bottom: 0.9rem;
    }

    .cf-hero h1 { font-size: 1.9rem; color: #fff; margin-bottom: 0.6rem; font-weight: 600; }
    .cf-hero p  { color: rgba(255,255,255,0.65); margin: 0; font-size: 0.95rem; }

    /* Filters row */
    .players-filter {
        display:flex;
        gap:12px;
        align-items:flex-end;
        flex-wrap:wrap;
        margin-bottom: 12px;
    }

    /* Grid of player cards */
    .cf-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 12px;
        margin-top: 1rem;
    }

    .cf-card {
        background: #fff;
        border: 0.5px solid #e5e7eb;
        border-radius: 12px;
        padding: 1rem;
        display: flex;
        flex-direction: column;
        gap: 8px;
        transition: border-color 0.15s, box-shadow 0.15s, transform 0.12s;
        min-height: 140px;
    }

    .cf-card:hover {
        border-color: #c0d4f0;
        box-shadow: 0 6px 18px rgba(55,138,221,0.06);
        transform: translateY(-3px);
    }

    .player-top {
        display:flex;
        gap:10px;
        align-items:center;
    }

    /* reduce player photo size */
    .player-photo {
        width: 36;
        height: 36px;
        border-radius: 50%;
        background: #f3f4f6;
        border: 0.5px solid #e5e7eb;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
        flex-shrink: 0;
    }

        .player-photo img {
            width: 90%;
            height: 100%;
            object-fit: cover;
        }

    .player-name { font-weight:700; color:#111827; font-size:1rem; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
    .player-meta { color:#6b7280; font-size:13px; }

    .cf-card-actions { margin-top:auto; display:flex; gap:8px; flex-wrap:wrap; }

    .cf-small-btn { font-size:13px; padding:6px 10px; }

    @@media (max-width: 640px) {
        .cf-hero { padding: 1.8rem 1rem; }
    }
</style>

<div class="cf-hero">
    <div class="cf-hero-content">
        <div class="cf-hero-badge">Cadastros</div>
        <h1>Jogadores</h1>
        <p>Consulte e gerencie os jogadores cadastrados no sistema.</p>
    </div>
</div>

<form asp-action="Index" method="get" class="players-filter">
    <div>
        <label for="posicao" class="form-label">Posição</label>
        @Html.DropDownList("posicao", (SelectList)ViewBag.Posicoes, "Todas", new { @class = "form-select" })
    </div>

    <div>
        <label for="nacionalidade" class="form-label">Nacionalidade</label>
        @Html.DropDownList("nacionalidade", (SelectList)ViewBag.Nacionalidades, "Todas", new { @class = "form-select" })
    </div>

    <div>
        <label for="timeId" class="form-label">Time</label>
        @Html.DropDownList("timeId", (SelectList)ViewBag.Times, "Todos", new { @class = "form-select" })
    </div>

    <div>
        <button type="submit" class="btn btn-primary cf-small-btn">Filtrar</button>
        <a asp-action="Create" class="btn btn-success cf-small-btn" style="margin-left:6px;">Novo Jogador</a>
    </div>
</form>
<div class="d-flex gap-2 mb-3 align-items-center flex-wrap">
    <form asp-action="BuscarFotosTodos" method="post" style="display:inline;">
        @Html.AntiForgeryToken()
        @Html.DropDownList("timeId", (SelectList)ViewBag.Times, "Selecione um clube", new { @class = "form-select form-select-sm d-inline w-auto" })
        <button type="submit" class="btn btn-outline-secondary btn-sm"
                onclick="return confirm('Buscar fotos de todos os jogadores sem foto deste clube?')">
            📷 Buscar fotos do clube
        </button>
    </form>
</div>

<div class="cf-grid">
    @foreach (var jogador in Model)
    {
        <div class="cf-card">
            <div class="player-top">
                <div class="player-photo">
                    @* if you have a foto url in model, show it; otherwise placeholder *@
                    @if (!string.IsNullOrEmpty(jogador.FotoUrl))
                    {
                        <img src="@jogador.FotoUrl" alt="@jogador.Nome" />
                    }
                    else
                    {
                        <span style="color:#6b7280;">👤</span>
                    }
                </div>

                <div style="min-width:0;">
                    <div class="player-name">
                        <a asp-action="Estatisticas" asp-route-id="@jogador.Id" style="text-decoration:none; color:inherit;">
                            @jogador.Nome
                        </a>
                    </div>
                    <div class="player-meta">
                        @jogador.Posicao • @jogador.Idade anos
                    </div>
                </div>
            </div>

            <div>
                <small class="text-muted">
                    Nacionalidade: <span title="@jogador.Nacionalidade?.Nome">@FlagHelper.GetFlagEmoji(jogador.Nacionalidade?.Nome)</span>
                    • Time:
                    @if (jogador.Time != null)
                    {
                        <span style="display:inline-flex; align-items:center; gap:8px;">
                            @if (!string.IsNullOrEmpty(jogador.Time.EscudoUrl))
                            {
                                <img src="@jogador.Time.EscudoUrl" alt="@jogador.Time.Nome" style="width:20px;height:20px;object-fit:contain;border-radius:50%;border:0.5px solid #e5e7eb;background:#fff;" />
                            }
                            <span>@jogador.Time.Nome</span>
                        </span>
                    }
                    else
                    {
                        <span>—</span>
                    }
                </small>
            </div>

            <div class="cf-card-actions">
                <a asp-action="Details" asp-route-id="@jogador.Id" class="btn btn-outline-primary btn-sm cf-small-btn">Detalhes</a>
                <a asp-action="Edit" asp-route-id="@jogador.Id" class="btn btn-warning btn-sm cf-small-btn">Editar</a>
                <a asp-action="Delete" asp-route-id="@jogador.Id" class="btn btn-danger btn-sm cf-small-btn">Excluir</a>

                <!-- Botão que abre o modal -->
                <button type="button" class="btn btn-info btn-sm cf-small-btn" data-bs-toggle="modal" data-bs-target="#linkModal-@jogador.Id">
                    Url Transfermarkt
                </button>

                <!-- Modal Bootstrap -->
                <div class="modal fade" id="linkModal-@jogador.Id" tabindex="-1" aria-labelledby="linkModalLabel-@jogador.Id" aria-hidden="true">
                    <div class="modal-dialog">
                        <div class="modal-content">
                            <form asp-action="SalvarLinkTransfermarkt" asp-route-id="@jogador.Id" method="post">
                                @Html.AntiForgeryToken()
                                <div class="modal-header">
                                    <h5 class="modal-title" id="linkModalLabel-@jogador.Id">Informar URL Transfermarkt</h5>
                                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fechar"></button>
                                </div>
                                <div class="modal-body">
                                    <input type="text" name="linktransfermarket" class="form-control" placeholder="Cole o link aqui" value="@jogador.linktransfermarket" />
                                </div>
                                <div class="modal-footer">
                                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                                    <button type="submit" class="btn btn-primary">Salvar</button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>

                <!-- Botão Buscar Foto -->
                <form asp-action="BuscarFoto" asp-route-id="@jogador.Id" method="post" style="display:inline;">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-outline-secondary btn-sm cf-small-btn"
                            title="Buscar foto"
                            onclick="return confirm('Buscar foto de @jogador.Nome ?')">
                        📷
                    </button>
                </form>
            </div>

        </div>
    }
</div>

<noscript>
    <h3>Lista de Jogadores (sem JavaScript)</h3>
    <table class="table">
        <thead>
            <tr>
                <th>Nome</th>
                <th>Posição</th>
                <th>Idade</th>
                <th>Nacionalidade</th>
                <th>Time</th>
                <th>Ações</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var jogador in Model)
            {
                <tr>
                    <td>
                        <a href="/Jogadores/Estatisticas/@jogador.Id" class="link-normal">@jogador.Nome</a>
                    </td>
                    <td>@jogador.Posicao</td>
                    <td>@jogador.Idade</td>
                    <td><span title="@jogador.Nacionalidade?.Nome">@ControleFutebolWeb.Helpers.FlagHelper.GetFlagEmoji(jogador.Nacionalidade?.Nome)</span></td>
                    <td>
                        @if (jogador.Time != null)
                        {
                            @if (!string.IsNullOrEmpty(jogador.Time.EscudoUrl))
                            {
                                <img src="@jogador.Time.EscudoUrl" style="height:20px;width:20px;object-fit:contain;border-radius:50%;border:0.5px solid #e5e7eb;margin-right:6px;" />
                            }
                            @jogador.Time.Nome
                        }
                        else
                        {
                            <span>—</span>
                        }
                    </td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@jogador.Id" class="btn btn-warning btn-sm">Editar</a>
                        <a asp-action="Details" asp-route-id="@jogador.Id" class="btn btn-info btn-sm">Detalhes</a>
                        <a asp-action="Delete" asp-route-id="@jogador.Id" class="btn btn-danger btn-sm">Excluir</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</noscript>


